Stage Reset
{
	DisplayName "Event Complete"
	StartUp
	{
		Action ResetStart
		{
			TeamControl StopGhosts
			{
				Type Deactivate
				Team Ghostteam
			}
			TeamControl StopHorrors
			{
				Type Deactivate
				Team Horrorsteam
			}
			TeamControl StopSeers
			{
				Type Deactivate
				Team Seerteam
			}
			TeamControl StartAspect
			{
				Type Deactivate
				Team AspectYinteam
			}
			TeamControl StopAspect
			{
				Type Deactivate
				Team AspectAllyteam
			}
	  		GlowieControl Deactivate
	  		{
	  			Type Deactivate
	  			Glowie GlowieAnchor
	  		}
			GlowieControl Remove
			{
				Type Remove
				Glowie GlowieAnchor
			}
			TeamControl StopAnchor
			{
				Type Deactivate
				Team Anchorteam
			}
		}
	}
	Timer ResetTimer
	{
		Duration 1:00
		//Display
	}
	Trigger End
	{
		Requires ResetTimer complete>
		Action GotoReset
		{
			DebugPrint "Reset complete: Going to DefeatEnemies."
		}
		NextStage DefeatEnemies
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint "Shutting down stage Reset"
		}
	}
}
Stage Stop
{
	StartUp
	{
		Action StopStart
		{
			DebugPrint "Starting Stop stage"
		}
		Action TurnOffCritters
		{
			TeamControl StopGhosts
			{
				Type Deactivate
				Team Ghostteam
			}
			TeamControl StopSeers
			{
				Type Deactivate
				Team Seerteam
			}
			TeamControl StopHorrors
			{
				Type Deactivate
				Team Horrorsteam
			}
			TeamControl StopAspect
			{
				Type Deactivate
				Team AspectYinteam
			}
			TeamControl StopAspect
			{
				Type Deactivate
				Team AspectAllyteam
			}
	  		GlowieControl Deactivate
	  		{
	  			Type Deactivate
	  			Glowie GlowieAnchor
	  		}
			GlowieControl Remove
			{
				Type Remove
				Glowie GlowieAnchor
			}
			TeamControl StopAnchor
			{
				Type Deactivate
				Team Anchorteam
			}
		}
	}
	Trigger Never
	{
		requires 0
	}
	ShutDown
	{
		Action ShutdownStop
		{
			DebugPrint "Shutting down Stage Stop"
		}
	}
}
