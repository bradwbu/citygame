		Duration 0:30
		Display
	}
	Trigger Reset
	{
		Requires ResetTimer complete>
		NextStage Reset
		Action RewardReset
		{
			DebugPrint <<Switching to Reset from Reward>>
		}
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Reward>>
		}
	}
}


Stage ProtestFailed
{
	StartUp
	{
		Action GlowieTeardown
		{
			RemoveWaypoints
			GlowieControl Deactivate
			{
				Type Deactivate
				Glowie glowie
			}
			GlowieControl Remove
			{
				Type Remove
				Glowie glowie
			}
		}
	}
	Trigger Reset
	{
		NextStage Reset
		Action RewardReset
		{
			DebugPrint <<Switching to Reset from ProtestFailed>>
		}
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage ProtestFailed>>
		}
	}
}


Stage Stop
{
	StartUp
	{
		Action StopStart
		{
			RemoveWaypoints
			DebugPrint <<Starting Stop stage>>
		}
		Action GlowieTeardown
		{
			GlowieControl Deactivate
			{
				Type Deactivate
				Glowie glowie
			}
			GlowieControl Remove
			{
				Type Remove
				Glowie glowie
			}
		}
		Action KillCritters
		{
			TeamControl StopResistance
			{
				Type DoBehavior
				Team Resistanceteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopResistanceAlly
			{
				Type DoBehavior
				Team ResistanceAllyteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopMDestroyerteam
			{
				Type Deactivate
				Team Destroyerteam
			}
			TeamControl StopPolice
			{
				Type DoBehavior
				Team Policeteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopGuards
			{
				Type DoBehavior
				Team Guardteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopBossPolice
			{
				Type DoBehavior
				Team PoliceBossteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopBossGuards
			{
				Type DoBehavior
				Team ProtestBossteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopYellowSeers
			{
				Type DoBehavior
				Team Seerteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopAllySeers
			{
				Type DoBehavior
				Team SeerAllyteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopSeers
			{
				Type DoBehavior
				Team SeerAngryteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopMayhem
			{
				Type DoBehavior
				Team Mayhemteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopMayhemAlly
			{
				Type DoBehavior
				Team MayhemAllyteam
				Behavior <<PL_DestroyMe>>
			}
			TeamControl StopPoliceAlly
			{
				Type DoBehavior
				Team PoliceAllyteam
				Behavior <<PL_DestroyMe>>
			}
			RemoveWaypoints
		}
		Action TurnOffCritters
		{
			TeamControl StopResistanceAlly
			{
				Type Deactivate
				Team ResistanceAllyteam
			}
			TeamControl StopResistance
			{
				Type Deactivate
				Team Resistanceteam
			}
			TeamControl StopPolice
			{
				Type Deactivate
				Team Policeteam
			}
			TeamControl StopPoliceAlly
			{
				Type Deactivate
				Team PoliceAllyteam
			}
			TeamControl StopGuards
			{
				Type Deactivate
				Team Guardteam
			}
			TeamControl StopBossPolice
			{
				Type Deactivate
				Team PoliceBossteam
			}
			TeamControl StopBossProtest
			{
				Type Deactivate
				Team ProtestBossteam
			}
			TeamControl StopYellowSeers
			{
				Type Deactivate
				Team Seerteam
			}
			TeamControl StopAllySeers
			{
				Type Deactivate
				Team SeerAllyteam
			}
			TeamControl StopSeers
			{
				Type Deactivate
				Team SeerAngryteam
			}
			TeamControl StopMayhem
			{
				Type Deactivate
				Team Mayhemteam
			}
			TeamControl StopMayhemAlly
			{
				Type Deactivate
				Team MayhemAllyteam
			}
			TeamControl StopDestroyer
			{
				Type Deactivate
				Team DestoyerTeam
			}
		}
	}
	Trigger Never
	{
		requires 0
	}
	ShutDown
	{
		Action ShutdownStop
		{
			DebugPrint <<Shutting down Stage Stop>>
		}
	}
