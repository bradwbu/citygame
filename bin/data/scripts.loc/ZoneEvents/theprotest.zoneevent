//Start Event Reactivation Block

	Timer WaitTimer
	{
		Duration 1:00
	}
	Trigger ClearToStart
	{
		Requires WaitTimer complete> ZoneEventMutex InstanceTokenVal system> UNKNOWN eq &&
		Action
		{
			DebugPrint <<Event Restart Due To Other Event Ending>>
		}
		NextStage Protest
	}
	Trigger ResetWait
	{
		Requires WaitTimer complete> ZoneEventMutex InstanceTokenVal system> UNKNOWN eq ! &&
		Action
		{
			Reset WaitTimer ResetWait
		}
	}

//End Event Reactivation Block
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down stage ResetImmediateAndRecycle>>
		}
	}
}

Stage Protest
{
	DisplayName P154466690
	StartUp
	{
		Action StartKillProtest
		{
			DebugPrint <<Starting Stage Protest>>
		}
		Action TurnOnSpawns
		{
			TeamControl StartResistance
			{
				Type Activate
				Team Resistanceteam
			}
			TeamControl StartMayhemteam
			{
				Type Activate
				Team Mayhemteam
			}
			RemoveWaypoints
			WaypointPlace ProtestWaypoint ProtestMarker
		}
		Action TurnToMyTeam
		{
			TeamControl DirectMayhemteam
			{
				Type DoBehavior
				Team Mayhemteam
				Behavior <<DoNothing(Gang(1),Untargetable(1),Unselectable(1),Invincible(1))>>
			}
		}
	}
	Timer SeerTimer
	{
		Duration 0:14
	}
	Counter ProtestKills
	{
		Type VillainGroup
		Count 6
		VillainGroup PraetorianAngryCitizens
		VolumeName EventVolume_Prot
	}
	Counter SeerKills
	{
		Type team
		Count 1
		team Seerteam
	}
	Trigger SpawnInSeers
	{
		Requires SeerTimer complete>
		Action StartSeers
		{
			TeamControl StartSeers
			{
				Type Activate
				Team Seerteam
			}
		}
	}
	Trigger LoyalistSuccess
	{
		Requires ProtestKills complete>
		Action ProtestKillsDone
		{
			DebugPrint <<ProtestKills success: switching to ProtestLoyalist>>
			Floater Victory
			{
				Message P3612170673
				Color 00ff00
				Volume EventVolume_Prot
			}
		}
		NextStage ProtestLoyalist
	}
	Trigger ResistanceSuccess
	{
		Requires SeerKills complete>
		Action SeerKillsDone
		{
			DebugPrint <<SeerKills success: switching to ProtestResistance>>
			Floater Victory
			{
				Message P838902829
				Color 00ff00
				Volume EventVolume_Prot
			}
		}
		NextStage ProtestResistance
	}
	UICollection ProtestOption
	{
		UIItem ProtestKills
		{
			Type CenterText
			Text P2725170890
		}
		UIItem SeparatorLine
		{
			Type CenterText
			Text P3072676397
		}
		UIItem SeerKills
		{
			Type CenterText
			Text P1235620222
		}
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Protest>>
		}
	}

	Trigger OtherEventStarting
	{
		Requires ZoneEventMutex InstanceTokenVal system> UNKNOWN eq !
		Action
		{
			DebugPrint <<Event Shutting Down Due To Other Event Grabbing The Mutex>>
		}
		NextStage ResetImmediateAndRecycle
	}
}

