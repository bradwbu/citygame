//This trigger chases Maelstrom if his health hits 85% or less. NOTE: Trigger name refers to when it was 75%.
	Trigger Maelstrom-Health75-Stage5
	{
		Requires Maelstrom-CheckDelay-Timer5 complete> PropagandaThresholdReached-Stg5 scriptvalue> 2 < && Maelstrom-Health-Stage5 count> 85 <= && MaelstromChased scriptvalue> 0 == &&

		Action
		{
			TeamControl
			{
				Team Maelstrom-Stage5
				Type DoBehavior
				Behavior <<Maelstrom_TeleportOut(Timer(4)),Invincible(1),Invisible(1),Untargetable(1),Unselectable(1),DoNotMove(1),DoNotUseAnyPowers(1),DoAttackAI(0),DoNothing(CombatOverride(Passive))>>
			}
		}
		Action
		{
			Delay 1
			TeamControl
			{
				Team Maelstrom-Stage5
				Type SetHealth
				Health 1.0
			}
		}
		Action
		{
			Floater
			{
				Message P939099428
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Team SpecialObjectives
				Type ForceSpawn
			}
		}
		Action
		{
			Reset Maelstrom-ReturnTimer-Stage5
		}
		Action
		{
			SetScriptValue MaelstromChased 1
		}
		Action
		{
			Reset Maelstrom-Health75-Stage5
		}
	}

