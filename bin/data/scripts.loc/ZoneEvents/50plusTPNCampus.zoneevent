//This trigger is for failure after the Propaganda Victory is achieved.
	Trigger TotalFailure-Stage4
	{	
		Requires PropagandaThresholdReached-Stg4 scriptvalue> 2 >= Maelstrom-Timer-Stage4 complete> && Maelstrom-Defeated-Stage4 complete> ! &&
		NextStage Stop

		Action
		{
			DebugPrint <<Total Failure in Stage 4. Maelstrom convinces the populace.>>
			Floater
			{
				Message P779361687
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P732400918
				Color FF9900
			}
		}
	}

//This trigger is for victory after the Propaganda Victory is achieved.
	Trigger TotalVictory-Stage4

		Requires PropagandaThresholdReached-Stg4 scriptvalue> 2 >= Maelstrom-Timer-Stage4 complete> ! && Maelstrom-Defeated-Stage4 complete> &&
		NextStage Maelstrom-Recovery

		Action
		{
			DebugPrint <<Total Victory in Stage 4. Maelstrom is chased off.>>
			Floater
			{
				Message P2146642575
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P474643285
				Color FF9900
			}
		}
		//Reward players with the mid-trial item drop, added in 2150
		Action
		{
			Reward IS.Issue2150Midtrial
		}
		Action
		{
			Reward AstralMerit1
		}
	}

//Failure due to Public Opinion reaching zero at any point
	Trigger PropagandaFailure
	{
		Requires Propaganda scriptvalue> 0 <=
		NextStage Stop

		Action
		{
			DebugPrint <<Public Opinion Failure in Stage 4.>>
			Floater
			{
				Message P2657777427
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P732400918
				Color FF9900
			}
		}
	}

//Ratings and Public Opinion Master Calculations
	Trigger MasterCalculation
	{
		Requires CalculationCheck complete> PropagandaThresholdReached-Stg4 scriptvalue> 2 < &&

		Action
		{
			SetScriptValue Propaganda Propaganda scriptvalue> PropagandaThisTick scriptvalue> + Propaganda-TermComplete scriptvalue> 30 * + Propaganda-HD-Defeated scriptvalue> 30 * - Propaganda-DeadCitizens count> 5 * - Propaganda-ConvertedCitizens scriptvalue> 1 * - Propaganda-MaelstromControl scriptvalue> -
		}
		Action
		{
			SetScriptValue PropagandaThisTick 0
		}
		Action
		{
			SetScriptValue Propaganda-TermComplete 0
		}
		Action
		{
			SetScriptValue Propaganda-ConvertedCitizens 0
		}
		Action
		{
			SetScriptValue Propaganda-MaelstromControl 0
		}
		Action
		{
			SetScriptValue Propaganda-HD-Defeated 0
		}
		Action
		{
			Reset MasterCalculation
			Reset Propaganda-DeadCitizens
		}
		Action
		{
			Reset CalculationCheck
		}
	}

//Public Opinion Calculations
	Trigger PropagandaBaseGeneration
	{
		Requires PropagandaGeneration complete> PropagandaThresholdReached-Stg4 scriptvalue> 2 < &&

		Action
		{
			SetScriptValue PropagandaThisTick BonusClicks scriptvalue> Propaganda-TechnicianDegen count> - 
		}
		Action
		{
			Reset PropagandaGeneration
			Reset PropagandaBaseGeneration
		}
	}

//This trigger set deals with the cycling of Telepathist-South-A.
	Trigger Telepathist-South-A-Spawn
	{
		Requires Telepathist-South-A-InitialSpawn-Timer complete> Telepathist-South-A-Spawned scriptvalue> 0 == &&

		Action
		{
			SetScriptValue Telepathist-Initial-Spawn 1
		}
		Action
		{
			Floater
			{
				Message P10066930
				Color FF0022
				AlertType PriorityAlert
			}
			TeamControl
			{
				Team Telepathist-South-A
				Type Activate
			}
		}
		Action
		{
			Delay 1
			SetScriptValue Telepathist-South-A-Spawned 1
		}
	}

	Trigger Telepathist-South-A-Recycle
	{
		Requires Telepathist-South-A-Alive complete> Telepathist-South-A-Spawned scriptvalue> 1 == && PropagandaThresholdReached-Stg4 scriptvalue> 2 < &&

		Action
		{
			DebugPrint <<Starting Telepathist South A Respawn>>
		}
		Action
		{
			Delay 40
			DebugPrint <<Telepathist South A Respawned>>
			TeamControl
			{
				Team Telepathist-South-A
				Type ForceSpawn
			}
		}
		Action
		{
			Delay 42
			DebugPrint <<Finished Telepathist South A Respawn>>
			Reset Telepathist-South-A-Recycle
		}
	}

