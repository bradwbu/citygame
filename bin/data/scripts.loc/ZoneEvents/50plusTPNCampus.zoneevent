Stage Assault
{
	DisplayName P4058669003
	Tooltip P2022843722

//No Karma is awarded in this initial stage. There is no failsafe.

// Start Hospital Door Block

	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:00
	}
	
	Trigger HospitalDoor-Unlock-Recovery
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1533101862
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

//End Hospital Door Block

//Start Warmth Spawn Block

	Trigger WarmthBuffActivation
	{
		Requires eventLockedByGroup? ! WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Granted>>
			SetScriptValue WarmthBuffSpawned 1
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team WarmthBuff
			}
		}
		Action
		{
			Floater
			{
				Message P1172875117
				Color FF9900
			}
		}
	}

	Trigger WarmthBuffBlocked
	{
		Requires eventLockedByGroup? WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Disabled>>
			SetScriptValue WarmthBuffSpawned 1
		}
	}

//End Warmth Spawn Block

//This block will create the guards at the start, the bonus objectives entity team for building completion karma and set all badge scriptvalues to 0, which will award badges if those values are still 0 at the end of the event.

	Startup
	{
		Action
		{
			DebugPrint <<TPN Campus Incarnate Trial Started>>
		}
		Action
		{
			TeamControl
			{
				Team IDF-Guards-Plaza
				Type Activate
			}
		}
		Action
		{
			TeamControl
			{
				Team SpecialObjectives
				Type Activate
			}
		}
		Action
		{
			SetScriptValue WarmthBuffSpawned 0
		}		
		Action
		{
			SetScriptValue InitialCameraSpawn-Stage1 0
		}
		Action
		{
			SetScriptValue ShowFavorability-Stage1 0
		}
		Action
		{
			SetScriptValue SternWarning-Stage1 0
		}
		Action
		{
			SetScriptValue Badge-PropagandaChallenge-Stage3 0
		}
		Action
		{
			SetScriptValue Badge-PropagandaChallenge-Stage4 0
		}
		Action
		{
			SetScriptValue Badge-PropagandaChallenge-Stage5 0
		}
		Action
		{
			SetScriptValue Badge-TelepathistChallenge 0
		}
		Action
		{
			SetScriptValue Badge-MaelstromChallenge 0
		}
		Action
		{
			SetScriptValue Badge-TelevisionChallenge-Health 0
		}
		Action
		{
			SetScriptValue Badge-TelevisionChallenge-Buildings 0
		}
		Action
		{
			SetScriptValue Cutscene-Skippable 1
		}
		Action
		{
			Delay 5
			TeamControl
			{
				Team BadgeChecker
				Type Activate
			}
		}
	}

//This counter detects the defeat of the entity which checks to see if any players do not have the completion badge.
	Counter BadgeCheckerDefeated
	{
		Type Team
		Team BadgeChecker
		Direction Up
		Count 1
	}
	
//Counter which tracks the number of IDF defeated by players.		
	Counter IDF-Defeated-Stage1
	{
		Type Team
		Team IDF-Guards-Plaza
		Count 500
	}

//Counter which tracks the number of IDF defeated in order to spawn an additional camera.
	Counter IDF-Defeated-CameraSpawn-Stage1
	{
		Type Team
		Team IDF-Guards-Plaza
		Count 5
	}

//Counter which tracks the number of cameras defeated on the map.
	Counter Cameras-Defeated-Stage1
	{
		Type Team
		Team Television-Cameras
		Count 500
	}

//Counter which tracks the number of cameras defeated before a warning is issued.
	Counter Cameras-Defeated-Warning-Stage1
	{
		Type Team
		Team Television-Cameras
		Count 1
	}

//Victory Condition for the Stage
	Trigger Stage1-Victory
	{
		Requires IDF-Defeated-Stage1 count> Cameras-Defeated-Stage1 count> 5 * - 50 >=
		NextStage Television

		Action
		{
			DebugPrint <<Victory in Stage 1. IDF forces pushed back>>
			Floater
			{
				Message P4033874878
				Color FF9900
			}
			Floater
			{
				Message P1026613006
				Color FF9900
			}
		}
	}

//Set the skippability of the cutscene in Stage 2.
	Trigger Stage1-SetCutsceneSkippable
	{
		Requires BadgeCheckerDefeated complete>

		Action
		{
			DebugPrint <<Badge Checker Defeated. Cutscene Will Not Be Skipped.>>
		}
		Action
		{
			SetScriptValue Cutscene-Skippable 0
		}
	}

//Trigger the music for the stage.
	Trigger Stage1-StartMusic
	{
		Requires IDF-Defeated-CameraSpawn-Stage1 count> 1 >= MusicStarted-Stage1 scriptvalue> 0 == &&

		Action
		{
			SetScriptValue MusicStarted-Stage1 1
		}
		Action
		{
			PlaySound
			{
				Sound i20_03Low_b_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			Caption IntroCaption
			{
				Message P2063834979
			}
		}
	}

//Trigger the initial camera's spawn for the first five guards defeated.
	Trigger Stage1-CameraSpawn-Initial
	{
		Requires IDF-Defeated-CameraSpawn-Stage1 complete> InitialCameraSpawn-Stage1 scriptvalue> 0 == &&

		Action
		{
			TeamControl
			{
				Team Television-Cameras
				Type Activate
			}
		}
		Action
		{
			Floater
			{
				Message P2883858675
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P3383326353
				Color FF9900
			}
		}
		Action
		{
			Reset IDF-Defeated-CameraSpawn-Stage1
		}
		Action
		{
			SetScriptValue InitialCameraSpawn-Stage1 1
		}
		Action
		{
			SetScriptValue ShowFavorability-Stage1 1
		}
	}

//Trigger the on-going spawn of cameras for every five guards after the first five.
	Trigger Stage1-CameraSpawn-Ongoing
	{
		Requires IDF-Defeated-CameraSpawn-Stage1 complete> InitialCameraSpawn-Stage1 scriptvalue> 1 >= && IDF-Defeated-Stage1 count> Cameras-Defeated-Stage1 count> 5 * - 50 < &&

		Action
		{
			Floater
			{
				Message P1436002561
				Color FF9900
			}
			TeamControl
			{
				Team Television-Cameras
				Type ForceSpawn
			}
		}
		Action
		{
			Reset IDF-Defeated-CameraSpawn-Stage1
		}
		Action
		{
			Reset Stage1-CameraSpawn-Ongoing
		}
	}

//Trigger HD's stern warning the first time players destroy a camera.
	Trigger Stage1-SternWarning
	{
		Requires Cameras-Defeated-Warning-Stage1 complete> SternWarning-Stage1 scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P3674620863
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P3148100893
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue SternWarning-Stage1 1
		}
		Action
		{
			Reset Cameras-Defeated-Warning-Stage1
		}
	}

//Trigger floaters each time a camera is defeated after the first warning.
	Trigger Stage1-CameraDestroyed-PostWarning
	{
		Requires Cameras-Defeated-Warning-Stage1 complete> SternWarning-Stage1 scriptvalue> 1 >= &&

		Action
		{
			Floater
			{
				Message P873219791
				Color FF9900
			}
		}
		Action
		{
			Reset Cameras-Defeated-Warning-Stage1
		}
		Action
		{
			Reset Stage1-CameraDestroyed-PostWarning
		}
	}


//UI Information for Stage 1
	UICollection Stage1
	{
		UIItem PlazaGuards-Stage1
		{
			Type BarBlue
			Text P2968021209
			ShortText P3504659590
			Current IDF-Defeated-Stage1 count>
			HideIf ShowFavorability-Stage1 scriptvalue> 1 >=
			Target 5
		}
		UIItem Favorability-Stage1
		{
			Type BarGold
			Text P619863062
			ShortText P397631154
			Current IDF-Defeated-Stage1 count> Cameras-Defeated-Stage1 count> 5 * -
			HideIf ShowFavorability-Stage1 scriptvalue> 1 <
			Target 50
		}
	}

	Shutdown
	{
		Action
		{
			TeamControl
			{
				Team Television-Cameras
				Type DoBehavior
				Behavior <<MoveToPos(marker:EnterMainBuilding),RunIntoDoor,DestroyMe>>
			}
		}
		Action
		{
			TeamControl
			{
				Team IDF-Guards-Plaza
				Type Deactivate
			}
		}
	}
}

Stage Television
{
	DisplayName P2737957419
	ToolTip P1506560704

	AwardKarma
	KarmaThreshold 10

//Start New Failsafe Block

	Counter ZonePlayers
        {
                Type ZEPlayers
        }
        Counter ZonePlayersAlive
        {
                Type ZEPlayersAlive
        }
        Counter ZonePlayersActive
        {
                Type ZEPlayersActive
        }
	Counter FailsafePlayersAlive
	{
		Type ZEPlayersAlive
	}
	Counter FailsafePlayersPhased
	{
		Type ZEPlayersPhased
	}
	Timer FailsafeDelay
	{
		Duration 0:15
	}
	Timer FailsafeLongDelay
	{
		Duration 1:00
	}

	//Trigger the failsafe for an unlocked league if the number of players is less than 2.
	Trigger FailsafeStart
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeStart
		{
			DebugPrint <<Starting Failsafe countdown for unlocked league>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the failsafe for a locked league if the number of players is less than 4 and the event is an 8-16 player event.
	Trigger FailsafeStart-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 8>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Eight
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}
	
	//Trigger the failsafe for a locked league if the number of players is less than 6 and the event is a 12-24 player event.
	Trigger FailsafeStart-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 12>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Twelve
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the end of the failsafe for an unlocked league after 15s if it still has less than 2 players.
	Trigger FailsafeConclude
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 1 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 4 players in an 8 player event.
	Trigger FailsafeConclude-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 6 players in an 12 player event.
	Trigger FailsafeConclude-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 2 before the 15s timer ends.
	Trigger FailsafeReset
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 > FailsafeInProcess scriptvalue> 1 == && eventLockedByGroup? ! && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart 
			Reset FailsafeReset
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 4 before the 15s timer ends.
	Trigger FailsafeReset-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Eight 
			Reset FailsafeReset-LockedTeam-Eight 
			Reset FailsafeDelay 
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 6 before the 60s timer ends.
	Trigger FailsafeReset-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Twelve 
			Reset FailsafeReset-LockedTeam-Twelve 
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

//End New Failsafe Block

// Start Hospital Door Block

	Timer HospitalDoor-Lock-Timer
