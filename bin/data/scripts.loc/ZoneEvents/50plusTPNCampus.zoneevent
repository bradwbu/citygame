//Television in Today Building Definitions
	Trigger TelevisionToday-Spawn
	{
		Requires ReadyForNextBuilding scriptvalue> 0 == BuildingToSpawn scriptvalue> 3 == && TodayBuildingUnlocked scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 4: HD Spawned at TPN Today>>
			Floater
			{
				Message P1341763080
				Color ff9900
			}
		}
		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-TPNToday
			}
		}
		Action
		{
			PorterControl
			{
				Type Deactivate
				Porter TPTR-TPNToday
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Television-Today
			}
			TeamControl
			{
				Type Activate
				Team IDF-Guards-Today
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-TodayTerm-A
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-TodayTerm-B
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-TodayTerm-C
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-TodayTerm-D
			}
			TeamControl
			{
				Type Activate
				Team Attackers-TodayHD
			}
		}
		Action
		{
			Reset TelevisionToday-Alive
			Reset TelevisionToday-Health
		}
		Action
		{
			SetScriptValue AnyBuildingUnlocked 1
		}
		Action
		{
			SetScriptValue TodayBuildingUnlocked 1
		}
		Action
		{
			SetScriptValue TodayTerminal-A-Unlocked-State 0
		}
		Action
		{
			SetScriptValue TodayTerminal-B-Unlocked-State 0
		}
		Action
		{
			SetScriptValue TodayTerminal-C-Unlocked-State 0
		}
		Action
		{
			SetScriptValue TodayTerminal-D-Unlocked-State 0
		}
		Action
		{
			Reset TelevisionToday-Spawn
		}
	}

//Today Building - Spawn Technicians
	Trigger TelevisionToday-TechnicianSpawn
	{
		Requires TodayBuildingUnlocked scriptvalue> 1 == PlayersInTodayRoom count> 1 >= && TodayBuildingUnlocked-TechsSpawned scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P961931930
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Techs-TodayTerm-A
			}
			TeamControl
			{
				Type Activate
				Team Techs-TodayTerm-B
			}
			TeamControl
			{
				Type Activate
				Team Techs-TodayTerm-C
			}
			TeamControl
			{
				Type Activate
				Team Techs-TodayTerm-D
			}
		}
		Action
		{
			Reset Techs-TodayTerm-A-Defeated
			Reset Techs-TodayTerm-B-Defeated
			Reset Techs-TodayTerm-C-Defeated
			Reset Techs-TodayTerm-D-Defeated
		}
		Action
		{
			Delay 2
			SetScriptValue TodayBuildingUnlocked-TechsSpawned 1
		}
	}

//Today Building Closure Triggers
	Trigger TelevisionToday-Death
	{
		//If TPN Today is unlocked and HD is defeated there before all terminals are used, shutdown TPN Today.
		Requires TodayBuildingUnlocked scriptvalue> 1 == TelevisionToday-Alive count> 0 == &&

		Action
		{
			DebugPrint <<Stage 4: HD Defeated at TPN Today>>
			Floater
			{
				Message P279845870
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue Propaganda-HD-Defeated 1
		}
		Action
		{
			SetScriptValue RunTodayBuildingShutdown 1
		}
	}

	Trigger TelevisionToday-TerminalsCompleted
	{
		//If TPN Today is unlocked and HD is not defeated there before all terminals are used, shutdown TPN Today.
		Requires TodayBuildingUnlocked scriptvalue> 1 == TelevisionToday-Alive count> 0 > && TodayTerminalsUsed scriptvalue> 3 >= &&

		Action
		{
			DebugPrint <<Stage 4: All Terminals Completed at TPN Today>>
			Floater
			{
				Message P1711264195
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue Badge-TelevisionChallenge-Buildings Badge-TelevisionChallenge-Buildings scriptvalue> 1 +
		}
		Action
		{
			TeamControl
			{
				Team SpecialObjectives
				Type ForceSpawn
			}
		}
		Action
		{
			SetScriptValue RunTodayBuildingShutdown 1
		}
	}

//Today Building Shutdown
	Trigger TodayBuilding-Shutdown
	{
		Requires RunTodayBuildingShutdown scriptvalue> 1 ==

		Action
		{
			SetScriptValue RunTodayBuildingShutdown 0
		}
		Action
		{
			SetScriptValue TodayBuildingUnlocked 0
		}
		Action
		{
			SetScriptValue TerminalSpawnsStarted 0
		}
		Action
		{
			SetScriptValue TodayTerminalsUsed 0
		}
		Action
		{
			SetScriptValue AnyBuildingUnlocked 0
		}
		Action
		{
			SetScriptValue TodayTerminal-A-Unlocked-State 2
		}
		Action
		{
			SetScriptValue TodayTerminal-B-Unlocked-State 2
		}
		Action
		{
			SetScriptValue TodayTerminal-C-Unlocked-State 2
		}
		Action
		{
			SetScriptValue TodayTerminal-D-Unlocked-State 2
		}
		Action
		{
			Delay 1
			Floater
			{
				Message P2312174155
				Color 0099FF
				AlertType PriorityAlert
				Volume TPTR-TPNToday
			}
		}
		Action
		{
			DoorControl
			{
				Type Lock
				Door Door-TPNToday
			}
		}
		Action
		{
			PorterControl
			{
				Type Activate
				Porter TPTR-TPNToday
			}
		}
		Action
		{
			Reset TodayTerminal-A-Unlocked
			Reset TodayTerminal-B-Unlocked
			Reset TodayTerminal-C-Unlocked	
			Reset TodayTerminal-D-Unlocked
		}
		Action
		{
			Reset TodayTerminal-A-Completed
			Reset TodayTerminal-B-Completed
			Reset TodayTerminal-C-Completed	
			Reset TodayTerminal-D-Completed
		}
		Action
		{
			Reset TelevisionToday-Alive
			Reset TelevisionToday-Health
		}
		Action
		{
			GlowieControl
			{
				Type Deactivate
				Glowie TodayTerminal-A
			}
			GlowieControl
			{
				Type Deactivate
				Glowie TodayTerminal-B
			}
			GlowieControl
			{
				Type Deactivate
				Glowie TodayTerminal-C
			}
			GlowieControl
			{
				Type Deactivate
				Glowie TodayTerminal-D
			}
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Television-Today
			}
			TeamControl
			{
				Type Deactivate
				Team IDF-Guards-Today
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-TodayTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-TodayTerm-B
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-TodayTerm-C
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-TodayTerm-D
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-TodayTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-TodayTerm-B
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-TodayTerm-C
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-TodayTerm-D
			}
			TeamControl
			{
				Type Deactivate
				Team Attackers-TodayHD
			}
		}

		Action
		{
			Reset TelevisionSpawnTimer
			Reset TelevisionToday-Death
		}
		Action
		{
			SetScriptValue TodayBuildingUnlocked-TechsSpawned 0
		}
		Action
		{
			SetScriptValue ReadyForNextBuilding 1
		}
		Action
		{
			Reset TelevisionToday-Death
		}
		Action
		{
			Reset TelevisionToday-TerminalsCompleted
		}
		Action
		{
			Reset TelevisionToday-TechnicianSpawn
		}
		Action
		{
			Reset TodayBuilding-Shutdown
		}
		Action
		{
			Reset Television-Building-Startup
		}
		Action
		{
			Delay 5
			Reset PlayersInTodayRoom
		}
	}

//Trigger Block: Today Terminal A
