			{
				Message P1834815494
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Reset Clicks-TodayTerminal-A
		}
		Action
		{
			SetScriptValue Propaganda-TermComplete Propaganda-TermComplete scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue BonusClicks BonusClicks scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue TodayTerminalsUsed TodayTerminalsUsed scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue TodayTerminal-A-Unlocked-State 2
		}
		Action
		{
			GlowieControl
			{
				Type Deactivate
				Glowie TodayTerminal-A
			}
		}
		Action
		{
			Reset TodayTerminal-A-Completed
		}
	}

