//Cycle the spawn of technicians after Maelstrom arrives.
	Trigger Maelstrom-PostArrival-Technicians-Stage2-CycleStart
	{
		Requires MaelstromPresent-Stage2 scriptvalue> 1 >= PostMaelstrom-Technicians-Stage2 scriptvalue> 0 == && MainTerminalsUsed scriptvalue> 4 >= &&

		Action
		{
			DebugPrint <<Stage 2: Post-Maelstrom Technician Respawn Cycle Started>>
		}
		Action
		{
			Reset Maelstrom-Technician-Timer
		}
		Action
		{
			Delay 1
			SetScriptValue PostMaelstrom-Technicians-Stage2 1
		}
		Action
		{
			Delay 5
			Floater
			{
				Message P463637679
				Color FF0000
				AlertType PriorityAlert
			}
		}
	}

	Trigger Maelstrom-PostArrival-Technicians-Stage2-CycleDone
	{
		Requires MaelstromPresent-Stage2 scriptvalue> 1 >= PostMaelstrom-Technicians-Stage2 scriptvalue> 1 == && MainTerminalsUsed scriptvalue> 4 >= && Maelstrom-Technician-Timer complete> &&

		Action
		{
			SetScriptValue MainTerminalsUsed 0
		}
		Action
		{
			DebugPrint <<Stage 2: Post-Maelstrom Technician Respawn Cycle Finished>>
			Floater
			{
				Message P2455141777
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team TechGuards-MainTerm-A-Stage2
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-MainTerm-B-Stage2
			}
			TeamControl
