//Television in Vis Building Definitions
	Trigger TelevisionVis-Spawn
	{
		Requires ReadyForNextBuilding scriptvalue> 0 == BuildingToSpawn scriptvalue> 2 == && VisBuildingUnlocked scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 4: HD Spawned at Vis Building>>
			Floater
			{
				Message P3737762771
				Color ff9900
			}
		}
		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-VisualCorp
			}
		}
		Action
		{
			PorterControl
			{
				Type Deactivate
				Porter TPTR-VisualCorp
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Television-Vis
			}
			TeamControl
			{
				Type Activate
				Team IDF-Guards-Vis
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-VisTerm-A
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-VisTerm-B
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-VisTerm-C
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-VisTerm-D
			}
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-A
			}
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-B
			}
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-C
			}
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-D
			}
			TeamControl
			{
				Type Activate
				Team Attackers-VisHD
			}
		}
		Action
		{
			Reset TelevisionVis-Alive
			Reset TelevisionVis-Health
		}
		Action
		{
			SetScriptValue AnyBuildingUnlocked 1
		}
		Action
		{
			SetScriptValue VisBuildingUnlocked 1
		}
		Action
		{
			SetScriptValue VisTerminal-A-Unlocked-State 0
		}
		Action
		{
			SetScriptValue VisTerminal-B-Unlocked-State 0
		}
		Action
		{
			SetScriptValue VisTerminal-C-Unlocked-State 0
		}
		Action
		{
			SetScriptValue VisTerminal-D-Unlocked-State 0
		}
		Action
		{
			Reset TelevisionVis-Spawn
		}
	}

//Vis Building - Spawn Technicians
	Trigger TelevisionVis-TechnicianSpawn
	{
		Requires VisBuildingUnlocked scriptvalue> 1 == PlayersInVisRoom count> 1 >= && VisBuildingUnlocked-TechsSpawned scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P961931930
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-A
			}
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-B
			}
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-C
			}
			TeamControl
			{
				Type Activate
				Team Techs-VisTerm-D
			}
		}
		Action
		{
			Reset Techs-VisTerm-A-Defeated
			Reset Techs-VisTerm-B-Defeated
			Reset Techs-VisTerm-C-Defeated
			Reset Techs-VisTerm-D-Defeated
		}
		Action
		{
			Delay 2
			SetScriptValue VisBuildingUnlocked-TechsSpawned 1
		}
	}

//Vis Building Closure Triggers
	Trigger TelevisionVis-Death
	{
		//If VisualCorp is unlocked and HD is defeated there before all terminals are used, shutdown VisualCorp.
		Requires VisBuildingUnlocked scriptvalue> 1 == TelevisionVis-Alive count> 0 == &&

		Action
		{
			DebugPrint <<Stage 4: HD Defeated at VisualCorp>>
			Floater
			{
				Message P2550115115
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue Propaganda-HD-Defeated 1
		}
		Action
		{
			SetScriptValue RunVisBuildingShutdown 1
		}
	}

	Trigger TelevisionVis-TerminalsCompleted
	{
		//If VisualCorp is unlocked and HD is not defeated there before all terminals are used, shutdown VisualCorp.
		Requires VisBuildingUnlocked scriptvalue> 1 == TelevisionVis-Alive count> 0 > && VisTerminalsUsed scriptvalue> 3 >= &&

		Action
		{
			DebugPrint <<Stage 4: Terminals Completed at VisualCorp>>
			Floater
			{
				Message P1995100883
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue Badge-TelevisionChallenge-Buildings Badge-TelevisionChallenge-Buildings scriptvalue> 1 +
		}
		Action
		{
			TeamControl
			{
				Team SpecialObjectives
				Type ForceSpawn
			}
		}
		Action
		{
			SetScriptValue RunVisBuildingShutdown 1
		}
	}

//Vis Building Shutdown
	Trigger VisBuilding-Shutdown
	{
		Requires RunVisBuildingShutdown scriptvalue> 1 ==

		Action
		{
			SetScriptValue RunVisBuildingShutdown 0
		}
		Action
		{
			SetScriptValue VisBuildingUnlocked 0
		}
		Action
		{
			SetScriptValue TerminalSpawnsStarted 0
		}
		Action
		{
			SetScriptValue VisTerminalsUsed 0
		}
		Action
		{
			SetScriptValue AnyBuildingUnlocked 0
		}
		Action
		{
			SetScriptValue VisTerminal-A-Unlocked-State 2
		}
		Action
		{
			SetScriptValue VisTerminal-B-Unlocked-State 2
		}
		Action
		{
			SetScriptValue VisTerminal-C-Unlocked-State 2
		}
		Action
		{
			SetScriptValue VisTerminal-D-Unlocked-State 2
		}
		Action
		{
			Delay 1
			Floater
			{
				Message P836403885
				Color 0099FF
				AlertType PriorityAlert
				Volume TPTR-VisualCorp
			}
		}
		Action
		{
			DoorControl
			{
				Type Lock
				Door Door-VisualCorp
			}
		}
		Action
		{
			PorterControl
			{
				Type Activate
				Porter TPTR-VisualCorp
			}
		}
		Action
		{
			Reset VisTerminal-A-Unlocked
			Reset VisTerminal-B-Unlocked
			Reset VisTerminal-C-Unlocked	
			Reset VisTerminal-D-Unlocked
		}
		Action
		{
			Reset VisTerminal-A-Completed
			Reset VisTerminal-B-Completed
			Reset VisTerminal-C-Completed	
			Reset VisTerminal-D-Completed
		}
		Action
		{
			Reset TelevisionVis-Alive
			Reset TelevisionVis-Health
		}
		Action
		{
			GlowieControl
			{
				Type Deactivate
				Glowie VisTerminal-A
			}
			GlowieControl
			{
				Type Deactivate
				Glowie VisTerminal-B
			}
			GlowieControl
			{
				Type Deactivate
				Glowie VisTerminal-C
			}
			GlowieControl
			{
				Type Deactivate
				Glowie VisTerminal-D
			}
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Television-Vis
			}
			TeamControl
			{
				Type Deactivate
				Team IDF-Guards-Vis
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-VisTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-VisTerm-B
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-VisTerm-C
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-VisTerm-D
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-VisTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-VisTerm-B
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-VisTerm-C
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-VisTerm-D
			}
			TeamControl
			{
				Type Deactivate
				Team Attackers-VisHD
			}
		}

		Action
		{
			Reset TelevisionSpawnTimer
			Reset TelevisionVis-Death
		}
		Action
		{
			SetScriptValue VisBuildingUnlocked-TechsSpawned 0
		}
		Action
		{
			SetScriptValue ReadyForNextBuilding 1
		}
		Action
		{
			Reset TelevisionVis-Death
		}
		Action
		{
			Reset TelevisionVis-TerminalsCompleted
		}
		Action
		{
			Reset TelevisionVis-TechnicianSpawn
		}
		Action
		{
			Reset VisBuilding-Shutdown
		}
		Action
		{
			Reset Television-Building-Startup
		}
		Action
		{
			Delay 5
			Reset PlayersInVisRoom
		}
	}

