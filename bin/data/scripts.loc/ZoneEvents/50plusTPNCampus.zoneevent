		}
		Action
		{
			SetScriptValue BonusClicks BonusClicks scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue MainTerminalsUsed MainTerminalsUsed scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue MainTerminal-A-Unlocked-State 2
		}
		Action
		{
			GlowieControl
			{
