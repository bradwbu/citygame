		Requires MainTerminal-D-Unlocked-State scriptvalue> 1 == VisTerminal-D-Unlocked-State scriptvalue> 1 == || TodayTerminal-D-Unlocked-State scriptvalue> 1 == ||

		Action
		{
			SetScriptValue Terminal-D-Unlocked-State 1
		}
		Action
		{
			Reset UI-Helper-Terminal-D-AllLocked
			Reset UI-Helper-Terminal-D-OneUnlocked
			Reset UI-Helper-Terminal-D-OneCompleted
		}
	}
	Trigger UI-Helper-Terminal-D-OneCompleted
	{
		Requires MainTerminal-D-Unlocked-State scriptvalue> 2 == VisTerminal-D-Unlocked-State scriptvalue> 2 == && TodayTerminal-D-Unlocked-State scriptvalue> 2 == &&

		Action
		{
			SetScriptValue Terminal-D-Unlocked-State 2
		}
		Action
		{
			Reset UI-Helper-Terminal-D-AllLocked
			Reset UI-Helper-Terminal-D-OneUnlocked
			Reset UI-Helper-Terminal-D-OneCompleted
		}		
	}

