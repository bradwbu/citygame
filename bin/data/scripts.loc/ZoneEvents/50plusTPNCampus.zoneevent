Name IncarnateTrial-TPNCampus
FirstStage Setup
StopStage Stop
RestartStage Reset
DisplayName P4192873205
//ZoneEventName = 50plusTPNCampus

//Event Reward Structure
// Stage 1: Gain 50 Favorability with H.D. - No Karma, No Merits
// Stage 2: Accrue 250 Public Opinion and Defeat Maelstrom - Karma 10, Astral Merit x1
// Stage 3: Accrue 500 Public Opinion and Defeat Maelstrom - Karma 10, Astral Merit x1 for Prop Victory, Astral Merit x1 for Maelstrom Defeat
// Stage 4: Accrue 500 Public Opinion and Defeat Maelstrom - Karma 10, Astral Merit x1 for Prop Victory, Astral Merit x1 for Maelstrom Defeat; Empyrean Merit x2 or Empyrean Merit x1
// Total: 3 Karma Stages. 
//	1 Completed stages: Incarnate Subcomponent
//	2-3 Completed stages: Component Drop Tables

Stage Setup
{
	StartUp
	{
		Action DebugMessageSetupEventStart
		{
			DebugPrint <<Stage SetupEvent Initialized...>>
		}
		Action
		{
			DebugPrint <<This is a 12-24 player event>>
			SetScriptValue EventSize 12
		}

// Create Waypoints
		Action
		{
			WaypointCreate WP-MainBuilding map_enticon_gate_entrysafe P1566528774
			WaypointCreate WP-VisualCorp map_enticon_gate_entrysafe P595826508
			WaypointCreate WP-TPNToday map_enticon_gate_entrysafe P993952476
			WaypointCreate WP-MissionExit map_enticon_neighborhood P3301789151
			WaypointCreate WP-HospitalExit map_enticon_neighborhood P2099690906
			WaypointCreate WP-HospitalExitSurface map_enticon_neighborhood P2099690906
			WaypointCreate WP-MainTerminalA map_enticon_pushpin P509890911
			WaypointCreate WP-MainTerminalB map_enticon_pushpin P2272067813
			WaypointCreate WP-MainTerminalC map_enticon_pushpin P4033491059
			WaypointCreate WP-MainTerminalD map_enticon_pushpin P1846453712
			WaypointCreate WP-VisTerminalA map_enticon_pushpin P509890911
			WaypointCreate WP-VisTerminalB map_enticon_pushpin P2272067813
			WaypointCreate WP-VisTerminalC map_enticon_pushpin P4033491059
			WaypointCreate WP-VisTerminalD map_enticon_pushpin P1846453712
			WaypointCreate WP-TodayTerminalA map_enticon_pushpin P509890911
			WaypointCreate WP-TodayTerminalB map_enticon_pushpin P2272067813
			WaypointCreate WP-TodayTerminalC map_enticon_pushpin P4033491059
			WaypointCreate WP-TodayTerminalD map_enticon_pushpin P1846453712
		}
		Action
		{
			WaypointPlace WP-MainBuilding WP-MainBuilding
			WaypointPlace WP-VisualCorp WP-VisualCorp
			WaypointPlace WP-TPNToday WP-TPNToday
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
			WaypointPlace WP-HospitalExitSurface WP-HospitalExitSurface
			WaypointPlace WP-MainTerminalA WP-MainTerminalA
			WaypointPlace WP-MainTerminalB WP-MainTerminalB
			WaypointPlace WP-MainTerminalC WP-MainTerminalC
			WaypointPlace WP-MainTerminalD WP-MainTerminalD
			WaypointPlace WP-VisTerminalA WP-VisTerminalA
			WaypointPlace WP-VisTerminalB WP-VisTerminalB
			WaypointPlace WP-VisTerminalC WP-VisTerminalC
			WaypointPlace WP-VisTerminalD WP-VisTerminalD
			WaypointPlace WP-TodayTerminalA WP-TodayTerminalA
			WaypointPlace WP-TodayTerminalB WP-TodayTerminalB
			WaypointPlace WP-TodayTerminalC WP-TodayTerminalC
			WaypointPlace WP-TodayTerminalD WP-TodayTerminalD
		}

// Create Teleportation Volumes
		Action
		{
			PorterCreate TPTR-MainBuilding //NamedVolume property: TPTR-MainBuilding; ScriptMarker
			PorterCreate TPTR-VisualCorp //NamedVolume property: TPTR-VisualCorp; ScriptMarker
			PorterCreate TPTR-TPNToday //NamedVolume property: TPTR-TPNToday; ScriptMarker
		}
		Action
		{
			PorterControl
			{
				Type Activate
				Porter TPTR-MainBuilding
			}
			PorterControl
			{
				Type Activate
				Porter TPTR-VisualCorp
			}
			PorterControl
			{
				Type Activate
				Porter TPTR-TPNToday
			}
		}
// Create and Lock Doors
		Action
		{
			DoorCreate Door-MainBuilding // Add the following property to the MapSwap: Requires 50plusTPNCampus.Door.Door-MainBuilding ZoneEvent>
			DoorCreate Door-VisualCorp // Add the following property to the MapSwap: Requires 50plusTPNCampus.Door.Door-VisualCorp ZoneEvent>
			DoorCreate Door-TPNToday // Add the following property to the MapSwap: Requires 50plusTPNCampus.Door.Door-TPNToday ZoneEvent>
			DoorCreate Door-Hospital // Add the following property to the MapSwap: Requires 50plusTPNCampus.Door.Door-Hospital ZoneEvent>

			DoorControl
			{
				Type Lock
				Door Door-MainBuilding
			}
			DoorControl
			{
				Type Lock
				Door Door-VisualCorp
			}
			DoorControl
			{
				Type Lock
				Door Door-TPNToday
			}
			DoorControl
			{
				Type Lock
				Door Door-Hospital
			}
		}

