			Floater
			{
				Message P18101250
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P732400918
				Color FF9900
			}
		}
	}

//Victory Condition for the Stage
	Trigger Stage2-Victory
	{
		Requires Propaganda scriptvalue> 0 > Maelstrom-Defeated-Stage2 complete> &&
		NextStage Television-Recovery

		Action
		{
			DebugPrint <<Victory in Stage 2. Maelstrom Defeated>>
			Floater
			{
				Message P619537622
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			Delay 1
			Floater
			{
				Message P2493134829
				Color 0099FF
				AlertType PriorityAlert
			}
		}
		Action
		{
			Reward AstralMerit1
		}
	}

//Ratings and Public Opinion Master Calculations
	Trigger MasterCalculation
	{
		Requires CalculationCheck complete>

		Action
		{
			SetScriptValue Propaganda Propaganda scriptvalue> PropagandaThisTick scriptvalue> + Propaganda-TermComplete scriptvalue> 10 * +
		}
		Action
		{
			SetScriptValue PropagandaThisTick 0
		}
		Action
		{
			SetScriptValue Propaganda-TermComplete 0
		}
		Action
		{
			Reset MasterCalculation
		}
		Action
		{
			Reset CalculationCheck
		}
	}

//Public Opinion Calculations
	Trigger PropagandaBaseGeneration
	{
		Requires TerminalSpawnsStarted scriptvalue> 1 >= PropagandaGeneration complete> &&

		Action
		{
			SetScriptValue PropagandaThisTick BonusClicks scriptvalue> Propaganda-TechnicianDegen count> -
		}
		Action
		{
			Reset PropagandaGeneration
			Reset PropagandaBaseGeneration
		}
	}

//Start Terminal Spawns
		
	Trigger StartTerminals-Stage2
	{
		Requires PlayersInBackRoom count> 1 >= TerminalSpawnsStarted scriptvalue> 0 == &&

		Action
		{
			SetScriptValue ShowPropagandaBar-Stage2 1
		}
		Action
		{
			SetScriptValue TerminalSpawnsStarted 1
		}
		Action
		{
			Reset PropagandaGeneration
			Reset PropagandaBaseGeneration
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-A
			}
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-B
			}
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-C
			}
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-D
			}
		}
		Action
		{
			Floater
			{
				Message P3346132990
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Delay 2
			Floater
			{
				Message P3696269114
				Color FF9900
				AlertType PriorityAlert
			}
		}
	}

//Trigger Block: Main Terminal A
//Activate Terminal A for clicking when the corresponding Technician is eliminated.

	Trigger MainTerminal-A-Unlocked
	{
		Requires Techs-MainTerm-A-Defeated complete> TerminalSpawnsStarted scriptvalue> 1 >= &&

		Action
		{
			DebugPrint <<Main Terminal A Activated>>
			Floater
			{
				Message P273871093
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue MainTerminal-A-Unlocked-State 1
		}
		Action
		{
			Reset Techs-MainTerm-A-Defeated
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Techs-MainTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-MainTerm-A-Stage2
			}
			GlowieControl MainTerminal-A
			{	
				Type Activate
				Glowie MainTerminal-A
			}
		}
		Action
		{
			Reset MainTerminal-A-Unlocked
		}
	}

//Begin Public Opinion Generation for Terminal A when it is used to completion.

	Trigger MainTerminal-A-Completed
	{
		Requires Clicks-MainTerminal-A complete>

		Action
		{
			DebugPrint <<Main Terminal A Completed. Prop Bonus!>>
			Floater
			{
				Message P1834815494
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Reset Clicks-MainTerminal-A
		}
		Action
		{
			SetScriptValue Propaganda-TermComplete Propaganda-TermComplete scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue BonusClicks BonusClicks scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue MainTerminalsUsed MainTerminalsUsed scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue MainTerminal-A-Unlocked-State 0
		}
		Action
		{
			GlowieControl
			{
				Type Deactivate
				Glowie MainTerminal-A
			}
		}
		Action
		{
			Reset MainTerminal-A-Completed
		}
	}

