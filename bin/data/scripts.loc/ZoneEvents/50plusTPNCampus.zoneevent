// This trigger spawns a 5th citizen set for 18+ players.	
	Trigger Stage4-SpawnFor18
	{
		Requires ZonePlayers count> 18 >= 

		Action
		{
			TeamControl
			{
				Team Citizens-South-B
				Type Activate
			}
			TeamControl
			{
				Team Citizens-South-Signs-B
				Type Activate
			}
		}
		Action
		{
			SetScriptValue TelepathistExtra 1
		}
		Action
		{
			SetScriptValue TelepathistMaxCount 5
		}
	}

// This trigger spawns a 6th citizen set for 24 players.
	Trigger Stage4-SpawnFor24
	{
		Requires ZonePlayers count> 24 >= TelepathistExtra scriptvalue> 1 == &&

		Action
		{
			TeamControl
			{
				Team Citizens-North-B
				Type Activate
			}
			TeamControl
			{
				Team Citizens-North-Signs-B
				Type Activate
			}
		}
		Action
		{
			SetScriptValue TelepathistExtra 2
		}
		Action
		{
			SetScriptValue TelepathistMaxCount 6
		}
	}

//Failure Condition for the Stage should the timer run out.
	Trigger Stage4-Failure-TimerExpires
	{
		Requires Stage4-Failure-Timer complete> PropagandaThresholdReached-Stg4 scriptvalue> 1 < &&
		NextStage Stop

		Action
		{
			DebugPrint <<Failure in Stage 4. Timer expired.>>
			Floater
			{
				Message P1756841932
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P732400918
				Color FF9900
			}
		}			
	}

//Public Opinion Requirements to Advance the Stage
	Trigger PropagandaHits500-Stage4
	{
		Requires Propaganda scriptvalue> 500 >= PropagandaThresholdReached-Stg4 scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Public Opinion Threshold Reached. Starting Stage Countdown Timer!>>
			Floater
			{
				Message P1927465235
				Color FF9900
			}
		}
		Action
		{
			Reset Maelstrom-Timer-Stage4
		}
		Action
		{
			Reset PropagandaVictory4-Timer
		}
		Action
		{
			SetScriptValue PropagandaThresholdReached-Stg4 1
		}
		Action
		{
			Reset PropagandaHits500-Stage4
			Reset PropagandaFallsUnder500-Stage4
		}
	}

	Trigger PropagandaFallsUnder500-Stage4
	{
		Requires Propaganda scriptvalue> 500 < PropagandaThresholdReached-Stg4 scriptvalue> 1 == && PropagandaVictory4-Timer complete> ! &&
		
		Action
		{
			DebugPrint <<Public Opinion Threshold Lost. Stopping Success Countdown.>>
			Floater
			{
				Message P4154764513
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue PropagandaThresholdReached-Stg4 0
		}
		Action
		{
			Reset PropagandaHits500-Stage4
			Reset PropagandaFallsUnder500-Stage4
		}
	}

//Badge Trigger - Propaganda Challenge Failed
	Trigger PropagandaChallenge-Failed-Stage4
	{
		Requires Badge-PropagandaChallenge-Stage4-Timer complete> PropagandaThresholdReached-Stg4 scriptvalue> 2 < &&

		Action
		{
			DebugPrint <<Badge Check: 8:00 challenge for Stage 4 Propaganda Failed>>
			SetScriptValue Badge-PropagandaChallenge-Stage4 1
		}
	}

//This trigger runs if Propaganda Victory is achieved.
	Trigger PropagandaVictory-Stage4
	{
		Requires Propaganda scriptvalue> 500 >= PropagandaThresholdReached-Stg4 scriptvalue> 1 == && PropagandaVictory4-Timer complete> &&

		Action
		{
			Caption StageThreeCaption-2
			{
				Message P1994458050
			}
		}
		Action
		{
			DebugPrint <<Public Opinion Victory in Stage 4. Stage Fight with Maelstrom can begin.>>
			Floater
			{
				Message P4192607708
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Team Maelstrom-Stage4
				Type Activate
			}
		}
		Action
		{
			Reset Maelstrom-Timer-Stage4
			Reset MaelstromSayDelay
		}
		Action
		{
			Reset MaelstromBattle-SpawnAdds-InitialTimer-Stage4
		}
		Action
		{
			Reset MaelstromBattle-SpawnAdds-OngoingTimer-Stage4
		}
		Action
		{
			Delay 1
			Floater
			{
				Message P1461558426
				Color FF0022
				AlertType PriorityAlert
			}
		}
		Action
		{
			Delay 2
			Floater
			{
				Message P3583306914
				Color FF0022
				AlertType PriorityAlert
			}
		}
		Action
		{
			PlaySound
			{
				Sound i20_02High_a_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			Reward AstralMerit1
		}
		Action
		{
			SetScriptValue PropagandaThresholdReached-Stg4 2
		}
		Action
		{
			SetScriptValue Propaganda-Victory-Achieved 1
		}
		Action
		{
			SetScriptValue ShowReinforcementTimer-Stage4 1
		}
	}

//This trigger spawns the first wave of Maelstrom's adds.

	Trigger MaelstromBattle-SpawnAdds-Initial-Stage4
	{
		Requires PropagandaThresholdReached-Stg4 scriptvalue> 2 == MaelstromBattle-SpawnAdds-InitialTimer-Stage4 complete> &&

		Action
		{
			TeamControl
			{
				Team IDF-MaelstromAdds-Stage4
				Type Activate
			}
		}
		Action
		{
			Floater
			{
				Message P4190649898
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue ShowReinforcementTimer-Stage4 2
		}
		Action
		{
			Reset MaelstromBattle-SpawnAdds-OngoingTimer-Stage4
		}
	}

//This trigger spawns the ongoing wave of Maelstrom's adds.

	Trigger MaelstromBattle-SpawnAdds-Ongoing-Stage4
	{
		Requires PropagandaThresholdReached-Stg4 scriptvalue> 2 == MaelstromBattle-SpawnAdds-OngoingTimer-Stage4 complete> &&

		Action
		{
			TeamControl
			{
				Team IDF-MaelstromAdds-Stage4
				Type ForceSpawn
			}
		}
		Action
		{
			Reset MaelstromBattle-SpawnAdds-OngoingTimer-Stage4
		}
		Action
		{
			Floater
			{
				Message P4190649898
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Delay 2
			Reset MaelstromBattle-SpawnAdds-Ongoing-Stage4
		}
	}

//This trigger gives Maelstrom something to say as he is battled by players. It hits at 75%.
	Trigger MaelstromBattle-CaptionAt-75-Stage4
	{
		Requires PropagandaThresholdReached-Stg4 scriptvalue> 2 == Maelstrom-Health-Stage4 count> 75 < && MaelstromSayDelay complete> &&

		Action
		{
			TeamControl
			{
				Team Maelstrom-Stage4
				Type DoBehavior
				Behavior Say(P4117386425)
			}
			Caption
			{
				Message P2637769130
			}
		}
	}

