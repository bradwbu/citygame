Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Starting Stage RewardWinners>>
		}
		Action
		{
			Caption StageSixCaption
			{
				Message P279818077
			}
		}
	}
	Trigger AwardBadge-Completion
	{
		Action
		{
			DebugPrint <<Awarding Completion Badge>>
			Reward IT_TPN_Complete
		}
	}
	Trigger AwardBadge-PropagandaChallenge
	{
		Requires Badge-PropagandaChallenge-Stage3 scriptvalue> 0 == Badge-PropagandaChallenge-Stage4 scriptvalue> 0 == && Badge-PropagandaChallenge-Stage5 scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Awarding NewsFlash Badge>>
			Reward IT_TPN_PropagandaChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-TelepathistChallenge
	{
		Requires Badge-TelepathistChallenge scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding TruthInTelevision Badge>>
			Reward IT_TPN_TelepathistChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-TelevisionChallenge
	{
		Requires Badge-TelevisionChallenge-Health scriptvalue> 0 == Badge-TelevisionChallenge-Buildings scriptvalue> 6 >= &&
		Action
		{
			DebugPrint <<Awarding AddictedToTelevision Badge>>
			Reward IT_TPN_TelevisionChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-MaelstromChallenge
	{
		Requires Badge-MaelstromChallenge scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding TopStory Badge>>
			Reward IT_TPN_MaelstromChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger End
	{
		NextStage Stop
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Reward>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					NumStagesRequired 2
					RewardTable Issue21EndKarma0
				}
				Reward class2
				{
					PercentileNeeded 0.00
					NumStagesRequired 3
					PointsNeeded 10
					RewardTable IS.Issue2150EndKarma1Plus
				}
			}
		}
	}
}

