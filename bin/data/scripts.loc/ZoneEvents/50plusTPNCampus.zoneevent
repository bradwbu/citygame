			DebugPrint <<Starting Telepathist North B Respawn>>
		}
		Action
		{
			Delay 40
			DebugPrint <<Telepathist North B Respawned>>
			TeamControl
			{
				Team Telepathist-North-B
				Type ForceSpawn
			}
		}
		Action
		{
			Delay 42
			DebugPrint <<Finished Telepathist North B Respawn>>
			Reset Telepathist-North-B-Recycle
		}
	}

