//Maelstrom Arrival Cutscene Skipped
	Trigger MaelstromCutscene-Skipped
	{
		Requires Cutscene-Skippable scriptvalue> 1 == TerminalSpawnsStarted scriptvalue> 1 >= && BonusClicks scriptvalue> 4 >= && MaelstromPresent-Stage2 scriptvalue> 0 == && MaelstromCutscene-Started scriptvalue> 0 == &&

		Action
		{
			SetScriptValue MaelstromCutscene-Started 2
		}
		Action
		{
			SetScriptValue ShowPropagandaBar-Stage2 2
		}
	}

//Maelstrom Arrival Cutscene
	Trigger MaelstromCutscene-Start
	{
		Requires Cutscene-Skippable scriptvalue> 0 == TerminalSpawnsStarted scriptvalue> 1 >= && BonusClicks scriptvalue> 4 >= && MaelstromPresent-Stage2 scriptvalue> 0 == && MaelstromCutscene-Started scriptvalue> 0 == &&

		Action
		{
			Reset MaelstromCutscene-Timer
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 3
			}
		}
		Action
		{
			TeamControl
			{
				Team Cutscene-Stage2
				Type Activate
			}
		}
		Action
		{
			Delay 1
			SetScriptValue MaelstromCutscene-Started 1
		}
	}

	Trigger MaelstromCutscene-Finish
	{
		Requires MaelstromCutscene-Started scriptvalue> 1 == MaelstromCutscene-Timer complete> &&
		Action
		{
			TeamControl
			{
				Team Cutscene-Stage2
				Type Deactivate
			}
		}
		Action
		{
			Delay 1
			SetScriptValue MaelstromCutscene-Started 2
		}
		Action
		{
			SetScriptValue ShowPropagandaBar-Stage2 2
		}
	}

//Maelstrom Arrives
	Trigger MaelstromArrives-Stage2
	{
		Requires TerminalSpawnsStarted scriptvalue> 1 >= BonusClicks scriptvalue> 4 >= && MaelstromPresent-Stage2 scriptvalue> 0 == && MaelstromCutscene-Started scriptvalue> 2 == &&
	
		Action
		{
			DebugPrint <<Maelstrom Arrives in Stage 2>>
			Floater
			{
				Message P3583306914
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Maelstrom-Stage2
			}
