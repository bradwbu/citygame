//Failure Condition for the Stage should the timer run out.
	Trigger Stage2-Failure-TimerExpires
	{
		Requires Stage2-Failure-Timer complete>
		NextStage Stop

		Action
		{
			DebugPrint <<Failure in Stage 2. Timer expired.>>
			Floater
			{
				Message P1756841932
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P732400918
				Color FF9900
			}
		}			
	}

//Failure Condition for the Stage when Maelstrom is Not Present
	Trigger Stage2-Failure-NoMaelstrom
	{
		Requires Propaganda scriptvalue> 0 <= MaelstromPresent-Stage2 scriptvalue> 0 == &&
		NextStage Stop

		Action
		{
			DebugPrint <<Failure in Stage 2. Public Opinion fell to 0 before Maelstrom arrived.>>
			Floater
			{
				Message P1756841932
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P732400918
				Color FF9900
			}
		}			
	}

//Failure Condition for the Stage when Maelstrom is Present
	Trigger Stage2-Failure-MaelstromPresent
	{
