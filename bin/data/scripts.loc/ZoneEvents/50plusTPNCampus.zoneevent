//This set of triggers will determine which building should be spawning.
//Stage 5 building sequence starts with Main Building, then VisualCorp, then TPN Today.

	Trigger Television-Building-Startup
	{
		Requires TelevisionSpawnTimer complete> ReadyForNextBuilding scriptvalue> 1 == && BuildingToSpawn scriptvalue> 3 <= &&

		Action
		{
			SetScriptValue ReadyForNextBuilding 0
		}
		Action
		{
			SetScriptValue BuildingToSpawn BuildingToSpawn scriptvalue> 1 +
		}
	}

	Trigger Television-Building-Loop
	{
		Requires ReadyForNextBuilding scriptvalue> 0 == BuildingToSpawn scriptvalue> 3 > &&

		Action
		{
			DebugPrint <<Stage 5: Building Count Exceeds Three. Lowering Building Count.>>
		}
		Action
		{
			SetScriptValue BuildingToSpawn BuildingToSpawn scriptvalue> 3 -
		}
		Action
		{
			Reset Television-Building-Loop
		}
	}

//Television in Main Building Definitions
	Trigger TelevisionMain-Spawn
	{
		Requires ReadyForNextBuilding scriptvalue> 0 == BuildingToSpawn scriptvalue> 1 == && MainBuildingUnlocked scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 5: HD Spawned at Main Building>>
			Floater
			{
				Message P306181867
				Color ff9900
			}
		}
		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-MainBuilding
			}
		}
		Action
		{
			PorterControl
			{
				Type Deactivate
				Porter TPTR-MainBuilding
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Television-Main
			}
			TeamControl
			{
				Type Activate
				Team IDF-Guards-Main
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-MainTerm-A
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-MainTerm-B
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-MainTerm-C
			}
			TeamControl
			{
				Type Activate
				Team TechGuards-MainTerm-D
			}
			TeamControl
			{
				Type Activate
				Team Attackers-MainHD
			}
		}
		Action
		{
			Reset TelevisionMain-Alive
			Reset TelevisionMain-Health
		}
		Action
		{
			SetScriptValue AnyBuildingUnlocked 1
		}
		Action
		{
			SetScriptValue MainBuildingUnlocked 1
		}
		Action
		{
			SetScriptValue MainTerminal-A-Unlocked-State 0
		}
		Action
		{
			SetScriptValue MainTerminal-B-Unlocked-State 0
		}
		Action
		{
			SetScriptValue MainTerminal-C-Unlocked-State 0
		}
		Action
		{
			SetScriptValue MainTerminal-D-Unlocked-State 0
		}
		Action
		{
			Reset TelevisionMain-Spawn
		}
	}

//Main Building - Spawn Technicians
	Trigger TelevisionMain-TechnicianSpawn
	{
		Requires MainBuildingUnlocked scriptvalue> 1 == PlayersInMainRoom count> 1 >= && MainBuildingUnlocked-TechsSpawned scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P961931930
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-A
			}
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-B
			}
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-C
			}
			TeamControl
			{
				Type Activate
				Team Techs-MainTerm-D
			}
		}
		Action
		{
			Reset Techs-MainTerm-A-Defeated
			Reset Techs-MainTerm-B-Defeated
			Reset Techs-MainTerm-C-Defeated
			Reset Techs-MainTerm-D-Defeated
		}
		Action
		{
			Delay 2
			SetScriptValue MainBuildingUnlocked-TechsSpawned 1
		}
	}

//Main Building Closure Triggers
	Trigger TelevisionMain-Death
	{
		//If the main building is unlocked and HD is defeated there before all terminals are used, shutdown the main building.
		Requires MainBuildingUnlocked scriptvalue> 1 == TelevisionMain-Alive count> 0 == &&

		Action
		{
			DebugPrint <<Stage 5: HD Defeated at Main Building>>
			Floater
			{
				Message P2120227797
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue Propaganda-HD-Defeated 1
		}
		Action
		{
			SetScriptValue RunMainBuildingShutdown 1
		}
	}

	Trigger TelevisionMain-TerminalsCompleted
	{
		//If the main building is unlocked and HD is not defeated there before all terminals are used, shutdown the main building.
		Requires MainBuildingUnlocked scriptvalue> 1 == TelevisionMain-Alive count> 0 > && MainTerminalsUsed scriptvalue> 3 >= &&

		Action
		{
			DebugPrint <<Stage 5: Terminals Completed at Main Building>>
			Floater
			{
				Message P590190667
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue Badge-TelevisionChallenge-Buildings Badge-TelevisionChallenge-Buildings scriptvalue> 1 +
		}
		Action
		{
			TeamControl
			{
				Team SpecialObjectives
				Type ForceSpawn
			}
		}
		Action
		{
			SetScriptValue RunMainBuildingShutdown 1
		}
	}

//Main Building Shutdown
	Trigger MainBuilding-Shutdown
	{	
		Requires RunMainBuildingShutdown scriptvalue> 1 ==

		Action
		{
			SetScriptValue RunMainBuildingShutdown 0
		}
		Action
		{
			SetScriptValue MainBuildingUnlocked 0
		}
		Action
		{
			SetScriptValue TerminalSpawnsStarted 0
		}
		Action
		{
			SetScriptValue MainTerminalsUsed 0
		}
		Action
		{
			SetScriptValue AnyBuildingUnlocked 0
		}
		Action
		{
			SetScriptValue MainTerminal-A-Unlocked-State 2
		}
		Action
		{
			SetScriptValue MainTerminal-B-Unlocked-State 2
		}
		Action
		{
			SetScriptValue MainTerminal-C-Unlocked-State 2
		}
		Action
		{
			SetScriptValue MainTerminal-D-Unlocked-State 2
		}
		Action
		{
			Delay 1
			Floater
			{
				Message P2493134829
				Color 0099FF
				AlertType PriorityAlert
				Volume TPTR-MainBuilding
			}
		}
		Action
		{
			DoorControl
			{
				Type Lock
				Door Door-MainBuilding
			}
		}
		Action
		{
			PorterControl
			{
				Type Activate
				Porter TPTR-MainBuilding
			}
		}
		Action
		{
			Reset MainTerminal-A-Unlocked
			Reset MainTerminal-B-Unlocked
			Reset MainTerminal-C-Unlocked	
			Reset MainTerminal-D-Unlocked
		}
		Action
		{
			Reset MainTerminal-A-Completed
			Reset MainTerminal-B-Completed
			Reset MainTerminal-C-Completed	
			Reset MainTerminal-D-Completed
		}
		Action
		{
			Reset TelevisionMain-Alive
			Reset TelevisionMain-Health
		}
		Action
		{
			GlowieControl
			{
				Type Deactivate
				Glowie MainTerminal-A
			}
			GlowieControl
			{
				Type Deactivate
				Glowie MainTerminal-B
			}
			GlowieControl
			{
				Type Deactivate
				Glowie MainTerminal-C
			}
			GlowieControl
			{
				Type Deactivate
				Glowie MainTerminal-D
			}
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Television-Main
			}
			TeamControl
			{
				Type Deactivate
				Team IDF-Guards-Main
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-MainTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-MainTerm-B
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-MainTerm-C
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-MainTerm-D
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-MainTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-MainTerm-B
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-MainTerm-C
			}
			TeamControl
			{
				Type Deactivate
				Team Techs-MainTerm-D
			}
			TeamControl
			{
				Type Deactivate
				Team Attackers-MainHD
			}
		}
		Action
		{
			Reset TelevisionSpawnTimer
			Reset TelevisionMain-Death
		}
		Action
		{
			SetScriptValue MainBuildingUnlocked-TechsSpawned 0
		}
		Action
		{
			SetScriptValue ReadyForNextBuilding 1
		}
		Action
		{
			Reset TelevisionMain-Death
		}
		Action
		{
			Reset TelevisionMain-TerminalsCompleted
		}
		Action
		{
			Reset TelevisionMain-TechnicianSpawn
		}
		Action
		{
			Reset MainBuilding-Shutdown
		}
		Action
		{
			Reset Television-Building-Startup
		}
		Action
		{
			Delay 5
			Reset PlayersInMainRoom
		}
	}

//Trigger Block: Main Terminal A
//Activate Terminal A for clicking when the corresponding Technician is eliminated.

	Trigger MainTerminal-A-Unlocked
	{
		Requires Techs-MainTerm-A-Defeated complete> MainBuildingUnlocked-TechsSpawned scriptvalue> 1 >= && MainTerminal-A-Unlocked-State scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Main Terminal A Activated>>
			Floater
			{
				Message P273871093
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue MainTerminal-A-Unlocked-State 1
		}
		Action
		{
			Reset Techs-MainTerm-A-Defeated
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Techs-MainTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-MainTerm-A
			}
			GlowieControl MainTerminal-A
			{	
				Type Activate
				Glowie MainTerminal-A
			}
		}
		Action
		{
			Reset MainTerminal-A-Unlocked
		}
	}

//Begin Public Opinion Generation for Terminal A when it is used to completion.

