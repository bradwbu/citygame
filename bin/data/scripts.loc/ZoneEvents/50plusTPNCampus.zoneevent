// This trigger spawns a 5th citizen set for 18+ players.	
	Trigger Stage5-SpawnFor18
	{
		Requires ZonePlayers count> 18 >= 

		Action
		{
			TeamControl
			{
				Team Citizens-South-B
				Type Activate
			}
			TeamControl
			{
				Team Citizens-South-Signs-B
				Type Activate
			}
		}
		Action
		{
			SetScriptValue TelepathistExtra 1
		}
		Action
		{
			SetScriptValue TelepathistMaxCount 5
		}
	}

// This trigger spawns a 6th citizen set for 24 players.
	Trigger Stage5-SpawnFor24
	{
		Requires ZonePlayers count> 24 >= TelepathistExtra scriptvalue> 1 == &&

		Action
		{
			TeamControl
			{
				Team Citizens-North-B
				Type Activate
			}
			TeamControl
			{
				Team Citizens-North-Signs-B
				Type Activate
			}
		}
		Action
		{
			SetScriptValue TelepathistExtra 2
		}
		Action
		{
			SetScriptValue TelepathistMaxCount 6
		}
	}

//Failure Condition for the Stage should the timer run out.
	Trigger Stage5-Failure-TimerExpires
	{
		Requires Stage5-Failure-Timer complete> PropagandaThresholdReached-Stg5 scriptvalue> 1 < &&
		NextStage Stop

		Action
		{
			DebugPrint <<Failure in Stage 5. Timer expired.>>
			Floater
			{
				Message P1756841932
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P732400918
				Color FF9900
			}
		}			
	}

//Public Opinion Requirements to Advance the Stage
	Trigger PropagandaHits500-Stage5
	{
		Requires Propaganda scriptvalue> 500 >= PropagandaThresholdReached-Stg5 scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Public Opinion Threshold Reached. Starting Stage Countdown Timer!>>
			Floater
			{
				Message P1927465235
				Color FF9900
			}
		}
		Action
		{
			Reset PropagandaVictory5-Timer
		}
		Action
		{
			Reset Maelstrom-Timer-Stage5
		}
		Action
		{
			SetScriptValue PropagandaThresholdReached-Stg5 1
		}
		Action
		{
			Reset PropagandaHits500-Stage5
			Reset PropagandaFallsUnder500-Stage5
		}
	}

	Trigger PropagandaFallsUnder500-Stage5
	{
		Requires Propaganda scriptvalue> 500 < PropagandaThresholdReached-Stg5 scriptvalue> 1 == && PropagandaVictory5-Timer complete> ! &&
		
		Action
		{
			DebugPrint <<Public Opinion Threshold Lost. Stopping Success Countdown.>>
			Floater
			{
				Message P4154764513
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue PropagandaThresholdReached-Stg5 0
		}
		Action
		{
			Reset PropagandaHits500-Stage5
			Reset PropagandaFallsUnder500-Stage5
		}
	}

//Badge Trigger - Propaganda Challenge Failed
	Trigger PropagandaChallenge-Failed-Stage5
	{
		Requires Badge-PropagandaChallenge-Stage5-Timer complete> PropagandaThresholdReached-Stg5 scriptvalue> 2 < &&

		Action
		{
			DebugPrint <<Badge Check: 8:00 challenge for Stage 5 Propaganda Failed>>
			SetScriptValue Badge-PropagandaChallenge-Stage5 1
		}
	}

//This trigger runs if Maelstrom is NOT chased when Propaganda Victory is achieved.
	Trigger PropagandaVictory-MaelstromPresent
	{
		Requires Propaganda scriptvalue> 500 >= PropagandaThresholdReached-Stg5 scriptvalue> 1 == && PropagandaVictory5-Timer complete> && MaelstromChased scriptvalue> 0 == &&

		Action
		{
