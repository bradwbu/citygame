//Trigger Block: Today Terminal A
//Activate Terminal A for clicking when the corresponding Technician is eliminated.

	Trigger TodayTerminal-A-Unlocked
	{
		Requires Techs-TodayTerm-A-Defeated complete> TodayBuildingUnlocked-TechsSpawned scriptvalue> 1 >= && TodayTerminal-A-Unlocked-State scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Today Terminal A Activated>>
			Floater
			{
				Message P273871093
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue TodayTerminal-A-Unlocked-State 1
		}
		Action
		{
			Reset Techs-TodayTerm-A-Defeated
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Techs-TodayTerm-A
			}
			TeamControl
			{
				Type Deactivate
				Team TechGuards-TodayTerm-A
			}
			GlowieControl TodayTerminal-A
			{	
				Type Activate
				Glowie TodayTerminal-A
			}
		}
		Action
		{
			Reset TodayTerminal-A-Unlocked
		}
	}

//Begin Public Opinion Generation for Terminal A when it is used to completion.

