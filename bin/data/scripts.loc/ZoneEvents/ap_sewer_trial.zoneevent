Stage CompleteStage
{
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Event is complete!>>
		}
		Action HydraBossTurnOff
		{
			TeamControl TurnOffHydraBossSpawn
			{
				Type Deactivate
				Team HydraBossSpawn
			}
		}
		Action ShutDownInstancedEvent
	        {
			TrialComplete Success
		}
		Action TurnOffMusic
		{
			FadeSound BattleMusic
			{
				Channel Music
				FadeTime 10
			}
		}
	}
}

Stage Stop
{
	StartUp
	{
		Action SettingMaxLevelto50
		{
			SetMaxPlayerLevel 50
		}
	}
}

Stage Stage1Hellions
{
	DisplayName P16755696
	StartUp
	{
		Action DebugStartStage1
		{
			DebugPrint <<Starting Hellion First Stage>>
		}
		Action SettingMaxLevelto2
		{
			SetMaxPlayerLevel 2
		}
		Action TurnOffTeleporters
		{
			PorterControl
			{
				Porter ST-Level2
				Type Deactivate
			}
			PorterControl
			{
				Porter ST-Level3
				Type Deactivate
			}
			PorterControl
			{
				Porter ST-Level4
				Type Deactivate
			}
			SetScriptValue CaptionStarted 0
		}
		Action TurnonHellions
		{
			TeamControl StartHellions1
			{
				Type Activate
				Team HellionSpawn1
			}
			TeamControl StartRunes
			{
				Type Activate
				Team Rune
			}
			TeamControl StartHellions2
			{
				Type Activate
				Team HellionSpawn2
			}
			TeamControl StartHellions3
			{
				Type Activate
				Team HellionSpawn3
			}
			TeamControl StartHellions4
			{
				Type Activate
				Team HellionSpawn4
			}
			TeamControl StartCaptionsVillain
			{
				Type Activate
				Team CaptionManagerVillain
			}
			TeamControl StartCaptionsHero
			{
				Type Activate
				Team CaptionManagerHero
			}
		}
	}
	Counter PlayersInFirstRoom
	{
		Type ZEPlayers
		VolumeName SewerTrialFirstRoom
	}
	Trigger StartCaption
	{
		Requires PlayersInFirstRoom count> 1 >= SoundStarted scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Starting Captions>>
			TeamControl
			{
				Team CaptionManagerVillain
				Type DoBehavior
				Behavior <<UsePower("SetHealth99")>>
			}
			TeamControl
			{
				Team CaptionManagerHero
				Type DoBehavior
				Behavior <<UsePower("SetHealth99")>>
			}
			SetScriptValue CaptionStarted 1
		}
	}
// Start Hospital Door Block
	Timer HospitalDoor-Lock-Timer
	{
		Duration 00:10
	}
	Timer HospitalDoor-Notification1-Timer
	{
		Duration 00:20
	}
	Timer HospitalDoor-Notification2-Timer
	{
		Duration 00:25
	}
	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:30
	}
	
	Trigger HospitalDoor-Lock
	{
		Requires HospitalDoor-Lock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Lock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1420074300
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

	Trigger HospitalDoor-Notification1
	{
		Requires HospitalDoor-Notification1-Timer complete>
		Action
		{	
			Floater
			{
				Message P3661210205
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}
	
	Trigger HospitalDoor-Notification2
	{
		Requires HospitalDoor-Notification2-Timer complete>
		Action
		{	
			Floater
			{
				Message P177740375
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

	Trigger HospitalDoor-Unlock
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{
			Reset HospitalDoor-Unlock-Timer
			Reset HospitalDoor-Lock-Timer
			Reset HospitalDoor-Notification1-Timer
			Reset HospitalDoor-Notification2-Timer
		}
		Action
		{	
			Floater
			{
				Message P2692826546
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
		Action
		{
			Reset HospitalDoor-Unlock
			Reset HospitalDoor-Lock
			Reset HospitalDoor-Notification1
			Reset HospitalDoor-Notification2
		}
	}

//End Hospital Door Block

	Counter HellionTeam1Kills
	{
		Type Team
		Count 11
		Team HellionSpawn1
	}
	Counter HellionTeam2Kills
	{
		Type Team
		Count 11
		Team HellionSpawn2
	}
	Counter HellionTeam3Kills
	{
		Type Team
		Count 11
		Team HellionSpawn3
	}
	Counter HellionTeam4Kills
	{
		Type Team
		Count 11
		Team HellionSpawn4
	}
	UICollection FirstStageUI
	{
		UIItem HellionKill1Count
		{
			Type BarBlue
			Text P3302687991
			ShortText P3302687991
			Current HellionTeam1Kills count>
			HideIf HellionTeam1Kills complete>
			Target 11
		}
		UIItem HellionKill2Count
		{
			Type BarBlue
			Text P1951467123
			ShortText P1951467123
			Current HellionTeam2Kills count>
			HideIf HellionTeam2Kills complete>
			Target 11
		}
		UIItem HellionKill3Count
		{
			Type BarBlue
			Text P3826383723
			ShortText P3826383723
			Current HellionTeam3Kills count>
			HideIf HellionTeam3Kills complete>
			Target 11
		}
		UIItem HellionKill4Count
		{
			Type BarBlue
			Text P2073625483
			ShortText P2073625483
			Current HellionTeam4Kills count>
			HideIf HellionTeam4Kills complete>
			Target 11
		}
	}
	Trigger FirstStageDone
	{
		Requires HellionTeam1Kills complete> HellionTeam2Kills complete> && HellionTeam3Kills complete> && HellionTeam4Kills complete> &&
		Action HellionsDefeatedNextStage
		{
			DebugPrint <<Hellions defeated, triggering boss>>
			Floater Victory
			{
				Message P2758138359
				Color 00ff00
			}
		}
		NextStage Stage2HellionBoss
	}
}

Stage Stage2HellionBoss
{
	DisplayName P16755696
	StartUp
	{
		Action DebugStartStage1
		{
			DebugPrint <<Starting Hellion Boss Stage>>
		}
		Action Stage2SetUp
		{
			TeamControl Remove1Hellions
			{
				Type Deactivate
				Team HellionSpawn1
			}
			TeamControl Remove2Hellions
			{
				Type Deactivate
				Team HellionSpawn2
			}
			TeamControl Remove3Hellions
			{
				Type Deactivate
				Team HellionSpawn3
			}
			TeamControl Remove4Hellions
			{
				Type Deactivate
				Team HellionSpawn4
			}
			TeamControl AddHellionBoss
			{
				Type Activate
				Team HellionBossSpawn
			}
		}
	}
	Counter HellionBossDefeated
	{
		Type Team
		Count 1
		Team HellionBossSpawn
	}
	UICollection SecondStageUI
	{
		UIItem HellionBossDefeated
		{
			Type BarBlue
			Text P2121508829
			ShortText P3454045601
			Current HellionBossDefeated count>
			Target 1
		}
	}
	Trigger SecondStageDone
	{
		Requires HellionBossDefeated complete>
		Action HellionBossDefeated
		{
			DebugPrint <<HellionBoss defeated, triggering next stage>>
			Floater Victory
			{
				Message P3015916867
				Color 00ff00
			}
		}
		NextStage Stage3Vahzilok
	}
	Trigger StartCaption2
	{
		Requires HellionBossDefeated complete>
		Action
		{
			DebugPrint <<Hellions defeated, triggering captions>>
			TeamControl
			{
				Team CaptionManagerVillain
				Type DoBehavior
				Behavior <<UsePower("SetHealth89")>>
			}
			TeamControl
			{
				Team CaptionManagerHero
				Type DoBehavior
				Behavior <<UsePower("SetHealth89")>>
			}
		}
	}
