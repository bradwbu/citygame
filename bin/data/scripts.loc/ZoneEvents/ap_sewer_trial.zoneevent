	{
		Requires PlayersInFinalRoom count> 1 >= SoundStarted scriptvalue> 0 == &&
		Action TurnOnSound
		{
			PlaySound GiantMonsterRoar
			{
				Sound i20_01High_b_Loop
				Channel Music
				VolumeLevel 1
			        VolumeName SewerTrialFinalRoom
		        }
			SetScriptValue SoundStarted 1
