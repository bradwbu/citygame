Stage Stage3Vahzilok
{
	DisplayName P1045891675
	StartUp
	{
		Action DebugStartStage3
		{
			DebugPrint <<Starting Vahzilok Spawn Stage>>
		}
		Action SettingMaxLevelto3
		{
			SetMaxPlayerLevel 3
		}
		Action UnlockDoor1
		{
			DoorControl
			{
				Type Unlock
				Door Door-FirstLeveltoSecondLevel
			}
		}
		Action Stage2SetUp
		{
			TeamControl RemoveHellions
			{
				Type Deactivate
				Team HellionBossSpawn
			}
			TeamControl AddVahzilok1
			{
				Type Activate
				Team VahzilokSpawn1
			}
			TeamControl AddVahzilok2
			{
				Type Activate
				Team VahzilokSpawn2
			}
