Name TheSeedOfHamidon
FirstStage Setup
StopStage Stop
RestartStage Reset
DisplayName P1188567604
EventVolume ZE-SeedOfHamidon

Stage Setup
{
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage Setup>>
		}

// Create Spawns: Seed of Hamidon
		Action
		{
			SpawnCreate SeedOfHamidon
			{
				Location SeedOfHamidon
				Group SeedOfHamidon
				Team SeedOfHamidon
				KillBehavior <<DestroyMe>>
			}
			TeamCreate
			{
				Team SeedOfHamidon
			}
		}	
	}
	Trigger End
	{
		NextStage SeedBattle
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage Setup>>
		}
	}
}

Stage SeedBattle
{
	DisplayName P801445521
	Tooltip P3585370982
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage SeedBattle>>
		}
		Action
		{
			TeamControl
			{
				Team SeedOfHamidon
				Type Activate
			}
			Floater
			{
				Message P2077008991
				Color 0066cc
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue GrantSeedling-Done 0
		}
		Action
		{
			SetScriptValue GrantUntouchable-Done 0
		}
		Action
		{
			SetScriptValue CaptionIntro-Done 0
		}
	}

//This is used to update the UI as to The Seed's current health.
	Counter SeedHealth
	{
		Type BossHealth
		Team SeedOfHamidon
	}

//This is used to keep track of the defeat of the Seed of Hamidon.
	Counter SeedDefeated
	{
		Type Name
		Name DevouringEarthSeed_Seed_Of_Hamidon
		VolumeName ZE_SeedOfHamidon
		Direction Up
		Count 1
	}

//This counter tracks the number of Bulwark Seedlings present within the event
	Counter BulwarksPresent
	{
		Type Name
		Name DevouringEarthSeed_Bulwark_Seedling
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

	Counter BulwarksPresent-Auto
	{
		Type Name
		Name DevouringEarthSeed_Bulwark_Seedling_AutoFlight
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

//This counter tracks the number of Hematic Seedlings present within the event
	Counter HematicsPresent
	{
		Type Name
		Name DevouringEarthSeed_Hematic_Seedling
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

	Counter HematicsPresent-Auto
	{
		Type Name
		Name DevouringEarthSeed_Hematic_Seedling_AutoFlight
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

//This counter tracks the number of Maturing Seedlings present within the event
	Counter MaturingsPresent
	{
		Type Name
		Name DevouringEarthSeed_Maturing_Seedling
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

	Counter MaturingsPresent-Auto
	{
		Type Name
		Name DevouringEarthSeed_Maturing_Seedling_AutoFlight
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

//This counter tracks the number of Respiring Seedlings present within the event
	Counter RespiringsPresent
	{
		Type Name
		Name DevouringEarthSeed_Respiring_Seedling
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

	Counter RespiringsPresent-Auto
	{
		Type Name
		Name DevouringEarthSeed_Respiring_Seedling_AutoFlight
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

//This counter tracks the number of Contaminating Seedlings present within the event
	Counter ContaminatingsPresent
	{
		Type Name
		Name DevouringEarthSeed_Contaminating_Seedling
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

	Counter ContaminatingsPresent-Auto
	{
		Type Name
		Name DevouringEarthSeed_Contaminating_Seedling_AutoFlight
//		VolumeName ZE_SeedOfHamidon
		Direction Down
		Count 0
	}

//This is the timer which grants the Seed its Seedling Summon.

	Timer GrantSeedling-Timer
	{
		Duration 00:30
	}

//This is the timer which grants the Seed its Untouchable Aura.

	Timer GrantUntouchable-Timer
	{
		Duration 00:01
	}

//This is the timer that revokes the Untouchable Aura.

	Timer RevokeUntouchable-Timer
	{
		Duration 06:40
	}

//This trigger grants the Seed the Summon.
	Trigger GrantSeedling
	{
		Requires GrantSeedling-Timer complete> GrantSeedling-Done scriptvalue> 0 == &&

		Action
		{
			SetScriptValue GrantSeedling-Done 1
		}
		Action
		{
			TeamControl
			{
				Team SeedOfHamidon
				Type DoBehavior
				Behavior <<UsePower("Grant_Create_Seedling"),DoNothing(Timer(2))>>
			}
		}
	}

//This trigger kicks off Vanessa's caption when the Seed gets below 95% health and at least 30 seconds have elapsed.
	Trigger CaptionIntro
	{
		Requires SeedHealth count> 95 <= CaptionIntro-Done scriptvalue> 0 == && GrantUntouchable-Timer complete> &&

		Action
		{
			SetScriptValue CaptionIntro-Done 1
		}
		Action
		{
			Caption VanessaIntro
			{
				Message P341673908
				Volume ZE-SeedOfHamidon
			}
		}
	}

//This trigger grants the Seed Untouchable.
	Trigger GrantUntouchable
	{
		Requires GrantUntouchable-Timer complete> GrantUntouchable-Done scriptvalue> 0 == &&

		Action
		{
			SetScriptValue GrantUntouchable-Done 1
		}
		Action
		{
			TeamControl
			{
				Team SeedOfHamidon
				Type DoBehavior
				Behavior <<UsePower("Grant_Untouchable"),DoNothing(Timer(2))>>
			}
		}
	}

//This trigger revokes the Seed's Untouchable.
//	Trigger RevokeUntouchable
//	{
//		Requires RevokeUntouchable-Timer complete> GrantUntouchable-Done scriptvalue> 1 == &&
//
