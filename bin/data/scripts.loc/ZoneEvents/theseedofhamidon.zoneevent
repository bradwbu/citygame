Stage Rewards
{
	DisplayName P3973291631
	Tooltip P268552813
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage Rewards>>
		}
		Action
		{
			Reward ZE_Seed_Rewards
		}
		Action
		{
			TeamControl
			{
				Team SeedOfHamidon
				Type Deactivate
			}
		}
	}
	Timer RewardTimer
	{
		Duration 00:20
	}
	Trigger End
	{
		Requires RewardTimer complete>
		
		NextStage Reset
	}
	UICollection RewardsStage
	{
		UIItem Directions
		{
			Type Text
			Text P3833823979
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage Rewards>>
		}
	}
}
	
