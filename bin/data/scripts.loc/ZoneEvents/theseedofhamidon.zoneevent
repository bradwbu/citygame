//			TeamControl
//			{
//				Team SeedOfHamidon
//				Type DoBehavior
//				Behavior <<UsePower("Revoke_Untouchable"),DoNothing(Timer(2))>>
//			}
//		}
//	}


//This trigger sets up the success condition for the event.
	Trigger Success
	{
		Requires SeedHealth count> 20 <= GrantSeedling-Timer complete> &&
	
		Action
		{
			DebugPrint <<Seed of Hamidon Low.>>
		}

		NextStage SeedFinal
	}

//This is the collection of UI items for the stage.
	UICollection SeedBattleStage
	{
		UIItem SeedHealthBar
		{
			Type BarRed
			Text P2610448982
			ShortText P472596995
			Current SeedHealth count>
			OnClickFindEnt SeedOfHamidon
			Target 100
		}
		UIItem SeedDefense
		{
			Type CenterText
			Text P3490950179
			ShortText P1223756150
			HideIf GrantUntouchable-Done scriptvalue> 1 == RevokeUntouchable-Timer complete> &&
		}
		UIItem SeedLine
		{
			Type CenterText
			Text P3916222277
			ShortText P3916222277
			HideIf GrantUntouchable-Done scriptvalue> 2 ==
		}
		UIItem BulwarkPresenceBar
		{
			Type BarGold
			Text P3312098493
			ShortText P3452728367
			Current BulwarksPresent count> BulwarksPresent-Auto count> +  25 *
			Target 100
		}
		UIItem MaturingPresenceBar
		{
			Type BarGold
			Text P694115325
			ShortText P402822971
			Current MaturingsPresent count> MaturingsPresent-Auto count> + 25 *
			Target 100
		}
		UIItem SeedLine2
		{
			Type CenterText
			Text P3916222277
			ShortText P3916222277
		}
		UIItem SeedDebuffs
		{
			Type CenterText
			Text P281978014
			ShortText P3565651664
		}
		UIItem SeedLine3
		{
			Type CenterText
			Text P3916222277
			ShortText P3916222277
		}
		UIItem HematicPresenceBar
		{
			Type BarGold
			Text P3463025140
			ShortText P3043489578
			Current HematicsPresent count> HematicsPresent-Auto count> +  25 *
			Target 100
		}
		UIItem RespiringPresenceBar
		{
			Type BarGold
			Text P3063610327
			ShortText P1291825364
			Current RespiringsPresent count> RespiringsPresent-Auto count> + 25 *
			Target 100
		}
		UIItem ContaminatingPresenceBar
		{
			Type BarGold
			Text P1621680316
			ShortText P3363418556
			Current ContaminatingsPresent count> ContaminatingsPresent-Auto count> + 25 *
			Target 100
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage SeedBattle>>
		}
//		Action
//		{
//			TeamControl
//			{
//				Team SeedOfHamidon
//				Type Deactivate
//			}
//		}
	}
}
Stage SeedFinal
{
	DisplayName P2350419781
	Tooltip P2981578300
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage SeedFinal>>
		}
		Action
		{
			Floater
			{
				Message P792042581
				Color 0066cc
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue RevokeDamage-Done 0
		}
		Action
		{
			SetScriptValue RevokeSeedling-Done 0
		}
		Action
		{
			SetScriptValue RevokeAuras-Done 0
		}
		Action
		{
			PlaySound
			{
				Sound i20_03High_a_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			Caption VanessaOutro
			{
				Message P1069376436
				Volume ZE-SeedOfHamidon
			}
		}
	}

//This is the timer which ensures that the pets no longer have their postdeath power when they are destroyed.

	Timer RevokeDamage-Timer
	{
		Duration 00:01
	}

//This is the 2nd timer which ensures that the pets no longer have their postdeath power when they are destroyed.

	Timer RevokeSeedlings-Timer
	{
		Duration 00:03
	}

//This is the timer which counts towards the Seed's P1354651601/reset.

	Timer Enrage-Timer
	{
		Duration 10:00
	}

//This is used to update the UI as to The Seed's current health.
	Counter SeedHealth
	{
		Type BossHealth
		Team SeedOfHamidon
	}

//This is used to keep track of the defeat of the Seed of Hamidon.
	Counter SeedDefeated
	{
		Type Name
		Name DevouringEarthSeed_Seed_Of_Hamidon
		VolumeName ZE_SeedOfHamidon
		Direction Up
		Count 1
	}

//This trigger removes the Summon from the Seed and destroys all of its pets.  It also switches out Corrosive Blast for Corrosive Barrage and adds the Seed's extra resistances for p2
	Trigger RevokeDamage
	{
		Requires RevokeDamage-Done scriptvalue> 0 == RevokeDamage-Timer complete> &&

		Action
		{
			SetScriptValue RevokeDamage-Done 1
		}
		Action
		{
			TeamControl
			{
				Team SeedOfHamidon
				Type DoBehavior
				Behavior <<UsePower("Revoke_Untouchable"),DoNothing(Timer(2)),UsePower("Revoke_Damage"),DoNothing(Timer(2)),UsePower("Revoke_Create_Seedling"),DoNothing(Timer(2)),UsePower("Revoke_Auras"),DoNothing(Timer(2))>>
			}
		}
	}

