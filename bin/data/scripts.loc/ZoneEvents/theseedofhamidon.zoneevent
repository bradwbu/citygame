//This trigger sets up the success condition for the event.
	Trigger Success
	{
		Requires SeedDefeated complete>
	
		Action
		{
			DebugPrint <<Seed of Hamidon Defeated.>>
		}

		NextStage Rewards
	}


//This trigger sets up the success condition for the event.
	Trigger Fail
	{
		Requires SeedDefeated complete> ! Enrage-Timer complete> &&
	
		Action
		{
			DebugPrint <<Seed of Hamidon Flees!>>
		}
		Action
		{
			TeamControl
			{
				Team SeedOfHamidon
				Type SetHealth
				Health 1.0
			}
		}
		Action
		{
			TeamControl
			{
				Team SeedOfHamidon
				Type DoBehavior
				Behavior <<UsePower("Grant_Auras"),DoNothing(Timer(2)),UsePower("Grant_Create_Seedling"),DoNothing(Timer(2))>>
			}
		}
		NextStage SeedBattle
	}

//This is the collection of UI items for the stage.
	UICollection SeedFinalStage
	{
		UIItem SeedHealthBar
		{
			Type BarRed
			Text P2610448982
			ShortText P472596995
			Current SeedHealth count>
			OnClickFindEnt SeedOfHamidon
			Target 100
		}
		UIItem SeedEnrageTimer
		{
			Type Timer
			Timer Enrage-Timer
			Text P2526697837
			ShortText P2764776255
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage SeedFinal>>
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 10
			}
		}
