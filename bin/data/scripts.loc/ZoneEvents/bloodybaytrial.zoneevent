	Counter Pushstage1-Counter
	{
		Type ZEPlayers
		VolumeName PreludePush1
	}
	Counter BWAKCount
	{
		Type Team
		Team BWAK1
		Direction Up
		Count 200
	}
	Counter BWAKCount2
	{
		Type Team
		Team BWAK1
		Direction Down
		Count 0
	}
//Meteor Counters for every stage - Start
	Counter MTeenCount
	{
		Type Click
		Glowie GMTeen
		Count 1
	}
//Meteor Counters for every stage - End
//Meteor Trigger Completes for every stage - Start
	Trigger TeenComplete
	{
		Requires MTeenCount complete>
		Action
		{
			SetScriptValue BadgeMeteors BadgeMeteors scriptvalue> 1 +
		}
		Action
		{
			Log <<Meteor Teen Claimed>>
		}
		Action
		{
			Floater Victory
			{
				Message P727470965
				Color 00FF00
			}
		}
	}
//Meteor Trigger Completes for every stage - Start
	Trigger VillainSpawnsBW
	{
		Requires villain scriptvalue> 1 ==
		Action
		{
			TeamControl
			{
				Type Activate
				Team BW-Villain-NPC1
			}
			TeamControl
			{
				Type Activate
				Team Pre-ARCmdr
			}
		}
		Action
		{
			SetScriptValue CurrentStageV 1
		}
		Action
		{
			RemoveWaypoints
		}
		Action
		{
			WaypointPlace WP-ARComm WP1
		}
	}
	Trigger HeroSpawnsBW
	{
		Requires hero scriptvalue> 1 ==
		Action
		{
			TeamControl
			{
				Type Activate
				Team BW-Hero-NPC1
			}
			TeamControl
			{
				Type Activate
				Team Pre-LBCmdr
			}
		}
		Action
		{
			RemoveWaypoints
		}
		Action
		{
			SetScriptValue CurrentStageH 1
		}
		Action
		{
			WaypointPlace WP-LBComm WP1
		}
	}
