	Trigger HeroCheck
	{
		Requires turnstileMissionName> LowLevelBloodyBayTrial_hero eq
		action
		{
			setscriptvalue hero 1
		}
		action
		{
			debugprint <<Setting as Hero>>
		}
	}
	Trigger VillainCheck
	{
		Requires turnstileMissionName> LowLevelBloodyBayTrial_villain eq
		action
		{
			setscriptvalue villain 1
		}
		action
		{
			debugprint <<Setting as Villain>>
		}
	}
	Trigger NeitherCheck
	{
		Requires turnstileMissionName> LowLevelBloodyBayTrial_hero eq ! turnstileMissionName> LowLevelBloodyBayTrial_villain eq ! &&
		action
		{
			setscriptvalue villain 1
		}
		action
		{
			debugprint <<No Side Set, Defaulting to villain>>
		}
	}
	Trigger End
	{
		NextStage Prelude
	}
}
Stage Prelude
{
	DisplayName P2186842247
	Startup
	{
		Action StartPrelude
		{
			DebugPrint <<Starting PRELUDE>>
		}
		Action
		{
			GurneyControl
			{
				Type Activate
				Gurney Gurney
			}
			DebugPrint <<Hosptial GURNEY ACTIVATED>>
		}
		Action TurnOffTeleporters
		{
			PorterControl
			{
				Porter PrtDestGZ
				Type Deactivate
			}
			PorterControl
			{
				Porter PrtDestFF
				Type Deactivate
			}
		}
		Action
		{
			SetScriptValue CurrentStage 1
		}
		Action TurnOnSpawnsGen
		{
			TeamControl
			{
				Type Activate
				Team BWAK1
			}
			TeamControl
			{
				Type Activate
				Team BW-Fallen
			}
		}
	} 
