		{
			TeamControl HellionStaticRemove
			{
				Type Deactivate
				Team HellionStatic1
			}
		}
		Action ProtestKillsDone
		{
			Floater Victory
			{
				Message P1474098038
				Color 00ff00
				Volume EventVolume_Hellions
			}
		}
