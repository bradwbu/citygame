				Type DoBehavior
				Team ObeliskSpawn
				Behavior <<Untargetable(1),Unselectable(1),Invincible(1)>>
			}
		}
		Action TurnOffBosses
		{
			TeamControl HellionBosses
			{
				Type Deactivate
				Team HellionBoss
			}
		}
		Action HellionFountainSpawn3
		{
			TeamControl NewFountainSpawn
			{
				Type Deactivate
				Team HellionFountainSpawn3
			}
		}
	}
	Counter HellionKills
	{
		Type VillainGroup
		Count 25
		VillainGroup Hellions
	}
	Counter ParagonPoliceKills
	{
		Type VillainGroup
		Count 5
		VillainGroup ParagonPolice
	}
	UICollection Stage1KillCount
	{
		UIItem HellionKills
		{
			Type BarBlue
			Text P3833793833
			ShortText P1391944229
			Current HellionKills count>
			Target 25
		}
		UIItem PPDKills
		{
			Type BarBlue
			Text P3812303450
			ShortText P1492594559
			Current ParagonPoliceKills count>
			Target 5
		}
	}
