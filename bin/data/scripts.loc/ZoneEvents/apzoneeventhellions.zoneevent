	{
		Requires ParagonPoliceKills complete>
		Action ProtestKillsDone
		{
			DebugPrint <<Paragon Police are falling back!>>
			Floater Victory
			{
				Message P1531687539
				Color 00ff00
				Volume EventVolume_Hellions
			}
		}
		NextStage NegativeStage1
	}
	Trigger GoodStuffHappens
	{
		Requires HellionKills complete>
		Action HellionKillsDone
		{
			DebugPrint <<Hellions are being pushed back!>>
			Floater Victory
			{
				Message P2022749481
				Color 00ff00
				Volume EventVolume_Hellions
			}
		}
		NextStage PositiveStage1
	}
}

