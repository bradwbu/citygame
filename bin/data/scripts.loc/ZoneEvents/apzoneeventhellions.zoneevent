				Team DemonSpawn
			}
		}
		Action TurnOffObelisks
		{
			TeamControl Pantheon
			{
				Type Deactivate
				Team ObeliskSpawn
			}
		}
	}
	Timer ResetTimer
	{
		Duration 0:30
	}
	Trigger End
	{
		Requires ResetTimer complete>
		NextStage NeutralStage
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down stage Reset>>
		}
	}
	UICollection Protestreset
	{
		UIItem TimeToNextEvent
		{
			Type Timer
			Timer ResetTimer
			Text P2969292143
			ShortText P1957261162
		}
	}
}

Stage NeutralStage
{
	DisplayName P2360237160
	StartUp
	{
		Action StartKillProtest
		{
			DebugPrint <<Starting Stage Protest>>
		}
		Action TurnOnSpawns
