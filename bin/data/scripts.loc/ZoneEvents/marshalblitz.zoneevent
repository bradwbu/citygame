	Counter BlitzHealth3
	{
		Type BossHealth
		Team BlitzStage3
	}

//This is used to keep track of the defeat of the Marshal Blitz.
	Counter BlitzDefeated
	{
		Type Name
		Name RogueArachnos_Marshal_Blitz_Stage3
//		VolumeName ZE_MarshalBlitz
		Direction Up
		Count 1
	}

//This is where timers go:
//This is the timer which ensures that Blitz spawns before the stage completes.

	Timer SpawnGuard-Timer
	{
		Duration 00:02
	}

//This trigger sets up the success condition for the event.
	Trigger Success
	{
		Requires BlitzHealth3 count> 0 <= SpawnGuard-Timer complete> &&
	
		Action
		{
			DebugPrint <<Marshal Blitz Defeated.>>
		}
		Action TriggerObjective
		{
			Objective ScriptBlitzDefeated
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 10
			}

		}

		NextStage Stop
	}

//This is the collection of UI items for the stage.
	UICollection BlitzStage3
	{
		UIItem BlitzHealthBar3
		{
			Type BarRed
			Text P2811579100
			ShortText P4267145610
			Current BlitzHealth3 count>
			OnClickFindEnt BlitzStage3
			Target 100
		}
	}
