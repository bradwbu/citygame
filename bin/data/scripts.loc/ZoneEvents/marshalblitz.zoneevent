		}
	}
//This trigger sets up the success condition for the event.
	Trigger Success
	{
		Requires FlierDefeated complete> BlitzLanded2-Timer complete> &&
	
		Action
		{
			DebugPrint <<Blitzkrieg Defeated.>>
		}

		NextStage Blitz3
	}

//This is the collection of UI items for the stage.
	UICollection BlitzStage2
	{
		UIItem BlitzkriegHealthBar
