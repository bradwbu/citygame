Name MarshalBlitz
FirstStage Setup
StopStage Stop
RestartStage Reset
DisplayName P2719249738
EventVolume ZE-MarshalBlitz

Stage Setup
{
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage Setup>>
		}

// Create Spawns: Martial Blitz
		Action
		{
			SpawnCreate BlitzStage1
			{
				Location BlitzStage1
				Group BlitzStage1
				Team BlitzStage1
				KillBehavior <<DoNothing(AnimList(Ghouls_Ambush_JumpUp), Timer(1)),DestroyMe>>
			}
			SpawnCreate BlitzStage2
			{
				Location BlitzStage2
				Group BlitzStage2
				Team BlitzStage2
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate BlitzStage3
			{
				Location BlitzStage3
				Group BlitzStage3
				Team BlitzStage3
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate Generator1
			{
				Location Generator1
				Group Generator1
				Team Generator1
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate Generator2
			{
				Location Generator2
				Group Generator2
				Team Generator2
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate Generator3
			{
				Location Generator3
				Group Generator3
				Team Generator3
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate Generator4
			{
				Location Generator4
				Group Generator4
				Team Generator4
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate Rocket
			{
				Location Rocket
				Group Rocket
				Team Rocket
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate SAM1
			{
				Location SAM1
				Group SAM1
				Team SAM1
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate SAM2
			{
				Location SAM2
				Group SAM2
				Team SAM2
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate SAM3
			{
				Location SAM3
				Group SAM3
				Team SAM3
				KillBehavior <<DestroyMe>>
			}
			SpawnCreate SAM4
			{
				Location SAM4
				Group SAM4
				Team SAM4
				KillBehavior <<DestroyMe>>
			}
			TeamCreate
			{
				Team BlitzStage1
			}
			TeamCreate
			{
				Team BlitzStage2
			}
			TeamCreate
			{
				Team BlitzStage3
			}
			TeamCreate
			{
				Team Generator1
				Creator BlitzStage1
			}
			TeamCreate
			{
				Team Generator2
				Creator BlitzStage1
			}
			TeamCreate
			{
				Team Generator3
				Creator BlitzStage1
			}
			TeamCreate
			{
				Team Generator4
				Creator BlitzStage1
			}
			TeamCreate
			{
				Team Rocket
			}
			TeamCreate
			{
				Team SAM1
			}
			TeamCreate
			{
				Team SAM2
			}
			TeamCreate
			{
				Team SAM3
			}
			TeamCreate
			{
				Team SAM4
			}
// Create Glowies: SAM activation terminals			
			GlowieCreate SAM1Glowie
			{
				DisplayName P2951641255
				Location SAM1Glowie
				Quantity 1
				ResetDelay 30
//				VanishOnComplete
				Model V_OO_Arachnos_Comp_Floor_02
				Interact P2894777210
				Interrupt P1720911274
				Complete P2781290439
				BarText P3089117839
				InteractTime 4
			}
			GlowieCreate SAM2Glowie
			{
				DisplayName P2951641255
				Location SAM2Glowie
				Quantity 1
				ResetDelay 30
//				VanishOnComplete
				Model V_OO_Arachnos_Comp_Floor_02
				Interact P2894777210
				Interrupt P1720911274
				Complete P2781290439
				BarText P3089117839
				InteractTime 4
			}
			GlowieCreate SAM3Glowie
			{
				DisplayName P2951641255
				Location SAM3Glowie
				Quantity 1
				ResetDelay 30
//				VanishOnComplete
				Model V_OO_Arachnos_Comp_Floor_02
				Interact P2894777210
				Interrupt P1720911274
				Complete P2781290439
				BarText P3089117839
				InteractTime 4
			}
			GlowieCreate SAM4Glowie
			{
				DisplayName P2951641255
				Location SAM4Glowie
				Quantity 1
				ResetDelay 30
//				VanishOnComplete
				Model V_OO_Arachnos_Comp_Floor_02
				Interact P2894777210
				Interrupt P1720911274
				Complete P2781290439
				BarText P3089117839
				InteractTime 4
			}
		}
		Action SetupGlowies
		{
			GlowieControl
			{
				Type Place
				Glowie SAM1Glowie
			}
			GlowieControl
			{
				Type Place
				Glowie SAM2Glowie
			}
			GlowieControl
			{
				Type Place
				Glowie SAM3Glowie
			}
			GlowieControl
			{
				Type Place
				Glowie SAM4Glowie
			}
		}
//Spawn Turrets
		Action
		{
			TeamControl
			{
				Team SAM1
				Type Activate
			}
			TeamControl
			{
				Team SAM2
				Type Activate
			}
			TeamControl
			{
				Team SAM3
				Type Activate
			}
			TeamControl
			{
				Team SAM4
				Type Activate
			}
		}
	}
	Trigger End
	{
		Requires TriggerVolume_Outside objectivesucceeded>
		NextStage Blitz1
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage Setup>>
		}
	}
}

