//This is used to update the UI as to Martial Blitz's current health.  Also used for trigger into stage2
	Counter BlitzHealth
	{
		Type BossHealth
		Team BlitzStage1
	}

//This is used to keep track of how many generators are left alive.
	Counter Generators-Stage1
	{
		Type Name
		Name Objects_Power_Generator_Sig3
		Direction Down
		Count 0
	}

//This is where timers go:
//This is the timer which makes sure that Blitz has spawned before his health fail condition is met.

	Timer BlitzLanded-Timer
	{
		Duration 00:05
	}

