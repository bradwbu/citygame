//This trigger sets up the success condition for the event.
	Trigger Success
	{
		Requires BlitzHealth count> 20 <= BlitzLanded-Timer complete> &&
	
		Action
		{
			DebugPrint <<Marshal Blitz Low.>>
		}

		NextStage Blitz2
	}

//This is the collection of UI items for the stage.
	UICollection Blitz1
	{
		UIItem BlitzHealthBar
		{
			Type BarRed
			Text P2811579100
			ShortText P4267145610
			Current BlitzHealth count>
			OnClickFindEnt BlitzStage1
			Target 100
		}
		UIItem BlitzDefense
		{
			Type CenterText
			Text P1258041250
			ShortText P2320040416
			HideIf Generators-Stage1 count> 0 ==
		}
		UIItem BlitzLine
		{
			Type CenterText
			Text P3916222277
			ShortText P3916222277
//			HideIf GrantUntouchable-Done scriptvalue> 2 ==
		}
		UIItem GeneratorPresenceBar
		{
			Type BarBlue
			Text P1987073529
			ShortText P3987961155
			Current Generators-Stage1 count>
			Target 4
			HideIf Generators-Stage1 count> 0 ==
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage Blitz1>>
		}
