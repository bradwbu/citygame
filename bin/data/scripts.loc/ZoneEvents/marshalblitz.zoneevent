//This is used to update the UI as to the Flier's current health.
	Counter FlierHealth
	{
		Type BossHealth
		Team BlitzStage2
	}
//This counts glowie clicks:
	Counter SAM1Clicks
	{
		Type Click
		Count 1
		Glowie SAM1Glowie
	}
	Counter SAM2Clicks
	{
		Type Click
		Count 1
		Glowie SAM2Glowie
	}
	Counter SAM3Clicks
	{
		Type Click
		Count 1
		Glowie SAM3Glowie
	}
	Counter SAM4Clicks
	{
		Type Click
		Count 1
		Glowie SAM4Glowie
	}
//This is used to keep track of the defeat of the mini-flier.
	Counter FlierDefeated
	{
		Type Name
		Name RogueArachnos_Arachnos_Flier_Mini
		VolumeName ZE_MarshalBlitz
		Direction Up
		Count 1
	}
//This trigger fires the SAM at the flier
Trigger SAM1Success
	{
		Requires SAM1Clicks complete>
		Action
		{
			Reset SAM1Clicks
		}
		Action
		{
			DebugPrint <<SAM 1 Hacked>>
			TeamControl SAM1
			{
				Type DoBehavior
				Team SAM1
				Behavior <<UsePower("Incendiary_Swarm_Missiles")>>
			}
		}
		Action
		{
			Reset SAM1Success
		}
	}
//This trigger fires the SAM at the flier
Trigger SAM2Success
	{
		Requires SAM2Clicks complete>
		Action
		{
			Reset SAM2Clicks
		}
		Action
		{
			DebugPrint <<SAM 2 Hacked>>
			TeamControl SAM2
			{
				Type DoBehavior
				Team SAM2
				Behavior <<UsePower("Incendiary_Swarm_Missiles")>>
			}
		}
		Action
		{
			Reset SAM2Success
		}
	}
//This trigger fires the SAM at the flier
