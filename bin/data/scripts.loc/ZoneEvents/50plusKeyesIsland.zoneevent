//Fire the Antimatter Pulse
	Trigger AntimatterPulseStage3A-HitLow
	{
		Requires AntimatterPulseStage3A complete> AntimatterPresentStage3 scriptvalue> 0 == &&
		
		Action AntimatterPulseFire-3ALow
		{
			DebugPrint <<Antimatter Pulse Hit!>>
			TeamControl
			{	
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("AntimatterPulse")>>
			}
		}
		Action AntimatterPulseReset-3ALow
		{
			Reset AntimatterPulseStage3A-HitLow
			Reset AntimatterPulseStage3A
		}
	}

//Fire the Improved Antimatter Pulse	
	Trigger AntimatterPulseStage3A-HitHigh
	{
		Requires AntimatterPulseStage3A complete> AntimatterPresentStage3 scriptvalue> 1 >= &&
		
		Action AntimatterPulseFire-3AHigh
		{
			DebugPrint <<Antimatter Pulse-AM3 Hit!>>
			TeamControl
			{	
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("AntimatterPulseAM3")>>
			}
		}
		Action AntimatterPulseReset-3AHigh
		{
			Reset AntimatterPulseStage3A-HitHigh
			Reset AntimatterPulseStage3A
		}
	}

//This trigger block checks to see if players complete the badge requirements for Bunker A.
	Trigger DoorDestruction-BunkerA-Initial
	{
		Requires BunkerA-DestructionStarted scriptvalue> 0 == BunkerA-MainDoor complete> BunkerA-SideDoor complete> || BunkerA-RearDoor complete> || &&

		Action
		{
			Reset BunkerDoors-Destroyed-A
		}
		Action
		{
			Delay 1
			SetScriptValue BunkerA-DestructionStarted 1
		}
	}
	Trigger BunkerA-MainDoor-Destroyed
	{
		Requires BunkerA-MainDoor complete>
		
		Action
		{
			SetScriptValue TotalDoorsDestroyed-BunkerA TotalDoorsDestroyed-BunkerA scriptvalue> 1 +
		}
	}
	Trigger BunkerA-SideDoor-Destroyed
	{
		Requires BunkerA-SideDoor complete>
		
		Action
		{
			SetScriptValue TotalDoorsDestroyed-BunkerA TotalDoorsDestroyed-BunkerA scriptvalue> 1 +
		}
	}
	Trigger BunkerA-RearDoor-Destroyed
	{
		Requires BunkerA-RearDoor complete>
		
		Action
		{
			SetScriptValue TotalDoorsDestroyed-BunkerA TotalDoorsDestroyed-BunkerA scriptvalue> 1 +
		}
	}
	Trigger DoorDestruction-BunkerA-BadgeCheck-Success
	{
		Requires BunkerDoors-Destroyed-A complete> BunkerA-DestructionStarted scriptvalue> 1 == && BunkerA-BadgeCheckComplete scriptvalue> 0 == && TotalDoorsDestroyed-BunkerA scriptvalue> 3 == &&
		
		Action
		{
			SetScriptValue BunkerA-BadgeRequirementsMet 1
		}
		Action
		{
			SetScriptValue BunkerA-BadgeCheckComplete 1
		}
	}
	Trigger DoorDestruction-BunkerA-BadgeCheck-Failure
	{
		Requires BunkerDoors-Destroyed-A complete> BunkerA-DestructionStarted scriptvalue> 1 == && BunkerA-BadgeCheckComplete scriptvalue> 0 == && TotalDoorsDestroyed-BunkerA scriptvalue> 3 < &&
		
		Action
		{
			SetScriptValue BunkerA-BadgeCheckComplete 1
		}
	}

