			{
				Type DoBehavior
				Team RecoveryTeam-A-Guards
				Behavior <<Praetorian_TeleportOut(CombatOverride(Passive),Untargetable(1),Unselectable(1),Invincible(1),Timer(2)),DestroyMe>>
			}
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team RecoveryTeam-A-Guards
			}
		}
		Action
		{
			Reset RecoveryTeam-A-Guards-Spawned
			Reset Despawn-Escort-A
		}
	}


