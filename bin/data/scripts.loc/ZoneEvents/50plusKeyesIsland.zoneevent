//Fire the Antimatter Pulse
	Trigger AntimatterPulse-Hit
	{
		Requires AntimatterPulseStage1A complete> AntimatterPresentStage1 scriptvalue> 0 == &&
		
		Action AntimatterPulseFire-1A
		{
			DebugPrint <<Antimatter Pulse Hit!>>
			TeamControl
			{	
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("AntimatterPulse")>>
			}
		}
		Action AntimatterPulseReset-1A
		{
			Reset AntimatterPulse-Hit
			Reset AntimatterPulseStage1A
		}
	}

//Fire the Improved Antimatter Pulse
	Trigger AntimatterPulseAM1-Hit
	{
		Requires AntimatterPulseStage1A complete> AntimatterPresentStage1 scriptvalue> 1 >= &&
		
		Action AntimatterPulseFire-1A
		{
			DebugPrint <<Antimatter Pulse-AM1 Hit!>>
			TeamControl
			{	
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("AntimatterPulseAM1")>>
			}
		}
		Action AntimatterPulseReset-1A
		{
			Reset AntimatterPulseAM1-Hit
			Reset AntimatterPulseStage1A
		}
	}

