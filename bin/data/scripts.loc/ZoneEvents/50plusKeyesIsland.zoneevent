//Start of everything else, finally.

//After players have encountered 6 patrols, whether via defeat or escape, announce that Terminals are now open for business, spawn the terminals and their guards.
	Trigger CtrlTerminalsNowAccessible
	{
		Requires CtrlTerminals-Accessible scriptvalue> 0 == TotalPatrolsSpawned scriptvalue> 6 >= &&
		
		Action
		{
			Floater
			{
				Message P334324241
				Color FF9900
			}
			Floater
			{	
				Message P889263442
				Color FF9900
			}
		}
		Action ActivateCentralTerminals
		{
			TeamControl Ctrl-Terminal-1A
			{
				Type Activate
				Team Ctrl-Terminal-1A
			}
			TeamControl Ctrl-Terminal-1B
			{
				Type Activate
				Team Ctrl-Terminal-1B
			}
			TeamControl Ctrl-Terminal-1C
			{
				Type Activate
				Team Ctrl-Terminal-1C
			}
			TeamControl Ctrl-Terminal-1D
			{
				Type Activate
				Team Ctrl-Terminal-1D
			}
			TeamControl Ctrl-Terminal-2A
			{
				Type Activate
				Team Ctrl-Terminal-2A
			}
			TeamControl Ctrl-Terminal-2B
			{
				Type Activate
				Team Ctrl-Terminal-2B
			}
			TeamControl Ctrl-Terminal-2C
			{
				Type Activate
				Team Ctrl-Terminal-2C
			}
			TeamControl Ctrl-Terminal-2D
			{
				Type Activate
				Team Ctrl-Terminal-2D
			}
			TeamControl Ctrl-Terminal-3A
			{
				Type Activate
				Team Ctrl-Terminal-3A
			}
			TeamControl Ctrl-Terminal-3B
			{
				Type Activate
				Team Ctrl-Terminal-3B
			}
		}
		
		Action CreateCtrlRift
		{
			TeamControl
			{
				Type Activate
				Team Ctrl-Rift-Marker
			}
			TeamControl
			{
				Type Activate
				Team Ctrl-Rift-Spawn
			}
		}
		Action
		{
			SetScriptValue CtrlTerminals-Accessible 1
		}
	}
	
//After players have encountered ten patrols or have completed two terminals, announce Antimatter's return.	
	Trigger CtrlReactor-HeraldAntimatter
	{
		Requires AntimatterHeraldedStage2 scriptvalue> 0 == TotalPatrolsSpawned scriptvalue> 10 >= TerminalWatcherCount-Ctrl count> 1 >= || &&
		Action
		{
			Floater
			{
				Message P2191254399
				Color FF0000
			}
		}	
		Action
		{
			Reset AntimatterArrivesTimer2
		}
		Action
		{
			Reset AntimatterArrivesIn30s-2
		}
		Action
		{
			SetScriptValue AntimatterHeraldedStage2 1
		}
		Action
		{
			SetScriptValue HideAntimatterTimer2 1
		}
		Action
		{
			TeamControl
			{
				Team CaptionManagerA
				Type DoBehavior
				Behavior <<UsePower("SetHealth59")>>
			}
		}
	}

//30 seconds until Antimatter arrives.
	Trigger AntimatterIn30-2
	{
		Requires AntimatterHeraldedStage2 scriptvalue> 1 >= AntimatterArrivesIn30s-2 complete> && AntimatterPresentStage2 scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P1491201881
				Color FF0000
			}
		}
		Action
		{
			Reset AntimatterArrivesIn30s-2
		}
	}	

//Two minutes after having encountered ten patrols or completing two terminals, Antimatter arrives to fight the players.	
	Trigger SecondAntimatterArrival
	{
		Requires AntimatterHeraldedStage2 scriptvalue> 1 >= AntimatterArrivesTimer2 complete> && AntimatterPresentStage2 scriptvalue> 0 == &&
		
		Action
		{
			Floater
			{
				Message P3170641586
				Color FF0000
				AlertType PriorityAlert
			}
			Floater
			{
				Message P1099778591
				Color FF9900
			}
			Floater
			{
				Message P2193119367
				Color FF9900
			}
			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Stage1
				Behavior <<SpawnPosIsSelf,Praetorian_TeleportIn(Timer(1),CombatOverride(Passive)),Invisible(0),Invincible(0),Unselectable(0),Untargetable(0)>>
			}
		}
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team Suppressor
				Behavior <<DestroyMe>>
			}
		}
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team SurrogateB
				Behavior <<DestroyMe>>
			}
		}
		Action
		{
			Reset AntimatterAttack2
		}
		Action
		{
			SetScriptValue AntimatterPresentStage2 1
		}
		Action
		{
			SetScriptValue HideAntimatterTimer2 0
		}
	}

//Five seconds after arriving, Antimatter will begin his attack.
	Trigger AntimatterStartAttack2
	{
		Requires AntimatterPresentStage2 scriptvalue> 1 >= AntimatterAttack2 complete> && AntimatterAttacking2 scriptvalue> 0 == &&
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Stage1
				Behavior <<OverrideSpawnPosCur,Combat>>
			}
		}
		Action
		{
			SetScriptValue AntimatterAttacking2 1
		}
	}

//When a single terminal is completed, notify players of their success.
	Trigger CtrlTerminalCompleted-Single
	{
		Requires TerminalWatcherFloat-Ctrl complete> TerminalWatcherCount-Ctrl complete> ! &&
		Action
		{
			Reset TerminalWatcherFloat-Ctrl
			Floater
			{
				Message P3561770778
				Color 00CC99
			}
		}
		Action
		{
			Reset CtrlTerminalCompleted-Single
		}
	}

//When all terminals are completed, notify players of their stage victory.
	Trigger ReactorCtrl-Victory
	{
		Requires TerminalWatcherCount-Ctrl complete>
		NextStage ReactorCtrl-Recovery

		//Notify players of their success.
		Action
		{
			Floater
			{
				Message P1372838051
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P3737118633
				Color FF9900
			}
		}
		//Reward players with the mid-trial item drop, added in 2150
//		Action
//		{
//			Reward IS.Issue2150Midtrial
//		}

		//Reward players with their merit reward for successfully completing the stage.		
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable AstralMerit1
				}
			}
		}
	}

//This failure condition is triggered if the Antimatter Detonation timer runs out. This will run the map-wide power that kills all players.
	Trigger ReactorCtrl-Failure-Timer
	{
		Requires AntimatterDetonation-Ctrl complete>
		NextStage Failure
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("Annihilation")>>
			}
		}
		Action
		{
			Floater
			{
				Message P3733242003
				Color ff9900
			}
		}
		Action
		{
			Floater
			{
				Message P2881932779
				Color ff9900
			}
		}
		Action DebugMessage-ReactorC-FailTimer
		{
			DebugPrint <<Stage ReactorCtrl Failed due to Reactor Overload...>>
		}
	}

//This failure condition is triggered if the players defeat Antimatter during the stage. This causes his map-wide eruption that kills all players.	
	Trigger ReactorWest-Failure-AntimatterDead
	{
		Requires AntimatterDeath2 complete> TerminalWatcherCount-Stage2B complete> ! &&
		NextStage Failure

		Action
		{
			Floater
			{
				Message P2379961059
				Color ff9900
			}
		}
		Action
		{
			Floater
			{
				Message P2881932779
				Color ff9900
			}
		}
		Action DebugMessage-ReactorC-FailAM
		{
			DebugPrint <<Stage ReactorCtrl Failed due to Antimatter Defeat...>>
		}
	}

	Shutdown
	{
		//Force Anti-Matter to break his attack and move to his next position. He will wait there until P1316136102 in stage 3.
		Action InvulnerableAM
		{
			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Stage1
				Behavior <<Praetorian_TeleportOut(Timer(1),CombatOverride(Passive)),Invisible(1),Invincible(1),Untargetable(1),Unselectable(1),MoveToPos(marker:Keyes-AM-TP-East-DN,Radius(2),CombatOverride(Passive)),DoNothing(CombatOverride(Passive))>>
