	Trigger EntanglementActivated
	{
		Requires EntanglementTrigger complete>
		
		Action EntanglementTriggerReset
		{
			DebugPrint <<EntanglementHit!>>
			Reset EntanglementTrigger
			Reset EntanglementActivated
			TeamControl
			{	
				Type DoBehavior
				Team Entanglement
				Behavior <<UsePower("Entanglement")>>
			}
			Floater
			{
				Message P1149405925
				Color FF0000
				AlertType PriorityAlert
			}
		}
	}
	Trigger DevastationActivated-First
	{
		Requires DevastationTrigger-First complete> DevastationInitialFire scriptvalue> 0 == &&

		Action
		{
			SetScriptValue DevastationInitialFire 1
		}
		Action DevastationTriggerReset
		{
			DebugPrint <<DevastationHitFirst!>>
			Reset DevastationTrigger
			TeamControl
			{
				Type DoBehavior
				Team DevastationBeam
				Behavior <<UsePower("Devastation_Beam")>>
			}
			Floater
			{
				Message P260942496
				Color FF0000
				AlertType PriorityAlert
			}
		}
	}
	Trigger DevastationActivated
	{
		Requires DevastationTrigger complete> DevastationInitialFire scriptvalue> 1 >= &&
		
		Action
		{
			Reset DevastationTrigger
		}
		Action DevastationTriggerReset
		{
			DebugPrint <<DevastationHit!>>
			TeamControl
			{
				Type DoBehavior
				Team DevastationBeam
				Behavior <<UsePower("Devastation_Beam")>>
			}
			Floater
			{
				Message P260942496
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			Reset DevastationActivated
		}
	}

//This trigger detects if any of the Devastation Beam's hold watcher entities have been defeated, which prevents awarding of the badge.
	Trigger PlayerHeldByDevastationBeam
	{
		Requires DevastationBeam-HoldWatcher complete>

		Action
		{
			SetScriptValue FinalEncounter-NoHolds FinalEncounter-NoHolds scriptvalue> 1 +
		}
		Action
		{
			Reset DevastationBeam-HoldWatcher
		}
		Action
		{
			Reset PlayerHeldByDevastationBeam
		}
	}


