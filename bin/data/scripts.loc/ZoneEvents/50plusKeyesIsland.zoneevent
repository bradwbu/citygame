				Color ff9900
			}
		}
		Action DebugMessage-ReactorE-FailTimer
		{
			DebugPrint <<Stage ReactorEast Failed due to Reactor Overload.>>
		}
	}	
	
//This failure condition is triggered if the players defeat Antimatter during the stage. This causes his map-wide eruption that kills all players.	
	Trigger ReactorEast-Failure-AntimatterDead
	{
		Requires AntimatterDeath3 complete> TerminalWatcherCount-East complete> ! &&
		NextStage Failure

		Action
