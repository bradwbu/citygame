//30 seconds until Antimatter arrives.
	Trigger AntimatterIn30-1
	{
		Requires RestockCountdownWest scriptvalue> 1 >= AntimatterArrivesIn30s-1 complete> && AntimatterPresentStage1 scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P1491201881
				Color FF0000
			}
		}
		Action
		{
			Reset AntimatterArrivesIn30s-1
		}
	}

//Two minutes after using ten containers, Antimatter arrives to fight the players.
	Trigger AntimatterArrives
	{
		Requires RestockCountdownWest scriptvalue> 1 >= AntimatterArrivesTimer complete> && AntimatterPresentStage1 scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P1211124567
				Color FF0000
				AlertType PriorityAlert
			}
			Floater
			{
				Message P3503713592
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Keyes-Antimatter-Stage1
			}
		}
		Action
		{
			SetScriptValue AntimatterPresentStage1 1
		}
		Action
		{
			SetScriptValue HideAntimatterTimer1 0
		}
		Action
		{
			Reset AntimatterHealth1
		}
		Action
		{
			Reset AntimatterAttack1
		}
	}

//Five seconds after arriving, Antimatter will begin his attack.
	Trigger AntimatterStartAttack1
	{
		Requires AntimatterPresentStage1 scriptvalue> 1 == AntimatterAttack1 complete> && AntimatterAttacking1 scriptvalue> 0 == &&
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Stage1
				Behavior <<Combat>>
			}
		}
		Action
		{
			SetScriptValue UnderTenPercentCheck 1
		}
	}

//If Anti-Matter is present and his health is brought below 10%, then set the badge trigger.

	Trigger AntimatterBelowTenPercent
	{
		Requires AntimatterHealth1 count> 10 <= UnderTenPercentCheck scriptvalue> 1 == &&

		Action
		{
			SetScriptValue UnderTenPercentCheck 2
		}
	}

