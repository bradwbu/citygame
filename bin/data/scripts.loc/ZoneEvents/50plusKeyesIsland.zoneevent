			Floater
			{
				Message P2692826546
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
		Action
		{
			Reset HospitalDoor-Unlock
			Reset HospitalDoor-Lock
			Reset HospitalDoor-Notification1
			Reset HospitalDoor-Notification2
		}
	}

//End Hospital Door Block

