	Trigger AnyTerminalsDestroyed
	{
		Requires Terminals-FirstHeal-A complete> Terminals-FirstHeal-B complete> || Terminals-FirstHeal-C complete> || Terminals-FirstHeal-D complete> || Terminals-SecondHeal-A complete> || Terminals-SecondHeal-B complete> || Terminals-SecondHeal-C complete> || Terminals-SecondHeal-D complete> || Terminals-ThirdHeal-A complete> || Terminals-ThirdHeal-B complete> || Terminals-ThirdHeal-C complete> || Terminals-ThirdHeal-D complete> || DelayBeforeAction complete> &&

