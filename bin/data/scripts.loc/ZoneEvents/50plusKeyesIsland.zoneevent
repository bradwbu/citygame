//Fire the Antimatter Pulse
	Trigger AntimatterPulseStage2A-HitLow
	{
		Requires AntimatterPulseStage2A complete> AntimatterPresentStage2 scriptvalue> 0 == &&
		
		Action AntimatterPulseFire-2ALow
		{
			DebugPrint <<Antimatter Pulse Hit!>>
			TeamControl
			{	
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("AntimatterPulse")>>
			}
		}
		Action AntimatterPulseReset-2ALow
		{
			Reset AntimatterPulseStage2A-HitLow
			Reset AntimatterPulseStage2A
		}
	}

//Fire the Improved Antimatter Pulse	
	Trigger AntimatterPulseStage2A-HitHigh
	{
		Requires AntimatterPulseStage2A complete> AntimatterPresentStage2 scriptvalue> 1 >= &&
		
		Action AntimatterPulseFire-2AHigh
		{
			DebugPrint <<Antimatter Pulse-AM2 Hit!>>
			TeamControl
			{	
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("AntimatterPulseAM2")>>
			}
		}
		Action AntimatterPulseReset-2AHigh
		{
			Reset AntimatterPulseStage2A-HitHigh
			Reset AntimatterPulseStage2A
		}
	}

	Trigger PatrolEscaped
	{
		Requires RecoveryTeam-Escaped complete>
		Action
		{
			Reset RecoveryTeam-Escaped
			Reset RecoveryTeam-A-Spawned
			Reset RecoveryTeam-B-Spawned
			Reset RecoveryTeam-C-Spawned
			Reset RecoveryTeam-D-Spawned
			Reset RecoveryTeam-E-Spawned
			Reset RecoveryTeam-F-Spawned
			Reset RecoveryTeam-G-Spawned
			Reset RecoveryTeam-H-Spawned
			Reset RecoveryTeam-I-Spawned
			Reset RecoveryTeam-J-Spawned
			Reset RecoveryTeam-K-Spawned
			Reset RecoveryTeam-L-Spawned
			Reset PatrolEscaped
			Reset RollNextSpawn
		}
	}

//Trigger Blocks for Controlling Patrol Spawns

	Trigger RollNextSpawn 
	{
		//If the total number of spawns with active members is less than 3, then execute the random roll.
		Requires RollsSinceSpawn scriptvalue> 3 < RecoveryTeam-A-Spawned count> 0 > RecoveryTeam-B-Spawned count> 0 > + RecoveryTeam-C-Spawned count> 0 > + RecoveryTeam-D-Spawned count> 0 > +  RecoveryTeam-E-Spawned count> 0 > + RecoveryTeam-F-Spawned count> 0 > + RecoveryTeam-G-Spawned count> 0 > + RecoveryTeam-H-Spawned count> 0 > + RecoveryTeam-I-Spawned count> 0 > + RecoveryTeam-J-Spawned count> 0 > + RecoveryTeam-K-Spawned count> 0 > + RecoveryTeam-L-Spawned count> 0 > + 3 < &&

		Action
		{
	
			SetScriptValue RandomRoll 12 rand * 1 +
		}
		Action
		{
			SetScriptValue WaitingForRoll 0
		}
		Action
		{
			SetScriptValue TotalRolls TotalRolls scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue RollsSinceSpawn RollsSinceSpawn scriptvalue> 1 +
		}
		Action
		{
			Reset RollNextSpawn
		}
	}
	Trigger RerollIfLessThanOne
	{
		//If the roll is less than 1, re-roll. This should not occur mathematically, but it is here as a precaution.
		Requires RandomRoll scriptvalue> 1 <

		Action
		{
	
			SetScriptValue RandomRoll 12 rand * 1 +
		}
		Action
		{
			SetScriptValue WaitingForRoll 0
		}
		Action
		{
	
			Reset RerollIfLessThanOne
		}

	}

	Trigger ResetAllForceTriggers
	{
		Requires Force-RecoveryTeamA scriptvalue> 1 == Force-RecoveryTeamB scriptvalue> 1 == && Force-RecoveryTeamC scriptvalue> 1 == && Force-RecoveryTeamD scriptvalue> 1 == && Force-RecoveryTeamE scriptvalue> 1 == && Force-RecoveryTeamF scriptvalue> 1 == && Force-RecoveryTeamG scriptvalue> 1 == && Force-RecoveryTeamH scriptvalue> 1 == && Force-RecoveryTeamI scriptvalue> 1 == && Force-RecoveryTeamH scriptvalue> 1 == && Force-RecoveryTeamK scriptvalue> 1 == && Force-RecoveryTeamL scriptvalue> 1 == &&
		
		Action
		{
			SetScriptValue Force-RecoveryTeamA 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamB 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamC 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamD 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamE 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamF 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamG 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamH 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamI 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamJ 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamK 0
		}
		Action
		{
			SetScriptValue Force-RecoveryTeamL 0
		}
		Action
		{
			Reset Force-RecoveryTeam-A Force-RecoveryTeam-B Force-RecoveryTeam-C Force-RecoveryTeam-D Force-RecoveryTeam-E Force-RecoveryTeam-F Force-RecoveryTeam-G Force-RecoveryTeam-H Force-RecoveryTeam-I Force-RecoveryTeam-J Force-RecoveryTeam-K Force-RecoveryTeam-L
			Reset Force-RecoveryTeam-A-Streak Force-RecoveryTeam-B-Streak Force-RecoveryTeam-C-Streak Force-RecoveryTeam-D-Streak Force-RecoveryTeam-E-Streak Force-RecoveryTeam-F-Streak Force-RecoveryTeam-G-Streak Force-RecoveryTeam-H-Streak Force-RecoveryTeam-I-Streak Force-RecoveryTeam-J-Streak Force-RecoveryTeam-K-Streak Force-RecoveryTeam-L-Streak
			Reset ResetAllForceTriggers
		}
	}	

