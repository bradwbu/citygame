Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Stage Reward Winners Initialized...>>
		}
		Action
		{
			SetScriptValue OpenLeagueAward 0
		}
	}
	Trigger AwardBadge-Completion
	{
		Action
		{
			DebugPrint <<Awarding Completion Badge>>
			Reward IT_Keyes_Complete
		}
	}
	Trigger AwardBadge-EnduredStrongPulses
	{
		Requires UnderTenPercentCheck scriptvalue> 2 ==
		Action
		{
			DebugPrint <<Awarding Strong Pulse Badge>>
			Reward IT_Keyes_StrongPulse
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-BunkerBuster
	{
		Requires BunkerA-BadgeRequirementsMet scriptvalue> 1 == BunkerB-BadgeRequirementsMet scriptvalue> 1 == && BunkerC-BadgeRequirementsMet scriptvalue> 1 == &&
		Action
		{
			DebugPrint <<Awarding Bunker Buster Badge>>
			Reward IT_Keyes_BunkerBuster
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-Challenge
	{
		Requires FinalEncounter-PlayerDeath scriptvalue> 0 == FinalEncounter-TerminalsDestroyed scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Awarding Challenge Badge>>
			Reward IT_Keyes_Challenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}

	Trigger AwardBadge-NoHolds
	{
		Requires FinalEncounter-NoHolds scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding No Holds Badge>>
			Reward IT_Keyes_NoHolds
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardMerit-OpenLeague
	{
		Requires eventLockedByGroup? ! OpenLeagueAward scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Bonus Merit for an Open League Awarded>>
			SetScriptValue OpenLeagueAward 1
		}
		Action
		{
			Reward AstralMerit1
		}
	}	
	Trigger End
	{
		NextStage Stop
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Stage Reward Winners Completed...>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					NumStagesRequired 3
					RewardTable Issue20EndKarma0
				}
				Reward class2
				{
					PercentileNeeded 0.00
					NumStagesRequired 4
					PointsNeeded 10
					RewardTable IS.Issue2150EndKarma1Plus
				}
			}
		}
	}
}

Stage Failure
{
	StartUp
	{
		Action FailureStart
		{
