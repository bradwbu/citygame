//When a single terminal is completed, notify players of their success.	
	Trigger WestTerminalCompleted-Single
	{
		Requires TerminalWatcherFloat-West complete> TerminalWatcherCount-West complete> ! &&
		Action
		{
			Reset TerminalWatcherFloat-West
			Floater
			{
				Message P3561770778
				Color 00CC99
			}
		}
		Action
		{
			Reset WestTerminalCompleted-Single
		}
	}

//When all terminals are completed, notify players of their stage victory.
	Trigger ReactorWest-Victory
	{
		Requires TerminalWatcherCount-West complete>
		NextStage ReactorWest-Recovery

		//Notify players of their success.
		Action
		{
			Floater
			{
				Message P1372838051
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P2816864145
				Color FF9900
			}
		}
		
		//Reward players with their merit reward for successfully completing the stage.
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable AstralMerit1
				}
			}
		}
	}

//This failure condition is triggered if the Antimatter Detonation timer runs out. This will run the map-wide power that kills all players.
	Trigger ReactorWest-Failure-Timer
	{
		Requires AntimatterDetonation-West complete>
		NextStage Failure
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team AntimatterPulse
				Behavior <<UsePower("Annihilation")>>
			}
		}
		Action
		{
			Floater
			{
				Message P3733242003
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P2881932779
				Color FF9900
			}
		}
		Action DebugMessage-ReactorW-FailTimer
		{
			DebugPrint <<Stage ReactorWest Failed due to Reactor Overload.>>
		}
	}

//This failure condition is triggered if the players defeat Antimatter during the stage. This causes his map-wide eruption that kills all players.	
	Trigger ReactorWest-Failure-AntimatterDead
	{
		Requires AntimatterDeath1 complete> TerminalWatcherCount-West complete> ! &&
		NextStage Failure
		Action
		{
			Floater
			{
				Message P2379961059
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P2881932779
				Color FF9900
			}
		}
		Action DebugMessage-ReactorW-FailAM
		{
			DebugPrint <<Stage ReactorWest Failed due to Antimatter Defeat.>>
		}
	}
	
	Shutdown
	{
		Action
		{
			DebugPrint <<Stage ReactorWest Ending>>
		}
		//Force Anti-Matter to break his attack and move to his next position. He will wait there until P1316136102 in stage 2.
		Action InvulnerableAM
		{
			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Stage1
				Behavior <<Praetorian_TeleportOut(Timer(1),CombatOverride(Passive)),Invisible(1),Invincible(1),Untargetable(1),Unselectable(1),MoveToPos(marker:Keyes-AM-TP-Ctrl-DN,Radius(2),CombatOverride(Passive)),DoNothing(CombatOverride(Passive))>>
			}
		}
		
		//Activate Systemic Decay Suppressor and destroy the Surrogate
		Action
		{
			TeamControl
			{
				Type Activate
				Team Suppressor
			}
			TeamControl
			{
				Type DoBehavior
				Team SurrogateA
				Behavior <<DestroyMe>>
			}
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 10
			}
