		Count 100
	}
	
//When using the 3rd Power Cell on a Terminal, a marker is spawned which auto-kills itself in a few seconds. The death of this entity is what is used to indicate a Terminal is fully charged, thus incrementing the counter.
	Counter TerminalWatcherCount-Ctrl
	{
		Type Name
		Name Objects_Keyes_Island_Terminal
		Count 6
	}

