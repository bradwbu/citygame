	{
		Duration 01:00
	}
	Timer AntimatterArrivesTimer
	{
		Duration 01:30
	}
	Timer AntimatterAttack1
	{
		Duration 0:05
	}
	Timer AntimatterDetonation-West
	{
		Duration 20:00
	}
	Timer CountUpTimer1
	{
		Duration 0:00
	}

//Send Brief Instructional Intro Floaters
	Trigger InitialFloaters1
	{
		Requires CountUpTimer1 complete>

		Action
		{
			Floater
			{
				Message P4011164214
				Color FF9900
			}
			Floater
			{
				Message P2800077340
				Color FF9900
			}
		}
