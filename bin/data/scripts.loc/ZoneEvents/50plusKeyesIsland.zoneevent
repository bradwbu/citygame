Name IncarnateTrialKeyesIsland
FirstStage SetupEvent
StopStage Stop
RestartStage ResetEvent
DisplayName P2553448467
//ZoneEventName = 50plusKeyesIsland

//Event Reward Structure
// Stage 1: Defeat trash - No Karma, No Merits
// Stage 2: Control western reactor - Karma 10, Astral Merit
// Stage 2a: Rest period - No Karma, No Merits
// Stage 3: Control central reactor - Karma 10, Astral Merit
// Stage 3a: Rest period - No Karma, No Merits
// Stage 4: Control eastern reactor - Karma 10, Astral Merit
// Stage 4a: Rest period - No Karma, No Merits
// Stage 5: Defeat Antimatter - Karma 10, Empyrean Merit (subject to lockout)
// Total: 4 Karma Stages. 
//	1-2 Completed stages: Incarnate Subcomponent
//	3 Completed stages: Component Drop Tables
//	4 Completed stages: Component Drop Tables

Stage SetupEvent
{
	StartUp
	{
		Action DebugMessageSetupEventStart
		{
			DebugPrint <<Stage SetupEvent Initialized...>>
		}
		Action
		{
			DebugPrint <<This is a 12-24 player event>>
			SetScriptValue EventSize 12
		}
		Action
		{
			DebugPrint <<Setting Cutscene to skippable unless some players have not seen it>>
			SetScriptValue Cutscene-Skippable 1
		}
		Action CreateComponents
		{

// Create and Lock Doors
			DoorCreate Door-EastBunkerA // Add the following property to the MapSwap: Requires 50plusKeyesIsland.Door.Door-EastBunkerA ZoneEvent>
			DoorCreate Door-EastBunkerB // Add the following property to the MapSwap: Requires 50plusKeyesIsland.Door.Door-EastBunkerB ZoneEvent>
			DoorCreate Door-EastBunkerC // Add the following property to the MapSwap: Requires 50plusKeyesIsland.Door.Door-EastBunkerC ZoneEvent>
			DoorCreate Door-Hospital // Add the following property to the MapSwap: Requires 50plusKeyesIsland.Door.Door-Hospital ZoneEvent> 

			DoorControl
			{
				Type Lock
				Door Door-EastBunkerA
			}
			DoorControl
			{
				Type Lock
				Door Door-EastBunkerB
			}
			DoorControl
			{
				Type Lock
				Door Door-EastBunkerC
			}
			DoorControl
			{
				Type Lock
				Door Door-Hospital
			}

// Create Waypoints
			WaypointCreate WP-ReactorWest map_enticon_neighborhood P215931631
			WaypointCreate WP-ReactorCtrl map_enticon_neighborhood P3838099656
			WaypointCreate WP-ReactorEast map_enticon_neighborhood P3181156470
			WaypointCreate WP-TruckDepot map_enticon_neighborhood P2070291873
			WaypointCreate WP-BunkerEastA map_enticon_neighborhood P724948136
