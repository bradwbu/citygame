//Start Warmth Spawn Block

	Trigger WarmthBuffActivation
	{
		Requires eventLockedByGroup? ! WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Granted>>
			SetScriptValue WarmthBuffSpawned 1
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team WarmthBuff
			}
		}
		Action
		{
			Floater
			{
				Message P1172875117
				Color FF9900
			}
		}
	}

	Trigger WarmthBuffBlocked
	{
		Requires eventLockedByGroup? WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Disabled>>
			SetScriptValue WarmthBuffSpawned 1
		}
	}

//End Warmth Spawn Block

//This counter detects when players have entered the 3rd room of the complex.
	Counter PlayersInStartVolume
	{
		Type ZEPlayers
		VolumeName Start
	}

//This counter detects the defeat of the entity which checks to see if any players do not have the completion badge.
	Counter BadgeCheckerDefeated
	{
		Type Team
		Team BadgeChecker
		Direction Up
		Count 1
	}

//This timer is used to indicate when the cutscene has ended and the stage can be flipped.
	Timer EndCutscene
	{
		Duration 00:75
	}
	
//This timer starts the cutscene automatically if no players have entered the start volume within 5 minutes.
	Timer TimeElapsed
	{
		Duration 05:00
	}

	Trigger StartCutscene-Volume
	{
		Requires PlayersInStartVolume count> 1 >= CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Cutscene Started by Volume>>
		}
		Action
		{
			Reset EndCutscene
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Cutscene
			}
		}
		Action
		{
			SetScriptValue CutsceneStarted 1
		}
	}

	Trigger StartCutscene-Timer
	{
		Requires TimeElapsed complete> CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == &&
		
		Action
		{
			DebugPrint <<Cutscene Started by Timer>>
		}
		Action
		{
			Reset EndCutscene
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Cutscene
			}
		}
		Action
		{
			SetScriptValue CutsceneStarted 1
		}
	}

	Trigger EndCutscene-AllBadges-Volume
	{
		Requires PlayersInStartVolume count> 1 >= CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == ! &&

		Action
		{
			DebugPrint <<Cutscene Skipped by Volume>>
		}
		
		NextStage ReactorApproach
	}
	
	Trigger EndCutscene-AllBadges-Timer
	{
		Requires TimeElapsed complete> CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == ! &&
		
		Action
		{
			DebugPrint <<Cutscene Skipped by Timer>>
		}

		NextStage ReactorApproach
	}

	Trigger EndCutscene-Stage
	{
		Requires CutsceneStarted scriptvalue> 1 == EndCutscene complete> &&

		Action
		{
			DebugPrint <<Cutscene Completed>>
		}

		NextStage ReactorApproach
	}

	UICollection OpeningCutscene
	{
		UIItem Directions
		{
			Type Text
			Text P2711733698
		}
		UIItem CutsceneAutostart
		{
			Type Timer
			Timer TimeElapsed
			Text P1199669832
			ShortText P3107402947
			HideIf CutsceneStarted scriptvalue> 1 ==
		}
		UIItem TimeRemaining
		{
			Type Timer
			Timer EndCutscene
			Text P1199669832
			ShortText P3107402947
			HideIf CutsceneStarted scriptvalue> 0 ==
		}
	}	

	Shutdown
	{
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Cutscene
			}
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team BadgeChecker
			}
		}
	}
}

Stage ReactorApproach
{
	DisplayName P1060471487
	Tooltip P802158096

// Start Hospital Door Block

	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:00
	}
	
	Trigger HospitalDoor-Unlock-Recovery
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1533101862
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

//End Hospital Door Block

	StartUp
	{
		Action DebugMessage-ReactorF-Start
		{
			DebugPrint <<Stage ReactorApproach Initialized...>>
		}
		Action PlaceWaypoints
		{
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
			WaypointPlace WP-ReactorWest WP-ReactorWest
			WaypointPlace WP-ReactorCtrl WP-ReactorCtrl
			WaypointPlace WP-ReactorEast WP-ReactorEast
			WaypointPlace WP-TruckDepot WP-TruckDepot
		}
		//Revoke the power cells from players.
		Action
		{
			DebugPrint <<Revoking All Power Cells from Reactor Ctrl stage.>>
		}
		Action
		{
			Reward Keyes_DrainPowerCells
		}
		Action ActivateControlSpawns
		{

			TeamControl
			{
				Type Activate
				Team ReactorF-Generic
			}
		}
		Action
		{
			SetScriptValue AssistantBadgeA 0
		}
	}
	Timer StartCaptions
	{
		Duration 0:10
	}
	Counter ReactorF-Defeats
	{
		Type Team
		Team ReactorF-Generic
		Count 30
	}
	UICollection ReactorFront
	{
		UIItem ReactorWestRodsBar
		{
			Type BarBlue
			Text P819673066
			ShortText P3714268034
			Current ReactorF-Defeats count>
			Target 30
		}
	}	
	Trigger GoToEventStart
	{
		Requires ReactorF-Defeats complete>
	
		NextStage ReactorWest
	}
	Trigger ProblemStarts
	{
		Requires StartCaptions complete> AssistantBadgeA scriptvalue> 0 == &&
		Action
		{
			TeamControl
			{
				Team CaptionManagerA
				Type DoBehavior
				Behavior <<UsePower("SetHealth99")>>
			}
		}
		Action
		{
			SetScriptValue AssistantBadgeA 1
		}
	}
	Shutdown
	{
		Action DebugMessage-ReactorF-Start
		{
			DebugPrint <<Stage ReactorApproach Completed. Draining Power Cells>>
		}
		Action
		{
			Reward Keyes_DrainPowerCells
		}
		Action DeactivateControlSpawns
		{

			TeamControl
			{
				Type Deactivate
				Team ReactorF-Generic
			}
		}
	}
}

Stage ReactorWest
{
	DisplayName P768614910
	ToolTip P3426220964

	AwardKarma
	KarmaThreshold 10

	StageActiveRequires ZonePlayers count> 8 > ZonePlayersActive count> ZonePlayers count> / 0.25 > &&
	
//Start New Failsafe Block

	Counter ZonePlayers
        {
                Type ZEPlayers
        }
        Counter ZonePlayersAlive
        {
                Type ZEPlayersAlive
        }
        Counter ZonePlayersActive
        {
                Type ZEPlayersActive
        }
	Counter FailsafePlayersAlive
	{
		Type ZEPlayersAlive
	}
	Counter FailsafePlayersPhased
	{
		Type ZEPlayersPhased
	}
	Timer FailsafeDelay
	{
		Duration 0:15
	}
	Timer FailsafeLongDelay
	{
		Duration 1:00
	}

	//Trigger the failsafe for an unlocked league if the number of players is less than 2.
	Trigger FailsafeStart
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeStart
		{
			DebugPrint <<Starting Failsafe countdown for unlocked league>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the failsafe for a locked league if the number of players is less than 4 and the event is an 8-16 player event.
	Trigger FailsafeStart-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 8>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Eight
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}
	
	//Trigger the failsafe for a locked league if the number of players is less than 6 and the event is a 12-24 player event.
	Trigger FailsafeStart-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 12>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Twelve
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the end of the failsafe for an unlocked league after 15s if it still has less than 2 players.
	Trigger FailsafeConclude
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 1 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 4 players in an 8 player event.
	Trigger FailsafeConclude-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 6 players in an 12 player event.
	Trigger FailsafeConclude-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 2 before the 15s timer ends.
	Trigger FailsafeReset
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 > FailsafeInProcess scriptvalue> 1 == && eventLockedByGroup? ! && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart 
			Reset FailsafeReset
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 4 before the 15s timer ends.
	Trigger FailsafeReset-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Eight 
			Reset FailsafeReset-LockedTeam-Eight 
			Reset FailsafeDelay 
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 6 before the 60s timer ends.
	Trigger FailsafeReset-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Twelve 
			Reset FailsafeReset-LockedTeam-Twelve 
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

//End New Failsafe Block

// Start Hospital Door Block

	Timer HospitalDoor-Lock-Timer
	{
		Duration 00:10
	}
