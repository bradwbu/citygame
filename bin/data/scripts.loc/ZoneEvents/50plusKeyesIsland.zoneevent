//After players have completed using eight containers or have completed one terminal, announce the restocking and Antimatter's arrival.
	Trigger StartRestockingPowerCells
	{
		Requires RestockCountdownWest scriptvalue> 0 == ContainersUsed scriptvalue> 8 >= TerminalWatcherCount-West count> 1 >= || &&
		
		Action
		{
			Floater
			{
				Message P2517497399
				Color 00CC99
			}
		}
		Action
		{
			Floater
			{
				Message P4187874670
				Color 00CC99
			}
		}
		Action
		{
			Reset NextContainerWave
		}
		Action
		{
			SetScriptValue HideAntimatterTimer1 1
		}
		Action
		{
			Reset AntimatterArrivesTimer
		}
		Action
		{
			Reset AntimatterArrivesIn30s-1
		}
		Action
		{
			SetScriptValue RestockCountdownWest 1
		}
		Action
		{
			TeamControl
			{
				Team CaptionManagerA
				Type DoBehavior
				Behavior <<UsePower("SetHealth79")>>
			}
		}
	}

