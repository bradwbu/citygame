// Reactor Drawdown - First Heal
	Trigger AntimatterHealthChannel1-HoldPhase
	{
		Requires DelayBeforeAction complete> AntimatterHealth4 count> 80 <= &&

		Action
		{
			SetScriptValue ReactorDrawdownHold1 1
			
			TeamControl
			{
				Type Activate
				Team Keyes-Watcher-FirstHeal
			}	

			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Final
				Behavior <<UsePower("Grant_Intangible"),DoNothing(CombatOverride(Passive),Untargetable(1),Unselectable(1),Timer(1)),MoveToPos(marker:Keyes-AM-TP-Heal1,Radius(2),CombatOverride(Passive),Untargetable(1),Unselectable(1)),DoNothing(CombatOverride(Passive),Untargetable(0),Unselectable(1))>>
			}
		}
		Action
		{
			Floater
			{
				Message P692312626
				Color 00CC99
				AlertType PriorityAlert
			}
		}
	}
	Trigger AntimatterHealthChannel1-HealPhase
	{
		Requires Watcher-FirstHeal complete>

		Action
		{
			SetScriptValue ReactorDrawdownHeal1 1

			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Final
				Behavior <<DoNothing(CombatOverride(Passive),Untargetable(1),Unselectable(1),Timer(1)),UsePower("Grant_Heal"),DoNothing(CombatOverride(Passive),Untargetable(1),Unselectable(1))>>
			}
		}

		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team Keyes-HealTerm-FirstHeal-A
				Behavior <<Untargetable(0),Unselectable(0),Invincible(0)>>
			}	

			TeamControl
			{
				Type DoBehavior
				Team Keyes-HealTerm-FirstHeal-B
				Behavior <<Untargetable(0),Unselectable(0),Invincible(0)>>
			}

			TeamControl
			{
				Type DoBehavior
				Team Keyes-HealTerm-FirstHeal-C
				Behavior <<Untargetable(0),Unselectable(0),Invincible(0)>>
			}

			TeamControl
			{
				Type DoBehavior
				Team Keyes-HealTerm-FirstHeal-D
				Behavior <<Untargetable(0),Unselectable(0),Invincible(0)>>
			}
		}
		Action
		{
			Floater
			{
				Message P3059579834
				Color 00cc99
			}
			Floater
			{
				Message P535679553
				Color 00cc99
			}
		}
	}

	Trigger AntimatterHealthChannel1-FullyRecovered
	{
		Requires ReactorDrawdownHeal1 scriptvalue> 1 == AntimatterHealth4 count> 99 >= &&
		
