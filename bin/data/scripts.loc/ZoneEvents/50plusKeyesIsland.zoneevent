//Two minutes after using nine containers, Antimatter arrives to fight the players.
	Trigger ThirdAntimatterArrival
	{
		Requires RestockCountdownEast scriptvalue> 1 >= AntimatterArrivesTimer3 complete> && AntimatterPresentStage3 scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P3170641586
				Color FF0000
				AlertType PriorityAlert
			}
			Floater
			{
				Message P1105543931
				Color FF0000
			}
			TeamControl
			{
				Type DoBehavior
				Team Keyes-Antimatter-Stage1
				Behavior <<SpawnPosIsSelf,Praetorian_TeleportIn(Timer(1),CombatOverride(Passive)),Invisible(0),Invincible(0),Unselectable(0),Untargetable(0)>>
			}
		}
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team Suppressor
				Behavior <<DestroyMe>>
			}
		}
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team SurrogateC
				Behavior <<DestroyMe>>
			}
		}
		Action
		{
			Reset AntimatterAttack3
		}
		Action
		{
			SetScriptValue AntimatterPresentStage3 1
		}
		Action
		{
			SetScriptValue HideAntimatterTimer3 0
		}
	}
	
//Five seconds after arriving, Antimatter will begin his attack.
	Trigger AntimatterStartAttack3
	{
		Requires AntimatterPresentStage3 scriptvalue> 1 >= AntimatterAttack3 complete> && AntimatterAttacking3 scriptvalue> 0 == &&
