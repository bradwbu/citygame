				Behavior <<DoNothing(CombatOverride(Passive),Untargetable(1),Unselectable(1),Timer(1)),UsePower("Revoke_Heal"),DoNothing(CombatOverride(Passive),Untargetable(0),Unselectable(0),Timer(1)),UsePower("Revoke_Intangible"),Combat>>
