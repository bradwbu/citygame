Stage Assault
{
	DisplayName P1689469796
	Tooltip P3142474748
	
// Start Hospital Door Block

	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:00
	}
	
	Trigger HospitalDoor-Unlock-Recovery
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1533101862
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

//End Hospital Door Block

//Start Warmth Spawn Block

	Trigger WarmthBuffActivation
	{
		Requires eventLockedByGroup? ! WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Granted>>
			SetScriptValue WarmthBuffSpawned 1
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team WarmthBuff
			}
		}
		Action
		{
			Floater
			{
				Message P1172875117
				Color FF9900
			}
		}
	}

	Trigger WarmthBuffBlocked
	{
		Requires eventLockedByGroup? WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Disabled>>
			SetScriptValue WarmthBuffSpawned 1
		}
	}

//End Warmth Spawn Block
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage 1: Assault>>
		}
		Action
		{
			SetScriptValue UI-DisplayChallengeTimer 0
		}
		Action
		{
			TeamControl
			{
				Team RepulsionField
				Type Activate
			}
			TeamControl
			{
				Team Fountain-Stage1
				Type Activate
			}
			TeamControl
			{
				Team Fountain-NoWander-Stage1
				Type Activate
			}
			TeamControl
			{
				Team Growth-A
				Type Activate
			}
			TeamControl
			{
				Team Growth-B
				Type Activate
			}
			TeamControl
			{
				Team Growth-C
				Type Activate
			}
			TeamControl
			{
				Team Growth-D
				Type Activate
			}
			TeamControl
			{
				Team Growth-Guards-A
				Type Activate
			}
			TeamControl
			{
				Team Growth-Guards-B
				Type Activate
			}
			TeamControl
			{
				Team Growth-Guards-C
				Type Activate
			}
			TeamControl
			{
				Team Growth-Guards-D
				Type Activate
			}
		}
		Action
		{
			Delay 2
			TeamControl
			{
				Team BadgeChecker
				Type Activate
			}
		}
	}

//This counter measures Repulsive Spine A's health.
	Counter GrowthA-Health
	{
		Type BossHealth
		Team Growth-A
	}

//This counter measures Repulsive Spine B's health.
	Counter GrowthB-Health
	{
		Type BossHealth
		Team Growth-B
	}

//This counter measures Repulsive Spine C's health.
	Counter GrowthC-Health
	{
		Type BossHealth
		Team Growth-C
	}

//This counter measures Repulsive Spine D's health.
	Counter GrowthD-Health
	{
		Type BossHealth
		Team Growth-D
	}

//This counter detects the number of Banished Pantheon enemies which have been defeated.
	Counter EnemiesDefeated-BanishedPantheon
	{	
		Type VillainGroup
		VillainGroup BanishedPantheonEndgame
		Direction Up
		Count 80
	}

//This counter detects the number of Diabolique enemies which have been defeated.
	Counter EnemiesDefeated-Diabolique
	{
		Type VillainGroup
		VillainGroup Diabolique
		Direction Up
		Count 80
	}

//This counter detects the defeat of repulsion field controllers.
	Counter EnemiesDefeated-Growths
	{
		Type Name
		Name Objects_DD_Repulsion_Controller
		Direction Up
		Count 4
	}

//This timer tracks the challenge window for the defeat of all four Repulsive Spines.
	Timer Badge-TimeChallenge-Timer
	{
		Duration 1:00
	}

//This timer indicates when captions will begin.
	Timer Captions-Stage1-Timer-01
	{
		Duration 0:10
	}

//This timer indicates when captions will begin.
	Timer Captions-Stage1-Timer-02
	{
		Duration 0:56
	}

//This trigger resets the challenge timer when the first spine is defeated.
	Trigger Badge-TimeChallenge-Started
	{
		Requires EnemiesDefeated-Growths count> 1 ==

		Action
		{
			Reset Badge-TimeChallenge-Timer
		}
		Action
		{
			SetScriptValue UI-DisplayChallengeTimer 1
		}
	}

//This trigger resets the challenge timer when the first spine is defeated.
	Trigger Badge-TimeChallenge-Failed
	{
		Requires  UI-DisplayChallengeTimer scriptvalue> 1 == Badge-TimeChallenge-Timer complete> &&

		Action
		{
			Reset Badge-TimeChallenge-Timer
		}
		Action
		{
			Floater
			{
				Message P1458019102
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue UI-DisplayChallengeTimer 0
		}
	}

//This is the trigger for the captions by Diabolique at the start of the event.
	Trigger Captions-Stage1-01
	{
		Requires Captions-Stage1-Timer-01 complete>

		Action
		{
			Caption IntroCaption-Diabolique
			{
				Message P286119756
			}
		}
		Action
		{
			PlaySound
			{
				Sound i20_03Low_a_Loop
				Channel Music
				VolumeLevel 1
			}
		}
	}

//This is the trigger for the captions by Dream Doctor at the start of the event.
	Trigger Captions-Stage1-02
	{
		Requires Captions-Stage1-Timer-02 complete>

		Action
		{
			Caption IntroCaption-DreamDoctor
			{
				Message P4136011225
			}
		}
	}

//This is the trigger for the captions by Dream Doctor when one of the spines is destroyed.
	Trigger Captions-Stage1-03
	{
		Requires EnemiesDefeated-Growths count> 1 >=

		Action
		{
			Caption SpineCaption-DreamDoctor
			{
				Message P1504287329
			}
		}
	}

//This is the master set of trigger decks for creating heroes to be rescued. These are run now, in stage 1, so that stage 2 isn't delayed by any rolling for heroes.
	TriggerDeck Assault-CreateHeroes-Deck-GroupA
	{
		Type NeverShuffle

		Trigger Create-BackAlleyBrawler
		{
			Action
			{
				DebugPrint <<Stage 1: Group A: Back Alley Brawler Chosen as Rescuable Hero>>
//				WaypointPlace WP-BackAlleyBrawler WP-BackAlleyBrawler
			}
			Action
			{
				SetScriptValue TotalHeroesSpawned TotalHeroesSpawned scriptvalue> 1 +
			}
			Action
			{
				SetScriptValue BackAlleyBrawlerRescueState 1
			}
			Action
			{
				Delay 2
				Reset Assault-CreateHeroes-Deck
				TeamControl
				{
					Team BackAlleyBrawler
					Type Activate
				}
				GlowieControl BackAlleyBrawlerTotem
				{
					Type Place
					Glowie BackAlleyBrawlerTotem
				}
			}
		}

		Trigger Create-Mynx
		{
			Action
			{
				DebugPrint <<Stage 1: Group A: Mynx Chosen as Rescuable Hero>>
//				WaypointPlace WP-Mynx WP-Mynx
			}
			Action
			{
				SetScriptValue TotalHeroesSpawned TotalHeroesSpawned scriptvalue> 1 +
			}
			Action
			{
				SetScriptValue MynxRescueState 1
			}
			Action
			{
				Delay 2
				Reset Assault-CreateHeroes-Deck
				TeamControl
				{
					Team Mynx
					Type Activate
				}
				GlowieControl MynxTotem
				{
					Type Place
					Glowie MynxTotem
				}
			}
		}
	}

