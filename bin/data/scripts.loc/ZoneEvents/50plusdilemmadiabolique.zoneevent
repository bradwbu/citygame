	Trigger CreateSentinel
	{
		Requires ContainedHeroSelected scriptvalue> 1 ==

		Action
		{
			TeamControl
			{
				Team TheSentinel
				Type Activate
			}
		}
		Action
		{
			Delay 1
			TeamControl
			{
				Team TheSentinel
				Type DoBehavior
				Behavior <<Invincible(1),Untargetable(1),Unselectable(1),Patrol(NamedRoute(RT-Sentinel),MotionWire,LimitedSpeed(14),CombatOverride(Passive)),DoNothing(CombatOverride(Passive))>>
			}
		}
