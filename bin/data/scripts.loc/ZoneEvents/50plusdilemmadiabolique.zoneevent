	Objective
	{
		Type VillainGroup
		VillainGroup BanishedPantheonEndgame
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}

//Award Karma for defeating a member of Diabolique's demons.
	Objective
	{
		Type VillainGroup
		VillainGroup Diabolique
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}

//This timer is for the start of the 
	Timer Caption-Stage5-Delay
	{
		Duration 00:05
	}

//This trigger sets the scriptvalue for the number of players defeated based on the counter.
	Trigger SetDeadValue
	{
		Requires DeathCheckTimer complete>

		Action
		{
			Reset DeathCheckTimer
		}
		Action
		{
			SetScriptValue TotalPlayerDefeats FinalePlayersDefeated count>
		}
		Action
		{
			Reset SetDeadValue
		}
	}

//This trigger fires the level up effects when Diabolique gains more power from players.
	Trigger PlayLevelUpEffects
	{
		Requires FinalePlayersDefeated-Single complete>

		Action
		{
			Reset FinalePlayersDefeated-Single
		}
		Action
		{
			SetScriptValue FireLevelUpEffects 1
		}
		Action
		{
			SetScriptValue DefeatsLeftUntilAnnihilate DefeatsLeftUntilAnnihilate scriptvalue> 1 -
		}
		Action
		{
			Reset PlayLevelUpEffects
		}
	}

//This trigger resets the Consume process every 60s.
	Trigger ConsumeReset
	{
		Requires ConsumeCycleTimer complete>

		Action
		{
			Reset ConsumeCycleTimer
			Reset LifegivingEssenceSpawnTimer
		}
		Action
		{
			SetScriptValue StageFiveActive 1
		}
		Action
		{
			DebugPrint <<Stage 5: Consume Cycle Reset>>
			Floater
			{
				Message P1821869731
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			Delay 1
			Reset EssenceSpawns
			TeamControl
			{
				Team ShadowWisps
				Type Deactivate
			}
		}
	}

//This trigger spawns the Lifegiving Essences 15s after the consume cycle resets.	
	Trigger EssenceSpawns
	{
		Requires LifegivingEssenceSpawnTimer complete> StageFiveActive scriptvalue> 1 == &&

		Action
		{
			DebugPrint <<Stage 5: Lifegiving Essences Spawned>>
			Floater
			{
				Message P2923450212
				Color 0099FF
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Team ShadowWisps
				Type Activate
			}
		}
		Action
		{
			Delay 1
			Reset ConsumeReset
		}
	}

