		Action
		{
			DebugPrint <<Completed Stage 1: Assault with Badge achieved>>
		}
		Action
		{
			SetScriptValue Badge-TimeChallenge-Success 1
		}
		Action
		{
			Floater
			{
				Message P3978010469
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P2828596787
				Color FF9900
			}
		}
		NextStage Assault-Recovery
	}

