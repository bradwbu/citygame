//This trigger cycles The Swarm spawns.
	Trigger TheSwarmCycle
	{
		Requires TheSwarmCycle-Timer complete> SwarmWave-Shutoff complete> ! &&

		Action
		{
			TeamControl
			{
				Team TheSwarm
				Type ForceSpawn
			}
		}
		Action
		{
			Reset TheSwarmCycle-Timer
		}
		Action
		{
			Delay 1
			Reset TheSwarmCycle
		}
	}

//This trigger sets up the success condition for the stage.
	Trigger TheDescentSuccess-Timer
	{
		Requires DescentSurvivalTimer complete> ZonePlayersAlive count> 1 >= &&
	
		Action
		{
			DebugPrint <<Stage 4: The Descent Completed>>
		}
		Action
		{
			Floater
			{
				Message P1931742429
				Color FF9900
			}
		}
		Action
		{
			Reward AstralMerit1
		}
		NextStage Descent-Recovery
	}

//This trigger sets up the failure condition for the stage due to the timer.
	Trigger TheDescentFailure-Timer
	{
		Requires DescentSurvivalTimer complete> ZonePlayersAlive count> 1 < &&
	
		Action
		{
			DebugPrint <<Stage 4: The Descent Failed>>
		}
		Action
		{
			TeamControl
			{
				Team Annihilation-Living
				Type DoBehavior
				Behavior <<UsePower("Annihilation")>>
			}
		}
		Action
		{
			Floater
			{
				Message P2450907602
				Color FF9900
			}
		}
		NextStage Failure
	}

//Start Failsafe Block. This set of triggers will manage a variant of the failsafe specific to this stage.

	Timer FailsafeDelay
	{
		Duration 0:20
	}

	Trigger FailsafeAllowed
	{
		Requires AllPlayersDead-Timer complete>

		Action
		{
			DebugPrint <<Stage 4: Failsafe Activated>>
			SetScriptValue FailsafeAllowedToRun 1
		}
	}

	//Trigger the failsafe for an unlocked league if the number of players is less than 0.
	Trigger FailsafeStart
	{
		Requires ZonePlayersAlive count> 0 <= FailsafeAllowedToRun scriptvalue> 1 == && FailsafeInProcess scriptvalue> 0 == &&
//		Requires ZonePlayersAlive count> 0 <= FailsafeAllowedToRun scriptvalue> 1 == && FailsafeInProcess scriptvalue> 0 == && devMode? ! &&
		Action FloatersFailsafeStart
		{
			DebugPrint <<Starting failure trigger>>
			Reset FailsafeDelay
		}
		Action
		{
			Floater
			{
				Message P970230390
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the end of the failsafe for an unlocked league after 15s if it still has less than 2 players.
	Trigger FailsafeConclude
	{
		Requires ZonePlayersAlive count> 0 <= FailsafeInProcess scriptvalue> 1 == && FailsafeDelay complete> &&
//		Requires ZonePlayersAlive count> 0 <= FailsafeInProcess scriptvalue> 1 == && FailsafeDelay complete> && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P2450907602
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Failure
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 2 before the 15s timer ends.
	Trigger FailsafeReset
	{
		Requires ZonePlayersAlive count> 0 > FailsafeInProcess scriptvalue> 1 == &&
//		Requires ZonePlayersAlive count> 0 > FailsafeInProcess scriptvalue> 1 == && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart 
			Reset FailsafeReset
			Reset FailsafeDelay
		}
	}

//End Failsafe Block


//This is the collection of UI items for the stage.
	UICollection TheDescentStage
	{
		UIItem PlayersAliveBar
		{
			Type BarGold
			Text P2555454331
			ShortText P4110910291
			Current ZonePlayersAlive count>
			Target ZonePlayers count>
			UpdateTarget
		}
		UIItem TheSwarmCountdown
		{
			Type Timer
			Timer TheSwarmCycle-Timer
			Text P311299879
			ShortText P2455777706
			HideIf SwarmWave-Shutoff complete>
		}
		UIItem TheDescentCountdown
		{
			Type Timer
			Timer DescentSurvivalTimer
			Text P1346438663
			ShortText P2439468720
		}
		UIItem TheDescentDeathsCountdown
		{
			Type Timer
			Timer FailsafeDelay
			Text P2714390925
			ShortText P2545776225
			HideIf FailsafeInProcess scriptvalue> 0 ==
		}
		UIItem Stage4-Spacer
		{
			Type CenterText
			Text P3718001799
		}
		UIItem Stage4-Tip1
		{
			Type CenterText
			Text P1907337937
		}
		UIItem Stage4-Tip2
		{
			Type CenterText
			Text P321413289
		}
		UIItem Stage4-Tip2
		{
			Type CenterText
			Text P3568003571
		}
	}

	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage 4: The Descent>>
		}
		Action
		{	
			TeamControl
			{
				Team TheSwarm
				Type Deactivate
			}
			TeamControl
			{
				Team ImpendingDeath
				Type Deactivate
			}
		}
	}
}

Stage Descent-Recovery
{
	DisplayName P1570668787
	Tooltip P1959715258
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Rest Period with All NPCs>>
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 3
			}
		}
		Action
		{
			TeamControl
			{
				Team Dominatrix
				Type Activate
			}
			TeamControl
			{
				Team Diabolique
				Type Activate
			}
			TeamControl
			{
				Team ShadowWisps
				Type Activate
			}
		}
		Action
		{
			Delay 1
			TeamControl
			{
				Team ShadowWisps
				Type DoBehavior
				Behavior <<Untargetable(1),Unselectable(1),Invincible(1)>>
			}
		}
	}

//This counter detects when players have entered Tilman's Sanctum area.
	Counter PlayersInLivingWorldRoom
	{
		Type ZEPlayers
		VolumeName LivingWorld
	}

//This timer institutes a small delay in the check of the number of players in the 'living world'.
	Timer Descent-Recovery-Delay
	{
		Duration 00:05
	}

//This timer shows how long until Dream Doctor teleports players to the Shadow Realm.
	Timer TeleportTimer
	{
		Duration 00:10
	}

