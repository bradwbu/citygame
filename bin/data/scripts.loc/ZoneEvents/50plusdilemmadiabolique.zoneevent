Stage Cutscene
{
	DisplayName P1570668787
	Tooltip P4163438143
	
	Startup
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage 5A: Cutscene>>
		}
		Action GurneyReactivate
		{
			GurneyControl
			{
				Type EnableRezWindow
			}
		}
	}
	
//This timer delays the start of the cutscene a few moments.
	Timer Cutscene-Delay-Timer
	{
		Duration 00:05
	}

//This timer indicates the length of the cutscene.
	Timer Cutscene-Timer
	{
		Duration 00:36
	}

//This trigger starts the cutscene if someone in the event has never completed it.
	Trigger Cutscene-Start
	{
		Requires Cutscene-Skippable scriptvalue> 0 == Cutscene-Delay-Timer complete> &&

		Action
		{
			Reset Cutscene-Timer
		}
		Action
		{
			DebugPrint <<Stage 5A: Cutscene Activated>>
		}
		Action
		{
			TeamControl
			{
				Team Cutscene
				Type Activate
			}
		}
	}

//This trigger ends the stage with the cutscene if it is triggered.
	Trigger Cutscene-End
	{
		Requires Cutscene-Skippable scriptvalue> 0 == Cutscene-Timer complete> &&
		
		Action
		{
			TeamControl
			{
				Team Cutscene
				Type Deactivate
			}
		}
		Action
		{
			DebugPrint <<Stage 5A: Cutscene Ending>>
		}		
		NextStage RewardWinners
	}

//This trigger skips the cutscene if everyone in the event has the badge.
	Trigger Cutscene-Skip
	{
		Requires Cutscene-Skippable scriptvalue> 1 ==

		Action
		{
			DebugPrint <<Stage 5A: Cutscene Skipped>>
		}

		NextStage RewardWinners
	}

	Shutdown
	{
		Action
		{
			DebugPrint <<Ending Stage 5A: Cutscene>>
		}
	}
}

Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Starting Stage 6: Reward Winners>>
		}
		Action RewardTokenForCompletingTrial
		{
			Reward IS.DarkAstoriaTrialCompleteToken
		}
		Action
		{
			Floater
			{
				Message P387300622
				Color FF9900
			}
		}
	}
	Trigger AwardBadge-Completion
	{
		Action
		{
			DebugPrint <<Awarding Completion Badge>>
			Reward IT_DD_Complete
		}
	}
	Trigger AwardBadge-TimeChallenge
	{
		Requires Badge-TimeChallenge-Success scriptvalue> 1 ==
		Action
		{
			DebugPrint <<Awarding "Gate Crasher" Badge>>
			Reward IT_DD_TimeChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-SentinelChallenge
	{
		Requires Badge-SentinelChallenge-Success scriptvalue> 1 ==
		Action
		{
			DebugPrint <<Awarding "Sentinel Smasher" Badge>>
			Reward IT_DD_SentinelChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-NoRescueChallenge
	{
		Requires Badge-NoRescueChallenge-Success scriptvalue> 1 ==
		Action
		{
			DebugPrint <<Awarding "Sacrificial Lamb" Badge>>
			Reward IT_DD_NoRescueChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-HealingChallenge
	{
		Requires Badge-HealingChallenge-Success scriptvalue> 1 ==
		Action
		{
			DebugPrint <<Awarding "Life and Death" Badge>>
			Reward IT_DD_HealingChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardMerit-OpenLeague
	{
		Requires eventLockedByGroup? ! OpenLeagueAward scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Bonus Merit for an Open League Awarded>>
			SetScriptValue OpenLeagueAward 1
		}
		Action
		{
			Floater
			{
				Message P1336852141
				Color 0099FF
			}
		}
		Action
		{
			Reward AstralMerit1
		}
	}	
	Timer RewardWinnersDelay
	{
		Duration 00:05
	}
	Trigger RewardWinnersDelayEnd
	{
		Requires RewardWinnersDelay complete>
		NextStage Stop
		
		Action StopStart
		{
			DebugPrint <<Ending Stage 6: Reward Winners>>
		}
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Stage Reward Winners Completed...>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					NumStagesRequired 2
					RewardTable is.Issue22EndKarma0
				}
				Reward class2
				{
					PercentileNeeded 0.00
					NumStagesRequired 3
					PointsNeeded 10
					RewardTable is.Issue22EndKarma1
				}
			}
		}
	}
}
	
Stage Failure
{
	StartUp
	{
		Action FailureStart
		{
			DebugPrint <<Ending Stage -1: Failure>>
		}
		Action
		{
			Floater
			{
				Message P2875924815
				Color FF9900
			}
		}
	}
	Timer FailureDelay
	{
		Duration 00:10
	}
	Trigger FailureDelayEnd
	{
		Requires FailureDelay complete>
		NextStage Stop
		
		Action StopStart
		{
			DebugPrint <<Ending Stage -1: Failure>>
		}
	}

}

