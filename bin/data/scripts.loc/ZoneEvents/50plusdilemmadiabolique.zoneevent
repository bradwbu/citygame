//This is the trigger for the regeneration rate increases on Dominatrix due to freeing of Back Alley Brawler.
	Trigger Stage5-HeroRescue-BackAlleyBrawler
	{
		Requires BackAlleyBrawlerDefeated-Finale complete>

		Action
		{
			SetScriptValue UI-ShowBackAlleyBrawlerHealth-Finale 0
		}
		Action
		{
			SetScriptValue Badge-NoRescueChallenge-Success 0
		}
		Action
		{
			SetScriptValue FinaleHeroesSpawned FinaleHeroesSpawned scriptvalue> 1 -
		}
		Action
		{
			SetScriptValue FinaleHeroesDefeated FinaleHeroesDefeated scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue FireLevelUpEffects 1
		}
		Action
		{
			DebugPrint <<Stage 5: Back Alley Brawler freed>>
			Floater
			{
				Message P3302800255
				Color 00AA00
				AlertType PriorityAlert
			}
		}
	}

