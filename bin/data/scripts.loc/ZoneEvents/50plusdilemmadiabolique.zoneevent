//This is the master trigger deck for determining the hero spawned during the final battle with Diabolique.
	TriggerDeck Diabolique-SpawnedHero

	Requires FinaleHeroesSpawned scriptvalue> 2 <

	Type NeverShuffle

		Trigger Spawn-BackAlleyBrawler
		{
			Requires BackAlleyBrawlerRescueState scriptvalue> 1 == 

			Action
			{
				DebugPrint <<Stage 5: Back Alley Brawler Chosen as Spawned Hero>>
			}
			Action
			{
				SetScriptValue FinaleHeroesSpawned FinaleHeroesSpawned scriptvalue> 1 +
			}
			Action
			{
				SetScriptValue BackAlleyBrawlerRescueState 3
			}
			Action
			{
