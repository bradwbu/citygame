//This trigger sets up the success condition for the stage.
	Trigger DiaboliqueSuccess
	{
		Requires DiaboliqueDefeated complete>
	
		Action
		{
			DebugPrint <<Stage 5: Diabolique Defeated>>
		}
		Action
		{
			Floater
			{
				Message P3057824506
				Color FF9900
			}
		}
		Action
		{
			Reward EmpyreanMerit_Death
		}
		NextStage Cutscene
	}

	Trigger DiaboliqueFailure-Deaths
	{
		Requires FinalePlayersDefeated complete>
	
		Action
		{
			DebugPrint <<Stage 5: Too Many Deaths. Trial Failure>>
		}
		Action
		{
			TeamControl
			{
				Team Annihilation-Shadow
				Type DoBehavior
				Behavior <<UsePower("Annihilation")>>
			}
		}
		Action
		{
			Floater
			{
				Message P660803193
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P1259450649
				Color FF9900
			}
		}
		NextStage Failure
	}

	Trigger DiaboliqueFailure-Timer
	{
		Requires DiaboliqueFailureTimer complete>
	
		Action
		{
			DebugPrint <<Stage 5: Diabolique Failure Timer Expired>>
		}
		Action
		{
			TeamControl
			{
				Team Annihilation-Shadow
				Type DoBehavior
				Behavior <<UsePower("Annihilation")>>
			}
		}
		Action
		{
			Floater
			{
				Message P1826840696
				Color FF9900
			}
		}
		NextStage Failure
	}

//This is the collection of UI items for the stage.
	UICollection DiaboliqueStage
	{
		UIItem DiaboliqueHealth
		{
			Type BarRed
			Text P1507508184
			ShortText P820448025
			Current DiaboliqueHealth count>
			OnClickFindEnt Diabolique
			Target 100
		}
		UIItem BackAlleyBrawlerHealthBar-Finale
