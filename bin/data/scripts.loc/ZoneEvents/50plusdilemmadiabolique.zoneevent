			{
				Glowie ValkyrieTotem
				Type Deactivate
			}
		}
	}

//This trigger sets up the success condition for the stage.
	Trigger RescueSuccess
	{
		Requires TotalHeroesRescued scriptvalue> 4 >= 
	
		Action
		{
			DebugPrint <<Stage 2 Success: 4 Heroes Rescued>>
		}
		Action
		{
			Floater
			{
				Message P3354396677
				Color FF9900
			}
		}
		Action
		{
			Reward AstralMerit1
		}
		NextStage Rescue-Recovery
	}

//This trigger sets up the failure condition for the stage.
	Trigger RescueFailure-Timer
	{
		Requires RescueFailureTimer complete>
	
		Action
		{
			DebugPrint <<Stage 2 Failure: Timer Expired>>
		}
		Action
		{
			TeamControl
			{
				Team Annihilation-Exterior
				Type DoBehavior
				Behavior <<UsePower("Annihilation")>>
			}
		}
		Action
		{
			Floater
			{
				Message P3553720418
				Color FF9900
			}
		}
		
		NextStage Failure
	}

