Stage Sentinel-Recovery
{
	DisplayName P331614917
	Tooltip P3070820948

// Start Hospital Door Block

	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:00
	}
	
	Trigger HospitalDoor-Unlock-Recovery
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1533101862
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

//End Hospital Door Block	

	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage 3A: Recovery>>
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 3
			}
		}
		Action
		{
			PorterControl
			{
				Porter TPTR-MotDoorway
				Type Activate
			}
		}
	}

//This counter detects when players have entered Mot's interior.
	Counter PlayersInLivingWorldRoom
	{
		Type ZEPlayers
		VolumeName LivingWorld
	}

//This timer starts Dream Doctor's captions in this stage.
	Timer Captions-Stage3-Timer-02
	{
		Duration 00:20
	}

//This is the trigger for the captions by Diabolique at the start of the event.
	Trigger Captions-Stage3A-01
	{
		Action
		{
			Caption IntroCaption-Diabolique
			{
				Message P694126533
			}
		}
	}

//This is the trigger for the captions by Dream Doctor at the start of the event.
	Trigger Captions-Stage3A-02
	{
		Requires Captions-Stage3-Timer-02 complete>

		Action
		{
			Caption IntroCaption-DreamDoctor
			{
				Message P1209453475
			}
		}
	}

//This trigger sets up the success condition for the stage.
	Trigger Recovery-Complete-Stage3A
	{
		Requires PlayersInLivingWorldRoom count> 1 >=
	
		Action
		{
			DebugPrint <<Stage 3A: Players entered the Living World Mot Interior>>
		}

		NextStage Descent
	}

	UICollection Stage3A
	{
		UIItem Stage3A-Tip1
		{
			Type CenterText
			Text P1686073993
		}		
	}

	Shutdown
	{
		Action
		{
			DebugPrint <<Ending Stage 3A: Recovery>>
		}
	}
}

Stage Descent
{
	DisplayName P331614917
	Tooltip P280785873

//	AwardKarma
//	KarmaThreshold 10
//	StageActiveRequires ZonePlayers count> 8 > ZonePlayersActive count> ZonePlayers count> / 0.25 > &&

	StartUp
	{
		Action
		{
			DebugPrint <<Starting Stage 4: The Descent>>
		}
		Action
		{
			PlaySound
			{
				Sound i20_02High_c_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			TeamControl
			{
				Team TheSwarm
				Type Activate
			}
			TeamControl
			{
				Team ImpendingDeath
				Type Activate
			}
		}
		Action
		{
			SetScriptValue FinaleHeroesSpawned 0
		}
		Action
		{
			SetScriptValue FireLevelUpEffects 0
		}
		Action GurneyShutoff
		{
			GurneyControl
			{
				Type DisableRezWindow
			}
		}
	}

//These are typically failsafe counters, but here they are used to track players in the UI and success conditions.
	Counter ZonePlayers
        {
                Type ZEPlayers
        }
        Counter ZonePlayersAlive
        {
                Type ZEPlayersAlive
		VolumeName LivingWorld
        }
        Counter ZonePlayersActive
        {
                Type ZEPlayersActive
        }

//Award Karma for defeating a member of the Banished Pantheon.
	Objective
	{
		Type VillainGroup
		VillainGroup BanishedPantheonEndgame
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}

//Award Karma for defeating a member of Diabolique's demons.
	Objective
	{
		Type VillainGroup
		VillainGroup Diabolique
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}

//This timer is the failure timer for the stage.
	Timer DescentSurvivalTimer
	{
		Duration 5:00
	}

//This timer is for the cycling of The Swarm
	Timer TheSwarmCycle-Timer
	{
		Duration 00:30
	}

//This timer is for starting the all-death checks.
	Timer AllPlayersDead-Timer
	{
		Duration 00:15
	}

//This timer institutes a small delay for the captions in Stage 4.
	Timer Caption-Stage4-Delay
	{
		Duration 00:05
	}

//This timer institutes a small delay for the caption from Diabolique in Stage 4.
