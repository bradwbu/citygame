//This timer is the delay for Dream Doctor's first caption.
	Timer Captions-Stage2-Timer-02
	{
		Duration 00:43
	}

//This timer is the failure timer for the stage.
	Timer RescueFailureTimer
	{
		Duration 15:00
	}

//This is the trigger for the captions by Diabolique at the start of the event.
	Trigger Captions-Stage2-01
	{
		Action
		{
			PlaySound
			{
				Sound i20_03High_c_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			Caption StageTwoCaption-Diabolique
			{
				Message P3824312707
			}
		}
	}

//This is the trigger for the captions by Dream Doctor at the start of the event.
	Trigger Captions-Stage1-02
	{
		Requires Captions-Stage2-Timer-02 complete>

		Action
		{
			Caption StageTwoCaption-DreamDoctor
			{
				Message P3374040513
			}
		}
	}

//This trigger starts the spawn of Back Alley Brawler's totem guards if he is present.
	Trigger HeroGuarded-BackAlleyBrawler
	{
		Requires BackAlleyBrawlerRescueState scriptvalue> 1 ==

		Action
		{
			DebugPrint <<Stage 2: Back Alley Brawler Guarded>>
			WaypointPlace WP-BackAlleyBrawler WP-BackAlleyBrawler
			TeamControl
			{
				Team BackAlleyBrawlerTotem-Guards
				Type Activate
			}
		}
		Action
		{
			SetScriptValue UI-ShowBackAlleyBrawlerGuards 1
		}
	}

//This trigger unlocks Back Alley Brawler's totem if he is present.
	Trigger HeroUnlocked-BackAlleyBrawler
	{
		Requires BackAlleyBrawlerRescueState scriptvalue> 1 == BackAlleyBrawlerTotemGuardsDefeated complete> &&

		Action
		{
			SetScriptValue BackAlleyBrawler-DoNotDespawn 1
		}
		Action
		{
			DebugPrint <<Stage 2: Back Alley Brawler Unlocked>>
			GlowieControl
			{
				Glowie BackAlleyBrawlerTotem
				Type Activate
			}
		}
		Action
		{
			TeamControl
			{
				Team BackAlleyBrawlerTotem-Swarm
				Type Activate
			}
		}
		Action
		{
			SetScriptValue UI-ShowBackAlleyBrawlerGuards 0
		}
		Action
		{	
			SetScriptValue UI-ShowBackAlleyBrawlerTotem 1
		}
		Action
		{
			SetScriptValue TotemsUnlocked TotemsUnlocked scriptvalue> 1 +
		}
	}
	
//This trigger frees Back Alley Brawler if he is present and his totem is used.
	Trigger HeroFreed-BackAlleyBrawler
	{
		Requires BackAlleyBrawlerRescueState scriptvalue> 1 == BackAlleyBrawlerTotemClicked complete> &&

		Action
		{
			DebugPrint <<Stage 2: Back Alley Brawler Freed>>			
			TeamControl
			{
				Team BackAlleyBrawler
				Type DoBehavior
				Behavior <<Encounter_ReichsmanReleased(Timer(4)),Untargetable(0),Unselectable(0),Invincible(0),Combat>>
			}
		}
		Action
		{	
			SetScriptValue UI-ShowBackAlleyBrawlerTotem 0
		}
		Action
		{
			SetScriptValue UI-ShowBackAlleyBrawlerHealth 1
		}
		Action
		{
			SetScriptValue BackAlleyBrawlerRescueState 2
		}
	}

//This trigger shuts down Back Alley Brawler if he is present, his totem is locked and the number of unlocked totems is 4 or more.

	Trigger HeroNotRescued-BackAlleyBrawler
	{
		Requires BackAlleyBrawlerRescueState scriptvalue> 1 == TotemsUnlocked scriptvalue> 4 >= && BackAlleyBrawler-DoNotDespawn scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 2: Back Alley Brawler Not Rescued>>
			SetScriptValue BackAlleyBrawler-Shutdown 1
		}
	}

//This trigger tracks the rescue of Back Alley Brawler.
	Trigger HeroRescued-BackAlleyBrawler
	{
		Requires BackAlleyBrawlerDefeated complete> 
		
		Action
		{
			DebugPrint <<Stage 2: Back Alley Brawler Rescued>>
			Floater
			{
				Message P4145177627
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue BackAlleyBrawlerRescueState 3
		}
		Action
		{
			SetScriptValue TotalHeroesRescued TotalHeroesRescued scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue BackAlleyBrawler-Shutdown 1
		}
	}

//This trigger shutsdown aspects of Back Alley Brawler when freed or pulled out of the selections.
	Trigger HeroShutdown-BackAlleyBrawler
	{
		Requires BackAlleyBrawler-Shutdown scriptvalue> 1 ==
			
		Action
		{
			TeamControl
			{
				Team BackAlleyBrawler
				Type Deactivate
			}
			TeamControl
			{
				Team BackAlleyBrawlerTotem-Guards
				Type Deactivate
			}
			TeamControl
			{
				Team BackAlleyBrawlerTotem-Swarm
				Type Deactivate
			}
		}
		Action
		{
			SetScriptValue UI-ShowBackAlleyBrawlerGuards 0
		}
		Action
		{	
			SetScriptValue UI-ShowBackAlleyBrawlerTotem 0
		}
		Action
		{
			SetScriptValue UI-ShowBackAlleyBrawlerHealth 0
		}
		Action
		{
			GlowieControl
			{
				Glowie BackAlleyBrawlerTotem
				Type Deactivate
			}
		}
	}

//This trigger starts the spawn of Citadel's totem guards if he is present.
	Trigger HeroGuarded-Citadel
	{
		Requires CitadelRescueState scriptvalue> 1 ==

		Action
		{
			DebugPrint <<Stage 2: Citadel Guarded>>
			WaypointPlace WP-Citadel WP-Citadel
			TeamControl
			{
