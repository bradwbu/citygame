//This trigger shuts down Swan if she is present, her totem is locked and the number of unlocked totems is 4 or more.

	Trigger HeroNotRescued-Swan
	{
		Requires SwanRescueState scriptvalue> 1 == TotemsUnlocked scriptvalue> 4 >= && Swan-DoNotDespawn scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 2: Swan Not Rescued>>
			SetScriptValue Swan-Shutdown 1
		}
	}

//This trigger tracks the rescue of Swan.
	Trigger HeroRescued-Swan
	{
		Requires SwanDefeated complete> 
		
		Action
		{
			DebugPrint <<Stage 2: Swan Rescued>>
			Floater
			{
				Message P4124018765
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue SwanRescueState 3
		}
		Action
		{
			SetScriptValue TotalHeroesRescued TotalHeroesRescued scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue Swan-Shutdown 1
		}
	}

//This trigger shutsdown aspects of Swan when freed or pulled out of the selections.
	Trigger HeroShutdown-Swan
	{
		Requires Swan-Shutdown scriptvalue> 1 ==
			
		Action
		{
			TeamControl
			{
				Team Swan
				Type Deactivate
			}
			TeamControl
			{
				Team SwanTotem-Guards
				Type Deactivate
			}
			TeamControl
			{
				Team SwanTotem-Swarm
				Type Deactivate
			}
		}
		Action
		{
			SetScriptValue UI-ShowSwanGuards 0
		}
		Action
		{	
			SetScriptValue UI-ShowSwanTotem 0
		}
		Action
		{
			SetScriptValue UI-ShowSwanHealth 0
		}
		Action
		{
			GlowieControl
			{
				Glowie SwanTotem
				Type Deactivate
			}
		}
	}

//This trigger starts the spawn of Valkyrie's totem guards if she is present.
	Trigger HeroGuarded-Valkyrie
	{
		Requires ValkyrieRescueState scriptvalue> 1 ==

		Action
		{
			DebugPrint <<Stage 2: Valkyrie Guarded>>
			WaypointPlace WP-Valkyrie WP-Valkyrie
			TeamControl
			{
				Team ValkyrieTotem-Guards
				Type Activate
			}
		}
		Action
		{
			SetScriptValue UI-ShowValkyrieGuards 1
		}
	}

//This trigger unlocks Valkyrie's totem if she is present.
	Trigger HeroUnlocked-Valkyrie
	{
		Requires ValkyrieRescueState scriptvalue> 1 == ValkyrieTotemGuardsDefeated complete> &&

		Action
		{
			SetScriptValue Valkyrie-DoNotDespawn 1
		}
		Action
		{
			DebugPrint <<Stage 2: Valkyrie Unlocked>>
			GlowieControl
			{
				Glowie ValkyrieTotem
				Type Activate
			}
		}
		Action
		{
			TeamControl
			{
				Team ValkyrieTotem-Swarm
				Type Activate
			}
		}
		Action
		{
			SetScriptValue UI-ShowValkyrieGuards 0
		}
		Action
		{	
			SetScriptValue UI-ShowValkyrieTotem 1
		}
		Action
		{
			SetScriptValue TotemsUnlocked TotemsUnlocked scriptvalue> 1 +
		}
	}
	
//This trigger frees Valkyrie if she is present and her totem is used.
	Trigger HeroFreed-Valkyrie
	{
		Requires ValkyrieRescueState scriptvalue> 1 == ValkyrieTotemClicked complete> &&

		Action
		{
			DebugPrint <<Stage 2: Valkyrie Freed>>			
			TeamControl
			{
				Team Valkyrie
				Type DoBehavior
				Behavior <<Encounter_ReichsmanReleased(Timer(4)),Untargetable(0),Unselectable(0),Invincible(0),Combat>>
			}
		}
		Action
		{	
			SetScriptValue UI-ShowValkyrieTotem 0
		}
		Action
		{
			SetScriptValue UI-ShowValkyrieHealth 1
		}
		Action
		{
			SetScriptValue ValkyrieRescueState 2
		}
	}

//This trigger shuts down Valkyrie if she is present, her totem is locked and the number of unlocked totems is 4 or more.

	Trigger HeroNotRescued-Valkyrie
	{
		Requires ValkyrieRescueState scriptvalue> 1 == TotemsUnlocked scriptvalue> 4 >= && Valkyrie-DoNotDespawn scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 2: Valkyrie Not Rescued>>
			SetScriptValue Valkyrie-Shutdown 1
		}
	}

//This trigger tracks the rescue of Valkyrie.
	Trigger HeroRescued-Valkyrie
	{
		Requires ValkyrieDefeated complete> 
		
		Action
		{
			DebugPrint <<Stage 2: Valkyrie Rescued>>
			Floater
			{
				Message P3738267735
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue ValkyrieRescueState 3
		}
		Action
		{
			SetScriptValue TotalHeroesRescued TotalHeroesRescued scriptvalue> 1 +
		}
		Action
		{
			SetScriptValue Valkyrie-Shutdown 1
		}
	}

//This trigger shutsdown aspects of Valkyrie when freed or pulled out of the selections.
	Trigger HeroShutdown-Valkyrie
	{
		Requires Valkyrie-Shutdown scriptvalue> 1 ==
			
		Action
		{
			TeamControl
			{
				Team Valkyrie
				Type Deactivate
			}
			TeamControl
			{
				Team ValkyrieTotem-Guards
				Type Deactivate
			}
			TeamControl
			{
				Team ValkyrieTotem-Swarm
				Type Deactivate
			}
		}
		Action
