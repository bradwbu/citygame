//This trigger fails the badge if more than three Eyes of the Storm are created.
	Trigger Badge-PenelopeChallenge-Failed
	{
		Requires Badge-PenelopeChallenge-VoidDefeated count> 5 >=

		Action
		{
			SetScriptValue Badge-PenelopeChallenge 1
		}
	}	

//This trigger adds the bonus time to the clock and allows the timer to display.
	Trigger Penelope-BonusTime-Added
	{
		Requires PenelopeSetBonusTime complete> Penelope-BonusTime-Set scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Adding depletable bonus time>>
			TimerControl
			{
				Timer PenelopeFailureTimer
				Type Add
				Duration 10:00
			}
		}
		Action
		{
			SetScriptValue Penelope-BonusTime-Set 1
		}
		Action
		{
			Caption
			{
				Message P3407408213
			}
		}
	}

//This trigger starts the Psionic Typhoon in Penelope's room
