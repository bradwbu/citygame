//			Timer ResurrectionCycle
//			Text P926930693
//			ShortText P3974340810
//			HideIf ResurrectionBegun scriptvalue> 0 ==
//		}
//		UIItem ResurrectionStartCountdown
//		{
//			Type Timer
//			Timer ResurrectionDelay
//			Text P926930693
//			ShortText P3974340810
//			HideIf ResurrectionBegun scriptvalue> 1 ==
//		}
		UIItem DyingTilmanCountdown
		{
			Type Timer
			Timer FinaleFailureTimer
			Text P904769664
			ShortText P856300666
		}
		UIItem Finale-Spacer
		{
			Type CenterText
			Text P3718001799
			HideIf 100 DyingTilmanHealth count> - 0 60 minmax 60 / 100 * 100 ==
		}
		UIItem Finale-Advice1
		{
			Type CenterText
			Text P1073402150
			HideIf 100 DyingTilmanHealth count> - 0 60 minmax 60 / 100 * 100 ==
		}
		UIItem Finale-Advice2
		{
			Type CenterText
			Text P345861891
			HideIf 100 DyingTilmanHealth count> - 0 60 minmax 60 / 100 * 100 ==
		}
		UIItem Finale-Advice3
		{
			Type CenterText
			Text P133714127
			HideIf 100 DyingTilmanHealth count> - 0 60 minmax 60 / 100 * 100 ==
		}
	}

	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Boss Fight with Shalice Tilman>>
		}
//		Action
//		{
//			FadeSound
//			{
//				Channel Music
//				FadeTime 10
//			}
//		}
		Action
		{
			PorterControl
			{
				Porter TPTR-Finale
				Type Deactivate
			}
			TeamControl
			{
				Team NPC-CalvinScott
				Type Deactivate
			}
			TeamControl
			{
				Team Portal-Finale
				Type Deactivate
			}
			TeamControl
			{
				Team TilmansMind
				Type Deactivate
			}
			TeamControl
			{
				Team Portal-Final
				Type Deactivate
			}
			PorterControl
			{
				Porter TPTR-TheWell
				Type Deactivate
			}
		}
	}
}

Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Stage Reward Winners Initialized...>>
		}
		Action
		{
			SetScriptValue CurrentStage 6
		}
		Action
		{
			Floater
			{
				Message P3793641794
				Color FF9900
			}
		}
		Action
		{
			GurneyControl
			{
				Type EnableRezWindow
			}
		}
	}
	Trigger AwardBadge-Completion
	{
		Action
		{
			DebugPrint <<Awarding Completion Badge>>
			Reward IT_MoM_Complete
		}
	}
	Trigger AwardBadge-PenelopeChallenge
	{
		Requires Badge-PenelopeChallenge scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding A Perfect Storm Badge>>
			Reward IT_MoM_PenelopeChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-AuroraChallenge
	{
		Requires Badge-AuroraChallenge scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding Daylight Saver Badge>>
			Reward IT_MoM_AuroraChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-ShaliceChallenge
	{
		Requires Badge-ShaliceChallenge scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding Lost Connection Badge>>
			Reward IT_MoM_ShaliceChallenge
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardMerit-OpenLeague
	{
		Requires eventLockedByGroup? ! OpenLeagueAward scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Bonus Merit for an Open League Awarded>>
			SetScriptValue OpenLeagueAward 1
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger End
	{
		NextStage Stop
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Stage Reward Winners Completed...>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					NumStagesRequired 4
					RewardTable Issue21EndKarma0
				}
				Reward class2
				{
					PercentileNeeded 0.00
					NumStagesRequired 5
					PointsNeeded 10
					RewardTable IS.Issue2150EndKarma1Plus
				}
			}
		}
	}
}
	
Stage Failure
{
	StartUp
	{
		Action FailureStart
		{
			DebugPrint <<Initializing Stage Failure...>>
		}
		Action
		{
			Floater
			{
				Message P2594637490
				Color FF9900
			}
		}
		Action
		{
			GurneyControl
			{
				Type EnableRezWindow
			}
		}
	}
	Timer FailureDelay
	{
		Duration 00:10
	}
	Trigger FailureDelayEnd
	{
		Requires FailureDelay complete>
		NextStage Stop
		
		Action StopStart
		{
			DebugPrint <<Completing Stage Failure...>>
		}
	}

}

