//This trigger adds the bonus time to the clock and allows the timer to display.

	Trigger Malaise-BonusTime-Added
	{
		Requires MalaiseSetBonusTime complete> Malaise-BonusTime-Set scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Adding depletable bonus time>>
			TimerControl
			{
				Timer MalaiseFailureTimer
				Type Add
				Duration 15:00
			}
		}
		Action
		{
			SetScriptValue Malaise-BonusTime-Set 1
		}
		Action
		{
			Caption
			{
				Message P4013025294
			}
		}
	}

//This trigger increments a Nightmare defeat count when a Nightmare is defeated.

	Trigger Nightmare-IncrementDefeat
	{
		Requires EochaiDefeated complete> JackDefeated complete> || AdamastorDefeated complete> || BabbageDefeated complete> || PaladinDefeated complete> || KronosTitanDefeated complete> || JurassikDefeated complete> || CrystalTitanDefeated complete> || CalebDefeated complete> || RuladakDefeated complete> || LanaruDefeated complete> || BatzulDefeated complete> || DeathsurgeDefeated complete> || LordWinterDefeated complete> || AvatarDefeated complete> || LIWWDefeated complete> ||

		Action
		{
			SetScriptValue NightmaresDefeated NightmaresDefeated scriptvalue> 1 +
		}
		Action
		{
			Reset EochaiDefeated
			Reset JackDefeated
			Reset AdamastorDefeated
			Reset BabbageDefeated
			Reset PaladinDefeated
			Reset KronosTitanDefeated
			Reset JurassikDefeated
			Reset CrystalTitanDefeated
			Reset CalebDefeated
			Reset RuladakDefeated
			Reset LanaruDefeated
			Reset BatzulDefeated
			Reset DeathsurgeDefeated
			Reset LordWinterDefeated
			Reset AvatarDefeated
			Reset LIWWDefeated
		}
		Action
		{
			Reset Timer-DesdemonaSpeaks
		}
		Action
		{
			Delay 2
			Reset Nightmare-IncrementDefeat
		}
	}

//This trigger starts the Malaise Nightmare part of the event when he hits 50% health.
	Trigger Malaise-NightmareSummon-Start
	{
		Requires MalaiseHealthDelayTimer complete> MalaiseHealth count> 51 <= && MalaiseSummonState scriptvalue> 0 == &&
		
		Action
		{
			TeamControl
			{
				Team Malaise
				Type DoBehavior
				Behavior Say(P4254774943)
			}
			Caption
			{
				Message P3840951720
			}
		}
		Action
		{
			Delay 2
			TeamControl
			{
				Team Malaise
				Type DoBehavior
				Behavior <<CombatOverride(Passive),Untargetable(1),Unselectable(1),Invincible(1),MoveToPos(marker:MalaiseWait),DoNotMove(1),DoNothing(Timer(1)),DoNotUseAnyPowers(1),DoAttackAI(0),CastingLawRune(Timer(10))>>
			}
		}
		Action
		{
			Delay 3
			TeamControl
			{
				Team Malaise
				Type SetHealth
				Health 1.0
			}
		}
		Action
		{
			SetScriptValue MalaiseSummonState 1
		}
		Action
		{
			SetScriptValue NightmaresPhase 1
		}
		Action
		{
			SetScriptValue Stage1-Advice-State 1
		}
		Action
		{
			Delay 10
			SetScriptValue ReadyForNextNightmare 1
			Reset Timer-WorldOfAnguish
		}
		Action
		{
			Delay 11
			SetScriptValue WorldOfAnguishState 1
		}
		Action
		{
			Delay 15
			Reset Timer-DesdemonaSpeaks
		}
		Action
		{
			Delay 16
			SetScriptValue NightmarePhase-DesdemonaSpeaks 1
		}
	}

//This is the trigger which begins World of Anguish
	Trigger Malaise-WorldOfAnguish-Start
	{
		Requires WorldOfAnguishState scriptvalue> 1 == Timer-WorldOfAnguish complete> &&

		Action
		{
			TeamControl
			{
				Team WorldOfAnguish
				Type Activate
			}
			TeamControl
			{
				Team Malaise
				Type DoBehavior
				Behavior Say(P2886892482)
			}
			Caption
			{
				Message P1355715589
			}
			Floater
			{
				Message P1312419951
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue WorldOfAnguishState 2
		}
	}

//This is the trigger which resets the World of Anguish timer for correct display within the UI.
	Trigger Malaise-WorldOfAnguish-TimerReset
	{
		Requires WorldOfAnguishState scriptvalue> 2 == Timer-WorldOfAnguish complete> &&

		Action
		{
			Reset Timer-WorldOfAnguish
		}
		Action
		{
			Delay 2
			Reset Malaise-WorldOfAnguish-TimerReset
		}
	}

//This is the trigger for Desdemona to speak after a Nightmare is summoned the first time.
	Trigger Desdemona-Speaks-FirstNightmare
	{
		Requires NightmarePhase-DesdemonaSpeaks scriptvalue> 1 == Timer-DesdemonaSpeaks complete> && NightmaresDefeated scriptvalue> 0 == &&

		Action
		{
			Caption
			{
				Message P1991402773
			}
		}
	}

