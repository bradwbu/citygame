//This trigger adds the bonus time to the clock and allows the timer to display.

	Trigger TheWell-BonusTime-Added
	{
		Requires TheWellSetBonusTime complete> TheWell-BonusTime-Set scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Adding depletable bonus time>>
			TimerControl
			{
				Timer TheWellFailureTimer
