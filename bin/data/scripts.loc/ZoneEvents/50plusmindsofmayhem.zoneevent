//This timer adds the P2677571450 time which is depletable by use of resurrection.
	Timer FinaleSetBonusTime
	{
		Duration 0:01
	}

//This timer is the failure timer for the stage.
	Timer FinaleFailureTimer
	{
		Duration 0:30
	}

//This is used to check for Dying Tilman's defeat.
	Counter DyingTilmanDefeated
	{
		Type Team
		Team TilmansMind
		Count 1
	}

//This is used to update the UI with Dying Tilman's current health.
	Counter DyingTilmanHealth
	{
		Type BossHealth
		Team TilmansMind
	}

//Award Karma for defeating a member of Mother Mayhem group (any clone).
	Objective
	{
		Type VillainGroup
		VillainGroup MotherMayhem
		KarmaValue 30
		KarmaLife 30
		TeamKarmaValue 30
		TeamKarmaLife 30
	}

//This trigger adds the bonus time to the clock and allows the timer to display.

	Trigger Finale-BonusTime-Added
	{
		Requires FinaleSetBonusTime complete> Finale-BonusTime-Set scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Adding depletable bonus time>>
			TimerControl
			{
				Timer FinaleFailureTimer
				Type Add
				Duration 2:30
			}
		}
		Action
		{
			SetScriptValue Finale-BonusTime-Set 1
		}
	}

//This trigger sets up the success condition for the stage.
	Trigger FinaleSuccess
	{
		Requires DyingTilmanDefeated complete>
	
		Action
		{
			DebugPrint <<Shalice Tilman Defeated>>
		}
		Action
		{
			Floater
			{
				Message P2251382982
				Color FF9900
			}
		}
		Action
		{
			Delay 8
			PorterControl
			{
				Porter TPTR-FinaleDone
				Type Activate
			}
		}
		Action
		{
			Reward EmpyreanMerit_MoM
		}
		NextStage RewardWinners
	}

	Trigger FinaleFailure-Timer
	{
		Requires FinaleFailureTimer complete>
	
		Action
		{
			DebugPrint <<Shalice Tilman Battle Timer Expired>>
		}
		Action
		{
			TeamControl
			{
				Team Annihilation-Finale
				Type DoBehavior
				Behavior <<UsePower("Mind_Annihilation")>>
			}
		}
		Action
		{
			Floater
			{
				Message P3568486885
				Color FF9900
			}
		}

		NextStage Failure
	}

//This is the collection of UI items for the stage.
	UICollection FinaleStage
	{
		UIItem DyingTilmanHealth
		{
			Type BarRed
			Text P3206921154
			ShortText P2229585750
			Current DyingTilmanHealth count>
			OnClickFindEnt TilmansMind
			Target 100
		}
		UIItem Morale
		{
			Type BarGold
			Text P2665463120
			ShortText P3738247573
			Current 100 DyingTilmanHealth count> - 0 60 minmax 60 / 100 *
			Target 100
		}
//		UIItem FinaleResurrectionUsed
//		{
//			Type BarGold
//			Text P1073155066
//			Current DesdemonaBlessingUsedTotal scriptvalue>
//			HideIf DesdemonaBlessingUsedTotal scriptvalue> 0 ==
//			Target 10
//		}
