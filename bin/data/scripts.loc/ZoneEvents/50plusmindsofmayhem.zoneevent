Stage Cutscene
{
	DisplayName P3657441802
	Tooltip P4015418006
	
	Startup
	{
		Action StartSetup
		{
			DebugPrint <<Starting Cutscene>>
		}
	}
	
//This timer delays the start of the cutscene a few moments.
	Timer Cutscene-Delay-Timer
	{
		Duration 00:05
	}

//This timer indicates the length of the cutscene.
	Timer Cutscene-Timer
	{
		Duration 00:64
	}

//This trigger starts the cutscene if someone in the event has never completed it.
	Trigger Cutscene-Start
	{
		Requires Cutscene-Skippable scriptvalue> 0 == Cutscene-Delay-Timer complete> &&

		Action
		{
			Reset Cutscene-Timer
		}
		Action
		{
			SetScriptValue ShowTimer 1
		}
		Action
		{
			TeamControl
			{
				Team Cutscene
				Type Activate
			}
		}
	}

//This trigger ends the stage with the cutscene if it is triggered.
	Trigger Cutscene-End
	{
		Requires Cutscene-Skippable scriptvalue> 0 == Cutscene-Timer complete> &&
		
		Action
		{
			TeamControl
			{
				Team Cutscene
				Type Deactivate
			}
		}
		
		NextStage FinalChat
	}

//This trigger skips the cutscene if everyone in the event has the badge.
	Trigger Cutscene-Skip
	{
		Requires Cutscene-Skippable scriptvalue> 1 ==

		NextStage FinalChat
	}

//This is the collection of UI items for the stage.
	UICollection CutsceneStage
	{
		UIItem CutsceneTimer-Start
		{
			Type Timer
			Timer Cutscene-Delay-Timer
			Text P1740097365
			ShortText P1436029197
			HideIf ShowTimer scriptvalue> 0 == !
		}	
		UIItem CutsceneTimer-Ongoing
		{
			Type Timer
			Timer Cutscene-Timer
			Text P2024037260
			ShortText P1049793817
			HideIf ShowTimer scriptvalue> 1 == !
		}	
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Cutscene>>
		}
	}
}

Stage FinalChat
{
	DisplayName P3657441802
	Tooltip P4051736574
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Rest Period with All NPCs>>
		}
		Action
		{
			TeamControl
			{
				Team NPC-PenelopeYin
				Type Activate
			}
			TeamControl
			{
				Team NPC-AuroraBorealis
				Type Activate
			}
			TeamControl
			{
				Team NPC-CalvinScott
				Type DoBehavior
				Behavior <<MoveToPos(marker:CalvinFinalPos),DoNothing(Timer(2)),MoveToPos(marker:CalvinFinalPos2),Surrounded>>
			}
		}
		Action
		{
			SetScriptValue CurrentStage 4
		}
		Action
		{
			SetScriptValue ResurrectionBegun 0
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsed 0
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsedTotal 0
		}
		Action
		{
			SetScriptValue FourthPortal-State 0
		}
	}

//Resurrection Event Block

//This timer hits players with a resurrection soon after a stage ends
	Timer ResurrectionRapid
	{
		Duration 00:05
	}

//This timer is the cycle time for the next resurrection.
	Timer ResurrectionCycle
	{
		Duration 00:30
	}

//This trigger hits players with a resurrection soon after a stage ends.
	Trigger ResurrectionQuickHit

		Requires ResurrectionRapid complete>

		Action
		{
			TeamControl
			{
				Team Resurrection
				Type DoBehavior
				Behavior <<UsePower("Resurrection_Simple")>>
			}
		}
	}

//This trigger continues the use of the resurrection power for this stage.
	Trigger ResurrectionContinues

		Requires ResurrectionCycle complete>

		Action
		{
			Reset ResurrectionCycle
		}
		Action
		{
			TeamControl
			{
				Team Resurrection
				Type DoBehavior
				Behavior <<UsePower("Resurrection_Simple")>>
			}
		}
		Action
		{
			Reset ResurrectionContinues
		}
	}

//End Resurrection Event Block

//This counter detects when players have entered Tilman's Sanctum area.
	Counter PlayersInFinalRoom
	{
		Type ZEPlayers
		VolumeName PlayersInWell
	}

//This timer determines when the Desdemona will begin to open the fourth portal into the Seer Network.
	Timer FourthPortal-Timer
	{
		Duration 00:08
	}

//This trigger tells Desdemona to start opening the fourth portal.
	Trigger FourthPortal-Start
	{
		Requires ScriptStageFourBattleStart objectivesucceeded> FourthPortal-State scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 4: Desdemona begins to open portal to The Well.>>
		}
		Action
		{
			Reset FourthPortal-Timer
		}
		Action
		{
			TeamControl
			{
				Team NPC-Desdemona
				Type DoBehavior
				Behavior <<MoveToPos(marker:FourthPortalOpening-Des),Casting_Shield(Timer(6)),MoveToPos(marker:NPC-Desdemona)>>
			}
			TeamControl
			{
				Team NPC-PenelopeYin
				Type DoBehavior
				Behavior <<MoveToPos(marker:FourthPortalOpening-PY),Casting_Shield(Timer(6)),MoveToPos(marker:NPC-PenelopeYin)>>
			}
			TeamControl
			{
				Team NPC-AuroraBorealis
				Type DoBehavior
				Behavior <<MoveToPos(marker:FourthPortalOpening-AB),Casting_Shield(Timer(6)),MoveToPos(marker:NPC-AuroraBorealis)>>
			}
		}
		Action
		{
			Delay 1
			SetScriptValue FourthPortal-State 1
		}
	}

//This trigger informs players when the fourth portal is opened.
	Trigger FourthPortal-Open
	{
		Requires FourthPortal-Timer complete> FourthPortal-State scriptvalue> 1 == &&

		Action
		{
			DebugPrint <<Stage 4: Desdemona opens portal to The Well.>>
		}		
		Action
		{
			SetScriptValue FourthPortal-State 2
		}
		Action
		{
			TeamControl
			{
				Team Portal-Final
				Type Activate
			}
			PorterControl
			{
				Porter TPTR-TheWell
				Type Activate
			}
		}
		Action
		{
			Floater
			{
				Message P1053444195
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Delay 3
			Floater
			{
				Message P718515417
				Color FF9900
				AlertType PriorityAlert
			}
		}
	}

