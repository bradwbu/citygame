//Karma Objectives for Stage 1
//

//Award Karma for defeating a member of Mother Mayhem group (any clone).
	Objective
	{
		Type VillainGroup
		VillainGroup MotherMayhem
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}

//Award Karma for defeating a member of the Malaise group (any Nightmare).
	Objective
	{
		Type VillainGroup
		VillainGroup Malaise
		KarmaValue 30
		KarmaLife 60
		TeamKarmaValue 30
		TeamKarmaLife 60
	}

//Award Karma for chasing Malaise away.
