			Type Timer
			Timer FourthPortal-Timer
			Text P4279111462
			ShortText P1383531207
			HideIf FourthPortal-State scriptvalue> 1 == !
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Rest Period with All NPCs>>
		}
	}
}

Stage TheWell
{
	DisplayName P2111938672
	Tooltip P3847774560

	AwardKarma
	KarmaThreshold 10	

//Start New Failsafe Block

	Counter ZonePlayers
        {
                Type ZEPlayers
        }
        Counter ZonePlayersAlive
        {
                Type ZEPlayersAlive
        }
        Counter ZonePlayersActive
        {
                Type ZEPlayersActive
        }
	Counter FailsafePlayersAlive
	{
		Type ZEPlayersAlive
	}
	Counter FailsafePlayersPhased
	{
		Type ZEPlayersPhased
	}
	Timer FailsafeDelay
	{
		Duration 1:00
	}
	Timer FailsafeLongDelay
	{
		Duration 1:00
	}

	//Trigger the failsafe for an unlocked league if the number of players is less than 2.
	Trigger FailsafeStart
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeStart
		{
			DebugPrint <<Starting Failsafe countdown for unlocked league>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the failsafe for a locked league if the number of players is less than 4 and the event is an 8-16 player event.
	Trigger FailsafeStart-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 8>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Eight
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}
	
	//Trigger the failsafe for a locked league if the number of players is less than 6 and the event is a 12-24 player event.
	Trigger FailsafeStart-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 12>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Twelve
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the end of the failsafe for an unlocked league after 15s if it still has less than 2 players.
	Trigger FailsafeConclude
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 1 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 4 players in an 8 player event.
	Trigger FailsafeConclude-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 6 players in an 12 player event.
	Trigger FailsafeConclude-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 2 before the 15s timer ends.
	Trigger FailsafeReset
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 > FailsafeInProcess scriptvalue> 1 == && eventLockedByGroup? ! && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart 
			Reset FailsafeReset
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 4 before the 15s timer ends.
	Trigger FailsafeReset-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Eight 
			Reset FailsafeReset-LockedTeam-Eight 
			Reset FailsafeDelay 
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 6 before the 60s timer ends.
	Trigger FailsafeReset-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Twelve 
			Reset FailsafeReset-LockedTeam-Twelve 
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

//End New Failsafe Block	

	StartUp
	{
		Action
		{
			DebugPrint <<Starting Boss Fight with Mother Malaise>>
		}
		Action
		{
			PlaySound
			{
				Sound i20_03High_a_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			TeamControl
			{
				Team MotherMalaise
				Type Activate
			}
		}
		Action
		{
			SetScriptValue ShaliceTilmanState 0
		}
		Action
		{
			SetScriptValue ShaliceTilmanPresent 0
		}
		Action
		{
			SetScriptValue FinaleCountdown 0
		}
		Action
		{
			SetScriptValue WorldOfAnguishState 1
		}
		Action
		{
			SetScriptValue ResurrectionBegun 0
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsed 0
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsedTotal 0
		}
		Action
		{
			SetScriptValue TheWell-BonusTime-Set 0
		}
	}

//Resurrection Event Block

//This timer is the delay before the first resurrection begins.
	Timer ResurrectionDelay
	{
		Duration 00:15
	}

//This timer is the cycle time for the next resurrection.
	Timer ResurrectionCycle
	{
		Duration 00:30
	}

//This trigger starts the resurrection power for this stage.
	Trigger ResurrectionBegins
	{
		Requires ResurrectionDelay complete> ResurrectionBegun scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P3871633027
				Color FF9900
			}
		}
		Action
		{
			TeamControl
			{
				Team Resurrection
				Type DoBehavior
				Behavior <<UsePower("Resurrection")>>
			}
		}
		Action
		{
			SetScriptValue ResurrectionBegun 1
		}
		Action
		{
			Reset ResurrectionCycle
		}
	}

//This trigger continues the use of the resurrection power for this stage.
	Trigger ResurrectionContinues

		Requires ResurrectionCycle complete> ResurrectionBegun scriptvalue> 1 == &&

		Action
		{
			Reset ResurrectionCycle
		}
		Action
		{
			TeamControl
			{
				Team Resurrection
				Type DoBehavior
				Behavior <<UsePower("Resurrection")>>
			}
		}
		Action
		{
			Reset ResurrectionContinues
		}
	}

//This trigger depletes the stage timer if the resurrection is used.
	Trigger ResurrectionDepletion
	{
		Requires ResurrectionBegun scriptvalue> 1 == DesdemonaBlessingUsed scriptvalue> 0 > &&
	
		Action
		{
			DebugPrint <<Resurrection Used. Depleting The Well Stage Timer by 15 seconds.>>
		}
		Action
		{
			TimerControl
			{
				Timer TheWellFailureTimer
				Type Subtract
				Duration 00:15
			}
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsed DesdemonaBlessingUsed scriptvalue> 1 -
		}
		Action
		{
			Reset ResurrectionDepletion
		}
	}

//End Resurrection Event Block
	Timer Timer-WorldOfAnguish
	{
		Duration 00:30
	}

//This is the trigger which begins World of Anguish
	Trigger Malaise-WorldOfAnguish-Start
	{
		Requires WorldOfAnguishState scriptvalue> 1 == Timer-WorldOfAnguish complete> &&

		Action
		{
			TeamControl
			{
				Team WorldOfAnguishMini
				Type Activate
			}
			Floater
			{
				Message P1312419951
				Color FF0000
				AlertType PriorityAlert
			}
		}
		Action
		{
			SetScriptValue WorldOfAnguishState 2
		}
	}

//This is the trigger which resets the World of Anguish timer for correct display within the UI.
	Trigger Malaise-WorldOfAnguish-TimerReset
	{
		Requires WorldOfAnguishState scriptvalue> 2 == Timer-WorldOfAnguish complete> &&

		Action
		{
			Reset Timer-WorldOfAnguish
		}
		Action
		{
			Reset Malaise-WorldOfAnguish-TimerReset
		}
	}

//This is the trigger that suppresses World of Anguish when Malaise is not fighting the players
	Trigger Malaise-WorldOfAnguish-Suppress
	{
		Requires ShaliceTilmanPresent scriptvalue> 0 > WorldOfAnguishState scriptvalue> 3 == ! &&

		Action
		{
			SetScriptValue WorldOfAnguishState 3
		}
		Action
		{
			TeamControl
			{
				Team WorldOfAnguishMini
				Type Deactivate
			}
		}
		Action
		{
			Reset Malaise-WorldOfAnguish-Suppress
		}
	}

//This is the trigger that re-enables the World of Anguish when Malaise fights the players again
	Trigger Malaise-WorldOfAnguish-Reenable
	{
		Requires ShaliceTilmanPresent scriptvalue> 0 == WorldOfAnguishState scriptvalue> 3 == &&

		Action
		{
			SetScriptValue WorldOfAnguishState 2
		}
		Action
		{
			TeamControl
			{
				Team WorldOfAnguishMini
				Type Activate
			}
		}
		Action
		{
			Reset Timer-WorldOfAnguish
		}
		Action
		{
			Reset Malaise-WorldOfAnguish-Reenable
			Reset Malaise-WorldOfAnguish-Suppress
		}
	}


//This timer adds the P2677571450 time which is depletable by use of resurrection.
