				Type Activate
			}
			TeamControl
			{
				Team CloneArmy-Stage1-B
				Type Activate
			}
			TeamControl
			{
				Team CloneArmy-Stage1-C
				Type Activate
			}
			TeamControl
			{
				Team CloneArmy-Stage1-D
				Type Activate
			}
			TeamControl
			{
				Team CloneArmy-Stage1-E
				Type Activate
			}
			TeamControl
			{
				Team CloneArmy-Stage1-F
				Type Activate
			}
		}
		Action
		{
			SetScriptValue NightmaresPhase 0
		}
		Action
		{
			SetScriptValue MalaiseSummonState 0
		}
		Action
		{
			SetScriptValue NightmaresDefeated 0
		}
		Action
		{
			SetScriptValue ResurrectionBegun 0
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsed 0
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsedTotal 0
		}
		Action
		{
			SetScriptValue Malaise-BonusTime-Set 0
		}
		Action
		{
			SetScriptValue ReadyForNextNightmare 0
		}
		Action
		{
			SetScriptValue Stage1-Advice-State 0
		}
	}

//Resurrection Event Block

//This timer is the delay before the first resurrection begins.
	Timer ResurrectionDelay
	{
		Duration 00:15
	}

//This timer is the cycle time for the next resurrection.
	Timer ResurrectionCycle
	{
		Duration 00:30
	}

//This trigger starts the resurrection power for this stage.
	Trigger ResurrectionBegins
	{
		Requires ResurrectionDelay complete> ResurrectionBegun scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P3871633027
				Color FF9900
			}
		}
		Action
		{
			TeamControl
			{
				Team Resurrection
				Type DoBehavior
				Behavior <<UsePower("Resurrection")>>
			}
		}
		Action
		{
			SetScriptValue ResurrectionBegun 1
		}
		Action
		{
			Reset ResurrectionCycle
		}
	}

//This trigger continues the use of the resurrection power for this stage.
	Trigger ResurrectionContinues

		Requires ResurrectionCycle complete> ResurrectionBegun scriptvalue> 1 == &&

		Action
		{
			Reset ResurrectionCycle
		}
		Action
		{
			TeamControl
			{
				Team Resurrection
				Type DoBehavior
				Behavior <<UsePower("Resurrection")>>
			}
		}
		Action
		{
			Reset ResurrectionContinues
		}
	}

//This trigger depletes the stage timer if the resurrection is used.
	Trigger ResurrectionDepletion
	{
		Requires ResurrectionBegun scriptvalue> 1 == DesdemonaBlessingUsed scriptvalue> 0 > &&
	
		Action
		{
			DebugPrint <<Resurrection Used. Depleting Malaise Stage Timer by 15 seconds.>>
		}
		Action
		{
			TimerControl
			{
				Timer MalaiseFailureTimer
				Type Subtract
				Duration 00:15
			}
		}
		Action
		{
			SetScriptValue DesdemonaBlessingUsed DesdemonaBlessingUsed scriptvalue> 1 -
		}
		Action
		{
			Reset ResurrectionDepletion
		}
	}

//End Resurrection Event Block

//This timer adds the P2677571450 time which is depletable by use of resurrection.
	Timer MalaiseSetBonusTime
	{
		Duration 0:01
	}

//This timer is the failure timer for the stage.
	Timer MalaiseFailureTimer
	{
		Duration 5:00
	}

//This timer prevents the start of the Nightmare phase immediately, to allow the health counter to properly update.
	Timer MalaiseHealthDelayTimer
	{
		Duration 00:15
	}

//This timer indicates when World of Anguish will begin after the first Nightmare appears.
	Timer Timer-WorldOfAnguish
	{
		Duration 00:30
	}

//This timer indicates when Desdemona will speak after each Nightmare is summoned.
	Timer Timer-DesdemonaSpeaks
	{
		Duration 00:15
	}

