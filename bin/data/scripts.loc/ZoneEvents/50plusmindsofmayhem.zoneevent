Stage Desdemona
{
	DisplayName P3657441802
	Tooltip P2500667920
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Rest Period with Desdemona>>
		}
		Action
		{
			TeamControl
			{
				Team NPC-Desdemona
				Type Activate
			}
			TeamControl
			{
				Team Annihilation-Malaise
				Type Activate
			}
			TeamControl
			{
				Team Annihilation-Penelope
				Type Activate
			}
			TeamControl
			{
				Team Annihilation-Aurora
				Type Activate
			}
			TeamControl
			{
				Team Annihilation-TheWell
				Type Activate
			}
			TeamControl
			{
				Team Annihilation-Finale
				Type Activate
			}
			TeamControl
			{
				Team Resurrection
				Type Activate
			}
