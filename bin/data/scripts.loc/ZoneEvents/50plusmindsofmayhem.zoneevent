//Karma objectives for stage 3

//Award Karma for defeating a member of Mother Mayhem group (any clone).
	Objective
	{
		Type VillainGroup
		VillainGroup MotherMayhem
		KarmaValue 30
		KarmaLife 30
		TeamKarmaValue 30
		TeamKarmaLife 30
	}

//Award Karma for defeating a member of Malaise group (any nightmare).
