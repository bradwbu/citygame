//Start Warmth Spawn Block

	Trigger WarmthBuffActivation
	{
		Requires eventLockedByGroup? ! WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Granted>>
			SetScriptValue WarmthBuffSpawned 1
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team WarmthBuff
			}
		}
		Action
		{
			Floater
			{
				Message P1172875117
				Color FF9900
			}
		}
	}

	Trigger WarmthBuffBlocked
	{
		Requires eventLockedByGroup? WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Disabled>>
			SetScriptValue WarmthBuffSpawned 1
		}
	}

//End Warmth Spawn Block

//This counter detects when players have entered the 21st room of the complex.
	Counter PlayersInMalaiseRoom
	{
		Type ZEPlayers
		VolumeName TPTR-MalaiseDone
	}

//This timer determines when the Desdemona will begin to open the first portal into the Seer Network.
	Timer FirstPortal-Timer
	{
		Duration 00:08
	}

//This trigger tells Desdemona to start opening the first portal.
	Trigger FirstPortal-Start
	{
		Requires ScriptStageOneBattleStart objectivesucceeded> FirstPortal-State scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Stage 1: Desdemona begins to open portal to Malaise.>>
		}
		Action
		{
			Reset FirstPortal-Timer
		}
		Action
		{
			TeamControl
			{
				Team NPC-Desdemona
				Type DoBehavior
				Behavior <<MoveToPos(marker:FirstPortalOpening),Casting_Shield(Timer(6)),MoveToPos(marker:NPC-Desdemona)>>
			}
		}
		Action
		{
			Delay 1
			SetScriptValue FirstPortal-State 1
		}
	}

//This trigger informs players when the first portal is opened.
	Trigger FirstPortal-Open
	{
		Requires FirstPortal-Timer complete> FirstPortal-State scriptvalue> 1 == &&

		Action
		{
			DebugPrint <<Stage 1: Desdemona opens portal to Malaise.>>
		}		
		Action
		{
			SetScriptValue FirstPortal-State 2
		}
		Action
		{
			TeamControl
			{
				Team Portal-Malaise
				Type Activate
			}
			PorterControl
			{
				Porter TPTR-Malaise
				Type Activate
			}
		}
		Action
		{
			Floater
			{
				Message P255192904
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Delay 3
			Floater
			{
				Message P718515417
				Color FF9900
				AlertType PriorityAlert
			}
		}
	}

//This trigger sets up the success condition for the stage.
	Trigger DesdemonaSuccess
	{
		Requires PlayersInMalaiseRoom count> 1 >=
	
		Action
		{
			DebugPrint <<Portal to Malaise's Lair Entered>>
		}

		NextStage Malaise
	}

//This is the collection of UI items for the stage.
	UICollection DesdemonaStage
	{
		UIItem Stage1-SpeakToDesdemona
		{
			Type CenterText
			Text P4248609063
			HideIf FirstPortal-State scriptvalue> 0 >
		}
		UIItem MalaisePortalOpened
		{
			Type CenterText
			Text P2143884306
			ShortText P3290270427
			HideIf FirstPortal-State scriptvalue> 2 <
		}
		UIItem MalaiseCountdownToPortal
		{
			Type Timer
			Timer FirstPortal-Timer
			Text P4279111462
			ShortText P1383531207
			HideIf FirstPortal-State scriptvalue> 1 == !
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Rest Period with Desdemona>>
		}
	}
}

Stage Malaise
{
	DisplayName P3768984351
	Tooltip P4010902313

	AwardKarma
	KarmaThreshold 10	

//Start New Failsafe Block

	Counter ZonePlayers
        {
                Type ZEPlayers
        }
        Counter ZonePlayersAlive
        {
                Type ZEPlayersAlive
        }
        Counter ZonePlayersActive
        {
                Type ZEPlayersActive
        }
	Counter FailsafePlayersAlive
	{
		Type ZEPlayersAlive
	}
	Counter FailsafePlayersPhased
	{
		Type ZEPlayersPhased
	}
	Timer FailsafeDelay
	{
		Duration 1:00
	}
	Timer FailsafeLongDelay
	{
		Duration 1:00
	}

	//Trigger the failsafe for an unlocked league if the number of players is less than 2.
	Trigger FailsafeStart
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeStart
		{
			DebugPrint <<Starting Failsafe countdown for unlocked league>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the failsafe for a locked league if the number of players is less than 4 and the event is an 8-16 player event.
	Trigger FailsafeStart-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 8>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Eight
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}
	
	//Trigger the failsafe for a locked league if the number of players is less than 6 and the event is a 12-24 player event.
	Trigger FailsafeStart-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 12>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Twelve
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the end of the failsafe for an unlocked league after 15s if it still has less than 2 players.
	Trigger FailsafeConclude
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 1 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 4 players in an 8 player event.
	Trigger FailsafeConclude-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 6 players in an 12 player event.
	Trigger FailsafeConclude-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 2 before the 15s timer ends.
	Trigger FailsafeReset
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 > FailsafeInProcess scriptvalue> 1 == && eventLockedByGroup? ! && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart 
			Reset FailsafeReset
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 4 before the 15s timer ends.
	Trigger FailsafeReset-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Eight 
			Reset FailsafeReset-LockedTeam-Eight 
			Reset FailsafeDelay 
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 6 before the 60s timer ends.
	Trigger FailsafeReset-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Twelve 
			Reset FailsafeReset-LockedTeam-Twelve 
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

//End New Failsafe Block

	StartUp
	{
		Action
		{
			DebugPrint <<Starting Boss Fight with Malaise>>
		}
		Action
		{
			PlaySound
			{
				Sound i20_02High_a_Loop
