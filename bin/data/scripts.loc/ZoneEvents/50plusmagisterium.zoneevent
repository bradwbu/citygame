//Award Karma for defeating a member of the Chimera team.
	Objective
	{
		Type Team
		Team Chimera
		KarmaValue 30
		KarmaLife 60
		TeamKarmaValue 30
		TeamKarmaLife 60
	}

//This is the timer which counts towards the stage's P1354651601.
	Timer RoyaleEnrage-Timer
	{
		Duration 12:00
	}

//This is the timer for Triple Threat.
	Timer TripleThreatCheck-Timer
	{
		Duration 00:06
	}

//This is used to update the UI as to Chimera's current health.
	Counter ChimeraHealth
	{
		Type BossHealth
		Team Chimera
	}

//This is used to update the UI as to Shadowhunter's current health.
	Counter ShadowhunterHealth
	{
		Type BossHealth
		Team Shadowhunter
	}

//This is used to update the UI as to Pendragon's current health.
	Counter PendragonHealth
	{
		Type BossHealth
		Team Pendragon
	}

//This is used to keep track of the defeat of Chimera.
	Counter ChimeraDefeated
	{
		Type Name
		Name Chimera_P_Endgame_Chimera
		Direction Up
		Count 1
	}

//This is used to keep track of the defeat of the Shadowhunter.
	Counter ShadowhunterDefeated
	{
		Type Name
		Name Shadowhunter_P_Endgame_Shadowhunter
		Direction Up
		Count 1
	}

//This is used to keep track of the defeat of Pendragon.
	Counter PendragonDefeated
	{
		Type Name
		Name BlackKnights_P_Endgame_Pendragon
		Direction Up
		Count 1
	}

//This trigger activates Chimera's Dead Man's Switch.
	Trigger Minelayers
	{
		Requires ChimeraDefeated complete>
	
		Action
		{
			DebugPrint <<Chimera Defeated.  Enabling Minelayers>>
		}
		Action
		{
			TeamControl
			{
				Team Minelayer
				Type Activate
			}
		}
		Action
		{
			Floater Minelayer
			{
			Message P2700640
			Color FF0000
			}
		}
	}

//This trigger activates Pendragon's post-death Excalibur rain.
	Trigger Excalibur
	{
		Requires PendragonDefeated complete>
	
		Action
		{
			DebugPrint <<Pendragon Defeated.  Enabling Excalibur bombs>>
		}
		Action
		{
			TeamControl
			{
				Team Excalibur
				Type Activate
			}
		}
		Action
		{
			Floater Excalibur
			{
			Message P2755489639
			Color FF0000
			}
		}
	}

//This trigger displays a float for Shadowhunter's post-death mechanic.
	Trigger Banish
	{
		Requires ShadowhunterDefeated complete>
	
		Action
		{
			DebugPrint <<Shadowhunter Defeated.  Triggering display floater.>>
		}
		Action
		{
			Floater Excalibur
			{
			Message P2907200248
			Color FF0000
			}
		}
	}

//This trigger starts the triple threat counter when one boss dies.
	Trigger TripleThreatTimerStart
	{
		Requires ChimeraDefeated complete> ShadowhunterDefeated complete> || PendragonDefeated complete> ||
	
		Action
		{
			Log <<First AV Defeated. Starting Triple Threat timer.>>
			Reset TripleThreatCheck-Timer
		}
	}

//This trigger sets up the success condition for the event after earning Triple Threat.
	Trigger TripleThreat
	{
		Requires ChimeraDefeated complete> ShadowhunterDefeated complete> && PendragonDefeated complete> && TripleThreatCheck-Timer complete> ! &&
	
		Action
		{
			DebugPrint <<All AVs Defeated.>>
		}
		Action
		{
			TeamControl
			{
				Team Minelayer
				Type Deactivate
			}
			TeamControl
			{
				Team Excalibur
				Type Deactivate
			}
			SetScriptValue TripleThreatCheck 1
			Log  <<Triple Threat earned!>>
		}

		NextStage BattleRoyale-Recovery
	}

//This trigger sets up the success condition for the event while not earning Triple Threat.
	Trigger Success
	{
		Requires ChimeraDefeated complete> ShadowhunterDefeated complete> && PendragonDefeated complete> && TripleThreatCheck-Timer complete> &&
	
		Action
		{
			DebugPrint <<All AVs Defeated.>>
		}
		Action
		{
			TeamControl
			{
				Team Minelayer
				Type Deactivate
			}
			TeamControl
			{
				Team Excalibur
				Type Deactivate
			}
		Log <<Triple Threat not earned.>>
		}

		NextStage BattleRoyale-Recovery
	}


//This trigger sets up the success condition for the event.
	Trigger Fail
	{
		Requires ChimeraDefeated complete> ShadowhunterDefeated complete> && ! RoyaleEnrage-Timer complete> &&
	
		Action
		{
			DebugPrint <<You are defeated!>>
		}
		NextStage Failure
	}

//This is the collection of UI items for the stage.
	UICollection BattleRoyale
	{
		UIItem ChimeraHealthBar
		{
			Type BarRed
			Text P2542502378
			ShortText P3579301328
			Current ChimeraHealth count>
			HideIf ChimeraHealth count> 0 <=
			OnClickFindEnt Chimera
			Target 100
		}
		UIItem ShadowhunterHealthBar
		{
			Type BarRed
			Text P1425521178
			ShortText P3150862942
			HideIf ShadowhunterHealth count> 0 <=
			Current ShadowhunterHealth count>
			OnClickFindEnt Shadowhunter
			Target 100
		}
		UIItem PendragonHealthBar
		{
			Type BarRed
			Text P1160477472
			ShortText P1519520205
			HideIf PendragonHealth count> 0 <=
			Current PendragonHealth count>
			OnClickFindEnt Pendragon
			Target 100
		}
		UIItem PendragonAbsorbBar
		{
			Type BarGold
			Text P1871976773
			ShortText P1971123771
			HideIf PendragonHealth count> 0 <= PendragonAbsorb scriptvalue> 0 <= ||
			Current PendragonAbsorb scriptvalue> 9203 / 100 *
			Target 100
		}
		UIItem PendragonRageBar
		{
			Type BarBlue
			Text P1998231305
			ShortText P2490720293
			HideIf PendragonHealth count> 0 <=
			Current PendragonRage scriptvalue>
			Target 100
		}
		UIItem EnrageTimer
		{
			Type Timer
			Timer RoyaleEnrage-Timer
			Text P3649598134
			ShortText P3097074627
		}
		UIItem Stage1-Tip1
		{
			Type CenterText
			Text P3952926581
		}
		UIItem Stage1-Tip2
		{
			Type CenterText
			Text P4227994937
			HideIf ShadowhunterHealth count> 0 <=
		}
		UIItem Stage1-Tip3
		{
			Type CenterText
			Text P2876098752
			HideIf ChimeraHealth count> 0 <=
		}
		UIItem Stage1-Tip4
		{
			Type CenterText
			Text P1132614831
			HideIf PendragonHealth count> 0 <=
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage BattleRoyale>>

		}
	}
}

