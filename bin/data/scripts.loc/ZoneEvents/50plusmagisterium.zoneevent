	{
		Type Name
		Name BlackSwan_P_Endgame_BlackSwan
		Direction Up
		Count 1
	}

//This counter tracks the number of Portals present within the event
	Counter PortalsPresent
	{
		Type Name
		Name BlackSwan_Portal
		Direction Down
		Count 0
	}

//This trigger resets the Quills timer.
	Trigger QuillsUseTimer-Trigger
	{
		Requires QuillsTimerReset scriptvalue> 1 ==
		Action
		{
			SetScriptValue QuillsTimerReset 0
			Reset QuillsUseTimer-Trigger
			Reset QuillsUseTimer-Timer
		}
	}

//This trigger sets the script value for Shadow Master.
	Trigger ShadowMaster-Trigger-Failure
	{
		Requires PortalsPresent count> 6 >=
		Action
		{
			Log <<Six portals spawned, Shadow Master not granted.>>
			SetScriptValue ShadowMasterCheck 1
		}
	}


//This trigger sets the script value for Ready to Rumble.
	Trigger ReadyToRumble-Trigger-Success
	{
		Requires BlackSwanDefeated complete> ReadyToRumble-Timer complete> ! &&
		Action
		{
			SetScriptValue ReadyToRumbleCheck 1
		}
		Action
		{
			Log <<Black Swan Defeated, Ready to Rumble earned.>>
		}

		NextStage Cutscene
	}

//This trigger sets up the success condition for the event.
