Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Stage Reward Winners Initialized...>>
		}
		Action
		{
			SetScriptValue OpenLeagueAward 0
		}
	}
	Trigger AwardBadge-Completion
	{
		Action
		{
			Log <<Awarding Magisterium Completion Badge>>
			Reward IT_MAG_Complete
		}
	}
	Trigger AwardBadge-TripleThreat
	{
		Requires TripleThreatCheck scriptvalue> 1 ==
		Action
		{
			Log <<Awarding Triple Threat Badge>>
			Reward IT_MAG_Challenge1
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-ReadyToRumble
	{
		Requires ReadyToRumbleCheck scriptvalue> 1 ==
		Action
		{
			Log <<Awarding Ready to Rumble Badge>>
			Reward IT_MAG_Challenge2
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-ShadowMaster
	{
		Requires ShadowMasterCheck scriptvalue> 1 == !
		Action
		{
			Log <<Awarding Shadow Master Badge>>
			Reward IT_MAG_Challenge3
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardMerit-OpenLeague
	{
		Requires eventLockedByGroup? ! OpenLeagueAward scriptvalue> 0 == &&

		Action
		{
			Log <<Bonus Merit for an Open League Awarded>>
			SetScriptValue OpenLeagueAward 1
		}
		Action
		{
			Reward AstralMerit1
		}
	}	
	Trigger End
	{
		NextStage Stop
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Stage Reward Winners Completed...>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					NumStagesRequired 2
					RewardTable Issue20EndKarma1
				}
				Reward class2
				{
					PercentileNeeded 0.00
					NumStagesRequired 3
					PointsNeeded 10
					RewardTable is.Issue2150EndKarma1Plus
				}
			}
		}
	}
}

