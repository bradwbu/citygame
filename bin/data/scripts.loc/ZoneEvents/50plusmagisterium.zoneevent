	{
		Requires BlackSwanDefeated complete> ReadyToRumble-Timer complete> &&
	
		Action
		{
			DebugPrint <<Black Swan Defeated.>>
		}

		NextStage Cutscene
	}


//This trigger sets up the fail condition for the event.
	Trigger Fail
	{
		Requires BlackSwanDefeated complete> ! BlackSwanEnrage-Timer complete> &&
	
		Action
		{
			DebugPrint <<You are defeated!>>
		}
		NextStage Failure
	}

