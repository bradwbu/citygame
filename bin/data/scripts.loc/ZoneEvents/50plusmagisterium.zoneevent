		{
			SetScriptValue LightTimerReset 0
		}
		Action
		{
			SetScriptValue StagePostNuke 1
		}
		Action
		{
			PlaySound
			{
				Sound i20_02High_a_Loop
				Channel Music
				VolumeLevel 1
			}
		}
	}

//Award Karma for defeating a member of the Tyrant villain group.
	Objective
	{
		Type VillainGroup
		VillainGroup Tyrant
		KarmaValue 15
		KarmaLife 30
		TeamKarmaValue 15
		TeamKarmaLife 30
	}

//Award Karma for defeating a member of the SoulPortal team.
	Objective
	{
		Type Team
		Team SoulPortal
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}

//This is the timer which counts towards the stage's P1354651601.

	Timer Tyrant2Enrage-Timer
	{
		Duration 20:00
	}

//This is the timer which Prevents Tyrant from speaking all his dialogue instantly.

	Timer Tyrant2SpeechDelay-Timer
	{
		Duration 0:05
	}

//This is the timer which updates the number of Lights alive in the scriptvalue used for level shifting.
	Timer LightsReset-Timer
	{
		Duration 0:01
	}

//This is the timer which updates the number of Lights alive in the scriptvalue used for level shifting.
	Timer LightsSpawnTimer-Timer
	{
		Duration 0:40
	}

//This is the timer which prevents instantaneous completion.
	Timer SuccessDelay-Timer
	{
		Duration 0:10
	}

//This is used to update the UI as to Tyrant's current health.
	Counter Tyrant2Health
	{
		Type BossHealth
		Team Tyrant2
	}

//This is used to keep track of the defeat of Tyrant.
	Counter Tyrant2Defeated
	{
		Type Name
		Name Tyrant_P_Endgame_Tyrant_02
		Direction Up
		Count 1
	}
//This is used to keep track of the number of Lights.
	Counter LightsAlive
	{
		Type Name
		Name Tyrant_Light_of_the_Well
		Direction Down
		Count 0
	}

//This is used to keep track of the number of Lights that have been defeated.
	Counter LightsKilled
	{
		Type Name
		Name Tyrant_Light_of_the_Well
		Direction Up
		Count 13
	}

//This is used to keep track of The Really Hard Way.
	Counter AnyLightsKilled
	{
		Type Name
		Name Tyrant_Light_of_the_Well
		Direction Up
		Count 1
	}

//This trigger sets the Script Value for the number of living Lights.
	Trigger LightsSZE
	{
		Requires LightsReset-Timer complete>
	
		Action
		{
			SetScriptValue LivingLights 6 LightsAlive count> -
		}
		Action
		{
			Reset LightsReset-Timer
			Reset LightsSZE
		}
	}

//This trigger resets the Soul Portal.
	Trigger LightsSpawnTimer-Trigger
	{
		Requires LightTimerReset scriptvalue> 1 ==
		Action
		{
			SetScriptValue LightTimerReset 0
			Reset LightsSpawnTimer-Trigger
			Reset LightsSpawnTimer-Timer
		}
	}

//This trigger gives Tyrant something to say as he is battled by players. It hits at 50%.
	Trigger TyrantBigBattle-CaptionAt-50
	{
		Requires Tyrant2Health count> 50 < Tyrant2SpeechDelay-Timer complete> &&

		Action
		{
			TeamControl
			{
				Team Tyrant2
				Type DoBehavior
				Behavior Say(P1320018072)
			}
		}
	}

//This trigger sets up the success condition for the event.
	Trigger ReallyHardWay
	{
		Requires Tyrant2Health count> 10 <= SuccessDelay-Timer complete> && AnyLightsKilled complete> ! &&
	
		Action
		{
			DebugPrint <<Tyrant Defeated.>>
		}
		Action
		{
			Log <<The Really Hard Way challenge succeeded.>>
		}
		Action
		{
			Log <<Awarding The Really Hard Way Badge.  This league has beaten the game.>>
			Reward IT_MAG_EpicChallenge
		}
		Action
		{
			Reward EmpyreanMerit2
		}
		Action
		{
			Log <<Awarding The Hard Way Badge>>
			Reward IT_MAG_Challenge4
		}
		Action
		{
			Reward AstralMerit1
		}
		NextStage PostNuke-Recovery
	}

//This trigger sets up the success condition for the event.
	Trigger HardWay
	{
		Requires Tyrant2Health count> 10 <= SuccessDelay-Timer complete> && LightsKilled complete> ! && AnyLightsKilled complete> &&
	
		Action
		{
			DebugPrint <<Tyrant Defeated.>>
		}
		Action
		{
			Log <<Hard Way challenge succeeded.>>
		}
		Action
		{
			Log <<Awarding The Hard Way Badge>>
			Reward IT_MAG_Challenge4
		}
		Action
		{
			Reward AstralMerit1
		}

		NextStage PostNuke-Recovery
	}

//This trigger sets up the success condition for the event.
	Trigger Success
	{
		Requires Tyrant2Health count> 10 <= SuccessDelay-Timer complete> &&  LightsKilled complete> && AnyLightsKilled complete> &&
	
		Action
		{
			DebugPrint <<Tyrant Defeated.>>
			Log <<Hard Way challenge failed.>>
		}

		NextStage PostNuke-Recovery
	}


//This trigger sets up the fail condition for the event.
	Trigger Fail
	{
		Requires Tyrant2Defeated complete> ! Tyrant2Enrage-Timer complete> &&
	
		Action
		{
			DebugPrint <<You are defeated!>>
		}
		NextStage Failure
	}

//This is the collection of UI items for the stage.
	UICollection PostNuke
	{
		UIItem TyrantHealthBar
		{
			Type BarRed
			Text P2289510126
			ShortText P2839932528
			Current Tyrant2Health count>
			OnClickFindEnt Tyrant2
			Target 100
		}
		UIItem TyrantRegenBar
		{
			Type BarGold
			Text P3700690094
			ShortText P3803857980
