// Disable Spawns: All
		Action
		{
			TeamControl
			{
				TeamGroup All
				Type Deactivate
			}
		}
		Action ShutDownInstancedEvent
	        {
			TrialComplete Success
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 2
			}
		}
	}
	Trigger Never
	{
		Requires 0
	}
	ShutDown
	{
