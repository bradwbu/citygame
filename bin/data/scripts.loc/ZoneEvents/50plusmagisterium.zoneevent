Stage Approach
{
	DisplayName P3282363411
	Tooltip P2148775081
	
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage Approach>>
		}
		Action
		{
			SetScriptValue RetreatStarted 0
		}
		Action
		{
			TeamControl
			{
				Team IDF-Guards-Plaza-Initial
				Type Activate
			}
			TeamControl
			{
				Team NPC-DreamDoctor
				Type Activate
			}
			TeamControl
			{
				Team NPC-DominatrixDimensional
				Type Activate
			}
			TeamControl
			{
				Team NPC-Desdemona
				Type Activate
			}
			TeamControl
			{
				Team NPC-Mistress
				Type Activate
			}
		}
		Action
		{
			GurneyControl
			{
				Gurney PreNukeHosp
				Type Activate
			}
		}
		Action
		{
			GurneyControl
			{
				Gurney PostNukeHosp
				Type DeActivate
			}
		}
	}

//This is used to keep track of the number of IDF defeated in the UI.

	Counter Approach-Defeats
	{
		Type Team
		Team IDF-Guards-Plaza
		Count 250
	}

//Counters - Volume Entry for Retreat Trigger
	Counter PlayersInFrontVolume
	{
		Type ZEPlayers
		VolumeName FrontVolume
	}

//This is the timer that causes the portal to appear after the captions are done
	Timer Delay-Timer
	{
		Duration 00:24
	}

//This is the event timer that tracks the Ready to Rumble badge
	EventTimer ReadyToRumble-Timer
	{
		Duration 08:00
	}

//This is the timer that causes the portal to appear after the captions are done
	Timer Delay-Timer-Two
	{
		Duration 00:34
	}

//This is the timer that kills all the Talons after 20 seconds of their assault on the IDF.
	Timer Talons-Annihilate-Timer
	{
		Duration 00:20
	}

//This is the timer that initiates Desdemona's fallback sequence.
	Timer Desdemona-Fallback-Timer
	{
		Duration 00:32
	}

//This is the timer to display the time until reinforcements arrive in Stage 1.
	Timer Reinforcements-Arrive-Timer
	{
		Duration 00:36
	}

//This trigger sets off the exposition captions.
	Trigger IntroCaptions
	{
		Requires ScriptStageOneBattleStart objectivesucceeded>

		Action
		{
			Reset Delay-Timer
			Reset Delay-Timer-Two
			Caption DreamDoctorIntro
			{
				Message P1657121715
			}
		}
		Action
		{
			Delay 1
			SetScriptValue	CaptionComplete-Scriptvalue 1
		}
	}


//This trigger enables the teleport to the trial's start.
	Trigger BeginPort
	{
		Requires CaptionComplete-Scriptvalue scriptvalue> 1 == Delay-Timer complete> &&
	
		Action
		{
			SetScriptValue	CaptionComplete-Scriptvalue 2
		}
		Action
		{
			Caption PortalOpen
			{
				Message P617005977
				Volume TPTR-Hospital
			}
			TeamControl
			{
				Team BeginPortal
				Type Activate
			}
		}
		Action
		{
			Delay 1
			SetScriptValue	CaptionComplete-Scriptvalue 3
			Reset ReadyToRumble-Timer
		}
	}

//This trigger starts the event where Dominatrix departs the dimensional space and enters the Magisterium.
	Trigger Event-DominatrixLeaves
		
		Requires CaptionComplete-Scriptvalue scriptvalue> 3 == Delay-Timer-Two complete> &&		

		Action
		{
			TeamControl
			{
				Team NPC-DominatrixDimensional
				Type DoBehavior
				Behavior <<Say(P1801072254),MoveToPos(marker:BeginPortal)>>
			}
			Caption DuncanCaption-1
			{
				Message P3738701450
				Volume TPTR-Hospital
			}
		}
		Action
		{
			Delay 1
			TeamControl
			{
				Team NPC-DreamDoctor
				Type DoBehavior
				Behavior Say(P1070894632)
			}
			Caption DreamDoctor-1
			{
				Message P95392504
				Volume TPTR-Hospital
			}
		}
		Action
		{
			Delay 3
			TeamControl
			{
				Team NPC-DominatrixDimensional
				Type Deactivate
			}
		}
		Action
		{
			Delay 4
			TeamControl
			{
				Team NPC-DominatrixPraetoria
				Type Activate
			}
		}
		Action
		{
			Delay 6
			TeamControl
			{
				Team NPC-DominatrixPraetoria
				Type DoBehavior
				Behavior <<Say(P1741239775),MoveToPos(marker:NPC-DomToDesTalk),Say(P2064709971)>>
			}
			Caption DuncanCaption-2
			{
				Message P2619776997
				Volume FrontVolume
			}
		}
		Action
		{
			Delay 8
			TeamControl
			{
				Team NPC-Desdemona
				Type DoBehavior
				Behavior <<Say(P4051650818)>>
			}
			Caption DesdemonaCaption-1
			{
				Message P3081885557
				Volume FrontVolume
			}
		}
	}

//This trigger begins the retreat when the first player has arrived on the other side of the portal.
	Trigger Event-RetreatStart
	{
		Requires PlayersInFrontVolume count> 1 >= RetreatStarted scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Retreat Event Started>>
			Reset Talons-Annihilate-Timer
			Reset Desdemona-Fallback-Timer
			Reset Reinforcements-Arrive-Timer
		}
		Action
		{
			Caption TalonsCaption-1
			{
				Message P3286848768
				Volume FrontVolume
			}
			TeamControl
			{
				Team Talons-Ground-01
				Type Activate
			}
			TeamControl
			{
				Team Talons-Ground-02
				Type Activate
			}
			TeamControl
			{
				Team Talons-Flying-01
				Type Activate
			}
			TeamControl
			{
				Team Talons-Flying-02
				Type Activate
			}
			TeamControl
			{
				Team Carnival-01
				Type Activate
			}
			TeamControl
			{
				Team Carnival-02
				Type Activate
			}
			TeamControl
			{
				Team Carnival-03
				Type Activate
			}
		}
		Action
		{
			Delay 1
			SetScriptValue RetreatStarted 1
			Caption IDFCaption-1
			{
				Message P2992214520
				Volume FrontVolume
			}
		}
		Action
		{
			Delay 3
			Caption Carnival-1
			{
				Message P4030291447
				Volume FrontVolume
			}
		}
		Action
		{
			Delay 4
			TeamControl
			{
				Team Carnival-01
				Type DoBehavior
				Behavior <<MoveToPos(marker:Carnival-01-Retreat)>>
			}
			TeamControl
			{
				Team Carnival-02
				Type DoBehavior
				Behavior <<MoveToPos(marker:Carnival-02-Retreat)>>
			}
			TeamControl
			{
				Team Carnival-03
				Type DoBehavior
				Behavior <<MoveToPos(marker:Carnival-03-Retreat)>>
			}
		}
	}

//This trigger kills the Talons after twenty seconds.
	Trigger Event-TalonsDefeated
	{
		Requires RetreatStarted scriptvalue> 1 == Talons-Annihilate-Timer complete> &&

		Action
		{
			Caption IDFCaption-2
			{
				Message P3684485968
			}
		}
		Action
		{
			Delay 2
			TeamControl
			{
				Team Talons-Ground-01
				Type DoBehavior
				Behavior <<PlayFX(Powers\FireControl\VillainExplosion.fx,Timer(1)),Dead(Timer(1),DoNotDrawAggro(1),CombatOverride(Passive),Unselectable(1),Invincible(1),Untargetable(1),Gang(2)),DestroyMe>>
			}
			TeamControl
			{
				Team Talons-Ground-02
				Type DoBehavior
				Behavior <<PlayFX(Powers\FireControl\VillainExplosion.fx,Timer(1)),Dead(Timer(1),DoNotDrawAggro(1),CombatOverride(Passive),Unselectable(1),Invincible(1),Untargetable(1),Gang(2)),DestroyMe>>
			}
		}
		Action
		{
			Delay 3
			Caption TalonsCaption-2
			{
				Message P3843244126
			}
			TeamControl
			{
				Team Talons-Flying-01
				Type DoBehavior
				Behavior <<PlayFX(Powers\FireControl\VillainExplosion.fx,Timer(1)),Dead(Timer(1),DoNotDrawAggro(1),CombatOverride(Passive),Unselectable(1),Invincible(1),Untargetable(1),Gang(2)),DestroyMe>>
			}
			TeamControl
			{
				Team IDF-Guards-Plaza-Initial
				Type Deactivate
			}
		}
		Action
		{
			Delay 4
			TeamControl
			{
				Team Talons-Flying-02
				Type DoBehavior
				Behavior <<PlayFX(Powers\FireControl\VillainExplosion.fx,Timer(1)),Dead(Timer(1),DoNotDrawAggro(1),CombatOverride(Passive),Unselectable(1),Invincible(1),Untargetable(1),Gang(2)),DestroyMe>>
			}
		}
		Action
		{
			Delay 5
			SetScriptValue RetreatStarted 2
			TeamControl
			{
				Team NPC-Mistress
				Type DoBehavior
				Behavior <<Say(P263357285)>>
			}
			Caption MistressCaption-1
			{
				Message P3665983195
				Volume FrontVolume
			}
			TeamControl
			{
				Team Talons-Ground-01
				Type Deactivate
			}
			TeamControl
			{
				Team Talons-Ground-02
				Type Deactivate
			}
			TeamControl
			{
				Team Talons-Flying-01
				Type Deactivate
			}
			TeamControl
			{
				Team Talons-Flying-02
				Type Deactivate
			}
			TeamControl
			{
				Team Carnival-01
				Type DoBehavior
				Behavior <<CarnivalOfLight_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
			TeamControl
			{
				Team Carnival-02
				Type DoBehavior
				Behavior <<CarnivalOfLight_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
			TeamControl
			{
				Team Carnival-03
				Type DoBehavior
				Behavior <<CarnivalOfLight_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
		}

	}

//This trigger causes Desdemona, Dominatrix and the Mistress to fall back after the Talons are wiped out..
	Trigger Event-DesdemonaFallback
	{
		Requires RetreatStarted scriptvalue> 2 == Desdemona-Fallback-Timer complete> &&

		Action
		{
			TeamControl
			{
				Team NPC-Desdemona
				Type DoBehavior
				Behavior <<Say(P3674867555)>>
			}
			Caption DesdemonaCaption-2
			{
				Message P171587691
			}
		}
		Action
		{
			Delay 3
			SetScriptValue RetreatStarted 3
			Caption IDFCaption-2
			{
				Message P2307897934
			}			
			TeamControl
			{
				Team NPC-Desdemona
				Type DoBehavior
				Behavior <<MoveToPos(marker:DesdemonaFallback)>>
			}
			TeamControl
			{
				Team NPC-DominatrixPraetoria
				Type DoBehavior
				Behavior <<MoveToPos(marker:DominatrixFallback)>>
			}
			TeamControl
			{
				Team NPC-Mistress
				Type DoBehavior
				Behavior <<MoveToPos(marker:MistressFallback)>>
			}
			TeamControl
			{
				Team IDF-Guards-Plaza
				Type Activate
			}
		}
		Action
		{	
			Delay 9
			TeamControl
			{
				Team NPC-Desdemona
				Type DoBehavior
				Behavior <<CarnivalOfLight_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
			TeamControl
			{
				Team NPC-DominatrixPraetoria
				Type DoBehavior
				Behavior <<CarnivalOfLight_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
			TeamControl
			{
				Team NPC-Mistress
				Type DoBehavior
				Behavior <<CarnivalOfLight_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
		}
	}

//This trigger sets up the success condition for the event.
	Trigger Success
	{
		Requires Approach-Defeats complete>
	
		Action
		{
			DebugPrint <<Trash Cleared.>>
		}

		NextStage BattleRoyale
	}

//This is the collection of UI items for the stage.
	UICollection Approach
	{
		UIItem KillBar
		{
			Type BarBlue
			Text P718066303
			ShortText P3504659590
			Current Approach-Defeats count>
			Target 250
			HideIf RetreatStarted scriptvalue> 3 <
		}
		UIItem RetreatObserve
		{
			Type CenterText
			Text P2211039836
			HideIf RetreatStarted scriptvalue> 0 == RetreatStarted scriptvalue> 3 == ||
		}
		UIItem RetreatObserve
		{
			Type CenterText
			Text P406587310
			HideIf RetreatStarted scriptvalue> 0 == RetreatStarted scriptvalue> 3 == ||
		}
		UIItem StageApproach-Tip1
		{
			Type CenterText
			Text P339312489
			HideIf ScriptStageOneBattleStart objectivesucceeded>
		}
		UIItem MagisteriumEnter
		{
			Type CenterText
			Text P2549163497
			HideIf RetreatStarted scriptvalue> 0 >
		}
		UIItem ReinforcementTimer-Stage1
		{
			Type Timer
			Timer Reinforcements-Arrive-Timer
			Text P3298578148
			ShortText P3985542317
			HideIf RetreatStarted scriptvalue> 0 == RetreatStarted scriptvalue> 3 == ||
		}
		UIItem PortalTimer-Stage1
		{
			Type Timer
			Timer Delay-Timer
			Text P2143651426
			ShortText P2285458711
			HideIf CaptionComplete-Scriptvalue scriptvalue> 1 == !
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage Approach>>
		}
		Action
		{
			TeamControl
			{
				Team IDF-Guards-Plaza
				Type Deactivate
			}
			TeamControl
			{
				Team NPC-Desdemona
				Type Deactivate
			}
			TeamControl
			{
				Team NPC-DominatrixPraetoria
				Type Deactivate
			}
			TeamControl
			{
				Team NPC-Mistress
				Type Deactivate
			}
			TeamControl
			{
				Team Carnival-01
				Type Deactivate
			}
			TeamControl
			{
				Team Carnival-02
				Type Deactivate
			}
			TeamControl
			{
				Team Carnival-03
				Type Deactivate
			}
		}
	}
}
Stage BattleRoyale
{
	DisplayName P3229186760
	Tooltip P298261451

