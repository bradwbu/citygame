Name 50PlusMagisterium
FirstStage Setup
StopStage Stop
RestartStage Reset
DisplayName P1212531025

//Stage Names:
//Stage 1: Startup
//Stage 2: Approach
//Stage 3: BattleRoyale
//Stage 4: BlackSwan
//Stage 5: Cutscene
//Stage 6: PostNuke
//Stage 7: Finale

