				Type Activate
			}
		}
		Action
		{
			TeamControl
			{
				Team Pendragon
				Type Activate
			}
		}
		Action
		{
			TeamControl
			{
				Team NetherworldFX
				Type Activate
			}
		}
		Action
		{
			PlaySound
			{
				Sound i20_02Low_B_Loop
				Channel Music
				VolumeLevel 1
			}
		}
	}

//Award Karma for defeating a member of the Pendragon team.
	Objective
	{
		Type Team
		Team Pendragon
		KarmaValue 30
		KarmaLife 60
		TeamKarmaValue 30
		TeamKarmaLife 60
	}

//Award Karma for defeating a member of the Shadowhunter team.
	Objective
	{
		Type Team
		Team Shadowhunter
		KarmaValue 30
		KarmaLife 60
		TeamKarmaValue 30
		TeamKarmaLife 60
	}

//Award Karma for defeating a Shadowhunter wolf.
	Objective
	{
		Type Named
		Name Nightstalkers_Wodan_Summoned
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
