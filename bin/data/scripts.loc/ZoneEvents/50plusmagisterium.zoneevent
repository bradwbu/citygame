		{
			Type Timer
			Timer Tyrant2Enrage-Timer
			Text P3649598134
			ShortText P3097074627
		}
		UIItem LightTimer
		{
			Type Timer
			Timer LightsSpawnTimer-Timer
			Text P2807360348
			ShortText P1839801972
		}
		UIItem Connections
		{
			Type BarGold
			Text P2816767867
			ShortText P1968888155
			Current LightsAlive count>
			Target 6
		}
//		UIItem TyrantRageBar
//		{
//			Type BarBlue
//			Text P2324809002
//			ShortText P3319732960
//			HideIf Tyrant2Health count> 0 <=
//			Current TyrantRage scriptvalue>
//			Target 8
//		}
		UIItem Stage3-Tip1
		{
			Type CenterText
			Text P361685042
		}
		UIItem Stage3-Tip2
		{
			Type CenterText
			Text P3147343913
		}
		UIItem Stage3-Tip3
		{
			Type CenterText
			Text P2930046085
		}
		UIItem Stage3-Tip4
		{
			Type CenterText
			Text P1692667418
		}
		UIItem Stage3-Tip5
		{
			Type CenterText
			Text P4141315198
		}
		UIItem Stage3-Tip6
		{
			Type CenterText
			Text P4255242437
			HideIf Tyrant2Health count> 50 > Tyrant2SpeechDelay-Timer complete> ! ||
		}
	}
	ShutDown
	{
		Action StartSetup
		{
			DebugPrint <<Ending Stage PostNuke>>
			TeamControl
			{
				Team Tyrant2
				Type DoBehavior 
				Behavior <<SetHealth(Health(1)),Unselectable(1),Invincible(1),UsePower("Shrink"),Say(P3747658080)DoNothing(Timer(6)),Combat(CombatModShift(-8),Unselectable(0),Invincible(0))>>
			}
		}
	}
}


