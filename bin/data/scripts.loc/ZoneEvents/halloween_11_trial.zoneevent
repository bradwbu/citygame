			Action
			{
				TeamControl
				{
					Team PreludeZombie3
					Type DoBehavior
					Behavior <<Say(P1667020859)>>	
				}
			}
			Action
			{
				Reset LoopingDialog-prelude-timer, LoopingDialog-Barker
			}
		}
		Trigger 4x
