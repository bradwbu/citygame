				Type DoBehavior
				Behavior <<MoveToPos(marker:AbominationFacing),Loop("Cheering(Timer(Rand(6,24))),DoNothing(AnimList(Threaten),Timer(Rand(2,4))),DoNothing(AnimList(HandsOnHead),Timer(Rand(1,2))),DoNothing(AnimList(Surrounded),Timer(Rand(2,4))),DoNothing(AnimList(CrazyMenace),Timer(Rand(3,11))),")>>
			}
		}
	}


