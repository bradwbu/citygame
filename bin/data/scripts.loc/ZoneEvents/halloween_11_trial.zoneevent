// --------------------------------------------------------------------

// ======================== MANSION EXTERIOR: FRONT ===================
Stage Prelude
{
	DisplayName P2955815761
	ToolTip P2631793388

	StartUp
	{
		Action DebugStageTimer2
		{
			DebugPrint <<Starting PRELUDE Stage>>
		}
		Action
		{
			GurneyControl
			{
			Type Activate
			Gurney MansionExteriorG
			}
		}
		Action 
		{
			DebugPrint <<MANSION EXTERIOR GURNEY ACTIVATED>>
		}	
		Action
		{
			WayPointPlace WP-MissionExit WP-MissionExit
			WayPointPlace WP-MansionEntrance WP-MansionEntrance
			WayPointPlace WP-MansionExit WP-MansionExit
			WayPointPlace WP-CaveInt WP-CaveInt
			WayPointPlace WP-Graveyard WP-Graveyard
		}
		Action
		{
			PlaySound
			{
				Sound Halloween11_Music
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team PreludeNPCs
			}
			TeamControl
			{
				Type Activate
				Team PreludeCorpseDig
			}
			TeamControl
			{
				Type Activate
				Team PreludeZombie1
			}
			TeamControl
			{
				Type Activate
				Team PreludeZombie2
			}
			TeamControl
			{
				Type Activate
				Team PreludeZombie3
			}
			TeamControl
			{
				Type Activate
				Team PreludeWolf
			}
			TeamControl
			{
				Type Activate
				Team PreludeDevilGirl
			}
			TeamControl
			{
				Type Activate
				Team PreludeDevilGirl2
			}
			TeamControl
			{
				Type Activate
				Team MansionTallMan
			}
			TeamControl
			{
				Type Activate
				Team PreludeBlackWhipGuy
			}
			TeamControl
			{
				Type Activate
				Team PreludeBlackWhipGal
			}
		}
	}
	
	UICollection Mansion
	{	
		UIItem EnterMansion
		{
			Type Text
			Text P1072666334
			ShortText P2155926258
			HideIf Captions-Prelude scriptvalue> 2 == !
		}
	}

	Counter MansionPlayers
	{
		Type ZEPlayers
		VolumeName MansionInterior
	}
	Counter MansionExterior-Captions
	{
		Type ZEPlayers
		VolumeName MansionExterior-Caption
	}	
	Timer Captions-Prelude-Timer
	{
		Duration 00:02
	}

//Caption Trigger
// --------------------------------------------------------------------
	Trigger Captions-Prelude
	{
		Requires MansionExterior-Captions count> 1 >= Captions-Prelude scriptvalue> 0 == &&
		Action
		{
			Reset MansionDoor-Prelude-Timer
		}
		Action
		{
			SetScriptValue Captions-Prelude 1
		}
		Action
		{
			Caption
			{
				Message P3049152182
			}
		}
		Action
		{
			DebugPrint <<PRELUDE CAPTION TRIGGERED>>
		}
	}

	Timer MansionDoor-Prelude-Timer
	{
		Duration 00:19
	}

// This is the control for the looping dialog outside the mansion
// --------------------------------------------------------------------
	
	Timer LoopingDialog-prelude-timer
	{
		MinDuration 00:08
		MaxDuration 00:15
	}

	TriggerDeck LoopingDialog-Barker
	{
		Type ShuffleAtEnd
		Requires LoopingDialog-prelude-timer complete>  Dialog-Safety scriptvalue> 0 == &&
				
		Trigger 1x
		{
			Action
			{
				TeamControl
				{
					Team PreludeZombie3
					Type DoBehavior
					Behavior <<Say(P2329458757)>>	
				}
			}
			Action
			{
				Reset LoopingDialog-prelude-timer, LoopingDialog-Barker
			}
		}
		Trigger 2x
