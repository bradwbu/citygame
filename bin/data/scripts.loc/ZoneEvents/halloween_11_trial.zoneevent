// This is the block for the It's Alive! badge
// ------------------------------------------------------------------------

	Counter GraveyardZombies-counter
	{
		Type Name
		Name Event_Halloween_11_Trial_Minion_graveyard
		Count 99
		Direction Up
		VolumeName GraveyardExterior
	}

	Timer GraveyardZombies-timer
	{
		Duration 12:00
	}

	Trigger ZombiesDead-trigger
	{
		Requires GraveyardZombies-counter complete>
		Action
		{
			SetScriptValue GraveyardZombiesDead-count 1
		}
		Action
		{
			DebugPrint <<ZOMBIES DEAD!!>>
		}
	}

	Trigger ZombiesDeadtimer-trigger
	{
		Requires GraveyardZombies-timer complete>
		Action
		{
			SetScriptValue GraveyardZombie-timeout 1
		}
		Action
		{
			DebugPrint <<TIME RAN OUT!!>>
		}
	}
		

// Checks to see if Abomination is still alive and, if not, ends the stage
// ------------------------------------------------------------------------
	Counter AbominationAlive
	{
		Type Team
		Team GraveyardZombie1boss
		Count 1
		Direction Up
		VolumeName GraveyardExterior
	}
	Trigger End
	{
		Requires AbominationAlive complete>
		NextStage Rewards
	}
}

