// Kane finishes his monologue and moves to activate the Abomination
// --------------------------------------------------------------------
	Timer GraveyardCaption-Timer
	{
		Duration 00:20
	}
	Trigger DrKaneMove-Trigger
	{
		Requires GraveyardCaption-Timer complete> KaneCaption scriptvalue> 1 == &&
		Action
		{
			Reset DrKaneMoveToPos-Timer
		}
		Action
		{
			TeamControl
			{
				Team GraveyardDrKane
				Type DoBehavior
				Behavior <<Unselectable(1),Invincible(1),MoveToPos(marker:ActivateAbomination)>>
			}
		}
		Action
		{
			SetScriptValue BossActivate 1
		}
	}

// Kane activates the Abomination
// --------------------------------------------------------------------

	Timer DrKaneMoveToPos-Timer
	{
		Duration 00:06
	}

	Trigger DrKaneActivateBoss-Trigger
	{
		Requires DrKaneMoveToPos-Timer complete> BossActivate scriptvalue> 1 == &&
		Action
		{
			TeamControl
			{
				Team GraveyardDrKane
				Type DoBehavior
				Behavior <<Say(P4059033935)>>	
			}
		}
		Action
		{
			SetScriptValue BossActivate 2
		}
	}

	Trigger AbominationLightingStrike-Trigger
	{
		Requires DrKaneMoveToPos-Timer complete> BossActivate scriptvalue> 2 == &&
		Action
		{
			Reset Abomination-Awaken-Timer
		}		
		Action
		{	
			TeamControl
			{
				Team GraveyardZombie1boss
				Type DoBehavior
				Behavior <<UsePower("Shock_Therapy")>>
			}
		}
		Action
		{	
			TeamControl
			{
				Team GraveyardDrKane
				Type DoBehavior
				Behavior <<Cheering>>
			}
		}
		Action
		{
			SetScriptValue BossActivate 3
		}
		Action
		{
			Reset GraveyardZombies-timer
		}
	}

	Timer Abomination-Awaken-Timer
	{
		Duration 00:01
	}

// The Abomination becomes active and the boss fight begins
// --------------------------------------------------------------------
	Trigger DrKaneActivateBoss-Trigger
	{
		Requires Abomination-Awaken-Timer complete> BossActivate scriptvalue> 3 == &&
		Action
		{
			Reset Abomination-Facing-Timer, GraveyardZombies-counter, GraveyardZombies-timer, AbominationFight-Timer
		}
		Action
		{
			TeamControl
			{
				Team GraveyardZombie1boss
				Type DoBehavior
				Behavior <<Untargetable(0),Unselectable(0),Invincible(0),UsePower("Grant_Electrical_Discharge"),Combat(FindTarget(1),SpawnPosIsSelf,CombatOverride(Aggressive),FeelingFear(0),GriefHPRatio(0),ProtectSpawnRadius(100000),OverridePerceptionRadius(100000),AlwaysAttack,FOVDegrees(360))>>
			}
			TeamControl
			{
				Team GraveyardDrKane
				Type DoBehavior
				Behavior <<Loop("Cheering(Timer(Rand(6,24))),DoNothing(AnimList(Threaten),Timer(Rand(2,4))),DoNothing(AnimList(HandsOnHead),Timer(Rand(1,2))),DoNothing(AnimList(Surrounded),Timer(Rand(2,4))),DoNothing(AnimList(CrazyMenace),Timer(Rand(3,11))),")>>
			}
		}

		Action
		{
			SetScriptValue Captions-Graveyard 1
		}

		Action
		{	
			Floater
			{
				Message P2011744447
				Color FF6600
				AlertType PriorityAlert
			}
		}
		Action
		{
			PlaySound
			{
				Sound Underground_Combat04
				Channel Music
				VolumeLevel 1
			}
		}
	}

// Kane faces the center of the arena
