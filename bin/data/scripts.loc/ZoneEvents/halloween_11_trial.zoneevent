//Mansion Front Door Trigger
// --------------------------------------------------------------------
	Trigger MansionDoor-Prelude
	{
		Requires MansionDoor-Prelude-Timer complete> Captions-Prelude scriptvalue> 1 == &&
		Action
		{
			Reset Floater-Prelude-Timer
		}
		Action
		{
			SetScriptValue TallMan 1
		}
//		Action
//		{
//			FadeSound
//			{
//				Channel Music
//				FadeTime 1
//			}
//		}
		Action
		{
			SetScriptValue Captions-Prelude 2
		}
		Action
		{	
			DoorControl
			{
				Type Unlock
				Door Door-Mansion1
			}
		}
		Action
		{
			PlaySound
			{
				Sound Halloween11_Scream1
				Channel SFX
				VolumeLevel 1
			}
		}
		Action
		{
			DebugPrint <<MANSION DOOR UNLOCKED>>
		}
		Action
		{	
			Floater
			{
				Message P1442476974
				Color FF6600
				AlertType PriorityAlert
			}
		}
	}

//TallMan Greeting Trigger
// --------------------------------------------------------------------
	Counter TallMan-counter
	{
		Type ZEPlayers
		VolumeName MansionInterior-tallman
	}
	Timer TallMan-timer
	{
		Duration 00:10
	}
	Trigger TallMan-trigger
	{
		Requires TallMan-counter count> 1 >= TallMan scriptvalue> 1 == &&

		Action
		{	
			TeamControl
			{
				Team MansionTallMan	
				Type DoBehavior
				Behavior <<Preach_Low(Timer(2)),Say(P981509041),DoNothing(AnimList(ArmsCrossed)),>>
			}
		}
		Action
		{
			SetScriptValue TallMan 2
		}
	}

//Black Whip event
// --------------------------------------------------------------------
	Counter BlackWhipHealth
	{
		Type BossHealth
		Team PreludeDemon
	}
	
	Trigger BlackWhip-1-Trigger
	{
		Requires ScriptBlackWhipStart objectivesucceeded>
		Action
		{
		SetScriptValue BlackWhip-Control 1
		}
		Action
		{	
			Delay 00:05
			Floater
			{
				Message P2004604770
				Color 8A2BE2
				AlertType PriorityAlert
			}
		}
	}

	Trigger BlackWhip-2-Trigger
	{
		Requires ScriptBlackWhipGuy objectivesucceeded> BlackWhip-Control scriptvalue> 1 == &&
		Action
		{
			TeamControl
			{
				Team PreludeBlackWhipGuy	
				Type DoBehavior
				Behavior <<MoveToPos(marker:GuyCandy),DoNothing(AnimList(Repair),Timer(2)),DoNothing(AnimList(Eat_Donut),Timer(5)),Say(P971607690),DoNothing(AnimList(Barf),Timer(6)),DoNothing(AnimList(DeadSlab))>>
			}
		}
	}
	Trigger BlackWhip-3-Trigger
	{
		Requires ScriptBlackWhipGal objectivesucceeded> BlackWhip-Control scriptvalue> 1 == &&
		Action
		{
			TeamControl
			{
				Team PreludeBlackWhipGal	
				Type DoBehavior
				Behavior <<MoveToPos(marker:GalCandy),DoNothing(AnimList(Repair),Timer(2)),DoNothing(AnimList(Eat_Donut),Timer(5)),Say(P971607690),DoNothing(AnimList(Barf),Timer(6)),DoNothing(AnimList(DeadSlab))>>
			}
		}
	}
	
	Trigger BlackWhip-4-Trigger
	{ 
		Requires ScriptBlackWhipGuy objectivesucceeded> ScriptBlackWhipGal objectivesucceeded> &&
		Action
		{
			Reset BlackWhip-dead-timer
		}
		Action
		{
			TeamControl
			{
				Team PreludeDevilGirl
				Type DoBehavior
				Behavior <<Meditate,Say(P1748006470)>>
			}
			TeamControl
