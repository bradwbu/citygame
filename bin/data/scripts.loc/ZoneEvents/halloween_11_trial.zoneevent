				Sound Halloween11_ZombieReveal1_Music
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			TeamControl
			{
				Team TombDrKane
				Type DoBehavior
				Behavior <<Preach_Low>>
			}
		}
	}


// Kane's tomb speech
// --------------------------------------------------------------------

	Timer KaneSpeech-tomb-timer
	{
		Duration 00:02
	}

	Timer KaneSpeech-tomb-retrigger-timer
	{
		Duration 00:04
	}
	
	Trigger KaneSpeech-first-trigger
	{
		Requires KaneSpeech-tomb-timer complete> KaneSpeechtomb scriptvalue> 0 == &&
		Action
		{
			TeamControl
			{
				Team TombDrKane
				Type DoBehavior
				Behavior <<Say(P2459084281)>>	
			}
		}
		Action
		{
			Reset KaneSpeech-tomb-retrigger-timer
		}
		Action
		{
			SetScriptValue KaneSpeechtomb 1
		}
	}
	Trigger KaneSpeech-second-trigger
	{
		Requires KaneSpeech-tomb-timer complete> KaneSpeech-tomb-retrigger-timer complete> && KaneSpeechtomb scriptvalue> 1 == &&
		Action
		{
			TeamControl
			{
				Team TombDrKane
				Type DoBehavior
				Behavior <<Say(P1302695248)>>	
			}
		}
		Action
		{
			Reset KaneSpeech-tomb-retrigger-timer
		}
		Action
		{
			SetScriptValue KaneSpeechtomb 2
		}
	}
	Trigger KaneSpeech-third-trigger
	{
		Requires  KaneSpeech-tomb-timer complete> KaneSpeech-tomb-retrigger-timer complete> && KaneSpeechtomb scriptvalue> 2 == &&
		Action
		{
			TeamControl
			{
				Team TombDrKane
				Type DoBehavior
				Behavior <<Say(P3101078191)>>	
			}
		}
		Action
		{
			SetScriptValue KaneSpeechtomb 3
		}
	}

// UI-tomb
// --------------------------------------------------------------------
	UICollection TombBoss
	{	
		UIItem TombBossFight
		{
			Type CenterText
			Text P891903392
			ShortText P891903392
			HideIf Captions-Tomb scriptvalue> 2 == !
		}
		UIItem TombBossExit
		{
			Type Text
			Text P524591475
			ShortText P524591475
			HideIf Captions-Tomb scriptvalue> 3 == !
		}
		UIItem EN9HealthBar
		{
			Type BarRed
			Text P3052244092
			ShortText P2334680323
			Current EN9Health-Counter count>
			OnClickFindEnt TombZombie1boss
			Target 100
			HideIf Captions-Tomb scriptvalue> 2 == !
		}
	}

// Kane activates EN9 and flees post monologue
// --------------------------------------------------------------------

	Timer TombBossRoomCaption-Timer
	{
		Duration 00:15
	}

//	Timer TombBossRoomDeathMin-Timer
//	{
//		Duration 00:40
//	}

	Counter EN9Health-Counter
	{
		Type BossHealth
		Team TombZombie1boss
	}

	Trigger TombBossRoomActivate-Trigger
	{
		Requires TombBossRoomCaption-Timer complete>
		Action
		{
			TeamControl
			{
				Team TombDrKane
				Type DoBehavior
				Behavior <<FleeToNearestDoor>>
			}
			TeamControl
			{
				Team TombZombie1boss
				Type DoBehavior
				Behavior <<Untargetable(0),Unselectable(0),Invincible(0),Combat(FindTarget(1),SpawnPosIsSelf,CombatOverride(Aggressive),ProtectSpawnRadius(100000),OverridePerceptionRadius(100000),AlwaysAttack,FOVDegrees(360))>>
			}
		}

		Action
		{
			SetScriptValue Captions-Tomb 2
		}

		Action
		{	
			Floater
			{
				Message P891903392
				Color FF6600
				AlertType PriorityAlert
			}
		}
			Action
		{
			PlaySound
			{
				Sound Underground_Combat03
				Channel Music
				VolumeLevel 1
			}
		}
	}
	
// Experiment Number Nine summons adds
// --------------------------------------------------------------------

	Timer AddSpawnControl-Timer
	{
		Duration 00:05
	}
	Trigger Adds1-Trigger
	{
		Requires AddSpawnControl-Timer complete> EN9Health-Counter count> 75 <= &&
		Action
		{
			TeamControl
			{
				Team TombMushroomBossAdds1
				Type Activate
			}
		}
		Action
		{	
			Floater
			{
				Message P938676149
				Color FF6600
				AlertType PriorityAlert
			}
		}
	}
	
//Checks for death of tomb boss and unlocks door.
// --------------------------------------------------------------------
	Counter TombBossDead
	{
		Count 1
		Direction Up
		Team TombZombie1boss
		Type Team
	}
	Trigger UnlockDoor-TombExit
	{
		Requires TombBossDead count>
		Action
		{	
			DoorControl
			{
				Door Door-TombExit
				Type Unlock
			}
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 3
			}
		}
		Action
		{
			SetScriptValue Captions-Tomb 3
		}

		Action
		{	
			Floater
			{
				Message P2437443035
				Color FF6600
				AlertType PriorityAlert
			}
		}
		Action
		{
			WayPointPlace WP-CaveIntExt WP-CaveIntExt
		}
		Action
		{
			DebugPrint <<TOMB DOOR UNLOCKED>>
		}
	}

//Checks for players in graveyard and advances to graveyard stage.
// --------------------------------------------------------------------
	Counter GraveyardPlayers
	{
		Type ZEPlayers
		VolumeName GraveyardExterior
	}
	Trigger End
	{
		Requires GraveyardPlayers count>
		NextStage Graveyard
	}
}

// --------------------------------------------------------------------

// ===================== MANSION EXTERIOR: GRAVEYARD ==================
Stage Graveyard
{
	DisplayName P235507155
	ToolTip P3922450016

	StartUp
	{
		Action DebugGraveyardStage
		{
			DebugPrint <<GRAVEYARD STAGE>>
		}
		Action
		{
			SetScriptValue Captions-Tomb 3
		}
				Action
		{
			DoorControl
			{
				Door Door-Mansion1
				Type Unlock
			}
			DoorControl
			{
				Door Door-Mansion2
				Type Unlock
			}
			DoorControl
			{
				Door Door-TombExit
				Type Unlock
			}
		}
		Action
		{
			GurneyControl
			{
			Type Deactivate
			Gurney TombEntrance
			}
			GurneyControl
			{
			Type Activate
			Gurney TombExit
			}
		}
		Action 
		{
			DebugPrint <<TOMB ENTRANCE GURNEY DEACTIVATED - TOMB EXIT GURNEY ACTIVATED>>
		}
		Action
		{
			PlaySound
			{
				Sound Halloween11_Music
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			Reset MusicFadeGraveyard-Timer
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team GraveyardDrKane
			}
			TeamControl
			{
				Type Activate
				Team GraveyardZombie1boss
			}
			TeamControl
			{
				Team KaneAdds1
				Type Activate
			}
			TeamControl
			{
				Team KaneAdds2
				Type Activate
			}
			TeamControl
			{
				Team KaneAdds3
				Type Activate
			}
			TeamControl
			{
				Team KaneAdds4
				Type Activate
			}
		}
	}
	
