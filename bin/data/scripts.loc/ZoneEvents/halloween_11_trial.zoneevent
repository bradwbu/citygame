//Timer and trigger for music fade
// --------------------------------------------------------------------------
	Timer MusicFadeGraveyard-Timer
	{
		Duration 00:10
	}

	Trigger
	{
		Requires MusicFadeGraveyard-Timer complete>
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 15
			}
		}
	}

//Counter watches boss health for UI
// --------------------------------------------------------------------------
	Counter AbominationHealth
	{
		Type BossHealth
		Team GraveyardZombie1boss
	}

//Starts the final encounter with Dr. Kane - speech
// --------------------------------------------------------------------------
	Counter FinalEncounter
	{
		Type ZEPlayers
		VolumeName finalkane
	}

	Trigger DrKaneCaption
	{
		Requires FinalEncounter count> 
		Action
		{
			DebugPrint <<FINAL SPEECH STARTED>>
		}
		Action
		{
			Reset GraveyardCaption-Timer, KaneSpeech-graveyard-timer, KaneSpeech-graveyard-retrigger-timer
		}
		Action
		{
			TeamControl
			{
				Team GraveyardDrKane
				Type DoBehavior
				Behavior <<Preach_Low>>
			}
		}
		Action
		{
			PlaySound
			{
				Sound Halloween11_DrKaneFinal_Music
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			SetScriptValue KaneCaption 1
		}
		Action
		{
			SetScriptValue KaneSpeechgraveyard 1
		}
	}

// Kane's graveyard speech - paired with above section
// --------------------------------------------------------------------

	Timer KaneSpeech-graveyard-timer
	{
		Duration 00:01
	}

	Timer KaneSpeech-graveyard-retrigger-timer
	{
		Duration 00:04
	}
	
	Trigger KaneSpeech-first-trigger
	{
		Requires KaneSpeech-graveyard-timer complete> KaneSpeechgraveyard scriptvalue> 1 == &&
		Action
		{
			TeamControl
			{
