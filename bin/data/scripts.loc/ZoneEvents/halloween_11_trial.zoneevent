			SetMinPlayerLevel 29
		}
		Action CreateGurneys
		{
			GurneyCreate MansionExteriorG
			{
			}
			GurneyCreate TombEntrance
			{			
			}
			GurneyCreate TombExit
			{
			}
		}
		Action CreateWaypoints
		{
			WaypointCreate WP-MansionEntrance map_enticon_neighborhood P1564030326
			WaypointCreate WP-MansionExit map_enticon_neighborhood P1564030326
			WaypointCreate WP-LabExit map_enticon_neighborhood P2807249635
			WaypointCreate WP-CaveInt map_enticon_neighborhood P1777895955
