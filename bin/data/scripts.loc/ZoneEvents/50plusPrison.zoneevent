	{
		Duration 0:30
	}

	Timer Captions-Start-Stage2-Timer
	{
		Duration 00:05
	}

	Trigger Captions-Start-Stage2
	{
		Requires Captions-Start-Stage2-Timer complete> Captions-Started-Stage2 scriptvalue> 0 == &&

		Action
		{
			SetScriptValue Captions-Started-Stage2 1
		}
		Action
		{
			TeamControl
			{
				Team CaptionManagerA
				Type DoBehavior
				Behavior <<UsePower("SetHealth89")>>
			}
		}
	}

	Trigger NightstarInitialPop
	{
		Requires NightstarInitialDelay complete>
		Action
		{	
			Floater
			{
				Message P1442033881
				Color ff9900
			}
			Reset NightstarWaveDelay
			Reset NightstarWaveDisplay
			TeamControl
			{
				Type Activate
				Team NightstarWavePets
			}
		}
		Action
		{
			TimerControl
			{
				Timer NightstarWaveDisplay
				Type Add
				Duration 0:15
			}
		}
	}

	Trigger NightstarWavePop
	{
		Requires NightstarWaveDelay complete>
		Action
		{
			Floater
			{
				Message P1442033881
				Color ff9900
			}
			Reset NightstarWavePop
			Reset NightstarWaveDelay
			Reset NightstarWaveDisplay
		}
		Action
		{
			TimerControl
			{
				Timer NightstarWaveDisplay
				Type Add
				Duration 0:15
			}
		}
		Action
		{
			TeamControl
			{
				Type ForceSpawn
				Team NightstarWavePets
			}
		}
	}

	Trigger NightstarPulledFromSpawn-Stage2
	{
		Requires NightstarWatcherCount-Stage2 complete> NightstarCount complete> ! &&
		Action
		{
			SetScriptValue NightstarPulledAwayStage2 1
		}
	}

	Trigger NightstarCountSuccess
	{
		Requires NightstarCount complete>
		Action NightstarDone
		{
			DebugPrint <<Suppression success: switching to Escape>>
		}
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable AstralMerit1
				}
			}
		}
		NextStage Escape
	}
	Trigger GuardTowerAHackSuccess
	{
		Requires GuardTowerClicksA complete>
		Action GuardTowerAHacked
		{
			DebugPrint <<Guard Tower A Hacked>>
			TeamControl SuppressGuardTowerA
			{
				Type DoBehavior
				Team GuardTowerAP2Team
				Behavior <<DoNothing(DisableAutoPowers(1),Timer(30)),Combat(DisableAutoPowers(0))>>
			}
		}
		Action
		{
			SetScriptValue TerminalsUsedStage2 TerminalsUsedStage2 scriptvalue> 1 +
		}
		Action GuardTowerAReset
		{
			Delay 20
			DebugPrint <<Guard Tower A Reset>>
			Reset GuardTowerAHackSuccess GuardTowerClicksA
		}
	}
