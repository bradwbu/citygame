			{
				Type ForceSpawn
				Team SiegeWavePets
			}
		}
		Action
		{
			Reset Adds-Siege
		}
	}

	Trigger NightstarPulledFromSpawn-Stage5
	{
		Requires NightstarWatcherCount-Stage5 complete> AddsAliveStage5 scriptvalue> 2 >= &&
		Action
		{
			SetScriptValue NightstarPulledAwayStage5 1
		}
	}
	Trigger SiegePulledFromSpawn-Stage5
	{
		Requires SiegeWatcherCount-Stage5 complete> AddsAliveStage5 scriptvalue> 2 >= &&
		Action
		{
			SetScriptValue SiegePulledAwayStage5 1
		}
	}

	Trigger SiegeDeadSuccess
	{
		Requires SiegeDead count> 1 == ResInProcess scriptvalue> 0 == &&
		Action FloatersSiegeDown
		{
			Floater SiegeDown
			{
				Message P4100004287
				Color 0099ff
				AlertType PriorityAlert
			}

			TeamControl NightstarStartRez
			{
				Type DoBehavior
				Team NightstarTeam
				Behavior <<UsePower("Resurrect")>>
			}
		}
		Action SiegeDeadReset
		{
			SetScriptValue ResInProcess 1
			Reset SiegeDeadSuccess TenSec FiveSec
		}
	}
	Trigger SiegeDeadHalfway
	{
		Requires SiegeDead count> 1 == ResInProcess scriptvalue> 1 == && FiveSec complete> &&
		Action FloatersSiegeHalfway
		{
			Floater SiegeHalfway
			{
				Message P1007937512
				Color 0099ff
				AlertType PriorityAlert
			}
		}
		Action SiegeDeadHalfwayReset
		{
			SetScriptValue ResInProcess 2
			Reset SiegeDeadHalfway
		}
	}
	Trigger SiegeRes
	{
		Requires SiegeDead count> 1 == ResInProcess scriptvalue> 2 == && TenSec complete> &&
		Action FloatersSiegeRes
		{
			Floater SiegeRes
			{
				Message P2338974117
				Color 0099ff
				AlertType PriorityAlert
			}
		}
		Action ActivateBossResser
		{
			TeamControl StartBossResser
			{
				Type Activate
				Team BossResserTeam
			}
			TeamControl SiegeInvincible
			{
				Type DoBehavior
				Team SiegeTeam
				Behavior <<Invincible>>
			}
			DebugPrint <<BossResser Active, Siege Invincible>>

			SetScriptValue ResInProcess 3

			Reset SiegeDead NightstarDead SiegeHealth NightstarHealth
		}
		Action DelayedReset
		{
			Delay 1
			TeamControl StopBossResser
			{
				Type Deactivate
				Team BossResserTeam
			}
			TeamControl SiegeNonInvincible
			{
				Type DoBehavior
				Team SiegeTeam
				Behavior <<Invincible(0)>>
			}
			DebugPrint <<BossResser Deactive, Siege Uninvincible>>
			
			SetScriptValue ResInProcess 0
			Reset SiegeRes
		}
	}

	Trigger NightstarDeadSuccess
	{
		Requires NightstarDead count> 1 == ResInProcess scriptvalue> 0 == &&
		Action FloatersNightstarDown
		{
			Floater NightstarDown
			{
				Message P440784556
				Color 0099ff
				AlertType PriorityAlert
			}

			TeamControl SiegeStartRez
			{
				Type DoBehavior
				Team SiegeTeam
				Behavior <<UsePower("Resurrect")>>
			}
		}
		Action NightstarDeadReset
		{
			SetScriptValue ResInProcess 1
			Reset NightstarDeadSuccess TenSec FiveSec
		}
	}
	Trigger NightstarDeadHalfway
	{
		Requires NightstarDead count> 1 == ResInProcess scriptvalue> 1 == && FiveSec complete> &&
		Action FloatersNightstarHalfway
		{
			Floater NightstarHalfway
			{
				Message P3868105166
				Color 0099ff
				AlertType PriorityAlert
			}
		}
		Action NightstarDeadHalfwayReset
		{
			SetScriptValue ResInProcess 2
			Reset NightstarDeadHalfway
		}
	}
	Trigger NightstarRes
	{
		Requires NightstarDead count> 1 == ResInProcess scriptvalue> 2 == && TenSec complete> &&
		Action FloatersNightstarRes
		{
			Floater NightstarRes
			{
				Message P2292934828
				Color 0099ff
				AlertType PriorityAlert
			}
		}
		Action ActivateBossResser
		{
			TeamControl StartBossResser
			{
				Type Activate
				Team BossResserTeam
			}
			TeamControl NightstarInvincible
			{
				Type DoBehavior
				Team NightstarTeam
				Behavior <<Invincible>>
			}
			DebugPrint <<BossResser Active, Nightstar Invincible>>

			SetScriptValue ResInProcess 3

			Reset NightstarDead SiegeDead SiegeHealth NightstarHealth
		}
		Action DelayedReset
		{
			Delay 1
			TeamControl StopBossResser
			{
				Type Deactivate
				Team BossResserTeam
			}
			TeamControl NightstarNonInvincible
			{
				Type DoBehavior
				Team NightstarTeam
				Behavior <<Invincible(0)>>
			}
			DebugPrint <<BossResser Deactive, Nightstar Uninvincible>>
			
			SetScriptValue ResInProcess 0
			Reset NightstarRes
		}
	}

	Trigger SiegeAndNightstarDeadSuccess-AddsAlive
	{
		Requires SiegeDead count> 1 == NightstarDead count> 1 == && TenSec complete> ! && ResInProcess scriptvalue> 1 == ResInProcess scriptvalue> 2 == || && Adds-Siege count> 0 > Adds-Nightstar count> 0 > || &&
		Action SiegeAndNightstarDone
		{
			DebugPrint <<SiegeAndNightstar success: switching to RewardWinners>>
		}
		Action
		{
			Floater
			{
				Message P1402606563
				Color ff9900
			}
		}
		Action
		{
			Floater
			{
				Message P1590952439
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue AddsAliveStage5 1
		}
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable EmpyreanMerit_BAF
				}
			}
		}
		NextStage RewardWinners
	}

	Trigger SiegeAndNightstarDeadSuccess-AddsClear
	{
		Requires SiegeDead count> 1 == NightstarDead count> 1 == && TenSec complete> ! && ResInProcess scriptvalue> 1 == ResInProcess scriptvalue> 2 == || && Adds-Siege count> 0 == && Adds-Nightstar count> 0 == &&
		Action SiegeAndNightstarDone
		{
			DebugPrint <<SiegeAndNightstar success: switching to RewardWinners>>
		}
		Action
		{
			Floater
			{
				Message P1402606563
				Color ff9900
			}
		}
		Action
		{
			Floater
			{
				Message P1590952439
				Color ff9900
			}
		}
		Action
		{
			SetScriptValue AddsAliveStage5 0
		}
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable EmpyreanMerit_BAF
				}
			}
		}
		NextStage RewardWinners
	}

	Trigger GuardTowerAHackSuccess
	{
		Requires GuardTowerClicksA complete>
		Action GuardTowerAHacked
		{
			DebugPrint <<Guard Tower A Hacked>>
			TeamControl SuppressGuardTowerA
			{
				Type DoBehavior
				Team GuardTowerAP5Team
				Behavior <<DoNothing(DisableAutoPowers(1),Timer(30)),Combat(DisableAutoPowers(0))>>
			}
		}
		Action
		{
			SetScriptValue TerminalsUsedStage5 TerminalsUsedStage5 scriptvalue> 1 +
		}
		Action GuardTowerAReset
		{
			Delay 20
			DebugPrint <<Guard Tower A Reset>>
			Reset GuardTowerAHackSuccess GuardTowerClicksA
		}
	}
