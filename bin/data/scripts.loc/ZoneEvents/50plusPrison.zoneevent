			Reset GuardTowerMHackSuccess GuardTowerClicksM
		}
	}
	Trigger GuardTowerNHackSuccess
	{
		Requires GuardTowerClicksN complete>
		Action GuardTowerNHacked
		{
			DebugPrint <<Guard Tower N Hacked>>
			TeamControl SuppressGuardTowerN
			{
				Type DoBehavior
				Team GuardTowerNP5Team
				Behavior <<DoNothing(DisableAutoPowers(1),Timer(30)),Combat(DisableAutoPowers(0))>>
			}
		}
		Action
		{
			SetScriptValue TerminalsUsedStage5 TerminalsUsedStage5 scriptvalue> 1 +
		}
		Action GuardTowerNReset
		{
			Delay 20
			DebugPrint <<Guard Tower N Reset>>
			Reset GuardTowerNHackSuccess GuardTowerClicksN
		}
	}
	Trigger GuardTowerOHackSuccess
	{
		Requires GuardTowerClicksO complete>
		Action GuardTowerOHacked
		{
			DebugPrint <<Guard Tower O Hacked>>
			TeamControl SuppressGuardTowerO
			{
				Type DoBehavior
				Team GuardTowerOP5Team
				Behavior <<DoNothing(DisableAutoPowers(1),Timer(30)),Combat(DisableAutoPowers(0))>>
			}
		}
		Action
		{
			SetScriptValue TerminalsUsedStage5 TerminalsUsedStage5 scriptvalue> 1 +
		}
		Action GuardTowerOReset
		{
			Delay 20
			DebugPrint <<Guard Tower O Reset>>
			Reset GuardTowerOHackSuccess GuardTowerClicksO
		}
	}
	Timer StageTimer
	{
		Duration 20:00
	}
	Trigger StageTimerFailed
	{
		Requires StageTimer complete>
		Action
		{
			DebugPrint <<Stage Timer Failed>>
		}
		Action
		{
			Floater
			{
				Message P198127376
				Color ff9900
			}
		}
		Action
		{
			Floater
			{
				Message P3386779019
				Color ff9900
			}
		}
		NextStage Stop
	}

