Name KillBoss
FirstStage Setup
StopStage Stop
RestartStage Reset
DisplayName P959045291
//EventVolume EventVolume // ZoneEventName = 50plusPrison

//Event Reward Structure
// Stage 1: Defeat trash - No Karma, No Merits
// Stage 2: Defeat Nightstar - Karma 10, Astral Merit
// Stage 3: Prevent escapes - Karma 10, Astral Merit
// Stage 4: Defeat Siege - Karma 10, Astal Merit
// Stage 5: Defeat Both - Karma 10, Empyrean Merit (subject to lockout)
// Total: 4 Karma Stages. 
//	1-2 Completed stages: Incarnate Subcomponent
//	3 Completed stages: Common Component
//	4 Completed stages: Component Drop Tables

Stage Setup
{
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage Setup>>
		}
		Action
		{
			DebugPrint <<This is a 12-24 player event>>
			SetScriptValue EventSize 12
		}
		Action
		{
			DebugPrint <<Setting Cutscene to skippable unless some players have not seen it>>
			SetScriptValue Cutscene-Skippable 1
		}
		Action CreateStuff
		{
			WaypointCreate AdminWaypoint map_enticon_neighborhood P1858564184
			WaypointCreate BivouacWaypoint map_enticon_neighborhood P975681099
			WaypointCreate EscapeWaypoint1 map_enticon_gate_entrydanger P120177712
			WaypointCreate EscapeWaypoint2 map_enticon_gate_entrydanger P120177712
			WaypointCreate EscapeWaypoint3 map_enticon_gate_entrydanger P120177712
			WaypointCreate SpawnWaypoint1 map_enticon_gate_entrysafe P2144990738
			WaypointCreate SpawnWaypoint2 map_enticon_gate_entrysafe P2144990738
			WaypointCreate SpawnWaypoint3 map_enticon_gate_entrysafe P2144990738
			WaypointCreate SpawnWaypoint4 map_enticon_gate_entrysafe P2144990738
			WaypointCreate SpawnWaypoint5 map_enticon_gate_entrysafe P2144990738
			WaypointCreate SpawnWaypoint6 map_enticon_gate_entrysafe P2144990738
			WaypointCreate WP-MissionExit map_enticon_neighborhood P3301789151
			WaypointCreate WP-HospitalExit map_enticon_neighborhood P2099690906

			DoorCreate Door-Hospital // Add the following property to the MapSwap: Requires 50plusPrison.Door.Door-Hospital ZoneEvent>

			DoorControl
			{
				Type Lock
				Door Door-Hospital
			}

