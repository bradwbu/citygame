Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Starting Stage RewardWinners>>
		}
		Action
		{
			SetScriptValue OpenLeagueAward 0
		}
	}
	Trigger End
	{
		NextStage Stop
	}
	Trigger AwardBadge-Completion
	{
		Action
		{
			DebugPrint <<Awarding Completion Badge>>
			Reward IT_BAF_Complete
		}
	}
	Trigger AwardBadge-NoTerminals
	{
		Requires TerminalsUsedStage2 scriptvalue> 0 == TerminalsUsedStage4 scriptvalue> 0 == && TerminalsUsedStage5 scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Awarding NoTerminals Badge>>
			Reward IT_BAF_NoTowers
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-NoAddsAliveAtEnd
	{
		Requires AddsAliveStage5 scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding NoAdds Badge>>
			Reward IT_BAF_NoAdds
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-NoPullTogether
	{
		Requires NightstarPulledAwayStage2 scriptvalue> 0 == NightstarPulledAwayStage5 scriptvalue> 0 == && SiegePulledAwayStage4 scriptvalue> 0 == && SiegePulledAwayStage5 scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Awarding NoPullTogether Badge>>
			Reward IT_BAF_NoMovingAVs
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardMerit-OpenLeague
	{
		Requires eventLockedByGroup? ! OpenLeagueAward scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Bonus Merit for an Open League Awarded>>
			SetScriptValue OpenLeagueAward 1
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Reward>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					NumStagesRequired 3
					RewardTable Issue20EndKarma0
				}
				Reward class2
				{
					PercentileNeeded 0.00
					NumStagesRequired 4
					PointsNeeded 10
					RewardTable Issue20EndKarma1
				}
			}
		}
	}
}

