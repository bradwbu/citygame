}

Stage Cutscene
{
	DisplayName P2707677793
	ToolTip P1895544780
	
	Startup
	{
		Action
		{
			SetScriptValue CutsceneStarted 0
		}
		Action
		{
			SetScriptValue WarmthBuffSpawned 0
		}
		Action
		{
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
		}
	}

//Start Warmth Spawn Block

	Trigger WarmthBuffActivation
	{
		Requires eventLockedByGroup? ! WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Granted>>
			SetScriptValue WarmthBuffSpawned 1
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team WarmthBuff
			}
		}
		Action
		{
			Floater
			{
				Message P1172875117
				Color FF9900
			}
		}
	}

	Trigger WarmthBuffBlocked
	{
		Requires eventLockedByGroup? WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Disabled>>
			SetScriptValue WarmthBuffSpawned 1
		}
	}

//End Warmth Spawn Block

//This counter detects when players have entered the 3rd room of the complex.
	Counter PlayersInStartVolume
	{
		Type ZEPlayers
		VolumeName Start
	}

//This counter detects the defeat of the entity which checks to see if any players do not have the completion badge.
//	Counter BadgeCheckerDefeated
//	{
//		Type Team
//		Team BadgeChecker
//		Direction Up
//		Count 1
//	}

//This timer is used to indicate when the cutscene has ended and the stage can be flipped.
	Timer EndCutscene
	{
		Duration 00:80
	}
	
//This timer starts the cutscene automatically if no players have entered the start volume within 5 minutes.
	Timer TimeElapsed
	{
		Duration 05:00
	}

	Trigger StartCutscene-Volume
	
		Requires PlayersInStartVolume count> 1 >= CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Cutscene Started by Volume>>
		}
		Action
		{
			Reset EndCutscene
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Cutscene
			}
		}
		Action
		{
			SetScriptValue CutsceneStarted 1
		}
	}

	Trigger StartCutscene-Timer
	{
		Requires TimeElapsed complete> CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == &&
		
		Action
		{
			DebugPrint <<Cutscene Started by Timer>>
		}
		Action
		{
			Reset EndCutscene
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team Cutscene
			}
		}
		Action
		{
			SetScriptValue CutsceneStarted 1
		}
	}

	Trigger EndCutscene-AllBadges-Volume
	{
		Requires PlayersInStartVolume count> 1 >= CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == ! &&

		Action
		{
			DebugPrint <<Cutscene Skipped by Volume>>
		}
		
		NextStage Riots
	}
	
	Trigger EndCutscene-AllBadges-Timer
	{
		Requires TimeElapsed complete> CutsceneStarted scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == ! &&
		
		Action
		{
			DebugPrint <<Cutscene Skipped by Timer>>
		}

		NextStage Riots
	}
	Trigger EndCutscene-Stage
	{
		Requires CutsceneStarted scriptvalue> 1 == EndCutscene complete> &&

		Action
		{
			DebugPrint <<Cutscene Completed>>
		}

		NextStage Riots
	}

	UICollection OpeningCutscene
	{
		UIItem Directions
		{
			Type Text
			Text P3793717247
		}
		UIItem CutsceneAutostart
		{
			Type Timer
			Timer TimeElapsed
			Text P1199669832
			ShortText P3107402947
			HideIf CutsceneStarted scriptvalue> 1 ==
		}
		UIItem TimeRemaining
		{
			Type Timer
			Timer EndCutscene
			Text P1199669832
			ShortText P3107402947
			HideIf CutsceneStarted scriptvalue> 0 ==
		}
	}	

	Shutdown
	{
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Cutscene
			}
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team BadgeChecker
			}
		}
	}
}

