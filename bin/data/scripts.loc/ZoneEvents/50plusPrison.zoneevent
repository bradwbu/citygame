	Trigger Captions-Start-Stage4
	{
		Requires Captions-Start-Stage4-Timer complete> Captions-Started-Stage4 scriptvalue> 0 == &&

		Action
		{
			SetScriptValue Captions-Started-Stage4 1
		}
		Action
		{
			TeamControl
			{
				Team CaptionManagerA
				Type DoBehavior
				Behavior <<UsePower("SetHealth69")>>
			}
		}
	}

	Trigger SiegeInitialPop
	{
		Requires SiegeInitialDelay complete>
		Action
		{
			Floater
			{
				Message P511493595
				Color ff9900
			}
			TeamControl StartSiegePets2
			{
				Type Activate
				Team SiegeWavePets
			}
			Reset SiegeWaveDelay
			Reset SiegeWaveDisplay
		}
		Action
		{
			TimerControl
			{
				Timer SiegeWaveDisplay
				Type Add
				Duration 0:15
			}
		}
	}
