Stage Escape
{
	DisplayName P1542684888
	ToolTip P1193694609
	AwardKarma
	KarmaThreshold 10

	StageActiveRequires ZonePlayers count> 8 > ZonePlayersActive count> ZonePlayers count> / 0.25 > &&

	Objective
	{
		Type VillainGroup
		VillainGroup PraetorianResistance
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}
	Objective
	{
		Type VillainGroup
		VillainGroup PraetorianWarworksEndgame
		KarmaValue 10
		KarmaLife 20
		TeamKarmaValue 10
		TeamKarmaLife 20
	}

//Start New Failsafe Block

	Counter ZonePlayers
        {
                Type ZEPlayers
        }
        Counter ZonePlayersAlive
        {
                Type ZEPlayersAlive
        }
        Counter ZonePlayersActive
        {
                Type ZEPlayersActive
        }
	Counter FailsafePlayersAlive
	{
		Type ZEPlayersAlive
	}
	Counter FailsafePlayersPhased
	{
		Type ZEPlayersPhased
	}
	Timer FailsafeDelay
	{
		Duration 0:15
	}
	Timer FailsafeLongDelay
	{
		Duration 1:00
	}

	//Trigger the failsafe for an unlocked league if the number of players is less than 2.
	Trigger FailsafeStart
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeStart
		{
			DebugPrint <<Starting Failsafe countdown for unlocked league>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the failsafe for a locked league if the number of players is less than 4 and the event is an 8-16 player event.
	Trigger FailsafeStart-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 8>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Eight
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}
	
	//Trigger the failsafe for a locked league if the number of players is less than 6 and the event is a 12-24 player event.
	Trigger FailsafeStart-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 0 == && FailsafeDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeStart-LockedTeam
		{
			DebugPrint <<Starting Failsafe countdown for locked league in Event Size 12>>
			Reset FailsafeDelay
			Reset FailsafeLongDelay
			Reset FailsafeStart-LockedTeam-Twelve
		}
		Action
		{
			SetScriptValue FailsafeInProcess 1
		}
	}

	//Trigger the end of the failsafe for an unlocked league after 15s if it still has less than 2 players.
	Trigger FailsafeConclude
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 <= FailsafeInProcess scriptvalue> 1 == && FailsafeDelay complete> && eventLockedByGroup? ! && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 4 players in an 8 player event.
	Trigger FailsafeConclude-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the end of the failsafe for a locked league after 60s if it still has less than 6 players in an 12 player event.
	Trigger FailsafeConclude-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 <= FailsafeInProcess scriptvalue> 1 == && FailsafeLongDelay complete> && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action FloatersFailsafeEnd
		{
			DebugPrint <<Failsafe triggered>>
			Floater FailsafeEnd
			{
				Message P1191472153
				Color ff0000
			}
			SetScriptValue FailsafeInProcess 0
		}
		NextStage Stop
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 2 before the 15s timer ends.
	Trigger FailsafeReset
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 1 > FailsafeInProcess scriptvalue> 1 == && eventLockedByGroup? ! && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart 
			Reset FailsafeReset
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 4 before the 15s timer ends.
	Trigger FailsafeReset-LockedTeam-Eight
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 3 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 8 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Eight 
			Reset FailsafeReset-LockedTeam-Eight 
			Reset FailsafeDelay 
			Reset FailsafeLongDelay
		}
	}

	//Trigger the failsafe reset for an unlocked league if the number of players equals or exceeds 6 before the 60s timer ends.
	Trigger FailsafeReset-LockedTeam-Twelve
	{
		Requires FailsafePlayersAlive count> FailsafePlayersPhased count> - 5 > FailsafeInProcess scriptvalue> 1 == && EventSize scriptvalue> 12 == && eventLockedByGroup? && devMode? ! &&
		Action
		{
			SetScriptValue FailsafeInProcess 0
		}
		Action FloatersFailsafeReset
		{
			DebugPrint <<Failsafe aborted>>
			Reset FailsafeStart-LockedTeam-Twelve 
			Reset FailsafeReset-LockedTeam-Twelve 
			Reset FailsafeDelay
			Reset FailsafeLongDelay
		}
	}

//End New Failsafe Block

// Start Hospital Door Block

	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:00
	}
	
	Trigger HospitalDoor-Unlock-Recovery
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1533101862
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

//End Hospital Door Block

	StartUp
	{
		Action StartEscape
		{
			DebugPrint <<Starting Stage Escape>>
//			GroupShow grpfog_EscapeFogNode
			WaypointPlace EscapeWaypoint1 EscapeWaypoint1
			WaypointPlace EscapeWaypoint2 EscapeWaypoint2
			WaypointPlace EscapeWaypoint3 EscapeWaypoint3
			WaypointPlace SpawnWaypoint1 SpawnWaypoint1
			WaypointPlace SpawnWaypoint2 SpawnWaypoint2
			WaypointPlace SpawnWaypoint3 SpawnWaypoint3
			WaypointPlace SpawnWaypoint4 SpawnWaypoint4
			WaypointPlace SpawnWaypoint5 SpawnWaypoint5
			WaypointPlace SpawnWaypoint6 SpawnWaypoint6
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
		}
		Action
		{
			SetScriptValue Captions-Started-Stage3 0
		}
		Action FloatersStage3Begins
		{
			Floater PowerFailure
			{
				Message P222014822
				Color ff9900
			}
			Floater PrisonersIn60
			{
				Message P3180370177
				Color ff9900
			}
		}
	}
	Counter RunnersACount
	{
		Type Team
		Count 0
		Direction Down
		Team ResistanceRunnersATeam
	}
	Counter RunnersBCount
	{
		Type Team
		Count 0
		Direction Down
		Team ResistanceRunnersBTeam
	}
	Counter RunnersCCount
	{
		Type Team
		Count 0
		Direction Down
		Team ResistanceRunnersCTeam
	}
	Counter RunnersDCount
	{
		Type Team
		Count 0
		Direction Down
		Team ResistanceRunnersDTeam
	}
	Counter RunnersECount
	{
		Type Team
		Count 0
		Direction Down
		Team ResistanceRunnersETeam
	}
	Counter RunnersFCount
	{
		Type Team
		Count 0
		Direction Down
		Team ResistanceRunnersFTeam
	}
	Counter MarkerCount
	{
		//This counts a special marker. The markers are generated by Resistance who reach the door successfully and immediately suicide. This should count as a kill here.
		Type Name
		Count 20
		Name Objects_BAFCounter
	}
	Counter MarkerIncrementCount
	{
		//This counts a single special marker. The markers are generated by Resistance who reach the door successfully and immediately suicide. This should count as a kill here.
		//This is used to pop a floater whenever any Escape occurs
		Type Name
		Count 1
		Name Objects_BAFCounter
	}
	Timer EscapeTimer
	{
		Duration 6:00
	}
	Timer StartTimer
	{
		Duration 1:00
	}

	Timer Captions-Start-Stage3-Timer
	{
		Duration 00:05
	}

	Trigger Captions-Start-Stage3
	{
		Requires Captions-Start-Stage3-Timer complete> Captions-Started-Stage3 scriptvalue> 0 == &&

		Action
		{
			SetScriptValue Captions-Started-Stage3 1
		}
		Action
		{
			TeamControl
			{
				Team CaptionManagerA
				Type DoBehavior
				Behavior <<UsePower("SetHealth79")>>
			}
		}
	}

	Trigger RunnersStart
	{
		//After the delay before runners Emerge
		Requires StartTimer complete>
		Action TurnOnSpawns
		{
			TeamControl TurnOnRunnersA
			{
				Type Activate
				Team ResistanceRunnersATeam
			}
			TeamControl TurnOnRunnersB
			{
				Type Activate
				Team ResistanceRunnersBTeam
			}
			TeamControl TurnOnRunnersC
			{
				Type Activate
				Team ResistanceRunnersCTeam
			}
			TeamControl TurnOnRunnersD
			{
				Type Activate
				Team ResistanceRunnersDTeam
			}
			TeamControl TurnOnRunnersE
			{
				Type Activate
				Team ResistanceRunnersETeam
			}
			TeamControl TurnOnRunnersF
			{
				Type Activate
				Team ResistanceRunnersFTeam
			}
		}
		Action
		{
			Floater RunnersStart
			{
				Message P2751411666
				Color ff9900
				AlertType PriorityAlert
			}
		}
	}

	Trigger RunnersCountSuccess
	{
		//If the timer is over, stage successful and move on to next stage
		//Also this is only triggered if there are any marker kills (escapes)
		Requires EscapeTimer complete> MarkerCount count> 0 > &&
	
		Action RunnersDone
		{
			DebugPrint <<Escape success: switching to Siege>>
		}
		Action FloatersStage3Success
		{
			Floater Stage3Success
			{
				Message P3028004554
				Color ff9900
			}
		}
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable AstralMerit1
				}
			}
		}
		NextStage PreSiege
	}
	Trigger RunnersCountSuperSuccess
	{
		//If no runners are still alive or the timer is over, stage successful and move on to next stage
		//Also this is only triggered if there are 0 marker kills (escapes)
		//This should award a badge to everyone present but doesn't
		Requires EscapeTimer complete> MarkerCount count> 0 == &&
	
		Action RunnersDone
		{
			DebugPrint <<Escape super success: switching to Siege>>
		}
		Action FloatersStage3SuperSuccess
		{
			Floater Stage3SuperSuccess
			{
				Message P767410818
				Color FF9900
			}
		}
		Action
		{
			DebugPrint <<Awarding No Escapes badge>>
			Reward IT_BAF_NoEscapes
		}
		Action
		{
			Reward AstralMerit1
		}
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable AstralMerit1
				}
			}
		}
		NextStage PreSiege
	}
	Trigger MarkerCountFailure
	{
		//This tracks if the specified number of maximum successful escapes has happened. If it has, fail the stage and go to reset.
		Requires MarkerCount complete>
		
		Action MarkerDone
		{
			DebugPrint <<Escape failure: switching to Reset>>
		}
		Action FloatersStage3Failure
		{
			Floater TooManyEscapes
			{
				Message P3686341648
				Color ff0000
			}
		}
		Action
		{
			Floater
			{
				Message P3386779019
				Color ff9900
			}
		}
		NextStage Stop
	}
	Trigger MarkerIncrementCountFailure
	{
		//This tracks a single escape to pop a floater when it happens but not on the last one
		Requires MarkerIncrementCount complete> MarkerCount complete> ! &&
		Action FloatersStage3Escape
		{
			Floater Escape
			{
				Message P2458345280
				Color ff9900
				AlertType PriorityAlert
			}
			DebugPrint <<Escape detected>>
			Reset MarkerIncrementCountFailure
			Reset MarkerIncrementCount
		}	
	}

	UICollection UIEscape
	{
		UIItem DefeatCountUI
		{
			Type BarRed
			Text P2855996394
			ShortText P3734417408
			Current MarkerCount count>
			Target 20
		}
		UIItem TimerShow
		{
			Type Timer
			Text P2719699290
			ShortText P3483776891
			Timer EscapeTimer

		}
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Escape>>
			SetScriptValue FailsafeInProcess 0
			RemoveWaypoints
		}
		Action TurnOffSpawns
		{
			TeamControl TurnOffRunnersA
			{
				Type Deactivate
				Team ResistanceRunnersATeam
			}
			TeamControl TurnOffRunnersB
			{
				Type Deactivate
				Team ResistanceRunnersBTeam
			}
			TeamControl TurnOffRunnersC
			{
				Type Deactivate
				Team ResistanceRunnersCTeam
			}
			TeamControl TurnOffRunnersD
			{
				Type Deactivate
				Team ResistanceRunnersDTeam
			}
			TeamControl TurnOffRunnersE
			{
				Type Deactivate
				Team ResistanceRunnersETeam
			}
			TeamControl TurnOffRunnersF
			{
				Type Deactivate
				Team ResistanceRunnersFTeam
			}
		}
	}
}

