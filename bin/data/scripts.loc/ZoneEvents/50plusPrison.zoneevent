	Timer TenSec
	{
		Duration 0:10
	}

	Timer FiveSec
	{
		Duration 0:05
	}

	Timer InitialNightstarWaveDelay
	{
		Duration 1:30
	}

	Timer NightstarWaveDelay
	{
		Duration 1:00
	}
	
	Timer SiegeWaveDelay
	{
		Duration 1:00
	}
	
	Timer ReinforcementDisplay
	{
		Duration 0:30
	}
	Timer RefreshInitialCount
	{
		Duration 00:10
	}
	Timer Captions-Start-Stage5-Timer
	{
		Duration 00:05
	}

	Trigger Captions-Start-Stage5
	{
		Requires Captions-Start-Stage5-Timer complete> Captions-Started-Stage5 scriptvalue> 0 == &&

		Action
		{
			SetScriptValue Captions-Started-Stage5 1
		}
		Action
		{
			TeamControl
			{
				Team CaptionManagerA
				Type DoBehavior
				Behavior <<UsePower("SetHealth59")>>
			}
		}
	}

	Trigger RefreshInitialCount
	{
		Requires RefreshInitialCount complete>
		
		Action
		{
			Reset Adds-Siege
			Reset Adds-Nightstar
		}
	}

	Trigger InitialReinforcementDisplay
	{
		Action
		{
			TimerControl
			{
				Timer ReinforcementDisplay
				Type Add
				Duration 0:30
			}
		}
	}

	Trigger NightstarWavePop
	{
		Requires NightstarWaveDelay complete> InitialNightstarWaveDelay complete> &&
		Action
		{
			Floater
			{
				Message P1442033881
				Color ff9900
			}
			Reset NightstarWavePop
			Reset NightstarWaveDelay
			Reset ReinforcementDisplay
		}
		Action
		{
			TeamControl
			{
				Type ForceSpawn
				Team NightstarWavePets
			}
		}
		Action
		{
			Reset Adds-Nightstar
		}
	}

	Trigger SiegeWavePop
	{
		Requires SiegeWaveDelay complete>
		Action
		{
			Floater
			{
				Message P511493595
