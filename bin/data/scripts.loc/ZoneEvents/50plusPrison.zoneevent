	Timer HospitalDoor-Lock-Timer
	{
		Duration 00:10
	}
	Timer HospitalDoor-Notification1-Timer
	{
		Duration 00:20
	}
	Timer HospitalDoor-Notification2-Timer
	{
		Duration 00:25
	}
	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:30
	}
	
	Trigger HospitalDoor-Lock
	{
		Requires HospitalDoor-Lock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Lock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1420074300
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

	Trigger HospitalDoor-Notification1
	{
		Requires HospitalDoor-Notification1-Timer complete>
		Action
		{	
			Floater
			{
				Message P3661210205
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}
	
	Trigger HospitalDoor-Notification2
	{
		Requires HospitalDoor-Notification2-Timer complete>
		Action
		{	
