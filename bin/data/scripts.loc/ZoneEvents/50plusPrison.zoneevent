				Team SiegeWavePets
			}
		}
	}

	Trigger SiegePulledFromSpawn-Stage4
	{
		Requires SiegeWatcherCount-Stage4 complete> SiegeCount complete> ! &&
		Action
		{
			SetScriptValue SiegePulledAwayStage4 1
		}
	}

	Trigger SiegeCountTriggerRes
	{
		Requires SiegeCount complete> SiegeAliveCount count> 0 == &&
		Action StartBossResser
		{
			TeamControl StartBossResser
			{
				Type Activate
				Team BossResserTeam
			}
			TeamControl SiegeInvincible
			{
				Type DoBehavior
				Team SiegeTeam
				Behavior <<Invincible>>
			}
			DebugPrint <<BossResser Active, Siege Invincible>>
		}
		Action DelayedSiegeCount
		{
			Delay 1

			TeamControl StopBossResser
			{
				Type Deactivate
				Team BossResserTeam
			}
			Reset SiegeAliveCount SiegeCountTriggerRes
		}
	}

	Trigger SiegeCountSuccess
	{
		//This strangeness ensures that Siege is back alive (due to the resser) before we transition to the next stage
		Requires SiegeCount complete> SiegeAliveCount count> 1 == &&
		Action SiegeDone
		{
			DebugPrint <<Siege success: switching to SiegeAndNightstar>>
			
			TeamControl StopBossResser
			{
				Type Deactivate
				Team BossResserTeam
			}
			TeamControl SiegeNonInvincible
			{
				Type DoBehavior
				Team SiegeTeam
				Behavior <<Invincible(0)>>
			}
			DebugPrint <<BossResser Deactive, Siege Uninvincible>>
		}
		Action
		{
			RewardGroup
			{
				MinorStageReward
				Reward Merits
				{
//					PointsNeeded 15
					RewardTable AstralMerit1
				}
			}
		}
		NextStage SiegeAndNightstar
	}

	Trigger GuardTowerAHackSuccess
	{
		Requires GuardTowerClicksA complete>
		Action GuardTowerAHacked
		{
			DebugPrint <<Guard Tower A Hacked>>
			TeamControl SuppressGuardTowerA
			{
				Type DoBehavior
				Team GuardTowerAP4Team
				Behavior <<DoNothing(DisableAutoPowers(1),Timer(30)),Combat(DisableAutoPowers(0))>>
			}
		}
		Action
		{
			SetScriptValue TerminalsUsedStage4 TerminalsUsedStage4 scriptvalue> 1 +
		}
		Action GuardTowerAReset
		{
			Delay 20
			DebugPrint <<Guard Tower A Reset>>
			Reset GuardTowerAHackSuccess GuardTowerClicksA
		}
	}
