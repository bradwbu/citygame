			{
				Message P177740375
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

	Trigger HospitalDoor-Unlock
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{
			Reset HospitalDoor-Unlock-Timer
			Reset HospitalDoor-Lock-Timer
			Reset HospitalDoor-Notification1-Timer
			Reset HospitalDoor-Notification2-Timer
		}
		Action
		{	
			Floater
			{
				Message P2692826546
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
		Action
		{
			Reset HospitalDoor-Unlock
			Reset HospitalDoor-Lock
			Reset HospitalDoor-Notification1
			Reset HospitalDoor-Notification2
		}
	}

//End Hospital Door Block

	StartUp
	{
		Action StartSuppression
		{
			DebugPrint <<Starting Stage Suppression>>
			WaypointPlace BivouacWaypoint BivouacWaypoint
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
		}
		Action
		{
			SetScriptValue TerminalsUsedStage2 0
		}
		Action
		{
			SetScriptValue NightstarPulledAwayStage2 0
		}
		Action
		{
			SetScriptValue Captions-Started-Stage2 0
