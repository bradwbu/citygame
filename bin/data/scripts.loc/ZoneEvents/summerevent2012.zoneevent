		}
		Action
		{
			SetScriptValue Favor Favor ScriptValue> 50 +
		}
	}
//Favor Block - Triggers APB Incite Power, Checks if the Favor Marker dies and rewards favor if so ---------------------------------------------------------------------------------------------------------------------------------------
//Sound Location #1 - This is the point where the players again the incite power and the crowd should roar	
	Trigger SistersCleanup1
	{
		Requires ClaudiaCount complete> CamillaCount complete> &&
		Action
		{
			SetScriptValue SistersComplete 1
		}
		Action
		{
			Reward is.SummerEvent_InciteTheCrowd
		}
		Action
		{
			Floater Victory
			{
				Message P3999993777
				Color 00FF00
			}
			PlaySound CrowdCheering
			{
				Sound ColiseumCrowd_Cheering
				Channel SFX
				VolumeLevel .5
				Volumename ColiseumExitVol
			}
		}
		Action
		{
			Reset CornutusSound-Timer
		}
		Action
		{
			SetScriptValue SoundFX 1
		}
	}
	Timer CornutusSound-Timer
	{
		Duration 00:15
	}
	Counter IncitementBonus-Cornutus
	{
		Type Name
		Name SummerEvent_Coliseum_Favor_Marker
		Count 1
		Direction Up
	}
//Sound Location #2 - This is the point where the players successfully use the incite power and the crowd should roar louder
	Trigger IncitementComplete
	{
		Requires IncitementBonus-Cornutus complete>
		Action
		{
			SetScriptValue Favor Favor Scriptvalue> 75 +
		}
		Action
		{
			PlaySound CrowdWildCheering
			{
				Sound ColiseumCrowd_WildCheering
				Channel SFX
				VolumeLevel .5
				VolumeName ColiseumExitVol
			}
		}
		Action
		{
			Log <<Incite Used - Stage Cornutus>>
		}
	}
	Trigger CornutusSoundFade
	{
		Requires CornutusSound-Timer complete> SoundFX scriptvalue> 1 == &&
		Action
		{
			SetScriptValue SoundFX 0
		}
		Action
		{
			FadeSound Cheering
			{
				Channel SFX
				FadeTime 3
				VolumeName ColiseumExitVol
			}
		}
	}
//Cornutus Dies, Gain Favor, Pause Favor Decrement ------------------------------------------------------------------------------------------------------------------------------------------------------------
	Trigger CornutusDefeated
	{
		Requires CornutusCount complete>
		Action
		{
			SetScriptValue FavorActive 0
		}
		Action
		{
			SetScriptValue CornutusActive 0
		}
		Action
		{
			Log <<Cornutus defeated, stage advancing shortly>>
		}
		Action
		{
			SetScriptValue Favor Favor ScriptValue> 75 +
		}
		Action
		{
			Reset ColiseumCornutusShutdown-Timer
			Reset ColiseumShutdownShort-Timer
			SetScriptValue ColiseumCornutusShutdown 1
			Floater Victory
			{
				Message P3995680509
				Color 00FF00
			}
			Floater Victory
			{
				Message P469309725
				Color 00FF00
			}
		}
		Action
		{
			TeamControl
			{
				Team ColiseumCamilla
				Type DoBehavior
				Behavior <<Say(P3004397658)>>
			}
			TeamControl
			{
				Team ColiseumClaudia
				Type DoBehavior
				Behavior <<Say(P2804938395)>>
			}
			TeamControl
			{
				Team ColiseumCamilla
				Type DoBehavior
				Behavior <<Body_Collapse>>
			}
			TeamControl
			{
				Team ColiseumClaudia
				Type DoBehavior
				Behavior <<Body_Collapse>>
			}
			TeamControl
			{
				Team ColiseumCamilla
				Type DoBehavior
				Behavior <<Untargetable(1),Unselectable(1),gang(1))>>
			}
			TeamControl
			{
				Team ColiseumClaudia
				Type DoBehavior
				Behavior <<Untargetable(1),Unselectable(1),gang(1)>>
			}
		}
	}
// Badge - Hellenic Beauty
	Trigger CornutusBadgeGrant
	{
		Requires Cornutuscount complete> CamillaCount complete> ! && claudiacount complete> ! &&
		Action
		{
			Reward SummerEvent_Hellenic
		}
	}			
	Trigger AnnouncerResponsePositive
	{
		Requires ColiseumShutdownShort-Timer complete> ColiseumCornutusShutdown scriptvalue> 1 == && Favor Scriptvalue> 100 >= &&
		Action
		{
			Caption
			{
				Message P2013715358
			}
		}
	}
	Trigger AnnouncerResponseNegative
	{
		Requires ColiseumShutdownShort-Timer complete> ColiseumCornutusShutdown scriptvalue> 1 == && Favor Scriptvalue> 100 <= &&
		Action
		{
			Caption
			{
				Message P1643995419
			}
		}
	}
	Trigger ColisemCornutusEnd
	{
		Requires ColiseumCornutusShutdown-Timer complete> ColiseumCornutusShutdown scriptvalue> 1 == &&
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team ColiseumCamilla
			}
			TeamControl
			{
				Type Deactivate
				Team ColiseumClaudia
			}
			DebugPrint <<Coliseum Cornutus Stage Over. Advancing.>>
		}
		NextStage ColiseumNinjas
	}
//UI Information ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
	Trigger UIUpdateCornutus
	{
		Requires CornutusHealth count> 100 ==
		Action
		{
			SetScriptValue CornutusActive 1
		}
	}
	Trigger UIUpdateCamilla
	{
		Requires CamillaHealth count> 100 ==
		Action
		{
			SetScriptvalue CamillaActive 1
		}
	}
	Trigger UIUpdateClaudia
	{
		Requires ClaudiaHealth count> 100 ==
		Action
		{
			SetScriptvalue ClaudiaActive 1
		}
	}
