			{
				Type Activate
				Porter ColiseumCutsceneOver
			}
		}
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team ColiseumCutsceneIntro
			}
			TeamControl
			{
				Type Deactivate
				Team ColiseumCrowdCS
			}
		}
		Action
		{
			SetScriptValue FavorActive 1
		}
