// Invictus Badge Grant
	Trigger InvictusBadgeGrant
	{
		Requires god_championhealth count> 35 <= SupportsKilled Scriptvalue> 0 == && Barrier-Safety complete> &&
		Action
		{
			Reward SummerEvent_Invictus
		}
		Action
		{
			Log <<God Champion's health reduced to 35% without any of his henchmen being killed - Invictus Badge Granted.>>
		}
	}
	Trigger InvictusBadgeFailsafe
	{
		Requires god_championcount complete> supportskilled scriptvalue> 0 == && Barrier-Safety complete> &&
		Action
		{
			Reward SummerEvent_Invictus
		}
		Action
		{
			Log <<God Champion was killed (how?) without any of his henchmen being killed - Invictus Badge Granted. This is a failsafe state.>>
		}
	}
	Trigger BossBarrier
	{
		Requires God_ChampionHealth count> 35 <= SupportsKilled Scriptvalue> 3 == ! && Barrier-Safety complete> &&
		Action
		{
			TeamControl
			{
				Type DoBehavior
				Team ColiseumGodChampion
				Behavior <<Body_Collapse>>
			}
			TeamControl
			{
				Type DoBehavior
				Team ColiseumGodChampion
				Behavior <<say(P1212194996)>>
			}
			TeamControl
			{
				Type DoBehavior
				Team ColiseumGodChampion
				Behavior <<Untargetable(1),Unselectable(1),gang(1)>>
			}
			TeamControl
			{
				Type DoBehavior
				Team ColiseumGotterdamFinale
				Behavior <<say(P2619043967)>>
			}
			TeamControl
			{
				Type DoBehavior
				Team ColiseumFrankFinale
				Behavior <<say(P2619043967)>>
			}
			TeamControl
			{
				Type DoBehavior
				Team ColiseumCornutusFinale
				Behavior <<say(P2619043967)>>
			}
		}
		Action
		{
			Reset Barrier-Timer
		}
		Action
		{
			SetScriptValue BarrierUp 1
		}
	}
