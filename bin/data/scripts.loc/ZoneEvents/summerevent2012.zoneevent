// Decides how many and which laser grids are knocked offline.
	Trigger DecideHowManyLasers
	{
		Requires GeneratorPersist count> 1 ==
		Action
		{
			SetScriptValue GeneratorsOffline GeneratorsOffline ScriptValue> 1 +
		}
		Action
		{
			Log <<Another Laser Turning Off For Stage B>>
		}
		Action
