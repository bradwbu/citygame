			{
				Message P3341829890
				Volume CasinoOffice
			}
			Caption GrifterFinalIs
			{
				Message P1532004879
				Volume CasinoOffice
			}
			Caption GrifterFinalEternal
			{
				Message P1200247349
				Volume CasinoOffice
			}
			Caption GrifterFinalVigilance
			{
				Message P1453839593
				Volume CasinoOffice
			}
		}
		Action
		{
			SetScriptValue TotalScoreB TotalScoreB scriptvalue> 2 +
		}
		Action
		{
			Debugprint <<Grifter completed the phrase, 2 points>>
		}
		Action
		{
			SetScriptValue GrifterBComplete 1
		}
		Action
		{
			SetScriptValue PerfectGrifter PerfectGrifter scriptvalue> 1 +
		}
		Action
		{
			Log <<Casino Interstitial B - Grifter - All Words Acquired for Password. 2 Points Added to Total Score for the Team.>>
		}
		Action
		{
			Log <<Casino Interstitial B - Grifter - Perfect Grifter Requirement Achieved for Phase B.>>
		}
		Action
		{
			GlowieControl
			{
				Type Activate
				Glowie ThiefVault
			}
		}
		Action
		{
			Log <<Casino Interstitial B - Grifter - Vault Panel Activated for the Thief.>>
		}
	}
//Hitter Section - Counting Cards --------------------------------------------------------------------------------------
	Timer CardLoserDialog-Timer
	{
		Duration 00:06
	}
	Timer CardLoserDialogB-Timer
	{
		Duration 00:10
	}
	Trigger HitterCardLoser1NarrativeA
	{
		Requires CardLoser1Update1 objectivesucceeded>
		Action
		{
			SetScriptValue CardLoser1Stage 1
		}
		Action
		{
			SetScriptvalue CardLoser2Stage 10
		}
		Action
		{
			SetScriptValue CardLoser3Stage 10
		}
		Action
		{
			TeamControl
			{
				Team CasinoCardLoser1
				Type DoBehavior
				Behavior <<Say("Alright, I think I get it. Hi-Lo strategy. Two through Six, I add one; Seven through Nine, nothing; Ten, Jack, Queen, King, Ace, I subtract one. Okay! Throw some numbers at me!">>
			}
		}
		Action
		{
			Log <<Casino Interstitial B - Hitter - Loser NPC Selected for Training.>>
		}
		Action
		{
			Reset CardLoserDialog-Timer
		}
		Action
		{
			SetScriptValue CardLoser1DialogCheck 1
		}
	}
	Trigger HitterCardLoser1NarrativeB
	{
		Requires CardLoser1Update1 objectivesucceeded> CardLoserDialog-Timer complete> && CardLoser1DialogCheck scriptvalue> 1 == &&
		Action
		{
			TeamControl
			{
				Team CasinoCardLoser1
				Type DoBehavior
				Behavior <<Say("Minus one, minus one, plus one, plus one, null, plus one. Arg, this is confusing to keep track of.  I think I got it though, keep going!">>
			}
		}
		Action
		{
			Reset CardLoserDialog-Timer
		}
		Action
		{
			SetScriptValue CardLoser1DialogCheck 2
		}
	}
	Trigger HitterCardLoser1NarrativeC
	{
		Requires CardLoser1Update1 objectivesucceeded> CardLoserDialog-Timer complete> && CardLoser1DialogCheck scriptvalue> 2 == &&
		Action
		{
			TeamControl
			{
				Team CasinoCardLoser1
				Type DoBehavior
				Behavior <<Say("I've got it! Woa-boy! The house is going DOWN! Before that, you got any more pointers?">>
			}
			Delay 00:02
			Caption HitterRemind1
			{
				Message P9438930
				Volume CasinoGameroom
			}
		}
		Action
		{
			SetScriptValue CardLoser1Stage 2
		}
	}
	Trigger HitterCardLoser1Abort
	{
		Requires CardLoser1Abort objectivesucceeded>
		Action
		{
			TeamControl
			{
				Team CasinoCardLoser1
				Type DoBehavior
				Behavior <<Say("Lame! But you're probably right. I'll get some more practice in before hitting the big leagues.">>
			}
		}
		Action
		{
			Log <<Casino Interstitial B - Hitter - Loser NPC Aborted for Training.>>
		}
		Action
		{
			SetScriptValue CardLoser1Stage 1
		}
		Action
		{
			SetScriptvalue CardLoser2Stage 0
		}
		Action
		{
			SetScriptValue CardLoser3Stage 0
		}
	}
	Trigger HitterCardCountCheck1A
	{
		Requires HitterCardCount1 objectivesucceeded> HitterBcomplete scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<You talked to the wrong person. Sorry.>>
		}
		Action
		{
			Log <<Casino Interstitial B - Hitter - Loser NPC Committed to for Card Counting. No Points Added to Total Score for the Team.>>
		}
		Action
		{
			TeamControl
			{
				Team CasinoCardLoser1
				Type DoBehavior
				Behavior <<Say(P3125028869),MoveToPos(Marker:CardLoser1Dest),Say(P897523145)>>
			}
		}
		Action
		{
			SetScriptValue HitterBcomplete 1
		}
		Action
		{
			Reset CardLoserDialogB-Timer
		}
		Action
		{
			SetScriptValue CardLoser1DialogCheck 3
		}
		Action
		{
			SetScriptValue CardLoser1Stage 10
		}
	}
	Trigger HitterCardCountcheck1B
	{
		Requires CardLoserDialogB-Timer complete> CardLoser1DialogCheck ScriptValue> 3 == &&
