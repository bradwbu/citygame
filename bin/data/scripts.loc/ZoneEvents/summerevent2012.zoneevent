	Trigger FavorSucceeded
	{
		Requires Favor scriptvalue> 500 >= FavorSuccess scriptvalue> 0 == &&
		Action
		{
			SetScriptValue FavorSuccess 1
		}
		Action
		{
			Log <<Favor has reached 500 and the players should receive the God Champion Stage>>
		}
		Action
		{
			Floater Victory
			{
				Message P2996506337
				Color 00FF00
			}
		}
	}
	Trigger FavorFailed
	{
		Requires Favor scriptvalue> 0 <=
		Action
		{
			SetScriptValue FavorSuccess 3
		}
		Action
		{
			Log <<Favor has reached 0 and the players have failed the favor portion of the Coliesum>>
		}
		Action
		{
			Floater Victory
			{
				Message P3019548869
				Color 00FF00
			}
		}
	}
