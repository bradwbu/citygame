		Action
		{
			Reward SummerEvent_Phitter
		}
		Action
		{
			Log <<The Heist - Hitter Disabled All Generators (Phase A) and Succeeded With a Distraction (Phase B). Granting Perfect Hitter Badge.>>
		}
	}
	Trigger PerfectHackerBadgeGrant
	{
		Requires Tedcount complete> perfecthacker scriptvalue> 2 == &&
		Action
		{
			Reward SummerEvent_Phacker
		}
		Action
		{
			Log <<The Heist - Hacker Disabled All Terminals (Phase A) and All Security Cameras (Phase B). Granting Perfect Hacker Badge.>>
		}
	}
	Trigger PerfectGrifterBadgeGrant
	{
		Requires Tedcount complete> perfectgrifter scriptvalue> 3 == &&
		Action
		{
			Reward SummerEvent_Pgrifter
		}
		Action
		{
			Log <<The Heist - Grifter Distracted Sylvia (Phase A) and Got the Password from Ted (Phase B). Granting Perfect Grifter Badge>>
		}
	}
