Stage CasinoShutdown
{
	Startup
	{
		Action
		{
			SetScriptValue CasinoComplete 1
		}
		Action
		{
			Log <<Starting CasinoShutdown Stage>>
		}
		Action
		{
			GlowieControl
			{
				Type Deactivate
				Glowie HitterTerminal
			}
			GlowieControl
			{
				Type Deactivate
				Glowie HackerTerminal
			}
			GlowieControl
			{
				Type Deactivate
				Glowie GrifterTerminal
			}
			GlowieControl
			{
				Type Deactivate
				Glowie ThiefTerminal
			}
		}
		Action
		{
			DoorControl
			{
				Door DoorCasino
				Type Lock
			}
		}
		Action
		{
			Reward SummerEvent_Heist_RevokeRoles
		}
	}
	Timer PorterActive-Timer
	{
		Duration 00:05
	}
	Trigger ExitTheCasino
	{
		Requires PorterActive-Timer complete>
		Action
		{
			PorterControl
			{
				Porter CasinoEntranceVol
				Type Activate
			}
		}
	}
	Timer DespawnEverything-Timer
	{
		Duration 00:10
	}
	Trigger TurnAllSpawnsOff
	{
		Requires DespawnEverything-Timer complete>
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team CasinoAmbient
			}
			TeamControl
			{
				Type Deactivate
				Team CasinoCardLoser1
			}
			TeamControl
			{
				Type Deactivate
				Team CasinoCardLoser2
			}
			TeamControl
			{
				Type Deactivate
				Team CasinoCardLoser3
			}
		}
		Action
		{
			SetScriptValue CasinoSectionComplete 1
		}
	}
	Trigger EventCompleted
	{
		Requires CasinoSectionComplete scriptvalue> 1 == ColiseumSectionComplete ScriptValue> 1 == &&
		NextStage Rewards
	}
	Trigger CasinoSectionCompleted
	{
		Requires CasinoSectionComplete scriptvalue> 1 == ColiseumSectionComplete ScriptValue> 0 == &&
		NextStage Prelude
	}
}
Stage Rewards
{
	Startup
	{
		Action
		{
			Log <<Granting Reward Table, Badge, Trial Complete/Succeeded>>
		}
		Action RewardChoiceTable
		{
			Reward SummerEventRepeatable
		}
		Action BadgeComplete
		{
			Reward SummerEvent_Complete
		}
		Action
		{
			TrialComplete Success
		}
	}
	Timer ShutItDown-Timer
	{
		Duration 05:00
	}
	Trigger ShutItDown
	{
		Requires ShutItDown-Timer complete>
		NextStage Stop
	}
}
