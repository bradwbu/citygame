	{
		Requires CamillaCount complete>
		Action
		{
			Floater Victory
			{
				Message P1560965617
				Color 00FF00
			}
			SetScriptValue CamillaActive 0
		}
		Action
		{
			Log <<Camilla has been defeated and the players have failed the criteria for attaining the 'Hellenic Beauty' badge>>
		}
		Action
		{
			SetScriptValue Favor Favor ScriptValue> 50 +
		}
	}
	Trigger ClaudiaCleanup
