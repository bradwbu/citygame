Stage ColiseumCornutus
{
	DisplayName P741289353
	Startup
	{
		Action StartColiseumCornutus
		{
			DebugPrint <<Starting Coliseum - Cornutus Fight>>
		}
		Action
		{
			SetScriptValue CornutusActive 0
		}
		Action
		{
			SetScriptValue CamillaActive 0
		}
		Action
		{
			SetScriptValue ClaudiaActive 0
		}
		Action
		{
			SetScriptValue FavorActive 0
		}
		Action
		{
			SetScriptValue CutsceneState 1
		}
		Action
		{
			RemoveWaypoints
		}
		Action
		{
			WaypointPlace WP-ColiseumExit WP-ColiseumExit
		}
	}
	Timer CutsceneIntro1
	{
		Duration 00:01
	}
	Timer CutsceneIntro2
	{
		Duration 00:40
	}
	Trigger IntroCutsceneStart
	{
		Requires CutsceneState scriptvalue> 1 == CutsceneIntro1 complete> &&
		Action
		{
			DebugPrint <<CutsceneStarting>>
		}
