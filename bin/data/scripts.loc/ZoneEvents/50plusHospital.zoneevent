//NamedVolume SeerNetworkPorter SeerNetwork
//NamedVolume MotherMayhemPorter MotherMayhem
Stage Setup
{
	StartUp
	{
		Action StartSetup
		{
			DebugPrint P1007512383
		}
		Action CreateStuff
		{
			DoorCreate RejuvenationPodsDoor // Requires ZoneEventName.Door.MarkerName ZoneEvent>
			PorterCreate RejuvenationPodsPorter // This needs a named volume with the name given here as well as a scriptmarker with the same name.
			DoorCreate SeerNetworkDoor // Requires ZoneEventName.Door.MarkerName ZoneEvent>
			PorterCreate SeerNetworkPorter // This needs a named volume with the name given here as well as a scriptmarker with the same name.
			DoorCreate MotherMayhemDoor // Requires ZoneEventName.Door.MarkerName ZoneEvent>
			PorterCreate MotherMayhemPorter // This needs a named volume with the name given here as well as a scriptmarker with the same name.
			PorterCreate InteriorPorter // This needs a named volume with the name given here as well as a scriptmarker with the same name.
			DoorControl InitLock
			{
				Type Lock
				Door RejuvenationPodsDoor
			}
			PorterControl InitPort
			{
				Type Activate
				Porter RejuvenationPorter
			}
			DoorControl InitLock
			{
				Type Lock
				Door SeerNetworkDoor
			}
			PorterControl InitPort
			{
				Type Activate
				Porter SeerNetworkPorter
			}
			DoorControl InitLock
			{
				Type Lock
				Door MotherMayhemDoor
			}
			PorterControl InitPort
			{
				Type Activate
				Porter MotherMayhemPorter
			}
			SpawnCreate MotherMayhem
			{
				Location MotherMayhemWave
				Group MotherMayhemWave
				Team MotherMayhemteam
				SpawnBehavior PL_Combat
				//MoveToMarker Villagesquare_01
				KillBehavior PL_DestroyMe
			}
			TeamCreate
			{
				Team MotherMayhemteam
			}
			SpawnCreate Malaise
			{
				Location MalaiseWave
				Group MalaiseWave
				Team Malaiseteam
				SpawnBehavior PL_Combat
				//MoveToMarker Villagesquare_01
				KillBehavior PL_DestroyMe
			}
			TeamCreate
			{
				Team Malaiseteam
			}
			SpawnCreate SeerSpawn
			{
				Location SeerWave
				Group SeerWave
				Team Seerteam
				SpawnBehavior Combat
				KillBehavior PL_DestroyMe
			}
			TeamCreate
			{
				Team Seerteam
				Heartbeat 2
				//RespawnMinCount 40
				RespawnRate 4
			}
			SpawnCreate SeerSpawn2
			{
				Location SeerWave2
				Group SeerWave2
				Team Seerteam2
				SpawnBehavior Combat
				KillBehavior PL_DestroyMe
			}
			TeamCreate
			{
				Team Seerteam2
				Heartbeat 2
				//RespawnMinCount 40
				RespawnRate 4
			}
			SpawnCreate GuardSpawn
			{
				Location GuardWave
				Group GuardWave
				Team Guardteam
				SpawnBehavior PL_Combat
				KillBehavior PL_DestroyMe
			}
			TeamCreate
			{
				Team Guardteam
				Heartbeat 10
				//RespawnMinCount 50
				RespawnRate 4
			}
			SpawnCreate PodGuardSpawn
			{
				Location PodGuardWave
				Group PodGuardWave
				Team PodGuardteam
				SpawnBehavior PL_Combat
				KillBehavior PL_DestroyMe
			}
			TeamCreate
			{
				Team PodGuardteam
				Heartbeat 10
				//RespawnMinCount 50
				RespawnRate 4
			}
			SpawnCreate PodSpawn
			{
				Location PodWave
				Group PodWave
				Team Podteam
				//SpawnBehavior DoNothing
				KillBehavior PL_DestroyMe
			}
			TeamCreate
			{
				Team Podteam
				Heartbeat 1
				//RespawnMinCount 10
				RespawnRate 1
			}
			GlowieCreate GlowieGas
			{
				DisplayName P3886168906
