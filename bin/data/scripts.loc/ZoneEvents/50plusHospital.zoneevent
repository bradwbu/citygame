				Quantity 14
				ResetDelay 30
				Model OO_Wrhs_Gascanister_01
				Interact P736801142
				Interrupt P2589200594
				Complete P3423616233
				BarText P4162231445
				InteractTime 4
				VanishOnComplete
			}
		}
	}
	Trigger End
	{
		NextStage DefeatSeers
	}
}
