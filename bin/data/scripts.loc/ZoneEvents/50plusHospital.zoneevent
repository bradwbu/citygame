			{
				Type Activate
				Team Malaiseteam
			}
		}
		Action TurnOffCanisters
		{
	  		GlowieControl Deactivate
	  		{
	  			Type Deactivate
	  			Glowie GlowieGas
	  		}
			GlowieControl Remove
			{
				Type Remove
				Glowie GlowieGas
			}
		}
		Action OpenUpMotherMayhem
		{
			DoorControl Unlock
			{
				Type Unlock
				Door MotherMayhemDoor
			}
			PorterControl StopPort
			{
				Type Deactivate
				Porter MotherMayhemPorter
			}
		}
		Action CloseInteriors
		{
			DoorControl Relock
			{
				Type Lock
				Door RejuvenationPodsDoor
			}
			Floater PortOut
			{
				// Floater blocks must contain the actual text in a Message line
				Message P3527806459
				// They can optionally have a Color line, which gives the color in rrggbb format.
				Color ff0000
				// Volume is optional, if provided the floater only goes to peopkle in the named volume. Otherwise it
				// goes to everyone on the map
				Volume RejuvenationPorter
			}
			DoorControl Relock
			{
				Type Lock
				Door SeerNetworkDoor
			}
			Floater PortOut
			{
				// Floater blocks must contain the actual text in a Message line
				Message P3527806459
				// They can optionally have a Color line, which gives the color in rrggbb format.
				Color ff0000
				// Volume is optional, if provided the floater only goes to peopkle in the named volume. Otherwise it
				// goes to everyone on the map
				Volume SeerNetworkPorter
			}
		}
		Action TurnOnMotherMayhem
		{
			TeamControl StartMotherMayhem
			{
				Type Activate
				Team MotherMayhemteam
			}
			TeamControl StartGuard
			{
				Type Activate
				Team Guardteam
			}
			PorterControl StopPort
			{
				Type Deactivate
				Porter InteriorPorter
			}
		}
	}
	Timer PortTimer
	{
		// It has a 5 second duration ...
		Duration 5
	}
	// five seconds after the stage starts, turn on the teleporter
	Trigger PortToMalaise
	{
		// This waits for the five second timer to elapse
		Requires PortTimer complete>
		// When it does, this action block enables the port volume
		Action StartSuccessPort
		{
			PorterControl StartPortInteriorPorter
			{
				Type Activate
				Porter InteriorPorter
			}
		}
	}
