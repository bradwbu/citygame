	Timer STBossRoofTimer
	{
		Duration 10:00
		Display
	}
	Timer STWindRoofHazardTimer
	{
		Duration 0:20
	}
	Trigger OneOrTheOther
	{
		Requires STBossRoofKills complete> ObjSTSyndicateRoofKills complete> ||
		Action UnleashMoreMobs
		{
			TeamControl StartSTSyndicateRoofXtrateam
			{
				Type Activate
				Team STSyndicateRoofXtrateam
			}
			DebugPrint <<Unleashing More Mobs>>
		}
		Action WarningForHazard
		{
			Floater WindWarning
			{
				Message P2790685736
				Color ff0000
				Volume SyndicateEventVolume
			}
		}
		Action TurnOnHazard
		{
			Delay 10
			TeamControl StartWindHazard
			{
				Type Activate
				Team STWindRoofHazard
			}
		}
	}
	Trigger STBossRoofDestroyedFail
	{
		Requires STBossRoofTimer complete>
		Action GotoReset
		{
			Floater FlushedOut
			{
				Message P4233942386
				Color ff0000
				Volume SyndicateEventVolume
			}
			DebugPrint <<FightSTBossRoof failed: Zone Reset>>
		}
		NextStage Reset
	}
	Trigger Done
	{
		Requires ObjSTSyndicateRoofKills count> ObjSTSyndicateRoofXtraKills count> + JennaRoof count> + JessRoof count> + JasonRoof count> + 25 >= STBossRoofKills complete> &&
		Action GotoProtest
		{
			Floater FlushedOut
			{
				Message P650838951
				Color 00ff00
				Volume SyndicateEventVolume
			}
			DebugPrint <<FightSTBossRoof done: switching to RewardWinners>>
		}
		NextStage RewardWinners
	}
	UICollection STSyndicateRoofCount
	{
		UIItem BossRoofKillsCount
		{
			Type BarRed
			Text P3143032732
			ShortText P3379963429
			Current STBossRoofHealth count>
			Target 100
		}
		UIItem RoofGuardCount
		{
			Type BarBlue
			Text P2700143158
			ShortText P2397001397
			Current ObjSTSyndicateRoofKills count> ObjSTSyndicateRoofXtraKills count> + JennaRoof count> + JessRoof count> + JasonRoof count> +
			Target 25
		}
	}
	ShutDown
	{
		Action TurnOffNPCs
		{
			TeamControl StopSTPPDvsSynRoof
			{
				Type Deactivate
				Team STPPDvsSynRoofteam
			}
			TeamControl StopPPDteam
			{
				Type Deactivate
				Team STPPDteam
			}
			TeamControl StopSTSyndicateIntteam
			{
				Type Deactivate
				Team STSyndicateIntteam
			}
			TeamControl StopSTBossRoofteam
			{
				Type Deactivate
				Team STBossRoofteam
			}
			TeamControl StopSTSyndicateRoofteam
			{
				Type Deactivate
				Team STSyndicateRoofteam
			}
			TeamControl StopSTSyndicateRoofXtrateam
			{
				Type Deactivate
				Team STSyndicateRoofXtrateam
			}
			TeamControl StartSTJessRoofteam
			{
				Type Deactivate
				Team STJessRoofteam
			}
			TeamControl StartSTJesnnaRoofteam
			{
				Type Deactivate
				Team STJennaRoofteam
			}
			TeamControl StartSTJasoRoofteam
			{
				Type Deactivate
				Team STJasonRoofteam
			}
			TeamControl StopSTBombSquad
			{
				Type Deactivate
				Team STBombSquadteam
			}
			TeamControl StopWatcher
			{
				Type Deactivate
				Team Watcher
			}
			TeamControl StopKiller
			{
				Type Deactivate
				Team Killer
			}
		}
		Action LockTheDoors
		{
			DoorControl InitLockSTBottomFloor
			{
				Type Lock
				Door STBottomFloorDoor
			}
			DoorControl InitLockSTRooftop
			{
				Type Lock
				Door STRooftopDoor 
			}
			PorterControl InitPortSTBottomFloor
			{
				Type Activate
				Porter STInteriorPorter
			}
		}
		Action TurnOffHazards
		{
			TeamControl StopWindHazard
			{
				Type Deactivate
				Team STWindRoofHazard
			}
		}
		Action ResetStart
		{
			Floater PortOut
			{
				// Floater blocks must contain the actual text in a Message line
				Message P3357996744
				// They can optionally have a Color line, which gives the color in rrggbb format.
				Color ff0000
				// Volume is optional, if provided the floater only goes to peopkle in the named volume. Otherwise it
				// goes to everyone on the map
				Volume STInteriorPorter
			}
		}
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage FightSTBossRoof>>
		}
	}
}

Stage RewardWinners
{
	DisplayName P2269381005
	StartUp
	{
		Action RewardStart
		{
			DebugPrint <<Starting Reward stage>>
			RemoveWaypoints
		}

		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class2
				{
					PercentileNeeded 0
					PointsNeeded 1
					NumStagesRequired 2
					RewardTable ZE_Syndicate_Base_Low
				}
				Reward class2_5
				{
					PercentileNeeded 0
					PointsNeeded 1
					NumStagesRequired 3
					RewardTable ZE_Syndicate_Base_Low
				}
				Reward class3
				{
					PercentileNeeded 0.33
					PointsNeeded 19
					NumStagesRequired 3
					RewardTable ZE_Syndicate_Base_Medium
				}
				Reward class4
				{
					PercentileNeeded 0.66
					PointsNeeded 25
					NumStagesRequired 3
					RewardTable ZE_Syndicate_Base_High
				}
			}
		}

		Action TurnOffNPCs
		{
			TeamControl StopSTSyndicateExt
			{
				Type Deactivate
				Team STBossRoofteam
			}
		}
	}
	UICollection PlayerWin
	{
		UIItem PlayerVictory
		{
			Type CenterText
			Text P4031330413
			ShortText P3874835759
		}
	}
	Timer StageResetTimer
	{
		Duration 0:30
		Display
	}
	Trigger Reset
	{
		Requires StageResetTimer complete>
		NextStage Reset
		Action RewardReset
		{
			DebugPrint <<Switching to Reset from Reward>>
		}
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Reward>>
		}
	}
}

