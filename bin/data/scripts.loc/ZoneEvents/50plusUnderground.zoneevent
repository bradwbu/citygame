//This trigger kills the trap power caster when all crystals are destroyed.
	Trigger CrystalTrapDefeated
	{
		Requires Room10EventTriggered scriptvalue> 1 == TotalCrystalsDestroyed scriptvalue> 4 >= &&

		Action
		{
			DebugPrint <<Crystal Trap Defeated>>	
			TeamControl
			{
				Team CrystalTrap-Power
				Type DoBehavior
				Behavior <<DestroyMe>>
			}
		}
		Action
		{
			TeamControl
			{
				Team Desdemona
				Type SetHealth
				Health 1.0
			}
		}
		Action
		{
			SetScriptValue DesdemonaIntangible 0
		}
		Action
		{
			Floater
			{
				Message P3439448117
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P287497152
				Color FF9900
			}
		}
		Action
		{
			TeamControl
			{
				Team Desdemona
				Type DoBehavior
				Behavior <<DoNotMove(0),DoNotUseAnyPowers(0),DoAttackAI(1)>>
			}
		}
		Action
		{
			DoorControl
			{
				Door DoorRoom10Exit
				Type Unlock
			}
		}
		Action
		{
			SetScriptValue Room10EventTriggered 2
		}
		Action
		{
			SetScriptValue EnteredRoom10 0
		}
		Action
		{
			TeamControl
			{
				Team CaptionManager-Desdemona
				Type DoBehavior
				Behavior <<UsePower("SetHealth59")>>
			}
		}
	}

