Name IncarnateTrialTheUnderground
FirstStage Setup
StopStage Stop
RestartStage Reset
DisplayName P1440119047
//EventVolume EventVolume // ZoneEventName = 50plusUnderground

//Event Reward Structure
// Stage 1: Defeat trash - No Karma, No Merits
// Stage 2: Defeat Extinction WW - Karma 10, Astral Merit
// Stage 3: Defeat SR WW and LI WW - Karma 10, Astral Merit per boss
// Stage 4: Defeat Avatar - Karma 10, Empyrean Merit (subject to lockout)
// Total: 3 Karma Stages. 
//	1 Completed stages: Incarnate Subcomponent
//	2 Completed stages: Common Component
//	3 Completed stages: Component Drop Tables

Stage Setup
{
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage Setup>>
		}
		Action
		{
			DebugPrint <<This is a 12-24 player event>>
			SetScriptValue EventSize 12
		}
