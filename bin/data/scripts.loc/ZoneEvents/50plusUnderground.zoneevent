	Timer RefreshTimer2
	{
		Duration 0:01
	}

	Timer BossChallenge2-Timer
	{
		Duration 8:00
	}
	Timer Boss2Enrage-Timer
	{
		Duration 20:00
	}

//This timer gives a brief delay after the room 10 event is triggered before starting the trap.
	Timer Room10-AutoStart
	{
		Duration 00:10
	}

//This timer gives a brief delay before starting to check Desdemona's health value.
	Timer DesdemonaHealth-StartChecking-Act2
	{
		Duration 00:05
	}

//This timer determines when this stage's badge is awarded to players.
	Timer Message03_Delay
	{
		Duration 0:15
	}

	Trigger SetRoom13Attackers
	{
		Requires RefreshTimer2 complete> Room13CounterSet scriptvalue> 0 == &&
		
		Action
		{
			SetScriptValue Room13-Attackers-Target StaticRoom13Cleared count>
		}
		Action
		{
			SetScriptValue Room13CounterSet 1
		}
	}

//This trigger awards the badge to players when the above timer is complete.
	Trigger Message03_Send
	{
		Requires Message03_Delay complete>
		Action
		{
			TeamControl
			{
				Team CaptionManager-Vanessa
				Type DoBehavior
				Behavior <<UsePower("SetHealth89")>>
			}
		}
	}


//This trigger sets a badge check value if Desdemona's health falls below 50%.
	Trigger DesdemonaHealth-FallsBelowFifty-Act2
	{
		Requires DesdemonaHealth-StartChecking-Act2 complete> DesdemonaHealth count> 50 < &&

		Action
		{
			SetScriptValue DesdemonaHealth-BelowFifty 1
		}
	}

//This trigger deactivates the patrolling team that spawns in Room 7 once players enter the volume for Room 7.
	Trigger Room7EnteredTrigger
	{
		Requires Room7Entered count> 0 >
		Action
		{
			DebugPrint <<Room 7 Entered>>
			TeamControl
			{
				Team GenRoom7-1
				Type Deactivate
			}
		}
	}

//This trigger activates the Crystal Power team and moves Desdemona to her P3197075251 position when a player enters Room 10.
	Trigger Room10EventIndicated
	{
		Requires PlayersInRoom10 count> 1 >= Room10EventTriggered scriptvalue> 0 == &&
		Action
		{
			Floater
			{
				Message P4068608316
				Color FF9900
			}
			Floater
			{
				Message P1463034486
				Color FF9900
			}
		}
	}

	Trigger ActivateRoom10Event
	{
		Requires DesdemonaWatcher10-Defeated complete> Room10EventTriggered scriptvalue> 0 == &&
		
		Action
		{
			SetScriptValue DesdemonaIntangible 1
		}		
		Action
		{
			Floater
			{
				Message P4073985618
				Color FF9900
			}
			TeamControl
			{
				Team Desdemona
				Type DoBehavior
				Behavior <<MoveToPos(marker:DefendDesdemonaC),DoNotMove(1),DoNotUseAnyPowers(1),DoAttackAI(0)>>
			}
		}
		Action
		{
			Reset Room10-AutoStart
		}
		Action
		{
			Delay 2
			SetScriptValue Room10EventTriggered 1
		}
	}

//This trigger activates the Crystal Power team once Desdemona enters the volume which kills the watcher.		
	Trigger HoldDesdemona
	{
		Requires Room10EventTriggered scriptvalue> 1 == Room10-AutoStart complete> &&
		Action
		{
			TeamControl
			{
				Team CaptionManager-Desdemona
