	Trigger LichenBossTrigger-ChallengeVictory
	{
		Requires LichenBossCleared complete> BossChallenge2-Timer complete> ! && Boss2Enrage-Timer complete> ! &&
		Action
		{
			DebugPrint <<LichenBoss down, ending Act2, next is Act3>>
		}
		Action
		{
			SetScriptValue BossChallenge2-Completed 1
		}
		Action
		{
			DebugPrint <<LichenBoss down, Challenge completed, ending Act2, next is Act3>>
			SetScriptValue LichenInProgress 0
			DoorControl
			{
				Door DoorBoss2Exit
				Type Unlock
			}
			Floater
			{
				Message P3571992110
				Color FF9900
			}
		}
		//Reward players with the mid-trial item drop, added in 2150
		Action
		{
			Reward IS.Issue2150Midtrial
		}
		Action
		{
