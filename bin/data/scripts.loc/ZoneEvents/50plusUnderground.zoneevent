Stage Prelude
//This stage only exists to give us time before we track Karma
{
	DisplayName P4116941047
	ToolTip P1035118780

// Start Hospital Door Block

	Timer HospitalDoor-Unlock-Timer
	{
		Duration 00:00
	}
	
	Trigger HospitalDoor-Unlock-Recovery
	{
		Requires HospitalDoor-Unlock-Timer complete>

		Action
		{
			DoorControl
			{
				Type Unlock
				Door Door-Hospital
			}
		}
		Action
		{	
			Floater
			{
				Message P1533101862
				Color 00ff99
				Volume Hospital
				AlertType PriorityAlert
			}
		}
	}

//End Hospital Door Block	
	
	StartUp
	{
		Action DebugNote
		{
			DebugPrint <<Starting Stage Prelude - Karma Off>>
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
		}
		Action TurnOnSpawns
		{
			TeamControl
			{
				Team Desdemona
				Type Activate
			}
			TeamControl
			{
				Team Vanessa
				Type Activate
			}
			TeamControl
			{
				Team GenRoom1
				Type Activate
			}
		}
		Action
		{
			SetScriptValue DesdemonaHealth-BelowFifty 0
		}
		Action
		{
			SetScriptValue Captions-Started-Stage1 0
		}
		Action
		{
			SetScriptValue TeleporterLocation 0
		}
		Action
		{
			SetScriptValue WarmthBuffSpawned 0
		}
	}

	Counter PreludeIDF
	{
		Type VillainGroup
		Count 1
		Villaingroup PraetorianIDFEndgame
	}

	Counter PreludeWarworks
	{
		Type VillainGroup
		Count 1
		Villaingroup PraetorianWarworksEndgame
	}

//Start Warmth Spawn Block

	Trigger WarmthBuffActivation
	{
		Requires eventLockedByGroup? ! WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Granted>>
			SetScriptValue WarmthBuffSpawned 1
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team WarmthBuff
			}
		}
		Action
		{
			Floater
			{
				Message P1172875117
				Color FF9900
			}
		}
	}

	Trigger WarmthBuffBlocked
	{
		Requires eventLockedByGroup? WarmthBuffSpawned scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Warmth of Prometheus Disabled>>
			SetScriptValue WarmthBuffSpawned 1
		}
	}

//End Warmth Spawn Block

	Trigger EndPrelude
	{
		Requires PreludeIDF complete> PreludeWarworks complete> ||
		Action
		{
