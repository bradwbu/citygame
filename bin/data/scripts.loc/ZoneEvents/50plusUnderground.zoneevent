				Color FF9900
			}
		}
		Action
		{
			TeamControl
			{
				Team CrystalGuardsA
				Type Activate
			}
			TeamControl
			{
				Team CrystalGuardsB
				Type Activate
			}
			TeamControl
			{
				Team CrystalGuardsC
				Type Activate
			}
			TeamControl
			{
				Team CrystalGuardsD
				Type Activate
			}
		}
		Action
