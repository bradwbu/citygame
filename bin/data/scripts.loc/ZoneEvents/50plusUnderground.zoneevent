//This timer indicates when the first badge text for this stage will be awarded.
	Timer Message05_Delay
	{
		Duration 0:05
	}

//This timer indicates when the second badge text for this stage will be awarded.
	Timer Message06_Delay
	{
		Duration 3:05
	}

//This timer indicates when the third badge text for this stage will be awarded.
	Timer Message07_Delay
	{
		Duration 6:05
	}

//This timer indicates the cycle time for the first bomb dropped into the Avatar's room.
	Timer AvatarBombDropTimerInitial
	{
		Duration 00:20
	}

//This timer indicates the cycle time for the ongoing bomb drops into the Avatar's room.
	Timer AvatarBombDropTimerOngoing
	{
		Duration 00:30
	}

//This timer is used to lock out the ongoing drop for a few seconds.
	Timer AvatarBombDropTimerLockout
	{
		Duration 00:10
	}

//This timer gives a brief delay before starting to check Desdemona's health value.
	Timer DesdemonaHealth-StartChecking-Act3
	{
		Duration 00:05
	}

//This timer gives the Avatar fight a 12 minute enrage timer.
	Timer AvatarEnrage-Timer
	{
		Duration 12:00
	}

//This timer tracks the length of the Avatar of Hamidon's cutscene.
	Timer Cutscene-Avatar-Timer
	{
		Duration 00:36
	}

//This trigger sets a badge check value if Desdemona's health falls below 50%.
	Trigger SetCounterLimitsForEndRooms-Act3
	{
		Requires DesdemonaHealth-StartChecking-Act3 complete> RoomCounts-Act3-Set scriptvalue> 0 == &&	
		Action
		{
			SetScriptValue Room19-Attackers-Target StaticRoom19Cleared count>
		}
		Action
		{
			SetScriptValue Room20-Attackers-Target StaticRoom20Cleared count>
		}
		Action
		{
			SetScriptValue RoomCounts-Act3-Set 1
		}
	}

//This trigger sets a badge check value if Desdemona's health falls below 50%.
	Trigger DesdemonaHealth-FallsBelowFifty-Act3
	{
		Requires DesdemonaHealth-StartChecking-Act3 complete> DesdemonaHealth count> 50 < &&

		Action
		{
			SetScriptValue DesdemonaHealth-BelowFifty 1
		}
	}

//This trigger checks to see if any players have entered Room 18.
	Trigger SporeMechanics-Information
	{
		Requires PlayersInRoom18 count> 1 >= SporeMechanicsDescribed scriptvalue> 0 == &&

		Action
		{
			SetScriptValue SporeMechanicsDescribed 1
		}
		Action
		{
			TeamControl
			{
				Team CaptionManager-Desdemona
				Type DoBehavior
				Behavior <<UsePower("SetHealth49")>>
			}
		}
		Action
		{		
			PorterControl
			{
				Porter TPTR-StartAct3
				Type Deactivate
			}
		}
		Action
		{
			RemoveWaypoints
		}
		Action
		{
			SetScriptValue TeleporterLocation 6
		}
		Action
		{
			WaypointPlace WP-Room17
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
			Floater
			{
				Message P1285955060
				Color 0099FF
				AlertType PriorityAlert
			}
			PorterControl
			{
				Porter TPTR-Room17
				Type Activate
			}
		}
	}

//This trigger checks to see if any bombs have been detonated.
	Trigger BombDetonation-Detected
	{
		Requires DemoChargesDefeated complete>

		Action
		{
			SetScriptValue AnyBombsDetonated 1
		}
	}

//This trigger checks to see if all bombs have been defeated.
	Trigger BombDefeats-Completed
	{
		Requires ExplosiveChargesDefeated complete>
		
		Action
		{
			SetScriptValue AllBombsDefeated 1
		}
	}

//This trigger advises players of the bomb mechanics.
	Trigger BombMechanics-Floaters
	{
		Requires PlayersInRoom16 count> 1 >= BombMechanicsDescribed scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P903232516
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P2564383682
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue BombMechanicsDescribed 1
		}
	}			

//This trigger runs the cutscene introducing the Avatar of Hamidon.
	Trigger Avatar-Introduction
	{
		Requires PlayersInAvatarBattleRoom count> 1 >= AvatarIntroductionBegun scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 == &&

		Action
		{
			TeamControl
			{
				Team Cutscene-Avatar
				Type Activate
			}
		}
		Action
		{
			Reset Cutscene-Avatar-Timer
		}
		Action
		{
			SetScriptValue AvatarIntroductionBegun 1
		}
		Action
		{
			SetScriptValue SkipFinalCutscene 0
		}
	}

//This trigger allows the Avatar objective to display if the cutscene is not run.
	Trigger Avatar-CutsceneSkipped
	{
		Requires PlayersInAvatarBattleRoom count> 1 >= AvatarIntroductionBegun scriptvalue> 0 == && Cutscene-Skippable scriptvalue> 0 > &&
		
		Action
		{
			SetScriptValue AvatarIntroductionBegun 1
		}
		Action
		{
			SetScriptValue SkipFinalCutscene 1
		}
	}

//This activates the Avatar's UI Objective after the cutscene is complete.
	Trigger ActivateAvatarObjective
	{
		Requires AvatarIntroductionBegun scriptvalue> 1 == Cutscene-Avatar-Timer complete> && AvatarObjectiveDisplayed scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P2549094838
				Color FF9900
			}
		}
		Action
		{
			PlaySound
			{
				Sound i20_01Low_b_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			SetScriptValue AvatarObjectiveDisplayed 1
		}
		Action
		{
			SetScriptValue BossAccessibleStage3 1
		}
		Action
		{
			TeamControl
			{
				Team SporeCloud-Avatar
				Type Activate
			}
		}
		Action
		{
			TeamControl
			{
				Team Cutscene-Avatar
				Type Deactivate
			}
		}
	}

//This trigger runs when the Avatar is damaged.
	Trigger AvatarBossEngaged
	{
		Requires AvatarBossHealth count> 100 < BossAccessibleStage3 scriptvalue> 1 == && AvatarEngaged scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Avatar of Hamidon engaged>>
		}
		Action
		{
			Reset AvatarEnrage-Timer
		}
		Action
		{
			Delay 1
			SetScriptValue AvatarEngaged 1
		}
		Action
		{
			TeamControl
			{
				Team StaticRoom21
				Type Deactivate
			}
		}
	}

//This trigger initializes the first bomb drop in the final battle.
	Trigger MegaBombDrop-Initialize
	{
		Requires AvatarObjectiveDisplayed scriptvalue> 1 == AvatarBossHealth count> 95 <= && BombActivationBegun scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P3361405767
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
				Message P1193717464
				Color FF9900
			}
		}
		Action
		{
			Reset AvatarBombDropTimerInitial
		}
		Action
		{
			SetScriptValue BombActivationBegun 1
		}
	}

//This trigger starts the first bomb drop in the Avatar's room.
	Trigger MegaBombDrop-First
	{
		Requires AvatarBombDropTimerInitial complete> BombActivationBegun scriptvalue> 1 == &&

		Action
		{
			Reset AvatarBombDropTimerOngoing
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team AvatarMegaBomb
			}
		}
		Action
		{
			SetScriptValue BombActivationBegun 2
		}
		Action
		{
			Reset AvatarChargesPresent
		}
		Action
		{
			Floater
			{
				Message P1269260137
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Floater
			{
				Message P337222074
				Color FF9900
				AlertType PriorityAlert
			}
		}
	}

//This trigger sets the ongoing bomb drop in the Avatar's room.
	Trigger MegaBombDrop-Ongoing
	{
		Requires AvatarBombDropTimerOngoing complete> BombActivationBegun scriptvalue> 2 == &&

		Action
		{
			Reset AvatarBombDropTimerOngoing
		}

		Action
		{
			TeamControl
			{
				Type ForceSpawn
				Team AvatarMegaBomb
			}
		}
		Action
		{
			Reset AvatarBombDropTimerLockout
		}
		Action
		{
			Reset AvatarChargesPresent
		}
		Action
		{
			SetScriptValue BombActivationBegun 3
		}
		Action
		{
			Floater
			{
				Message P1269260137
				Color FF9900
				AlertType PriorityAlert
			}
		}
	}

//This is the lockout trigger for ongoing bomb drops.
	Trigger MegaBombDrop-Lockout
	{
		Requires AvatarBombDropTimerLockout complete> BombActivationBegun scriptvalue> 3 == &&

		Action
		{
			Reset MegaBombDrop-Ongoing
		}
		Action
		{
			SetScriptValue BombActivationBegun 2
		}
		Action
		{
			Reset AvatarBombDropTimerLockout
		}
		Action
		{
			Reset MegaBombDrop-Lockout
		}
	}


