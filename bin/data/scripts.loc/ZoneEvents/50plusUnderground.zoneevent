//This trigger runs when the Extinction War Walker is damaged.
	Trigger ExtinctionBossEngaged
	{
		Requires ExtinctionBossHealth count> 100 < BossAccessibleStage1 scriptvalue> 1 == && ExtinctionBossEngaged scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Extinction War Walker engaged>>
		}
		Action
		{
			PlaySound
			{
				Sound i20_03High_a_Loop
				Channel Music
				VolumeLevel 1
			}
		}
		Action
		{
			Reset ExtinctionEnrage
		}
		Action
		{
			Delay 1
			SetScriptValue ExtinctionBossEngaged 1
		}
	}
//This trigger runs when the Extinction War Walker is defeated.
	Trigger ExtinctionBossTrigger
	{
		Requires ExtinctionBossCleared complete> ExtinctionEnrage complete> ! &&
