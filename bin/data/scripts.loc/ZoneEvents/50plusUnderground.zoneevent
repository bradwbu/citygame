//This trigger sets a badge check value if Desdemona's health falls below 50%.
	Trigger DesdemonaHealth-FallsBelowFifty-Act1
	{
		Requires DesdemonaHealth-StartChecking-Act1 complete> DesdemonaHealth count> 50 < &&

