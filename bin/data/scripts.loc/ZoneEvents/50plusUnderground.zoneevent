			{
				Team CrystalTrap-Power
				Type DoBehavior
				Behavior <<Untargetable(1),Unselectable(1),Invincible(1)>>
			}
		}
		Action
		{
			SetScriptValue EnteredRoom10 1
		}
		Action
		{
			Reset CrystalTrap-Defeated
		}
		Action
		{
			Floater
			{
				Message P3466722014
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			Floater
			{
				Message P1606182374
				Color FF9900
			}
		}
		Action
		{
			Floater
			{
