//This trigger pops a floater for the defeat of crystal trap A.
	Trigger CrystalTrapA-Defeated
	{
		Requires Room10EventTriggered scriptvalue> 1 == CrystalTrapA-Defeated complete> && CrystalTrapA-Dead scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Crystal Trap A Defeated>>
			Floater
			{
				Message P2413266169
				Color FF9900
			}
		}
		Action
		{
			SetScriptValue CrystalTrapA-Dead 1
		}
		Action
		{
