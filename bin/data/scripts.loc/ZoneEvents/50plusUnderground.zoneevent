Stage Cutscene
{
	Startup
	{

	}

//This timer is used to indicate when the cutscene has ended and the stage can be flipped.
	Timer CutsceneStart
	{
		Duration 00:08
	}
	
	Timer EndCutscene
	{
		Duration 00:62
	}
	
	Trigger PlayFinalCutscene
	{
		Requires CutsceneStart complete> SkipFinalCutscene scriptvalue> 0 == &&
		
		Action
		{
			TeamControl
			{
				Team Cutscene-Completion
				Type Activate
			}
		}
	}

	Trigger SkipFinalCutscene
	{
		Requires SkipFinalCutscene scriptvalue> 1 ==

		NextStage RewardWinners
	}

	Trigger EndCutscene-Stage
	{
		Requires EndCutscene complete>

		NextStage RewardWinners
	}

	Shutdown
	{
		Action
		{
			TeamControl
			{
				Type Deactivate
				Team Cutscene-Completion
			}
		}
	}
}

Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Starting Stage RewardWinners>>
		}
		Action
		{
			SetScriptValue OpenLeagueAward 0
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 10
			}
		}
	}

	Trigger AvatarBoss-DesdemonaCollapse-Recovery
	{
		Requires DesdemonaCollapsed scriptvalue> 1 ==

		Action
		{
			TeamControl
			{
				Team Desdemona
				Type DoBehavior
				Behavior <<ArmsCrossed>>
			}
		}
		Action
		{
			SetScriptValue DesdemonaCollapsed 2
		}
	}

	Trigger AwardBadge-Completion
	{
		Action
		{
			DebugPrint <<Awarding Completion Badge>>
			Reward IT_Underground_Complete
		}
	}
	Trigger AwardBadge-Boss2-FastKill
	{
		Requires BossChallenge2-Completed scriptvalue> 1 ==
		Action
		{
			DebugPrint <<Awarding Fast Kill Badge>>
			Reward IT_Underground_FastKill
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-DesdemonaHealth
	{
		Requires DesdemonaHealth-BelowFifty scriptvalue> 0 ==
		Action
		{
			DebugPrint <<Awarding Desdemona Health Badge>>
			Reward IT_Underground_DesHealth
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-BombsDefeated
	{
		Requires AllBombsDefeated scriptvalue> 1 == AnyBombsDetonated scriptvalue> 0 == &&
		Action
		{
			DebugPrint <<Awarding Bombs Defeated Badge>>
			Reward IT_Underground_AllBombs
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardBadge-AvatarBombs
	{
		Requires AvatarDefeatedWithChargePresent scriptvalue> 1 ==
		Action
		{
			DebugPrint <<Awarding Avatar With Bombs Badge>>
			Reward IT_Underground_AvatarBomb
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardMerit-OpenLeague
	{
		Requires eventLockedByGroup? ! OpenLeagueAward scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Bonus Merit for an Open League Awarded>>
			SetScriptValue OpenLeagueAward 1
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger End
	{
		NextStage Stop
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Reward>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					NumStagesRequired 2
					RewardTable Issue21EndKarma1
				}
				Reward class2
				{
					NumStagesRequired 3
					RewardTable IS.Issue2150AvatarKarma1
				}
			}
		}
	}
}

Stage Failure
{
	StartUp
	{
		Action FailureStart
		{
			DebugPrint <<Initializing Stage Failure...>>
		}
		Action
		{
			FadeSound
			{
				Channel Music
				FadeTime 10
			}
		}
	}
	Timer FailureDelay
	{
		Duration 00:10
	}
	Trigger FailureDelayEnd
	{
		Requires FailureDelay complete>
		NextStage Stop
		
		Action StopStart
		{
			DebugPrint <<Completing Stage Failure...>>
		}
	}
}

