Stage RewardWinners
{
	StartUp
	{
		Action StartRewardWinners
		{
			DebugPrint <<Starting Stage RewardWinners>>
		}
		Action
		{
			SetScriptValue OpenLeagueAward 0
		}
	}
	Trigger AwardBadge-Completion
	{
		Action
		{
			DebugPrint <<Awarding Completion Badge>>
			Reward IT_Lambda_Complete
		}
	}
	Trigger AwardAcidsBadge
	{
		Requires GrenadeGatherStarted scriptvalue> 0 == AcidGatherStarted scriptvalue> 1 == && AllAcidsGathered scriptvalue> 1 == && AnyAcidsUsed scriptvalue> 0 == && Restock-Utilized scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Awarding AcidsGatheredNotUsed badge>>
			Reward IT_Lambda_NoAcids
		}
		Action
		{
			Reward AstralMerit1
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardGrenadesBadge
	{
		Requires GrenadeGatherStarted scriptvalue> 1 == AcidGatherStarted scriptvalue> 0 == && AllGrenadesGathered scriptvalue> 1 == && AnyGrenadesUsed scriptvalue> 0 == && Restock-Utilized scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Awarding GrenadesGatheredNotUsed badge>>
			Reward IT_Lambda_NoGrenades
		}
		Action
		{
			Reward AstralMerit1
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardEverythingBadge
	{
		Requires GrenadeGatherStarted scriptvalue> 1 == AcidGatherStarted scriptvalue> 1 == && AllGrenadesGathered scriptvalue> 1 == && AllAcidsGathered scriptvalue> 1 == && AnyGrenadesUsed scriptvalue> 0 == && AnyAcidsUsed scriptvalue> 0 == && Restock-Utilized scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Awarding AllGatheredNotUsed badge>>
			Reward IT_Lambda_NoPowers
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger AwardMerit-OpenLeague
	{
		Requires eventLockedByGroup? ! OpenLeagueAward scriptvalue> 0 == &&

		Action
		{
			DebugPrint <<Bonus Merit for an Open League Awarded>>
			SetScriptValue OpenLeagueAward 1
		}
		Action
		{
			Reward AstralMerit1
		}
	}
	Trigger End
	{
		NextStage Stop
	}
	ShutDown
	{
		Action Shutdown
		{
			DebugPrint <<Shutting down Stage Reward>>
		}
		Action PhatLewt
		{
			RewardGroup reward
			{
				Reward class0
				{
					NumStagesRequired 0
					RewardTable IncarnatePool1None
				}
				Reward class1
				{
					PercentileNeeded 0.00
					NumStagesRequired 1
					PointsNeeded 10
					RewardTable Issue20EndKarma1
				}
			}
		}
	}
}

