Name KillBoss
FirstStage Setup
StopStage Stop
RestartStage Stop
DisplayName P4200101291
//EventVolume EventVolume // ZoneEventName = 50plusLambdaSector

//Event Reward Structure
// Stage 1: Defeat trash - No Karma, No Merits
// Stage 2: Defeat Guard - No Karma, No Merits
// Stage 3: Sabotage -No Karma, Astral Merit (no Karma) for gathering all 10 of a power type.
// Stage 4: Defeat Marauder - Karma 10, Astral Merit for defeating 30 IDF, Empyrean Merit (subject to lockout)
// Total: 1 Karma Stage 
//	1 Completed stage: Component Drop Tables

Stage Setup
{
	StartUp
	{
		Action StartSetup
		{
			DebugPrint <<Starting Stage Setup>>
		}
		Action
		{
			DebugPrint <<This is an 8-16 player event>>
			SetScriptValue EventSize 8
		}
		Action CreateStuff
		{
			DoorCreate InteriorDoor // Requires ZoneEventName.Door.MarkerName ZoneEvent>
			DoorCreate Door-LabElevatorA // Add the following property to the MapSwap: Requires 50plusLambdaSector.Door.Door-LabElevatorA ZoneEvent>
			DoorCreate Door-LabElevatorB // Add the following property to the MapSwap: Requires 50plusLambdaSector.Door.Door-LabElevatorB ZoneEvent>
			DoorCreate Door-LabElevatorC // Add the following property to the MapSwap: Requires 50plusLambdaSector.Door.Door-LabElevatorC ZoneEvent>
			DoorCreate Door-WarehouseElevatorA // Add the following property to the MapSwap: Requires 50plusLambdaSector.Door.Door-WarehouseElevatorA ZoneEvent>
			DoorCreate Door-WarehouseElevatorB // Add the following property to the MapSwap: Requires 50plusLambdaSector.Door.Door-WarehouseElevatorB ZoneEvent>
			DoorCreate Door-WarehouseElevatorC // Add the following property to the MapSwap: Requires 50plusLambdaSector.Door.Door-WarehouseElevatorC ZoneEvent>
			DoorCreate Door-Hospital // Add the following property to the MapSwap: Requires 50plusLambdaSector.Door.Door-Hospital ZoneEvent>
			PorterCreate MunitionsPorter // This needs a named volume with the name given here as well as a scriptmarker with the same name.
			PorterCreate TrainingPorter // This needs a named volume with the name given here as well as a scriptmarker with the same name.
			WaypointCreate WP-DeliveryAcids map_enticon_neighborhood P2976564000
			WaypointCreate WP-DeliveryGrenades map_enticon_neighborhood P554564519
			WaypointCreate WP-MissionExit map_enticon_neighborhood P3301789151
			WaypointCreate WP-HospitalExit map_enticon_neighborhood P2099690906

			DoorControl
			{
				Type Lock
				Door InteriorDoor
			}
			DoorControl
			{
				Type Lock
				Door Door-LabElevatorA
			}
			DoorControl
			{
				Type Lock
				Door Door-LabElevatorB
			}
			DoorControl
			{
				Type Lock
				Door Door-LabElevatorC
			}
			DoorControl
			{
				Type Lock
				Door Door-WarehouseElevatorA
			}
			DoorControl
			{
				Type Lock
				Door Door-WarehouseElevatorB
			}
			DoorControl
			{
				Type Lock
				Door Door-WarehouseElevatorC
			}
			DoorControl
			{
				Type Lock
				Door Door-Hospital
			}
			PorterControl
			{
				Type Activate
				Porter MunitionsPorter
			}
			PorterControl
			{
				Type Activate
				Porter TrainingPorter
			}

