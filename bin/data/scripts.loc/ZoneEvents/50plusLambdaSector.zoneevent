	Trigger Done
	{
		Requires MarauderKills complete>
		Action
		{
			DebugPrint <<Stage Marauder done: switching to RewardWinners>>
		}
		Action
		{
			Floater
			{
				Message P1759035138
				Color ff9900
			}
		}
		Action
		{
			Floater
			{
				Message P136176503
				Color ff9900
			}
		}
		Action
		{
			Reward EmpyreanMerit_Lambda
		}
		NextStage RewardWinners
	}

	Trigger FailureByKiting
	// This trigger detects the death of the watcher spawns which exist in four volumes around Lambda Sector. If Marauder enters any of the volumes, the entity within SilentKills itself and the event is failed.
	{
		Requires MarauderOutOfPosition complete>
		Action
		{
			Floater
			{
				Message P2944178968
				Color ff9900
			}
		}
		Action
		{
			Floater
			{
				Message P1498673322
				Color ff9900
			}
		}
		NextStage Stop
	}
	
	
