	Trigger Restock-Start
	{
		Requires DeliveryDelay complete> Restock-Started scriptvalue> 0 == &&

		Action
		{
			Floater
			{
				Message P1944231975
				Color FF9900
				AlertType PriorityAlert
			}
			Floater
			{
				Message P4033004328
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type Activate
				Team WeaponCache-Restock
			}
			TeamControl
			{
				Type Activate
				Team IncubationPod-Restock
			}
			TeamControl
			{
				Type Activate
				Team WeaponCache-Guards
			}
			TeamControl
			{
				Type Activate
				Team IncubationPod-Guards
			}
		}
		Action
		{
			Reset DeliveryTimer
		}
		Action
		{
			Reset DeliveryClear
		}
		Action
		{
			SetScriptValue Restock-Started 1
		}
		Action
		{
			WaypointPlace WP-DeliveryAcids WP-DeliveryAcids
			WaypointPlace WP-DeliveryGrenades WP-DeliveryGrenades
			WaypointPlace WP-MissionExit WP-MissionExit
			WaypointPlace WP-HospitalExit WP-HospitalExit
		}
	}

	Trigger Restock-Clear
	{
		Requires DeliveryClear complete> Restock-Started scriptvalue> 1 == &&

		Action
		{
			Floater
			{
				Message P3481312233
				Color FF9900
				AlertType PriorityAlert
			}
			TeamControl
			{
				Type DoBehavior
				Team WeaponCache-Guards
				Behavior <<Praetorian_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
			TeamControl
			{
				Type DoBehavior
				Team IncubationPod-Guards
				Behavior <<Praetorian_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
			TeamControl
			{
				Type DoBehavior
				Team WeaponCache-Restock
				Behavior <<Praetorian_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
			TeamControl
			{
				Type DoBehavior
				Team IncubationPod-Restock
				Behavior <<Praetorian_TeleportOut(Timer(1),CombatOverride(Passive)),DestroyMe>>
			}
		}
	}

	Trigger Restock-Cycle
	{
		Requires DeliveryTimer complete> Restock-Started scriptvalue> 1 == &&

		Action
		{
			Floater
			{
				Message P2842170616
				Color FF9900
				AlertType PriorityAlert
			}
		}
		Action
		{
			TeamControl
			{
				Type ForceSpawn
				Team WeaponCache-Restock
			}
			TeamControl
			{
				Type ForceSpawn
				Team IncubationPod-Restock
			}
			TeamControl
			{
				Type ForceSpawn
				Team WeaponCache-Guards
			}
			TeamControl
			{
				Type ForceSpawn
				Team IncubationPod-Guards
			}
		}
		Action
		{
			Reset DeliveryTimer
		}
		Action
		{
			Reset DeliveryClear
		}
		Action
		{
			Reset Restock-Clear
		}
		Action
		{
			Reset Restock-Cycle
		}
	}

	Trigger Restock-Utilization-Detected
	{
		Requires  WeaponCache-Defeats complete> IncubationPod-Defeats complete> ||

		Action
		{
			SetScriptValue Restock-Utilized 1
		}
	}

	Trigger Captions-Start-Stage4
	{
		Requires Captions-Start-Stage4-Timer complete> Captions-Started-Stage4 scriptvalue> 0 == &&

