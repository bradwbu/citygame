		Requires ReinforcementTeamA-Kills count> ReinforcementTeamB-Kills count> + ReinforcementTeamC-Kills count> + ReinforcementTeamD-Kills count> + ReinforcementTeamF-Kills count> + ReinforcementTeamG-Kills count> + ReinforcementTeamH-Kills count> + ReinforcementTeamI-Kills count> + ReinforcementTeamJ-Kills count> + ReinforcementTeamK-Kills count> + ReinforcementTeamL-Kills count> + 30 >=

		Action
		{
			Floater
			{
				Message P3848923895
				Color ff9900
			}
		}
		Action
		{
			Reward AstralMerit1
		}
	}

