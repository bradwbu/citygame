// InteractCompleteString :
"P2856362778" "You have routed the projector to the images you wanted to show..."
// InteractActionString :
"P2850664507" "Configuring..."

// -------------------------------------------------------------------------------- 
// Reward - Objective 
// -------------------------------------------------------------------------------- 
// Dialog :
"P2955812397" "You started the holographic projector and need to draw Flamespout's attention to the display."

// -------------------------------------------------------------------------------- 
// Reward - TaskSuccess 
