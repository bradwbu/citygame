// -------------------------------------------------------------------------------- 
// Reward - Objective 
// -------------------------------------------------------------------------------- 
// Script Variable BOSS_DISPLAYNAME :
"P4112721628" "Sergeant Mercado"
// Script Variable BOSS_INACTIVE_DIALOG :
"P3181482000" "Big Mike is down!<em t=1>I repeat!<em t=1>Big Mike is down!"
// Script Variable BOSS_ATTACK_DIALOG :
"P1980096147" "{HeroName}, you're out of control."
// Script Variable BOSS_1STBLOOD_DIALOG :
"P2247129488" "I'm taking you in {HeroName}."
// Script Variable BOSS_75HEALTH_DIALOG :
"P2763766534" "Don't make this harder than this needs to be."
// Script Variable BOSS_50HEALTH_DIALOG :
"P1415342875" "You're a menace!"
// Script Variable BOSS_25HEALTH_DIALOG :
"P1546361206" "I-I, I need back up.<em t=2>Now!"
// Script Variable BOSS_DEAD_DIALOG :
"P889673935" "Ugh."
