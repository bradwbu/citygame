// Script Variable HOSTAGE_INACTIVE_DIALOG :
"P1174586286" "I fear {HeroName} will not come.  Perhaps we have chosen poorly."
// Script Variable HOSTAGE_ACTIVE_DIALOG :
"P3050652068" "No... My fears spoke louder than my dreams.<em t=3>You are here, {HeroName}.<em t=3>Now... I ask you again... will you please help us?"
// Script Variable BOSS_INACTIVE_DIALOG :
"P3660363603" "DE....STROYYYYY...."
// Script Variable BOSS_ATTACK_DIALOG :
"P64901006" "DE....STROYYYYY!!!!!!"
// Script Variable SayOnRescue :
"P1837553219" "You have passed, {HeroName}.  I am most pleased.<em t=3>Let us speak."
// Script Variable SaysList :
"P1424427718" "The true chest is not too far from here."

// -------------------------------------------------------------------------------- 
// Objective - ScriptRescuedLeaderAgain 
// -------------------------------------------------------------------------------- 
// Description :
"P3209784073" "Save the Oneiromancers before they all die."

// -------------------------------------------------------------------------------- 
// Objective - ScriptMissionCompletionRequirement 
// -------------------------------------------------------------------------------- 
// Description :
"P2104658775" "Find the True Oculus chest"
// InteractBeginString :
"P3108683416" "You begin opening the chest"
