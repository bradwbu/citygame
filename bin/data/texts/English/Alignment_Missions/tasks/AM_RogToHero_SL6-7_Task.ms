// Description :
"P1609538580" "Dispel the Vault Wardings"
// InteractBeginString :
"P413150634" "You begin dispelling the vault wards..."
// InteractCompleteString :
"P3635503196" "You finished reading the runes in the correct order"
// InteractActionString :
"P612795131" "Dispelling the Ward..."

// -------------------------------------------------------------------------------- 
// Reward - Objective 
// -------------------------------------------------------------------------------- 
// Dialog :
"P2434942319" "You've dispelled the wards around the vault. Desdemona should be able to enter now and pilfer the knowledge within. Find her and escape before Arachnos can block off your escape!"
// Script Variable INACTIVE_DIALOG_MINION1 :
"P3660594292" "<shout>Find {HeroName} and Desdemona!"
// Script Variable ATTACK_DIALOG_MINION1 :
"P1881819831" "I knew you were getting soft over in Paragon City, {HeroName}, but you're no hero!"
// Script Variable BOSS_DISPLAYNAME :
"P3820238526" "Chief Webmaster"
// Script Variable BOSS_INACTIVE_DIALOG :
"P2417539885" "<shout>Find Desdemona! I'll deal with {HeroName}!"
// Script Variable BOSS_ATTACK_DIALOG :
