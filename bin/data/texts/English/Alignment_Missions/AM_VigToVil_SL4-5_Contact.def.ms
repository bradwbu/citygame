// -------------------------------------------------------------------------------- 
// Contact Name : Squawk From An Arachnos Headset 
// -------------------------------------------------------------------------------- 
// Name :
"P1188597845" "Squawk From An Arachnos Headset"
// LocationString :
// ProfessionString :
// AskAboutTextOverride :
// ContactRequiresText :
// IDontKnowYouString :
// NoTasksRemainingString :
// PlayerBusyString :
// ComeBackLaterString :
