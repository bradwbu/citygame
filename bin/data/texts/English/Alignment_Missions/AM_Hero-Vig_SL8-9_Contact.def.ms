// Contact Name : Art, Psychics & You 
// -------------------------------------------------------------------------------- 
// Name :
"P179715093" "Art, Psychics & You"
// LocationString :
// ProfessionString :
// AskAboutTextOverride :
// ContactRequiresText :
// IDontKnowYouString :
// NoTasksRemainingString :
// PlayerBusyString :
// ComeBackLaterString :
